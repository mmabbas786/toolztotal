---
import '../styles/global.css';
import { toolCatalog } from '../data/tools';

interface Props {
  title?: string;
  description?: string;
  faqJsonLd?: string;
}

const {
  title = "Free Online Calculators & Tools | ToolzTotal",
  description = "Free online calculators and tools — no signup, no clutter, just answers. 100% client-side, privacy-first, and near-instant load times.",
  faqJsonLd
} = Astro.props;

// Standard categories list for nav & footer
const categories = [
  { name: "Finance & Loans", slug: "finance" },
  { name: "Real Estate & Mortgage", slug: "real-estate" },
  { name: "Everyday / Life Utility", slug: "utility" },
  { name: "Developer Tools", slug: "dev" },
  { name: "Text & Content", slug: "text" },
  { name: "Marketing & SEO", slug: "marketing" },
  { name: "Health & Fitness", slug: "health" },
  { name: "Legal & Employment", slug: "legal" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ToolzTotal" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://toolztotal.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://toolztotal.com/og-image.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://toolztotal.com/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://toolztotal.com/og-image.png" />

    <!-- Google Fonts Inter & JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet" />

    <!-- Blocking dark mode theme initializer -->
    <script is:inline>
      (function () {
        // Suppress transitions during initial theme application
        document.documentElement.classList.add('no-transition');

        const theme = (function () {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
          }
          return 'light';
        })();
        
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }

        // Re-enable transitions after first paint (double RAF ensures it's after layout/paint)
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            document.documentElement.classList.remove('no-transition');
          });
        });
      })();
    </script>

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-R7HNNJFVY8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-R7HNNJFVY8');
    </script>

    {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}
  </head>
  <body class="bg-canvas-soft text-ink selection:bg-primary selection:text-on-primary min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 w-full h-[64px] bg-canvas/80 backdrop-blur-md border-b border-hairline">
      <div class="max-w-[1400px] h-full mx-auto px-4 md:px-6 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <svg class="w-6 h-6 text-primary transition-transform group-hover:scale-105" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          <span class="text-xl font-bold tracking-tight text-ink font-sans">Toolz<span class="text-mute">Total</span></span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-1">
          {categories.slice(0, 4).map(cat => (
            <a href={`/${cat.slug}`} class="text-body font-sans text-sm px-3 py-1.5 rounded-full hover:bg-canvas-soft hover:text-ink transition-all">
              {cat.name}
            </a>
          ))}
          <!-- Dropdown button for remaining -->
          <div class="relative group/menu">
            <button class="flex items-center gap-1 text-body font-sans text-sm px-3 py-1.5 rounded-full hover:bg-canvas-soft hover:text-ink transition-all cursor-pointer">
              More
              <svg class="w-4 h-4 text-mute group-hover/menu:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute right-0 top-full pt-2 opacity-0 translate-y-1 invisible group-hover/menu:opacity-100 group-hover/menu:translate-y-0 group-hover/menu:visible transition-all duration-200 z-50">
              <div class="w-56 bg-canvas border border-hairline rounded-lg shadow-lvl5 p-1 transition-colors duration-200">
                {categories.slice(4).map(cat => (
                  <a href={`/${cat.slug}`} class="block text-body font-sans text-sm px-3 py-2 rounded-md hover:bg-canvas-soft hover:text-ink transition-colors">
                    {cat.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </nav>

        <!-- Right actions -->
        <div class="flex items-center gap-3">
          <!-- Quick search trigger (Desktop) -->
          <button id="global-search-trigger" class="hidden sm:flex items-center gap-2 text-mute font-sans text-xs border border-hairline bg-canvas hover:border-hairline-strong transition-colors rounded-lg px-3 py-2 cursor-pointer shadow-lvl1">
            <span>Search tools...</span>
            <kbd class="bg-canvas-soft-2 border border-hairline px-1.5 py-0.5 rounded text-[10px]">⌘K</kbd>
          </button>

          <!-- Quick search trigger (Mobile) -->
          <button id="global-search-trigger-mobile" class="sm:hidden p-2 border border-hairline bg-canvas text-body hover:text-ink rounded-lg cursor-pointer transition-colors hover:border-hairline-strong shadow-lvl1" aria-label="Search Tools">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>

          <!-- Dark mode toggle -->
          <button id="theme-toggle" class="p-2 border border-hairline bg-canvas text-body hover:text-ink rounded-lg cursor-pointer transition-colors hover:border-hairline-strong shadow-lvl1" aria-label="Toggle Dark Mode">
            <!-- Sun icon -->
            <svg id="sun-icon" class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 9h-1m14.071-7.071l-.707.707M6.343 17.657l-.707.707m2.828-9.9a5 5 0 117.072 0l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707" />
            </svg>
            <!-- Moon icon -->
            <svg id="moon-icon" class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>

          <!-- Mobile Nav Toggle -->
          <button id="mobile-menu-toggle" class="lg:hidden p-2 border border-hairline bg-canvas text-body hover:text-ink rounded-lg cursor-pointer transition-colors shadow-lvl1" aria-label="Toggle Menu">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Navigation Menu Overlay -->
    <div id="mobile-menu-overlay" class="fixed inset-0 bg-primary/40 backdrop-blur-sm z-[100] hidden">
      <div class="absolute right-0 top-0 bottom-0 w-80 bg-canvas border-l border-hairline shadow-lvl5 flex flex-col p-6 transition-transform duration-300 translate-x-full">
        <!-- Close & Header -->
        <div class="flex items-center justify-between mb-8">
          <span class="text-lg font-bold tracking-tight text-ink">Categories</span>
          <button id="mobile-menu-close" class="p-2 text-mute hover:text-ink cursor-pointer" aria-label="Close Menu">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        
        <!-- Navigation Links -->
        <nav class="flex flex-col gap-4 overflow-y-auto pr-2">
          {categories.map(cat => (
            <a href={`/${cat.slug}`} class="text-body font-sans text-base py-2 border-b border-hairline hover:text-primary transition-colors">
              {cat.name}
            </a>
          ))}
          <div class="h-6"></div>
          <a href="/about" class="text-mute font-sans text-sm hover:text-ink">About Us</a>
          <a href="/contact" class="text-mute font-sans text-sm hover:text-ink">Contact Us</a>
          <a href="/privacy" class="text-mute font-sans text-sm hover:text-ink">Privacy Policy</a>
          <a href="/terms" class="text-mute font-sans text-sm hover:text-ink">Terms & Conditions</a>
        </nav>
      </div>
    </div>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="w-full bg-canvas border-t border-hairline py-16 md:py-24 mt-auto">
      <div class="max-w-[1400px] mx-auto px-4 md:px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 lg:gap-8">
        <!-- Brand column -->
        <div class="lg:col-span-2 flex flex-col gap-4">
          <a href="/" class="flex items-center gap-2 group w-fit">
            <svg class="w-6 h-6 text-primary transition-transform group-hover:scale-105" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
            <span class="text-xl font-bold tracking-tight text-ink font-sans">Toolz<span class="text-mute">Total</span></span>
          </a>
          <p class="text-body text-sm font-sans max-w-sm leading-relaxed">
            Free online calculators and tools — no signup, no clutter, just answers. Every tool runs completely client-side in your browser. None of your data is ever uploaded or stored.
          </p>
          <div class="text-xs text-mute mt-2">
            Built for speed using Astro and Tailwind CSS.
          </div>
        </div>

        <!-- Categories Col 1 -->
        <div class="flex flex-col gap-4">
          <span class="text-xs font-mono tracking-wider text-mute uppercase font-medium">Categories</span>
          <ul class="flex flex-col gap-2.5">
            {categories.slice(0, 4).map(cat => (
              <li>
                <a href={`/${cat.slug}`} class="text-body hover:text-ink text-sm transition-colors font-sans">
                  {cat.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Categories Col 2 -->
        <div class="flex flex-col gap-4">
          <span class="text-xs font-mono tracking-wider text-mute uppercase font-medium">Categories (Cont.)</span>
          <ul class="flex flex-col gap-2.5">
            {categories.slice(4).map(cat => (
              <li>
                <a href={`/${cat.slug}`} class="text-body hover:text-ink text-sm transition-colors font-sans">
                  {cat.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Info / Legal -->
        <div class="flex flex-col gap-4">
          <span class="text-xs font-mono tracking-wider text-mute uppercase font-medium">Platform</span>
          <ul class="flex flex-col gap-2.5">
            <li><a href="/about" class="text-body hover:text-ink text-sm transition-colors font-sans">About Us</a></li>
            <li><a href="/contact" class="text-body hover:text-ink text-sm transition-colors font-sans">Contact Us</a></li>
            <li><a href="/privacy" class="text-body hover:text-ink text-sm transition-colors font-sans">Privacy Policy</a></li>
            <li><a href="/terms" class="text-body hover:text-ink text-sm transition-colors font-sans">Terms & Conditions</a></li>
          </ul>
        </div>
      </div>

      <!-- Copyright row -->
      <div class="max-w-[1400px] mx-auto px-4 md:px-6 mt-16 pt-8 border-t border-hairline flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="text-xs text-mute font-sans">
          &copy; {new Date().getFullYear()} ToolzTotal. All rights reserved.
        </span>
        <div class="flex gap-6">
          <a href="/#search-section" class="text-xs text-mute hover:text-ink font-sans transition-colors">Tools Directory</a>
          <a href="/sitemap.xml" class="text-xs text-mute hover:text-ink font-sans transition-colors">Sitemap</a>
        </div>
      </div>
    </footer>

    <!-- Theme Toggle and Mobile Menu Scripts -->
    <script>
      // Theme Toggle — uses View Transitions API for GPU-composited crossfade
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const applyTheme = () => {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
          };

          if (!document.startViewTransition) {
            applyTheme();
            return;
          }

          document.startViewTransition(applyTheme);
        });
      }

      // Mobile Menu Overlay Toggle logic
      const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
      const mobileMenuClose = document.getElementById('mobile-menu-close');

      if (mobileMenuToggle && mobileMenuOverlay && mobileMenuClose) {
        const innerPanel = mobileMenuOverlay.querySelector('div');

        const openMenu = () => {
          mobileMenuOverlay.classList.remove('hidden');
          setTimeout(() => {
            innerPanel?.classList.remove('translate-x-full');
          }, 10);
        };

        const closeMenu = () => {
          innerPanel?.classList.add('translate-x-full');
          setTimeout(() => {
            mobileMenuOverlay.classList.add('hidden');
          }, 300);
        };

        mobileMenuToggle.addEventListener('click', openMenu);
        mobileMenuClose.addEventListener('click', closeMenu);
        
        // Close menu if clicked outside
        mobileMenuOverlay.addEventListener('click', (e) => {
          if (e.target === mobileMenuOverlay) {
            closeMenu();
          }
        });
      }
    </script>

    <!-- Global Command Palette Search Modal -->
    <div id="global-search-modal" class="fixed inset-0 bg-canvas-soft/40 backdrop-blur-md z-[100] hidden items-center justify-center p-4">
      <div class="absolute inset-0 cursor-default" id="global-search-backdrop"></div>
      <div class="bg-canvas border border-hairline w-full max-w-xl rounded-2xl shadow-lvl5 overflow-hidden flex flex-col max-h-[85vh] relative z-10 animate-in fade-in zoom-in-95 duration-150">
        <div class="p-4 border-b border-hairline flex items-center gap-3">
          <svg class="w-5 h-5 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input 
            type="text" 
            id="global-search-input" 
            placeholder="Search all tools (e.g. mortgage, json, password)..." 
            class="w-full bg-transparent border-none focus:outline-none text-ink font-sans text-base placeholder:text-mute"
            autocomplete="off"
          />
          <button id="global-search-close" class="text-mute hover:text-ink text-xs font-mono border border-hairline px-2.5 py-1 rounded-lg cursor-pointer hover:border-hairline-strong transition-colors">ESC</button>
        </div>
        <div id="global-search-results" class="overflow-y-auto p-3 space-y-4 max-h-[50vh] divide-y divide-hairline"></div>
        <div class="p-3 bg-canvas-soft border-t border-hairline flex items-center justify-between text-[10px] text-mute font-mono">
          <div class="flex items-center gap-4">
            <span class="flex items-center gap-1"><kbd class="border border-hairline px-1 rounded">↑↓</kbd> Navigate</span>
            <span class="flex items-center gap-1"><kbd class="border border-hairline px-1 rounded">Enter</kbd> Open</span>
          </div>
          <span>ToolzTotal Search</span>
        </div>
      </div>
    </div>

    <script define:vars={{ toolCatalog }}>
      window.TOOL_CATALOG = toolCatalog;
    </script>

    <!-- Command Palette Search Script -->
    <script>

      // Global Search Modal / Command Palette logic
      const searchModal = document.getElementById('global-search-modal');
      const searchInput = document.getElementById('global-search-input');
      const searchResults = document.getElementById('global-search-results');
      const searchClose = document.getElementById('global-search-close');
      const searchBackdrop = document.getElementById('global-search-backdrop');
      const searchTriggers = document.querySelectorAll('#global-search-trigger, #global-search-trigger-mobile, #homepage-search-trigger');
      
      let activeIndex = -1;
      const allTools = [];
      const catalog = window.TOOL_CATALOG || [];
      
      catalog.forEach(cat => {
        cat.tools.forEach(tool => {
          allTools.push({
            ...tool,
            categoryName: cat.name,
            categorySlug: cat.slug
          });
        });
      });

      const openSearch = () => {
        searchModal?.classList.remove('hidden');
        searchModal?.classList.add('flex');
        document.body.style.overflow = 'hidden';
        setTimeout(() => searchInput?.focus(), 50);
        renderSearchResults('');
      };

      const closeSearch = () => {
        searchModal?.classList.add('hidden');
        searchModal?.classList.remove('flex');
        document.body.style.overflow = '';
        if (searchInput) searchInput.value = '';
        activeIndex = -1;
      };

      searchTriggers.forEach(trigger => trigger.addEventListener('click', openSearch));
      searchClose?.addEventListener('click', closeSearch);
      searchBackdrop?.addEventListener('click', closeSearch);

      const renderSearchResults = (query) => {
        if (!searchResults) return;
        
        const cleanQuery = query.toLowerCase().trim();
        const filtered = allTools.filter(tool => {
          if (!cleanQuery) return true;
          return tool.name.toLowerCase().includes(cleanQuery) || 
                 tool.description.toLowerCase().includes(cleanQuery) || 
                 (tool.keywords && tool.keywords.some(kw => kw.toLowerCase().includes(cleanQuery)));
        });

        if (filtered.length === 0) {
          searchResults.innerHTML = `
            <div class="text-center py-12 text-mute font-sans text-sm">
              No tools match your search. Try searching for "mortgage", "json", etc.
            </div>
          `;
          return;
        }

        const grouped = {};
        filtered.forEach(tool => {
          if (!grouped[tool.categoryName]) {
            grouped[tool.categoryName] = [];
          }
          grouped[tool.categoryName].push(tool);
        });

        let html = '';
        Object.keys(grouped).forEach(catName => {
          html += `
            <div class="pt-3 first:pt-0">
              <div class="text-[10px] font-mono uppercase tracking-wider text-mute mb-2 px-2">${catName}</div>
              <div class="space-y-1">
                ${grouped[catName].map(tool => `
                  <a 
                    href="/${tool.categorySlug}/${tool.slug}" 
                    class="search-item flex flex-col gap-0.5 px-3 py-2 rounded-xl hover:bg-canvas-soft-2 transition-colors cursor-pointer group"
                    data-slug="${tool.slug}"
                  >
                    <div class="text-sm font-bold text-ink group-hover:text-primary transition-colors flex items-center justify-between">
                      <span>${tool.name}</span>
                      ${tool.status === 'live' 
                        ? '<span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></span><span class="text-[9px] font-mono text-emerald-500 uppercase font-semibold">Live</span></span>' 
                        : '<span class="text-[9px] font-mono text-mute uppercase">Coming Soon</span>'}
                    </div>
                    <div class="text-xs text-body font-sans leading-relaxed">${tool.description}</div>
                  </a>
                `).join('')}
              </div>
            </div>
          `;
        });
        searchResults.innerHTML = html;
        activeIndex = -1;
      };

      searchInput?.addEventListener('input', (e) => {
        renderSearchResults(e.target.value);
      });

      const highlightActiveItem = (items) => {
        items.forEach((item, idx) => {
          if (idx === activeIndex) {
            item.classList.add('bg-canvas-soft-2');
            item.scrollIntoView({ block: 'nearest' });
          } else {
            item.classList.remove('bg-canvas-soft-2');
          }
        });
      };

      window.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          if (searchModal?.classList.contains('hidden')) {
            openSearch();
          } else {
            closeSearch();
          }
          return;
        }

        if (e.key === 'Escape' && !searchModal?.classList.contains('hidden')) {
          closeSearch();
          return;
        }

        if (searchModal && !searchModal.classList.contains('hidden')) {
          const items = searchResults?.querySelectorAll('.search-item') || [];
          if (items.length === 0) return;

          if (e.key === 'ArrowDown') {
            e.preventDefault();
            activeIndex = (activeIndex + 1) % items.length;
            highlightActiveItem(items);
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            activeIndex = (activeIndex - 1 + items.length) % items.length;
            highlightActiveItem(items);
          } else if (e.key === 'Enter') {
            if (activeIndex >= 0 && activeIndex < items.length) {
              e.preventDefault();
              items[activeIndex].click();
            }
          }
        }
      });
    </script>
  </body>
</html>
