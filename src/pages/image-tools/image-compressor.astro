---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does browser-side image compression work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The compressor draws the uploaded image onto a canvas. By calling canvas.toDataURL(mime, quality), we configure the browser's native encoder to compress JPEGs/WebPs at the specified quality factor (e.g. 0.75 for 75%)."
      }
    },
    {
      "@type": "Question",
      "name": "Will compressing my image reduce quality?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For JPEG and WebP formats, compression is lossy, meaning it removes subtle details to reduce size. A quality setting between 70% and 85% usually yields a 50%+ file size reduction without visible quality loss."
      }
    },
    {
      "@type": "Question",
      "name": "Does this tool support WebP conversion?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can select WebP as the export format. WebP offers superior compression ratios compared to traditional JPEGs and PNGs."
      }
    },
    {
      "@type": "Question",
      "name": "Is my data uploaded to TinyPNG-like servers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Unlike other compression utilities, all optimization steps occur locally on your machine. Your images are never transmitted over the internet."
      }
    },
    {
      "@type": "Question",
      "name": "How is PNG compression handled?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard HTML5 canvases do not support lossy PNG compression natively. For PNGs, the quality slider adjusts the export compression level when supported, or you can convert PNGs to JPEGs or WebPs for major size savings."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Image Compressor - Free Client-Side Photo Compression | ToolzTotal"
  description="Compress JPEG, PNG, and WebP images client-side to reduce file size without quality loss. 100% private, no server uploads."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/image-tools/image-compressor"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/image-tools" class="hover:text-ink transition-colors">Image Tools</a>
      <span>/</span>
      <span class="text-ink">Image Compressor</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <!-- Trust badge -->
      <div class="inline-flex items-center gap-2 border border-emerald-500/20 bg-emerald-500/5 px-3.5 py-1.5 rounded-full mb-6 shadow-lvl1">
        <span class="text-[10px] font-mono text-emerald-600 dark:text-emerald-400 uppercase tracking-wider font-semibold">🔒 100% Client-Side Processing. No files leave your device.</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Client-Side Image Compressor
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Shrink file sizes instantly. Compress JPEGs, PNGs, and WebPs down to optimal sizes right inside your web browser.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Inputs & Stats (6 cols) -->
      <div class="lg:col-span-6 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Compression Settings</h2>
        
        <!-- Dropzone -->
        <div id="dropzone" class="border-2 border-dashed border-hairline hover:border-hairline-strong rounded-xl p-8 text-center cursor-pointer transition-colors bg-canvas-soft flex flex-col items-center justify-center space-y-3">
          <svg class="w-10 h-10 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          <div class="text-sm font-sans text-ink">
            <span class="font-semibold text-primary">Click to upload</span> or drag & drop
          </div>
          <span class="text-[10px] font-mono text-mute">Supports PNG, JPG, JPEG, WebP</span>
          <input type="file" id="file-input" class="hidden" accept="image/*" />
        </div>

        <!-- Quality Slider -->
        <div>
          <div class="flex justify-between items-center mb-2">
            <label for="comp-quality" class="block text-xs font-mono uppercase text-mute">Compression Quality</label>
            <span id="quality-val" class="text-xs font-mono text-ink font-bold">80%</span>
          </div>
          <input 
            type="range" 
            id="comp-quality" 
            min="5" 
            max="100" 
            value="80" 
            disabled
            class="w-full h-2 bg-hairline rounded-lg appearance-none cursor-pointer disabled:opacity-50"
          />
        </div>

        <!-- Format conversions -->
        <div>
          <label for="export-format" class="block text-xs font-mono uppercase text-mute mb-2">Convert to Format</label>
          <select id="export-format" disabled class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink shadow-lvl1 cursor-pointer">
            <option value="original">Original Format</option>
            <option value="image/jpeg">JPEG (.jpg)</option>
            <option value="image/png">PNG (.png)</option>
            <option value="image/webp">WebP (.webp)</option>
          </select>
        </div>

        <!-- Reset & Download -->
        <div class="flex justify-between items-center pt-4 border-t border-hairline">
          <button id="btn-reset" class="text-xs font-mono text-mute hover:text-red-500 cursor-pointer transition-colors">Clear</button>
          <button id="btn-download" disabled class="h-10 px-5 bg-primary hover:bg-mute text-on-primary font-semibold text-xs rounded-lg transition-colors cursor-pointer shadow-lvl1 flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Download Compressed
          </button>
        </div>
      </div>

      <!-- Right Column: Before/After Stats (6 cols) -->
      <div class="lg:col-span-6 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Compression Performance</h2>
        
        <!-- Big ratio panel -->
        <div class="p-6 bg-canvas-soft border border-hairline rounded-lg text-center space-y-1 shadow-lvl1">
          <span class="text-[10px] font-mono text-mute uppercase block mb-1">File Size Reduction</span>
          <span id="res-reduction-ratio" class="text-4xl md:text-5xl font-black text-ink font-sans block">0.0%</span>
        </div>

        <!-- Before/after size cards -->
        <div class="grid grid-cols-2 gap-4 text-xs font-mono text-mute">
          <div class="p-4 border border-hairline rounded-lg bg-canvas-soft">
            <span class="block uppercase mb-1">Before Size</span>
            <span id="stat-before-size" class="text-lg font-bold text-ink font-sans">0 KB</span>
          </div>
          <div class="p-4 border border-hairline rounded-lg bg-canvas-soft">
            <span class="block uppercase mb-1">After Size</span>
            <span id="stat-after-size" class="text-lg font-bold text-ink font-sans">0 KB</span>
          </div>
        </div>

        <!-- Preview Tab Switches -->
        <div class="flex gap-2 border-t border-hairline pt-4">
          <button id="tab-comp" class="h-8 px-3 bg-primary text-on-primary rounded text-xs font-mono font-semibold cursor-pointer shadow-lvl1">Compressed Preview</button>
          <button id="tab-orig" class="h-8 px-3 border border-hairline hover:border-hairline-strong bg-canvas rounded text-xs font-mono text-body cursor-pointer shadow-lvl1">Original Image</button>
        </div>

        <!-- Image preview block -->
        <div class="border border-hairline rounded-lg overflow-hidden min-h-[200px] flex justify-center items-center bg-canvas-soft relative shadow-lvl1">
          <img id="preview-img" class="max-w-full max-h-[300px] object-contain hidden" />
          <div id="preview-placeholder" class="text-xs font-mono text-mute uppercase text-center">
            Upload an image to render comparison previews
          </div>
        </div>
      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">Lossless vs. Lossy Image Compression: Client-Side Optimization Explained</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          Heavy assets are the single primary cause of high web response latencies. Because images frequently represent over 60% of overall page payloads, compressing photos before publishing is a core SEO requirement.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Compression Formats and Algorithms</h3>
        <p>
          Online minification services optimize graphics differently depending on the mime format:
        </p>
        <ul class="list-disc pl-5 space-y-3 font-sans text-sm">
          <li><strong>JPEG (Lossy):</strong> Discards low-frequency color frequencies using discrete cosine transforms (DCT) to reduce file weight.</li>
          <li><strong>PNG (Lossless):</strong> Preserves 100% pixel integrity using compression patterns (DEFLATE). To achieve size reduction without format shifts, PNGs must often be converted.</li>
          <li><strong>WebP (Modern):</strong> Employs predictive compression blocks based on neighboring pixels, creating files 25-34% smaller than JPEGs while retaining transparency.</li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Zero Server Uploads</h3>
        <p>
          ToolzTotal uses native HTML5 canvas encoders to convert and compress images locally in your device memory. This means your private media stays completely safe on your device, offering a fast, zero-upload alternative to cloud compressors.
        </p>
      </div>
    </article>

    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How does browser-side image compression work?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            The compressor draws the uploaded image onto a canvas. By calling canvas.toDataURL(mime, quality), we configure the browser's native encoder to compress JPEGs/WebPs at the specified quality factor (e.g. 0.75 for 75%).
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Will compressing my image reduce quality?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            For JPEG and WebP formats, compression is lossy, meaning it removes subtle details to reduce size. A quality setting between 70% and 85% usually yields a 50%+ file size reduction without visible quality loss.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Does this tool support WebP conversion?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. You can select WebP as the export format. WebP offers superior compression ratios compared to traditional JPEGs and PNGs.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Is my data uploaded to TinyPNG-like servers?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            No. Unlike other compression utilities, all optimization steps occur locally on your machine. Your images are never transmitted over the internet.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How is PNG compression handled?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Standard HTML5 canvases do not support lossy PNG compression natively. For PNGs, the quality slider adjusts the export compression level when supported, or you can convert PNGs to JPEGs or WebPs for major size savings.
          </div>
        </details>

      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const dropzone = document.getElementById('dropzone') as HTMLDivElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;

  const qualityInput = document.getElementById('comp-quality') as HTMLInputElement;
  const qualityVal = document.getElementById('quality-val') as HTMLSpanElement;
  const formatSelect = document.getElementById('export-format') as HTMLSelectElement;

  const resReduction = document.getElementById('res-reduction-ratio') as HTMLSpanElement;
  const statBefore = document.getElementById('stat-before-size') as HTMLSpanElement;
  const statAfter = document.getElementById('stat-after-size') as HTMLSpanElement;

  const tabComp = document.getElementById('tab-comp') as HTMLButtonElement;
  const tabOrig = document.getElementById('tab-orig') as HTMLButtonElement;

  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const placeholder = document.getElementById('preview-placeholder') as HTMLDivElement;

  const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;
  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;

  // State
  let sourceImage: HTMLImageElement | null = null;
  let originalSize = 0;
  let originalMime = "image/jpeg";
  let activeFilename = "compressed_image.jpg";
  
  let originalDataUrl = "";
  let compressedDataUrl = "";

  // ============================================================
  // File Uploader Listeners
  // ============================================================
  dropzone.addEventListener('click', () => fileInput.click());

  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('border-hairline-strong');
  });

  dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('border-hairline-strong');
  });

  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-hairline-strong');
    if (e.dataTransfer?.files?.length) {
      handleFile(e.dataTransfer.files[0]);
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) {
      handleFile(fileInput.files[0]);
    }
  });

  // ============================================================
  // Functions
  // ============================================================
  const formatBytes = (bytes: number): string => {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  };

  const handleFile = (file: File) => {
    if (!file.type.startsWith('image/')) return;
    originalSize = file.size;
    originalMime = file.type;
    activeFilename = "compressed_" + file.name;

    const reader = new FileReader();
    reader.onload = (e) => {
      originalDataUrl = e.target?.result as string;

      const img = new Image();
      img.onload = () => {
        sourceImage = img;

        // Enable inputs
        [qualityInput, formatSelect, btnDownload].forEach(el => {
          (el as any).disabled = false;
        });

        placeholder.classList.add('hidden');
        previewImg.classList.remove('hidden');

        statBefore.textContent = formatBytes(originalSize);
        
        // Match selection formats
        formatSelect.value = "original";

        compressImage();
      };
      img.src = originalDataUrl;
    };
    reader.readAsDataURL(file);
  };

  const compressImage = () => {
    if (!sourceImage) return;

    const quality = parseInt(qualityInput.value) / 100;
    qualityVal.textContent = Math.round(quality * 100) + "%";

    let targetMime = formatSelect.value;
    if (targetMime === "original") {
      targetMime = originalMime;
    }

    const canvas = document.createElement('canvas');
    canvas.width = sourceImage.width;
    canvas.height = sourceImage.height;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.drawImage(sourceImage, 0, 0);

    // Compress
    compressedDataUrl = canvas.toDataURL(targetMime, quality);
    
    // Set preview to compressed
    previewImg.src = compressedDataUrl;
    switchTab('compressed');

    // Estimate file size from base64 string
    // Formula: Size in Bytes = (StringLength * (3/4)) - padding_chars
    const padding = (compressedDataUrl.match(/=/g) || []).length;
    const base64Len = compressedDataUrl.split(',')[1].length;
    const compressedSize = Math.round((base64Len * 0.75) - padding);

    statAfter.textContent = formatBytes(compressedSize);

    // Reduction savings
    const reduction = ((originalSize - compressedSize) / originalSize) * 100;
    if (reduction >= 0) {
      resReduction.textContent = reduction.toFixed(1) + "%";
    } else {
      resReduction.textContent = "0.0%"; // No expansion reported
    }
  };

  const switchTab = (tab: 'compressed' | 'original') => {
    if (tab === 'compressed') {
      tabComp.className = "h-8 px-3 bg-primary text-on-primary rounded text-xs font-mono font-semibold cursor-pointer shadow-lvl1";
      tabOrig.className = "h-8 px-3 border border-hairline hover:border-hairline-strong bg-canvas rounded text-xs font-mono text-body cursor-pointer shadow-lvl1";
      previewImg.src = compressedDataUrl;
    } else {
      tabOrig.className = "h-8 px-3 bg-primary text-on-primary rounded text-xs font-mono font-semibold cursor-pointer shadow-lvl1";
      tabComp.className = "h-8 px-3 border border-hairline hover:border-hairline-strong bg-canvas rounded text-xs font-mono text-body cursor-pointer shadow-lvl1";
      previewImg.src = originalDataUrl;
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  qualityInput.addEventListener('input', compressImage);
  formatSelect.addEventListener('change', compressImage);

  tabComp.addEventListener('click', () => switchTab('compressed'));
  tabOrig.addEventListener('click', () => switchTab('original'));

  btnDownload.addEventListener('click', () => {
    if (!compressedDataUrl) return;
    const link = document.createElement('a');
    let ext = "jpg";
    const mime = formatSelect.value === 'original' ? originalMime : formatSelect.value;
    if (mime === 'image/png') ext = 'png';
    else if (mime === 'image/webp') ext = 'webp';

    // Stripping old extension and attaching the new one
    const nameWithoutExt = activeFilename.substring(0, activeFilename.lastIndexOf('.')) || activeFilename;
    link.download = `${nameWithoutExt}.${ext}`;
    link.href = compressedDataUrl;
    link.click();
  });

  btnReset.addEventListener('click', () => {
    sourceImage = null;
    originalSize = 0;
    compressedDataUrl = "";
    originalDataUrl = "";
    
    fileInput.value = "";
    qualityInput.value = "80";
    qualityVal.textContent = "80%";
    formatSelect.value = "original";

    previewImg.classList.add('hidden');
    placeholder.classList.remove('hidden');

    statBefore.textContent = "0 KB";
    statAfter.textContent = "0 KB";
    resReduction.textContent = "0.0%";

    [qualityInput, formatSelect, btnDownload].forEach(el => {
      (el as any).disabled = true;
    });
  });
</script>
