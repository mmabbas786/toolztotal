<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const dropzone = document.getElementById('dropzone') as HTMLDivElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;

  const resizeWidth = document.getElementById('resize-width') as HTMLInputElement;
  const resizeHeight = document.getElementById('resize-height') as HTMLInputElement;
  const lockRatio = document.getElementById('lock-ratio') as HTMLInputElement;

  const canvas = document.getElementById('preview-canvas') as HTMLCanvasElement;
  const placeholder = document.getElementById('preview-placeholder') as HTMLDivElement;

  const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;
  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;

  // Social presets
  const presetInstaPost = document.getElementById('preset-insta-post') as HTMLButtonElement;
  const presetInstaStory = document.getElementById('preset-insta-story') as HTMLButtonElement;
  const presetYtThumb = document.getElementById('preset-yt-thumb') as HTMLButtonElement;
  const presetXHeader = document.getElementById('preset-x-header') as HTMLButtonElement;
  const presetButtons = document.querySelectorAll('.preset-btn') as NodeListOf<HTMLButtonElement>;

  // State
  let loadedImage: HTMLImageElement | null = null;
  let originalAspect = 1.0;
  let activeFilename = "resized_image.png";

  // ============================================================
  // Event Listeners for File Input
  // ============================================================
  dropzone.addEventListener('click', () => fileInput.click());

  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('border-hairline-strong');
  });

  dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('border-hairline-strong');
  });

  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-hairline-strong');
    if (e.dataTransfer?.files?.length) {
      loadImage(e.dataTransfer.files[0]);
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) {
      loadImage(fileInput.files[0]);
    }
  });

  // ============================================================
  // Functions
  // ============================================================
  const loadImage = (file: File) => {
    if (!file.type.startsWith('image/')) return;
    activeFilename = "resized_" + file.name;

    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        loadedImage = img;
        originalAspect = img.width / img.height;

        // Populate controls
        resizeWidth.value = img.width.toString();
        resizeHeight.value = img.height.toString();

        // Enable inputs
        [resizeWidth, resizeHeight, lockRatio, btnDownload, ...Array.from(presetButtons)].forEach(el => {
          (el as any).disabled = false;
        });

        // Hide placeholder and show canvas
        placeholder.classList.add('hidden');
        canvas.classList.remove('hidden');

        // Initial render
        renderResized();
      };
      img.src = e.target?.result as string;
    };
    reader.readAsDataURL(file);
  };

  const renderResized = () => {
    if (!loadedImage) return;

    const targetW = parseInt(resizeWidth.value) || 1;
    const targetH = parseInt(resizeHeight.value) || 1;

    canvas.width = targetW;
    canvas.height = targetH;

    const ctx = canvas.getContext('2d');
    if (ctx) {
      ctx.drawImage(loadedImage, 0, 0, targetW, targetH);
    }
  };

  const handleWidthChange = () => {
    if (!loadedImage) return;
    const w = parseInt(resizeWidth.value) || 0;
    if (lockRatio.checked && w > 0) {
      resizeHeight.value = Math.round(w / originalAspect).toString();
    }
    renderResized();
  };

  const handleHeightChange = () => {
    if (!loadedImage) return;
    const h = parseInt(resizeHeight.value) || 0;
    if (lockRatio.checked && h > 0) {
      resizeWidth.value = Math.round(h * originalAspect).toString();
    }
    renderResized();
  };

  const applyPreset = (w: number, h: number) => {
    if (!loadedImage) return;
    resizeWidth.value = w.toString();
    resizeHeight.value = h.toString();
    renderResized();
  };

  // ============================================================
  // Actions
  // ============================================================
  resizeWidth.addEventListener('input', handleWidthChange);
  resizeHeight.addEventListener('input', handleHeightChange);

  presetInstaPost.addEventListener('click', () => applyPreset(1080, 1080));
  presetInstaStory.addEventListener('click', () => applyPreset(1080, 1920));
  presetYtThumb.addEventListener('click', () => applyPreset(1280, 720));
  presetXHeader.addEventListener('click', () => applyPreset(1500, 500));

  btnDownload.addEventListener('click', () => {
    if (!loadedImage) return;
    const link = document.createElement('a');
    link.download = activeFilename;
    link.href = canvas.toDataURL('image/png');
    link.click();
  });

  btnReset.addEventListener('click', () => {
    loadedImage = null;
    canvas.classList.add('hidden');
    placeholder.classList.remove('hidden');
    fileInput.value = "";
    resizeWidth.value = "";
    resizeHeight.value = "";

    [resizeWidth, resizeHeight, lockRatio, btnDownload, ...Array.from(presetButtons)].forEach(el => {
      (el as any).disabled = true;
    });
  });
</script>
