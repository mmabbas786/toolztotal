                  </div>
                  <div>
                    <label for="field-vc-last" class="block text-xs font-mono uppercase text-mute mb-1">Last Name</label>
                    <input type="text" id="field-vc-last" class="w-full h-9 px-3 bg-canvas-soft border border-hairline rounded-lg text-xs font-sans text-ink" />
                  </div>
                </div>
                <div>
                  <label for="field-vc-phone" class="block text-xs font-mono uppercase text-mute mb-1">Phone</label>
                  <input type="tel" id="field-vc-phone" class="w-full h-9 px-3 bg-canvas-soft border border-hairline rounded-lg text-xs font-sans text-ink" />
                </div>
                <div>
                  <label for="field-vc-email" class="block text-xs font-mono uppercase text-mute mb-1">Email</label>
                  <input type="email" id="field-vc-email" class="w-full h-9 px-3 bg-canvas-soft border border-hairline rounded-lg text-xs font-sans text-ink" />
                </div>
                <div>
                  <label for="field-vc-org" class="block text-xs font-mono uppercase text-mute mb-1">Company</label>
                  <input type="text" id="field-vc-org" class="w-full h-9 px-3 bg-canvas-soft border border-hairline rounded-lg text-xs font-sans text-ink" />
                </div>
              </div>
            </div>

            <!-- Customization Settings -->
            <div class="space-y-4 pt-4 border-t border-hairline">
              <h3 class="text-xs font-mono uppercase text-mute tracking-wider">Customization</h3>
              
              <!-- Color controls -->
