                  <div class="flex items-center gap-2">
                    <input type="color" id="color-background" class="w-10 h-10 border border-hairline cursor-pointer p-0.5 rounded-lg bg-canvas-soft shrink-0" value="#ffffff" />
                    <input type="text" id="color-background-hex" class="w-full h-10 px-3 bg-canvas-soft border border-hairline rounded-lg text-xs font-mono text-ink text-center" value="#ffffff" maxlength="7" />
