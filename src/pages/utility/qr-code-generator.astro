          </div>

          <!-- Active configuration context indicators -->
          <input type="hidden" id="is-bulk-active" value="false" />

          <!-- SINGLE MODE INPUTS -->
          <div id="single-inputs-panel" class="space-y-5">
            <!-- Content Type -->
            <div>
              <label for="content-type" class="block text-xs font-mono uppercase text-mute mb-2">Content Type</label>
