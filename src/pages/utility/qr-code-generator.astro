                  <label for="field-email-body" class="block text-xs font-mono uppercase text-mute mb-1.5">Body</label>
                  <textarea id="field-email-body" class="w-full h-20 p-3 bg-canvas-soft border border-hairline rounded-lg text-sm font-sans text-ink focus:outline-none focus:border-hairline-strong"></textarea>
                </div>
              </div>

              <!-- Phone field -->
              <div data-type="phone" class="type-group hidden">
                <label for="field-phone" class="block text-xs font-mono uppercase text-mute mb-2">Phone Number</label>
                <input type="tel" id="field-phone" class="w-full h-10 px-3 bg-canvas-soft border border-hairline rounded-lg text-sm font-sans text-ink focus:outline-none focus:border-hairline-strong" placeholder="+1234567890" />
