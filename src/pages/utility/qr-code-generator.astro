---
import Layout from '../../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do these QR codes expire?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. These are static QR codes. They embed the data directly within the visual matrix. Since there is no redirect server or intermediary link involved, the QR codes will remain active indefinitely and will never expire."
      }
    },
    {
      "@type": "Question",
      "name": "What is the QR error correction level?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Error correction (L, M, Q, H) allows a QR code to be scanned even if part of it is dirty, damaged, or covered by a logo. Level L recovers up to 7% damage, M up to 15%, Q up to 25%, and H up to 30%. Using a higher level makes the code more dense but allows for larger logo overlays in the center."
      }
    },
    {
      "@type": "Question",
      "name": "Can I add a logo to the center of the QR code?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, you can upload a PNG or JPEG logo. The generator uses client-side HTML5 canvas to place your image in the center. We recommend using Error Correction Level H to ensure the QR code remains scannable when covered by your logo."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between URL, WiFi, and vCard QR codes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "URL codes open a website in a browser. WiFi codes contain credentials (SSID and password) to automatically connect mobile devices to a network. vCard codes contain contact details (name, email, phone, company) which smartphones can import directly into address books."
      }
    },
    {
      "@type": "Question",
      "name": "Is my data private when generating QR codes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, 100% private. This generator runs entirely client-side. Your inputs, contact details, WiFi passwords, or logos never leave your computer and are never uploaded to our servers, keeping them secure."
      }
    },
    {
      "@type": "Question",
      "name": "Are there watermarks on downloaded QR codes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, never. Unlike other QR generators that charge fees or watermark their downloads, ToolzTotal generates high-resolution, completely watermark-free QR codes for both personal and commercial use."
      }
    },
    {
      "@type": "Question",
      "name": "How do I download my QR code in vector format?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The tool supports downloading your QR code as a standard high-res PNG image or as a vector SVG file. SVG files are resolution-independent and perfect for printing on business cards, brochures, or billboards."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I change the colors of the QR code?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can change the foreground (pattern) and background colors. However, ensure there is high contrast between the two. Light patterns on dark backgrounds (inverted) can fail to scan on some readers."
      }
    },
    {
      "@type": "Question",
      "name": "Can I generate QR codes in bulk?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Our bulk panel allows you to enter multiple URLs (one per line). The tool generates them in a grid, letting you inspect and download each high-res PNG individually without ads."
      }
    },
    {
      "@type": "Question",
      "name": "How is a WiFi QR code formatted?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "WiFi QR codes follow a standard syntax: WIFI:S:NetworkName;T:WPA;P:Password;;. Most smartphones parse this syntax automatically when scanned, prompting the user to join the network."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout
  title="QR Code Generator - Free, Custom & No Watermark | ToolzTotal"
  description="Generate custom, high-resolution QR codes for free with no watermark. Supports WiFi, vCards, URLs, bulk generation, logo overlays, and SVG/PNG downloads."
  faqJsonLd={faqJsonLd}
>


  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
