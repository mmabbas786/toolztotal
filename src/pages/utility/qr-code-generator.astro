                <textarea id="field-text" class="w-full h-24 p-3 bg-canvas-soft border border-hairline rounded-lg text-sm font-sans text-ink focus:outline-none focus:border-hairline-strong" placeholder="Type your text content here..."></textarea>
              </div>

              <!-- Email field -->
              <div data-type="email" class="type-group hidden space-y-3">
