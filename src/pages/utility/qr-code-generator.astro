      <!-- LEFT: Inputs & Configurations (6 cols) -->
      <div class="lg:col-span-6 space-y-6">
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <div class="border-b border-hairline pb-4 flex justify-between items-center">
