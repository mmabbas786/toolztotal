                  <option value="L">L (7% Recovery)</option>
                  <option value="M">M (15% Recovery)</option>
                  <option value="Q">Q (25% Recovery)</option>
                  <option value="H" selected>H (30% Recovery - Recommended with Logo)</option>
                </select>
              </div>

              <!-- Logo overlay upload -->
