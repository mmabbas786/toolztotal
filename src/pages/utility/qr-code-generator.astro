                  <input type="email" id="field-email-to" class="w-full h-10 px-3 bg-canvas-soft border border-hairline rounded-lg text-sm font-sans text-ink focus:outline-none focus:border-hairline-strong" placeholder="name@example.com" />
                </div>
                <div>
                  <label for="field-email-sub" class="block text-xs font-mono uppercase text-mute mb-1.5">Subject</label>
                  <input type="text" id="field-email-sub" class="w-full h-10 px-3 bg-canvas-soft border border-hairline rounded-lg text-sm font-sans text-ink focus:outline-none focus:border-hairline-strong" />
                </div>
