            <button id="btn-add-guest" class="h-10 px-4 bg-primary hover:bg-mute text-on-primary font-semibold text-xs rounded-lg transition-colors cursor-pointer shadow-lvl1">Add Guest</button>
          </div>

          <!-- Guest tags container -->
