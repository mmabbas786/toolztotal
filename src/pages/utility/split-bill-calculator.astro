---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does itemized bill splitting work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Itemized bill splitting allocates costs based on what each person actually ordered. Shared items (like appetizers) are divided equally among those who consumed them, while taxes and tips are allocated proportionally based on each person's individual subtotal."
      }
    },
    {
      "@type": "Question",
      "name": "Why is proportional tax and tip allocation fairer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If tax and tip are split equally, a person ordering a $10 salad pays the same tax and tip as someone ordering a $50 steak. Proportional splitting assigns tax and tip relative to the cost of each person's meal, which is the mathematically correct way to divide additions."
      }
    },
    {
      "@type": "Question",
      "name": "How do I share the split bill results with friends?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This calculator features a 'Generate Share Link' button. It encodes the entire state of your bill (names, items, costs, tax, tip) into the URL query parameters. Anyone who clicks the link sees the exact itemized breakdown instantly."
      }
    },
    {
      "@type": "Question",
      "name": "Does this tool require a login or app install?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, never. Unlike popular mobile apps that require downloads, accounts, or email captures, this tool is 100% static, runs in the browser, and stores zero personal finance data on external servers."
      }
    },
    {
      "@type": "Question",
      "name": "Can I split an item among only a few people?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Each item you add has checkbox triggers for every person in your list. You can assign the item to one person, split it between two, or split it among everyone."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Split Bill Calculator - Itemized Restaurant Bill Splitter | ToolzTotal"
  description="Calculate itemized bill splits, allocate tax and tip per person, and generate shareable allocation links. Clean static utility tool."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/utility/split-bill-calculator"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/utility" class="hover:text-ink transition-colors">Everyday Utility</a>
      <span>/</span>
      <span class="text-ink">Split Bill Calculator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Split Bill Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Itemize restaurant tabs fairly. Add guests, log shared dishes, assign tax/tip proportionally, and generate shareable split links.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Inputs & Items (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Guest Planner Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2 flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-primary"></span>
            1. Who is sharing the bill?
          </h2>
          
          <div class="flex gap-2">
            <input 
              type="text" 
              id="guest-name-input" 
              placeholder="Enter name (e.g. Alex)" 
              class="flex-1 h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none"
            />
            <button id="btn-add-guest" class="h-10 px-4 bg-primary hover:bg-mute text-on-primary font-semibold text-xs rounded-lg transition-colors cursor-pointer shadow-lvl1">Add Guest</button>
          </div>

          <!-- Guest tags container -->
          <div id="guests-list" class="flex flex-wrap gap-2 pt-2">
            <!-- Dynamic guest tags added here -->
          </div>
        </div>

        <!-- Items Planner Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2 flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-primary"></span>
            2. Add Bill Items
          </h2>

          <div class="grid grid-cols-12 gap-2">
            <div class="col-span-6">
              <input type="text" id="item-name" placeholder="Item Name (e.g. Steak)" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none" />
            </div>
            <div class="col-span-3">
              <input type="number" id="item-price" placeholder="Price ($)" min="0.01" step="0.01" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none" />
            </div>
            <button id="btn-add-item" class="col-span-3 h-10 bg-primary hover:bg-mute text-on-primary font-semibold text-xs rounded-lg transition-colors cursor-pointer shadow-lvl1">Add Item</button>
          </div>

          <!-- Items list container -->
          <div id="items-table-container" class="space-y-4 pt-2">
            <!-- Dynamic item rows with guests assignments checkbox lists -->
          </div>
        </div>

        <!-- Adjustments (Tax / Tip) -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2 flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-primary"></span>
            3. Tax & Tip Adjustments
          </h2>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="tax-pct" class="block text-xs font-mono uppercase text-mute mb-2">Sales Tax (%)</label>
              <input type="number" id="tax-pct" value="8" min="0" step="0.1" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none shadow-lvl1" />
            </div>
            <div>
              <label for="tip-pct" class="block text-xs font-mono uppercase text-mute mb-2">Service Tip (%)</label>
              <input type="number" id="tip-pct" value="18" min="0" step="0.5" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink focus:outline-none shadow-lvl1" />
            </div>
          </div>
        </div>

      </div>

      <!-- Right Column: Results & Share (5 cols) -->
      <div class="lg:col-span-5 space-y-6">
        
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-6">
          <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Split Breakdown</h2>
          
          <!-- Share URL panel -->
          <div class="flex gap-2">
            <button id="btn-share" class="w-full h-10 border border-hairline hover:border-hairline-strong bg-canvas rounded-lg text-xs font-mono text-ink cursor-pointer transition-colors shadow-lvl1">Generate Shareable Link</button>
          </div>

          <div id="split-results-container" class="space-y-4">
            <!-- Dynamic per-person calculation results -->
          </div>

          <!-- Total summary -->
          <div class="space-y-3 text-xs font-mono text-mute pt-4 border-t border-hairline">
            <div class="flex justify-between">
              <span>SUBTOTAL:</span>
              <span id="summary-subtotal" class="font-bold text-ink">$0.00</span>
            </div>
            <div class="flex justify-between">
              <span>ESTIMATED TAX:</span>
              <span id="summary-tax" class="font-bold text-ink">$0.00</span>
            </div>
            <div class="flex justify-between">
              <span>ESTIMATED TIP:</span>
              <span id="summary-tip" class="font-bold text-ink">$0.00</span>
            </div>
            <div class="flex justify-between pt-2 border-t border-hairline font-bold text-ink text-sm">
              <span>GRAND TOTAL:</span>
              <span id="summary-grand-total">$0.00</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">The Mathematics of Fair Restaurant Bill Splitting</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          Dining out with groups is a common social occasion. However, settling the tab at the end of the meal often causes awkwardness or calculations overhead. While simply dividing the total bill by the number of guests is convenient, it is rarely fair, as individual ordering costs vary.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Itemized Allocation and Share Math</h3>
        <p>
          To calculate splits fairly, the calculator evaluates:
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li><strong>Base Cost:</strong> Each person is assigned the cost of items they ordered. If an item is shared (like an appetizer), its cost is divided evenly among the checking consumers.</li>
          <li><strong>Proportional Tax & Tip:</strong> Tax and tips are additions. Dividing them equally is unfair to low-cost orderers. Proportional distribution calculates each guest's percentage subtotal of the overall subtotal and assigns that ratio of the tax/tip:
            <br />
            <strong class="block my-2 text-center text-ink font-mono text-xs">Person's Tax = Guest Subtotal &times; (Tax Percentage / 100)</strong>
          </li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Instant URLs</h3>
        <p>
          To make coordination easy, our bill splitter encodes list states in query parameters. Click **Generate Shareable Link** to copy a URL that loads the exact configurations on your friend's phone.
        </p>
      </div>
    </article>

    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How does itemized bill splitting work?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Itemized bill splitting allocates costs based on what each person actually ordered. Shared items (like appetizers) are divided equally among those who consumed them, while taxes and tips are allocated proportionally based on each person's individual subtotal.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Why is proportional tax and tip allocation fairer?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            If tax and tip are split equally, a person ordering a $10 salad pays the same tax and tip as someone ordering a $50 steak. Proportional splitting assigns tax and tip relative to the cost of each person's meal, which is the mathematically correct way to divide additions.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How do I share the split bill results with friends?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            This calculator features a 'Generate Share Link' button. It encodes the entire state of your bill (names, items, costs, tax, tip) into the URL query parameters. Anyone who clicks the link sees the exact itemized breakdown instantly.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Does this tool require a login or app install?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            No, never. Unlike popular mobile apps that require downloads, accounts, or email captures, this tool is 100% static, runs in the browser, and stores zero personal finance data on external servers.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Can I split an item among only a few people?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. Each item you add has checkbox triggers for every person in your list. You can assign the item to one person, split it between two, or split it among everyone.
          </div>
        </details>

      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // DOM Elements & State
  // ============================================================
  const guestInput = document.getElementById('guest-name-input') as HTMLInputElement;
  const btnAddGuest = document.getElementById('btn-add-guest') as HTMLButtonElement;
  const guestsContainer = document.getElementById('guests-list') as HTMLDivElement;

  const itemNameInput = document.getElementById('item-name') as HTMLInputElement;
  const itemPriceInput = document.getElementById('item-price') as HTMLInputElement;
  const btnAddItem = document.getElementById('btn-add-item') as HTMLButtonElement;
  const itemsContainer = document.getElementById('items-table-container') as HTMLDivElement;

  const taxPctInput = document.getElementById('tax-pct') as HTMLInputElement;
  const tipPctInput = document.getElementById('tip-pct') as HTMLInputElement;

  const resultsContainer = document.getElementById('split-results-container') as HTMLDivElement;
  const summarySubtotal = document.getElementById('summary-subtotal') as HTMLSpanElement;
  const summaryTax = document.getElementById('summary-tax') as HTMLSpanElement;
  const summaryTip = document.getElementById('summary-tip') as HTMLSpanElement;
  const summaryGrandTotal = document.getElementById('summary-grand-total') as HTMLSpanElement;

  const btnShare = document.getElementById('btn-share') as HTMLButtonElement;

  interface Guest {
    id: string;
    name: string;
  }

  interface BillItem {
    id: string;
    name: string;
    price: number;
    assignedGuests: string[]; // Guest IDs
  }

  let guests: Guest[] = [
    { id: '1', name: 'Alex' },
    { id: '2', name: 'Taylor' }
  ];

  let items: BillItem[] = [
    { id: '101', name: 'Appetizer Salad', price: 12.00, assignedGuests: ['1', '2'] },
    { id: '102', name: 'Prime Steak', price: 42.00, assignedGuests: ['1'] },
    { id: '103', name: 'Pasta Carbonara', price: 24.00, assignedGuests: ['2'] }
  ];

  // ============================================================
  // Functions
  // ============================================================
  const generateId = () => Math.random().toString(36).substr(2, 9);

  const calculateSplits = () => {
    const taxPct = parseFloat(taxPctInput.value) || 0;
    const tipPct = parseFloat(tipPctInput.value) || 0;

    // 1. Calculate base subtotal per guest
    const guestTotals: Record<string, number> = {};
    guests.forEach(g => guestTotals[g.id] = 0);

    let subtotal = 0;
    items.forEach(item => {
      subtotal += item.price;
      const count = item.assignedGuests.length;
      if (count > 0) {
        const splitCost = item.price / count;
        item.assignedGuests.forEach(gid => {
          if (guestTotals[gid] !== undefined) {
            guestTotals[gid] += splitCost;
          }
        });
      }
    });

    const taxAmount = subtotal * (taxPct / 100);
    const tipAmount = subtotal * (tipPct / 100);
    const grandTotal = subtotal + taxAmount + tipAmount;

    summarySubtotal.textContent = "$" + subtotal.toFixed(2);
    summaryTax.textContent = "$" + taxAmount.toFixed(2);
    summaryTip.textContent = "$" + tipAmount.toFixed(2);
    summaryGrandTotal.textContent = "$" + grandTotal.toFixed(2);

    // Render per-person details
    resultsContainer.innerHTML = "";
    guests.forEach(g => {
      const gBase = guestTotals[g.id];
      const gProportion = subtotal > 0 ? gBase / subtotal : 0;
      const gTax = taxAmount * gProportion;
      const gTip = tipAmount * gProportion;
      const gTotal = gBase + gTax + gTip;

      const pBox = document.createElement('div');
      pBox.className = "p-4 bg-canvas-soft border border-hairline rounded-lg space-y-2 shadow-lvl1";
      pBox.innerHTML = `
        <div class="flex justify-between items-center font-bold text-ink">
          <span>${g.name}</span>
          <span>$${gTotal.toFixed(2)}</span>
        </div>
        <div class="grid grid-cols-3 text-[10px] font-mono text-mute pt-1 border-t border-hairline/40">
          <span>BASE: $${gBase.toFixed(2)}</span>
          <span>TAX: $${gTax.toFixed(2)}</span>
          <span>TIP: $${gTip.toFixed(2)}</span>
        </div>
      `;
      resultsContainer.appendChild(pBox);
    });
  };

  const renderGuests = () => {
    guestsContainer.innerHTML = "";
    guests.forEach(g => {
      const span = document.createElement('span');
      span.className = "inline-flex items-center gap-1.5 px-3 py-1 border border-hairline bg-canvas text-xs font-mono text-ink rounded-full shadow-lvl1";
      span.innerHTML = `
        <span>${g.name}</span>
        <button class="text-mute hover:text-red-500 cursor-pointer" data-id="${g.id}">&times;</button>
      `;
      // Delete listener
      span.querySelector('button')?.addEventListener('click', () => {
        guests = guests.filter(x => x.id !== g.id);
        // Remove assignment
        items.forEach(item => {
          item.assignedGuests = item.assignedGuests.filter(id => id !== g.id);
        });
        renderGuests();
        renderItems();
        calculateSplits();
      });
      guestsContainer.appendChild(span);
    });
  };

  const renderItems = () => {
    itemsContainer.innerHTML = "";
    items.forEach(item => {
      const div = document.createElement('div');
      div.className = "p-4 border border-hairline rounded-lg bg-canvas-soft space-y-3 shadow-lvl1";
      
      let guestCheckboxes = "";
      guests.forEach(g => {
        const checked = item.assignedGuests.includes(g.id) ? "checked" : "";
        guestCheckboxes += `
          <label class="inline-flex items-center gap-1.5 text-xs text-ink cursor-pointer select-none">
            <input type="checkbox" data-item-id="${item.id}" data-guest-id="${g.id}" ${checked} class="guest-assign-checkbox" />
            <span>${g.name}</span>
          </label>
        `;
      });

      div.innerHTML = `
        <div class="flex justify-between items-center">
          <span class="text-xs font-mono text-ink font-semibold">${item.name} ($${item.price.toFixed(2)})</span>
          <button class="text-[10px] font-mono text-mute hover:text-red-500 cursor-pointer" data-item-id="${item.id}">Remove</button>
        </div>
        <div class="flex flex-wrap gap-4 pt-1">
          ${guestCheckboxes || '<span class="text-[10px] text-mute font-mono">No guests added.</span>'}
        </div>
      `;

      // Assign checkbox change listener
      div.querySelectorAll('.guest-assign-checkbox').forEach(cb => {
        cb.addEventListener('change', (e) => {
          const target = e.target as HTMLInputElement;
          const iid = target.getAttribute('data-item-id');
          const gid = target.getAttribute('data-guest-id');
          if (iid && gid) {
            const it = items.find(x => x.id === iid);
            if (it) {
              if (target.checked) {
                if (!it.assignedGuests.includes(gid)) it.assignedGuests.push(gid);
              } else {
                it.assignedGuests = it.assignedGuests.filter(id => id !== gid);
              }
            }
          }
          calculateSplits();
        });
      });

      // Remove item listener
      div.querySelector('button[data-item-id]')?.addEventListener('click', () => {
        items = items.filter(x => x.id !== item.id);
        renderItems();
        calculateSplits();
      });

      itemsContainer.appendChild(div);
    });
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnAddGuest.addEventListener('click', () => {
    const name = guestInput.value.trim();
    if (!name) return;
    guests.push({ id: generateId(), name });
    guestInput.value = "";
    renderGuests();
    renderItems();
    calculateSplits();
  });

  btnAddItem.addEventListener('click', () => {
    const name = itemNameInput.value.trim() || "Dinner Item";
    const price = parseFloat(itemPriceInput.value) || 0;
    if (price <= 0) return;
    
    // Assign to everyone by default
    const allGids = guests.map(g => g.id);

    items.push({
      id: generateId(),
      name,
      price,
      assignedGuests: allGids
    });

    itemNameInput.value = "";
    itemPriceInput.value = "";
    renderItems();
    calculateSplits();
  });

  [taxPctInput, tipPctInput].forEach(inp => {
    inp.addEventListener('input', calculateSplits);
  });

  btnShare.addEventListener('click', () => {
    // Pack current state to URL query params
    const state = {
      guests,
      items,
      tax: parseFloat(taxPctInput.value) || 0,
      tip: parseFloat(tipPctInput.value) || 0
    };
    const encoded = btoa(JSON.stringify(state));
    const shareUrl = `${window.location.origin}${window.location.pathname}?bill=${encoded}`;
    
    navigator.clipboard.writeText(shareUrl).then(() => {
      btnShare.textContent = "Link Copied to Clipboard!";
      setTimeout(() => {
        btnShare.textContent = "Generate Shareable Link";
      }, 2000);
    });
  });

  // Load state from URL parameters on mount if present
  const init = () => {
    const params = new URLSearchParams(window.location.search);
    const billData = params.get('bill');
    if (billData) {
      try {
        const decoded = JSON.parse(atob(billData));
        if (decoded.guests && decoded.items) {
          guests = decoded.guests;
          items = decoded.items;
          taxPctInput.value = decoded.tax;
          tipPctInput.value = decoded.tip;
        }
      } catch (e) {
        console.warn("Failed to parse bill sharing parameters.");
      }
    }
    renderGuests();
    renderItems();
    calculateSplits();
  };

  init();
</script>
