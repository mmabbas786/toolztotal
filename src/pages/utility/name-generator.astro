          'Luna', 'Bella', 'Charlie', 'Lucy', 'Cooper', 'Max',
          'Bailey', 'Daisy', 'Sadie', 'Lola', 'Buddy', 'Rocky',
          'Milo', 'Coco', 'Oliver', 'Nala', 'Gizmo', 'Teddy'
        ]
      }
    }
  } as any;

  // ============================================================
  // DOM Elements
  // ============================================================
  const categorySelect = document.getElementById('name-category') as HTMLSelectElement;
  const originSelect = document.getElementById('name-origin') as HTMLSelectElement;
  const genderSelect = document.getElementById('name-gender') as HTMLSelectElement;

  const btnGenerate = document.getElementById('btn-generate') as HTMLButtonElement;
  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;
  const btnClearStarred = document.getElementById('btn-clear-starred') as HTMLButtonElement;

  const suggestionsGrid = document.getElementById('suggestions-grid') as HTMLDivElement;
  const starredContainer = document.getElementById('starred-list-container') as HTMLDivElement;
  const resCountLabel = document.getElementById('res-count-label') as HTMLSpanElement;

  let starredNames: string[] = [];

  // ============================================================
  // Functions
  // ============================================================
  const loadStarred = () => {
    try {
      const data = localStorage.getItem('starred_names');
      starredNames = data ? JSON.parse(data) : [];
    } catch (e) {
      starredNames = [];
    }
  };

  const saveStarred = () => {
    localStorage.setItem('starred_names', JSON.stringify(starredNames));
    renderStarred();
  };

  const renderStarred = () => {
    starredContainer.innerHTML = "";
    if (starredNames.length === 0) {
      starredContainer.innerHTML = `<span class="text-[10px] text-mute font-mono">No starred names yet. Click the star icon to save.</span>`;
      return;
    }

    starredNames.forEach(name => {
      const span = document.createElement('span');
      span.className = "inline-flex items-center gap-1.5 px-3 py-1 border border-hairline bg-canvas text-xs font-mono text-ink rounded-full shadow-lvl1";
      span.innerHTML = `
        <span>${name}</span>
        <button class="text-mute hover:text-red-500 cursor-pointer" data-name="${name}">&times;</button>
      `;
      span.querySelector('button')?.addEventListener('click', () => {
        starredNames = starredNames.filter(x => x !== name);
        saveStarred();
        renderSuggestions(lastGeneratedList);
      });
      starredContainer.appendChild(span);
    });
  };

  let lastGeneratedList: string[] = [];

  const renderSuggestions = (list: string[]) => {
    suggestionsGrid.innerHTML = "";
    resCountLabel.textContent = `Showing ${list.length} names`;

    list.forEach(name => {
      const isStarred = starredNames.includes(name);
      const div = document.createElement('div');
      div.className = "p-4 border border-hairline rounded-lg bg-canvas-soft flex justify-between items-center shadow-lvl1 hover:shadow-lvl2 transition-shadow";
      div.innerHTML = `
        <span class="text-sm font-sans font-semibold text-ink">${name}</span>
        <button class="cursor-pointer text-mute hover:text-yellow-500 transition-colors focus:outline-none" data-starred="${isStarred}">
          <svg class="w-5 h-5 ${isStarred ? 'fill-yellow-500 text-yellow-500' : 'fill-none text-mute'}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.907c.961 0 1.36 1.238.582 1.83l-3.97 2.883a1 1 0 00-.364 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.971-2.883a1 1 0 00-1.178 0l-3.97 2.883c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.364-1.118L2.98 9.72c-.779-.592-.38-1.83.582-1.83h4.907a1 1 0 00.95-.69l1.519-4.674z"/>
          </svg>
        </button>
      `;

      // Handle star trigger click
      div.querySelector('button')?.addEventListener('click', (e) => {
        if (starredNames.includes(name)) {
          starredNames = starredNames.filter(x => x !== name);
        } else {
          starredNames.push(name);
        }
        saveStarred();
        renderSuggestions(list);
      });

      suggestionsGrid.appendChild(div);
    });
  };

  const generateNames = () => {
    const cat = categorySelect.value;
    const origin = originSelect.value;
    const gender = genderSelect.value;

    let pool: string[] = [];

    if (cat === 'business') {
      pool = [...nameDatabase.business.all.neutral];
    } else if (cat === 'pet') {
      pool = [...nameDatabase.pet.all.neutral];
    } else {
      // baby or fantasy
      const catData = nameDatabase[cat];
      const originsToQuery = origin === 'all' ? Object.keys(catData) : [origin];

      originsToQuery.forEach(org => {
        const orgData = catData[org];
        if (orgData) {
          if (gender === 'neutral') {
            pool.push(...(orgData.male || []), ...(orgData.female || []));
          } else {
            pool.push(...(orgData[gender] || []));
          }
        }
      });
    }

    // Shuffle pool and slice 6
    const shuffled = pool.sort(() => 0.5 - Math.random());
    const count = Math.min(6, shuffled.length);
    lastGeneratedList = shuffled.slice(0, count);

    renderSuggestions(lastGeneratedList);
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnGenerate.addEventListener('click', generateNames);

  btnReset.addEventListener('click', () => {
    categorySelect.value = 'baby';
    originSelect.value = 'all';
    genderSelect.value = 'neutral';
    generateNames();
  });

  btnClearStarred.addEventListener('click', () => {
    starredNames = [];
    saveStarred();
    renderSuggestions(lastGeneratedList);
  });

  // Category change listener to toggle origin/gender filters if business or pet
  categorySelect.addEventListener('change', () => {
    const val = categorySelect.value;
    if (val === 'business' || val === 'pet') {
      originSelect.disabled = true;
      genderSelect.disabled = true;
    } else {
      originSelect.disabled = false;
      genderSelect.disabled = false;
    }
  });

  // Initialize
  loadStarred();
  renderStarred();
  generateNames();
</script>
