---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does the name generator work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The generator combines name bases, root stems, prefixes, and suffixes from specific linguistic databases (Norse, Celtic, Latin, French, Old English) according to your selected filters (gender, category, origin) client-side."
      }
    },
    {
      "@type": "Question",
      "name": "What categories of names can I generate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can generate Baby Names, Fantasy/RPG Character Names, Pet Names, and Startup Business Names. Each category uses specialized naming dictionaries."
      }
    },
    {
      "@type": "Question",
      "name": "Are the generated names saved?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. When you click the star icon beside a name, it is added to your local 'Favorites' list which is cached using your browser's localStorage. The data never leaves your browser."
      }
    },
    {
      "@type": "Question",
      "name": "Can I generate names from specific origins?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Under the filters, you can select specific linguistic categories including Celtic, Norse, Greek, French, Latin, or English to narrow name selections."
      }
    },
    {
      "@type": "Question",
      "name": "Is this tool free and private?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, absolutely. The generator runs completely client-side in your local browser sandbox. It is free, requires no account, and doesn't track your naming choices."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Random Name Generator - Free Names Planner | ToolzTotal"
  description="Generate random names for babies, fantasy characters, pets, or businesses with origin filters. Save favorites list. Clean static utility tool."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/utility/name-generator"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/utility" class="hover:text-ink transition-colors">Everyday Utility</a>
      <span>/</span>
      <span class="text-ink">Random Name Generator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Random Name Generator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Generate custom naming profiles. Choose between baby names, fantasy avatars, startup businesses, and pet names with origin filters.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Inputs & Generator (5 cols) -->
      <div class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Name Settings</h2>
        
        <!-- Category -->
        <div>
          <label for="name-category" class="block text-xs font-mono uppercase text-mute mb-2">Category</label>
          <select id="name-category" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink shadow-lvl1 cursor-pointer">
            <option value="baby">Baby Names</option>
            <option value="fantasy">Fantasy Characters</option>
            <option value="business">Business / Startup Names</option>
            <option value="pet">Pet Names</option>
          </select>
        </div>

        <!-- Origin -->
        <div>
          <label for="name-origin" class="block text-xs font-mono uppercase text-mute mb-2">Linguistic Origin</label>
          <select id="name-origin" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink shadow-lvl1 cursor-pointer">
            <option value="all">All Origins</option>
            <option value="celtic">Celtic</option>
            <option value="norse">Norse</option>
            <option value="greek">Greek</option>
            <option value="latin">Latin</option>
            <option value="french">French</option>
            <option value="english">English</option>
          </select>
        </div>

        <!-- Gender -->
        <div>
          <label for="name-gender" class="block text-xs font-mono uppercase text-mute mb-2">Gender Option</label>
          <select id="name-gender" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm text-ink shadow-lvl1 cursor-pointer">
            <option value="neutral">Neutral / All</option>
            <option value="male">Male</option>
            <option value="female">Female</option>
          </select>
        </div>

        <!-- Actions -->
        <div class="flex justify-between items-center pt-4 border-t border-hairline">
          <button id="btn-reset" class="text-xs font-mono text-mute hover:text-red-500 cursor-pointer transition-colors">Reset</button>
          <button id="btn-generate" class="h-10 px-5 bg-primary hover:bg-mute text-on-primary font-semibold text-xs rounded-lg transition-colors cursor-pointer shadow-lvl1">Generate Names</button>
        </div>
      </div>

      <!-- Right Column: Output Lists (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Results Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2 flex items-center justify-between">
            <span>Suggestions</span>
            <span class="text-xs font-mono text-mute" id="res-count-label">Showing 6 names</span>
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="suggestions-grid">
            <!-- Dynamic name cards rendered here -->
          </div>
        </div>

        <!-- Saved/Favorites Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2 flex items-center justify-between">
            <span>Starred Favorites</span>
            <button id="btn-clear-starred" class="text-[10px] font-mono text-mute hover:text-red-500 cursor-pointer">Clear Starred</button>
          </h2>

          <div class="flex flex-wrap gap-2" id="starred-list-container">
            <!-- Saved names display here -->
          </div>
        </div>

      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">Etymology, Naming Frameworks, and Selecting the Perfect Handle</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          Naming is the first step in defining an identity. Whether choosing a baby name, creating a fantasy character for a roleplaying game, naming a new family pet, or branding a startup business, name selection is guided by linguistic origins and conventions.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Linguistic Origins and Roots</h3>
        <p>
          Names hold historical footprints of cultural and linguistic evolution:
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li><strong>Celtic Roots:</strong> Soft phonetics and natural references (e.g. Maeve, Rowan, Dylan) evoking earth, water, and legends.</li>
          <li><strong>Norse/Scandinavian Roots:</strong> Strong syllables, often referring to gods, battle, or protection (e.g. Astrid, Freya, Leif, Gunnar).</li>
          <li><strong>Latin/Greek Roots:</strong> Formal, structured derivations often symbolizing virtues or physical descriptions (e.g. Felix, Sophia, Lucas).</li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Fantasy and Brand Naming Algorithms</h3>
        <p>
          Fantasy naming combines soft consonants and trailing vowels (e.g., -el, -ia) to evoke classic Tolkien-esque settings. Conversely, startup business naming prioritizes modern compound words (e.g. *ZetaCorp*, *ToolzTotal*), blending syllables to sound professional, memorable, and web-ready.
        </p>
      </div>
    </article>

    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How does the name generator work?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            The generator combines name bases, root stems, prefixes, and suffixes from specific linguistic databases (Norse, Celtic, Latin, French, Old English) according to your selected filters (gender, category, origin) client-side.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            What categories of names can I generate?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            You can generate Baby Names, Fantasy/RPG Character Names, Pet Names, and Startup Business Names. Each category uses specialized naming dictionaries.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Are the generated names saved?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. When you click the star icon beside a name, it is added to your local 'Favorites' list which is cached using your browser's localStorage. The data never leaves your browser.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Can I generate names from specific origins?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. Under the filters, you can select specific linguistic categories including Celtic, Norse, Greek, French, Latin, or English to narrow name selections.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Is this tool free and private?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes, absolutely. The generator runs completely client-side in your local browser sandbox. It is free, requires no account, and doesn't track your naming choices.
          </div>
        </details>

      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // Name data dictionaries
  // ============================================================
  const nameDatabase = {
    baby: {
      celtic: {
        male: ['Maeve', 'Rowan', 'Cillian', 'Fianna', 'Declan', 'Kieran'],
        female: ['Fiona', 'Niamh', 'Brigid', 'Caoimhe', 'Saoirse', 'Rhiannon']
      },
      norse: {
        male: ['Leif', 'Gunnar', 'Sven', 'Thor', 'Ragnar', 'Bjorn'],
        female: ['Astrid', 'Freya', 'Ingrid', 'Sigrid', 'Valkyrie', 'Thora']
      },
      greek: {
        male: ['Atlas', 'Lucas', 'Leo', 'Apollo', 'Theodore', 'Atticus'],
        female: ['Sophia', 'Elena', 'Iris', 'Athena', 'Chloe', 'Daphne']
      },
      latin: {
        male: ['Felix', 'Maximus', 'Augustus', 'Clara', 'Marcus', 'Leo'],
        female: ['Aurora', 'Clara', 'Stella', 'Valeria', 'Emilia', 'Julia']
      },
      french: {
        male: ['Louis', 'Remy', 'Pierre', 'Jean', 'Hugo', 'Arthur'],
        female: ['Elise', 'Colette', 'Clara', 'Adele', 'Genevieve', 'Camille']
      },
      english: {
        male: ['Arthur', 'Edward', 'Alfred', 'William', 'Charles', 'Thomas'],
        female: ['Hazel', 'Violet', 'Ivy', 'Alice', 'Charlotte', 'Audrey']
      }
    },
    fantasy: {
      celtic: {
        male: ['Gwydion', 'Belenus', 'Oisin', 'Peredur', 'Culhwch'],
        female: ['Ceridwen', 'Arianrhod', 'Morrigan', 'Danu', 'Rhiannon']
      },
      norse: {
        male: ['Odin', 'Baldur', 'Loki', 'Fenrir', 'Sigurd', 'Ymir'],
        female: ['Frigg', 'Hel', 'Gerd', 'Skadi', 'Nanna', 'Freya']
      },
      greek: {
        male: ['Zeus', 'Perseus', 'Achilles', 'Theseus', 'Orpheus'],
        female: ['Hera', 'Artemis', 'Hestia', 'Medusa', 'Pandora']
      },
      latin: {
        male: ['Romulus', 'Aeneas', 'Vulkan', 'Nero', 'Augustus'],
        female: ['Diana', 'Minerva', 'Vesta', 'Juno', 'Lavinia']
      },
      french: {
        male: ['Lancelot', 'Galahad', 'Tristan', 'Roland', 'Percival'],
        female: ['Guinevere', 'Morgana', 'Vivienne', 'Yseult', 'Melusine']
      },
      english: {
        male: ['Merlin', 'Arthur', 'Gawain', 'Bors', 'Kay'],
        female: ['Nimue', 'Morgause', 'Igraine', 'Elaine', 'Enid']
      }
    },
    business: {
      all: {
        neutral: [
          'ZetaCorp', 'ApexLink', 'NovoFlow', 'VortexLab', 'OptimaFlow',
          'AeroGrid', 'SolasGroup', 'CrestTech', 'CoreSaaS', 'SyncBase',
          'Vercelz', 'Antigrav', 'ToolzTotal', 'DataLoop', 'LuxMedia'
        ]
      }
    },
    pet: {
      all: {
        neutral: [
          'Luna', 'Bella', 'Charlie', 'Lucy', 'Cooper', 'Max',
          'Bailey', 'Daisy', 'Sadie', 'Lola', 'Buddy', 'Rocky',
          'Milo', 'Coco', 'Oliver', 'Nala', 'Gizmo', 'Teddy'
        ]
      }
    }
  } as any;

  // ============================================================
  // DOM Elements
  // ============================================================
  const categorySelect = document.getElementById('name-category') as HTMLSelectElement;
  const originSelect = document.getElementById('name-origin') as HTMLSelectElement;
  const genderSelect = document.getElementById('name-gender') as HTMLSelectElement;

  const btnGenerate = document.getElementById('btn-generate') as HTMLButtonElement;
  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;
  const btnClearStarred = document.getElementById('btn-clear-starred') as HTMLButtonElement;

  const suggestionsGrid = document.getElementById('suggestions-grid') as HTMLDivElement;
  const starredContainer = document.getElementById('starred-list-container') as HTMLDivElement;
  const resCountLabel = document.getElementById('res-count-label') as HTMLSpanElement;

  let starredNames: string[] = [];

  // ============================================================
  // Functions
  // ============================================================
  const loadStarred = () => {
    try {
      const data = localStorage.getItem('starred_names');
      starredNames = data ? JSON.parse(data) : [];
    } catch (e) {
      starredNames = [];
    }
  };

  const saveStarred = () => {
    localStorage.setItem('starred_names', JSON.stringify(starredNames));
    renderStarred();
  };

  const renderStarred = () => {
    starredContainer.innerHTML = "";
    if (starredNames.length === 0) {
      starredContainer.innerHTML = `<span class="text-[10px] text-mute font-mono">No starred names yet. Click the star icon to save.</span>`;
      return;
    }

    starredNames.forEach(name => {
      const span = document.createElement('span');
      span.className = "inline-flex items-center gap-1.5 px-3 py-1 border border-hairline bg-canvas text-xs font-mono text-ink rounded-full shadow-lvl1";
      span.innerHTML = `
        <span>${name}</span>
        <button class="text-mute hover:text-red-500 cursor-pointer" data-name="${name}">&times;</button>
      `;
      span.querySelector('button')?.addEventListener('click', () => {
        starredNames = starredNames.filter(x => x !== name);
        saveStarred();
        renderSuggestions(lastGeneratedList);
      });
      starredContainer.appendChild(span);
    });
  };

  let lastGeneratedList: string[] = [];

  const renderSuggestions = (list: string[]) => {
    suggestionsGrid.innerHTML = "";
    resCountLabel.textContent = `Showing ${list.length} names`;

    list.forEach(name => {
      const isStarred = starredNames.includes(name);
      const div = document.createElement('div');
      div.className = "p-4 border border-hairline rounded-lg bg-canvas-soft flex justify-between items-center shadow-lvl1 hover:shadow-lvl2 transition-shadow";
      div.innerHTML = `
        <span class="text-sm font-sans font-semibold text-ink">${name}</span>
        <button class="cursor-pointer text-mute hover:text-yellow-500 transition-colors focus:outline-none" data-starred="${isStarred}">
          <svg class="w-5 h-5 ${isStarred ? 'fill-yellow-500 text-yellow-500' : 'fill-none text-mute'}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.907c.961 0 1.36 1.238.582 1.83l-3.97 2.883a1 1 0 00-.364 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.971-2.883a1 1 0 00-1.178 0l-3.97 2.883c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.364-1.118L2.98 9.72c-.779-.592-.38-1.83.582-1.83h4.907a1 1 0 00.95-.69l1.519-4.674z"/>
          </svg>
        </button>
      `;

      // Handle star trigger click
      div.querySelector('button')?.addEventListener('click', (e) => {
        if (starredNames.includes(name)) {
          starredNames = starredNames.filter(x => x !== name);
        } else {
          starredNames.push(name);
        }
        saveStarred();
        renderSuggestions(list);
      });

      suggestionsGrid.appendChild(div);
    });
  };

  const generateNames = () => {
    const cat = categorySelect.value;
    const origin = originSelect.value;
    const gender = genderSelect.value;

    let pool: string[] = [];

    if (cat === 'business') {
      pool = [...nameDatabase.business.all.neutral];
    } else if (cat === 'pet') {
      pool = [...nameDatabase.pet.all.neutral];
    } else {
      // baby or fantasy
      const catData = nameDatabase[cat];
      const originsToQuery = origin === 'all' ? Object.keys(catData) : [origin];

      originsToQuery.forEach(org => {
        const orgData = catData[org];
        if (orgData) {
          if (gender === 'neutral') {
            pool.push(...(orgData.male || []), ...(orgData.female || []));
          } else {
            pool.push(...(orgData[gender] || []));
          }
        }
      });
    }

    // Shuffle pool and slice 6
    const shuffled = pool.sort(() => 0.5 - Math.random());
    const count = Math.min(6, shuffled.length);
    lastGeneratedList = shuffled.slice(0, count);

    renderSuggestions(lastGeneratedList);
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnGenerate.addEventListener('click', generateNames);

  btnReset.addEventListener('click', () => {
    categorySelect.value = 'baby';
    originSelect.value = 'all';
    genderSelect.value = 'neutral';
    generateNames();
  });

  btnClearStarred.addEventListener('click', () => {
    starredNames = [];
    saveStarred();
    renderSuggestions(lastGeneratedList);
  });

  // Category change listener to toggle origin/gender filters if business or pet
  categorySelect.addEventListener('change', () => {
    const val = categorySelect.value;
    if (val === 'business' || val === 'pet') {
      originSelect.disabled = true;
      genderSelect.disabled = true;
    } else {
      originSelect.disabled = false;
      genderSelect.disabled = false;
    }
  });

  // Initialize
  loadStarred();
  renderStarred();
  generateNames();
</script>
