---
import Layout from "../../layouts/Layout.astro";
import ToolSchema from "../../components/ToolSchema.astro";
import RelatedTools from "../../components/RelatedTools.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

// ToolSchema provides FAQ data as JSON-LD. Keep UI FAQ accordion in sync.
const faqs = [
  {
    question: "Comparing Passwords and Multi-Word Passphrases",
    answer:
      "Choosing between standard passwords and dictionary passphrases depends on accessibility:",
  },
  {
    question: "Shannon Entropy and Password Strength",
    answer:
      "Password security is measured in Shannon entropy bits. Bits of entropy measure the logarithmic complexity of the key. A password with 80 bits of entropy requires $2^{80}$ attempts to crack via a brute-force search. Standard online services recommend a minimum of 60 bits for standard users and 80+ bits for root systems or server keys.",
  },
  {
    question: "100% Local & Private Execution",
    answer:
      "To maintain confidentiality, all character selection and entropy math run locally in your browser's private stack memory. No data is stored, saved, or uploaded, protecting your keys from internet leaks.",
  },
  {
    question: "Understanding Password Entropy and Cryptographic Security",
    answer:
      "Information theory measures password strength using entropy, which calculates the complexity of a password in bits. Higher entropy means a password is mathematically harder to guess or brute-force. The entropy formula is: E = L * log2(R) , where L is the password character length and R is the size of the character pool (e.g., 95 characters for standard keyboard characters). A password with 16 characters containing lowercase letters, uppercase letters, digits, and special symbols has over 100 bits of entropy, which is considered cryptographically secure against supercomputer brute-force attacks.",
  },
  {
    question: "The Risk of Password Reuse and Credential Stuffing",
    answer:
      "Credential stuffing is a cyberattack where automated scripts attempt to log into various websites using databases of leaked usernames and passwords from previous breaches. If you reuse the same password across multiple online services, a single breach at a minor site can expose all your other accounts (like email, banking, or social media). Using a password generator to create a unique, high-entropy password for every service, and storing them inside a secure password manager, represents the baseline requirement for personal cybersecurity.",
  },
  {
    question: "How Long Does It Take to Crack a Weak Password?",
    answer:
      "Brute-forcing speeds have increased exponentially due to high-performance GPU hardware. A standard 8-character password consisting only of lowercase letters can be cracked instantly in under a fraction of a second. Even adding uppercase letters and numbers only raises the time to a few minutes. However, a 16-character password with mixed characters requires trillions of years to crack using modern computing resources. This highlights why length is the single most important factor when generating secure passwords.",
  },
  {
    question: "Best Practices for Password Management",
    answer:
      "Generating secure, complex passwords represents only half the challenge; storing and managing them safely is equally important. Experts recommend: 1. Use a dedicated password manager (like Bitwarden or 1Password) to generate, store, and autofill credentials; 2. Enable multi-factor authentication (MFA) on all critical accounts, preferring authenticator apps or security keys over SMS; 3. Never write passwords down on post-it notes or store them in unsecured text files on your desktop.",
  },
  {
    question: "Related Developer & Utility Tools",
    answer:
      "UUID Generator Generate time-ordered or random UUID primary keys bulk in your browser.",
  },
];
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';
---

<Layout
  title="Random Password Generator - Free, Secure & Private | ToolzTotal"
  description="Generate secure, cryptographically random passwords and Diceware-style passphrases. Bulks generation and strength indicators — 100% local and free."
>
  <ToolSchema
    toolName="Random Password Generator"
    toolSlug="password-generator"
    categoryName="Everyday / Life Utility"
    categorySlug="utility"
    description="Generate secure, cryptographically random passwords and Diceware-style passphrases. Bulks generation and strength indicators — 100% local and free."
    faqs={faqs}
  />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categoryName="Everyday / Life Utility"
      categorySlug="utility"
      toolName="Random Password Generator"
      toolSlug="password-generator"
    />

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div
        class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider"
          >Free Tool</span
        >
      </div>
      <h1
        class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty"
      >
        Random Password Generator
      </h1>
      <p
        class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl"
      >
        Generate cryptographically secure random passwords or multi-word
        passphrases instantly. Runs 100% locally in your browser using secure
        operating system entropy.
      </p>
    </div>

    <!-- Main Calculator Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start max-w-7xl">
      <!-- LEFT: Inputs & Configurations (5 cols) -->
      <div class="lg:col-span-5 space-y-6">
        <div
          class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6"
        >
          <div class="border-b border-hairline pb-4">
            <h2 class="text-base font-bold text-ink font-sans">
              Generator Settings
            </h2>
            <p class="text-xs text-mute font-sans mt-1">
              Select the generation mode and complexity rules.
            </p>
          </div>

          <!-- Mode Selector Toggles -->
          <div>
            <label class="block text-xs font-mono uppercase text-mute mb-2"
              >Generation Mode</label
            >
            <div
              class="flex rounded-lg bg-canvas-soft-2 p-0.5 border border-hairline shadow-lvl1"
            >
              <button
                type="button"
                id="mode-random"
                class="flex-1 text-center py-2 text-xs font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer"
              >
                Random Characters
              </button>
              <button
                type="button"
                id="mode-passphrase"
                class="flex-1 text-center py-2 text-xs font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer"
              >
                Passphrase
              </button>
            </div>
            <input type="hidden" id="active-mode" value="random" />
          </div>

          <!-- Length Parameter -->
          <div id="settings-length-group">
            <div class="flex justify-between items-center mb-2">
              <label
                for="length-slider"
                class="text-xs font-mono uppercase text-mute"
                >Password Length</label
              >
              <span
                id="length-val"
                class="text-sm font-mono font-bold text-ink bg-canvas-soft border border-hairline rounded px-2 py-0.5"
                >16</span
              >
            </div>
            <input
              type="range"
              id="length-slider"
              min="8"
              max="64"
              value="16"
              class="w-full accent-primary h-2 bg-canvas-soft rounded-lg cursor-pointer border border-hairline"
            />
          </div>

          <!-- Passphrase Words Parameter -->
          <div id="settings-words-group" class="hidden">
            <div class="flex justify-between items-center mb-2">
              <label
                for="words-slider"
                class="text-xs font-mono uppercase text-mute">Word Count</label
              >
              <span
                id="words-val"
                class="text-sm font-mono font-bold text-ink bg-canvas-soft border border-hairline rounded px-2 py-0.5"
                >4</span
              >
            </div>
            <input
              type="range"
              id="words-slider"
              min="3"
              max="10"
              value="4"
              class="w-full accent-primary h-2 bg-canvas-soft rounded-lg cursor-pointer border border-hairline"
            />

            <div class="mt-4">
              <label
                for="passphrase-separator"
                class="block text-xs font-mono uppercase text-mute mb-2"
                >Word Separator</label
              >
              <input
                type="text"
                id="passphrase-separator"
                value="-"
                maxlength="3"
                class="w-20 h-9 px-3 bg-canvas-soft border border-hairline rounded-md text-xs font-mono text-ink text-center focus:outline-none focus:border-hairline-strong transition-colors"
              />
            </div>
          </div>

          <!-- Character Set Toggles -->
          <div id="settings-charsets" class="space-y-3">
            <label class="block text-xs font-mono uppercase text-mute"
              >Included Characters</label
            >
            <div class="grid grid-cols-2 gap-3 text-xs font-sans text-body">
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input
                  type="checkbox"
                  id="char-upper"
                  checked
                  class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline"
                />
                <span>Uppercase (A-Z)</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input
                  type="checkbox"
                  id="char-lower"
                  checked
                  class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline"
                />
                <span>Lowercase (a-z)</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input
                  type="checkbox"
                  id="char-numbers"
                  checked
                  class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline"
                />
                <span>Numbers (0-9)</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input
                  type="checkbox"
                  id="char-symbols"
                  checked
                  class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline"
                />
                <span>Symbols (!@#$)</span>
              </label>
            </div>
          </div>

          <!-- Additional Filters -->
          <div class="space-y-3 pt-3 border-t border-hairline">
            <label class="block text-xs font-mono uppercase text-mute"
              >Advanced Filters</label
            >
            <div class="space-y-2.5 text-xs font-sans text-body">
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input
                  type="checkbox"
                  id="exclude-similar"
                  class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline"
                />
                <span>Exclude similar (e.g. i, l, 1, o, 0)</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input
                  type="checkbox"
                  id="exclude-ambiguous"
                  class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline"
                />
                <span>Exclude ambiguous (e.g. {}, [ ], /)</span>
              </label>
            </div>
          </div>

          <!-- Bulk Generation -->
          <div class="pt-3 border-t border-hairline">
            <div class="flex justify-between items-center mb-2">
              <label
                for="bulk-slider"
                class="text-xs font-mono uppercase text-mute"
                >Bulk Generation (Qty)</label
              >
              <span
                id="bulk-val"
                class="text-sm font-mono font-bold text-ink bg-canvas-soft border border-hairline rounded px-2 py-0.5"
                >1</span
              >
            </div>
            <input
              type="range"
              id="bulk-slider"
              min="1"
              max="50"
              value="1"
              class="w-full accent-primary h-2 bg-canvas-soft rounded-lg cursor-pointer border border-hairline"
            />
          </div>

          <button
            type="button"
            id="generate-btn"
            class="w-full h-11 bg-primary text-on-primary hover:opacity-90 font-sans text-sm font-semibold rounded-lg shadow-lvl2 transition-all cursor-pointer"
          >
            Generate Password
          </button>
        </div>
      </div>

      <!-- RIGHT: Output Panels (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        <!-- Output Display -->
        <div
          class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl3 space-y-6"
        >
          <div
            class="border-b border-hairline pb-4 flex justify-between items-center"
          >
            <h2 class="text-sm font-bold text-ink font-sans">Secure Result</h2>
            <span id="entropy-badge" class="text-xs font-mono text-mute"
              >Entropy: 0 bits</span
            >
          </div>

          <!-- Single password display -->
          <div id="single-output-panel" class="space-y-4">
            <div
              class="bg-canvas-soft border border-hairline rounded-lg p-4 md:p-6 shadow-lvl1 flex items-center justify-between gap-4"
            >
              <code
                id="password-output"
                class="text-lg md:text-xl font-mono text-ink break-all select-all tracking-wide block flex-1"
                >Click Generate</code
              >
              <button
                type="button"
                id="copy-btn"
                class="h-9 px-4 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink rounded-lg shadow-lvl1 transition-colors flex items-center gap-1.5 cursor-pointer shrink-0"
              >
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                  ></path>
                </svg>
                Copy
              </button>
            </div>

            <!-- Strength Meter -->
            <div class="space-y-2">
              <div class="flex justify-between text-xs font-mono text-mute">
                <span>Strength:</span>
                <span id="strength-label" class="font-bold text-ink uppercase"
                  >N/A</span
                >
              </div>
              <div
                class="w-full h-2 bg-canvas-soft-2 rounded-full overflow-hidden border border-hairline shadow-lvl1"
              >
                <div
                  id="strength-bar"
                  class="w-0 h-full transition-all duration-300 bg-error"
                >
                </div>
              </div>
            </div>
          </div>

          <!-- Bulk passwords display -->
          <div id="bulk-output-panel" class="hidden space-y-4">
            <div class="flex gap-2">
              <button
                type="button"
                id="copy-bulk-btn"
                class="h-8 px-3 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink text-xs font-sans rounded-md shadow-lvl1 transition-colors flex items-center gap-1 cursor-pointer"
              >
                Copy All
              </button>
              <button
                type="button"
                id="download-bulk-btn"
                class="h-8 px-3 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink text-xs font-sans rounded-md shadow-lvl1 transition-colors flex items-center gap-1 cursor-pointer"
              >
                Download List
              </button>
            </div>
            <textarea
              id="bulk-output"
              readonly
              class="w-full h-[280px] bg-canvas-soft-2 text-ink font-mono text-[13px] leading-relaxed p-4 border border-hairline rounded-lg focus:outline-none resize-none shadow-lvl1"
            ></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- SEO text block -->
    <article
      class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16"
    >
      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6"
      >
        About the Secure Password Generator: Cryptographic Randomness Explained
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          A <strong>random password generator</strong> is a core security prerequisite
          for protecting digital identity. Standard pseudorandom generator formulas
          in JavaScript, such as <code>Math.random()</code>, are mathematically
          predictable. If a malicious system knows the seed or state of the
          random number engine, they can duplicate the output passwords. This <strong
            >secure password generator</strong
          > uses a cryptographically secure pseudorandom number generator (CSPRNG)
          through the standard browser <code>crypto.getRandomValues()</code> API,
          ensuring true entropy.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">
          Comparing Passwords and Multi-Word Passphrases
        </h3>
        <p>
          Choosing between standard passwords and dictionary passphrases depends
          on accessibility:
        </p>
        <ul class="list-disc pl-5 space-y-2">
          <li>
            <strong>Random Character Passwords:</strong> Constructed using complex
            mixed symbol arrays (numbers, upper/lowercase, symbols). They provide
            high entropy per character but are extremely difficult to memorize, requiring
            a password manager vault.
          </li>
          <li>
            <strong>Passphrases (Diceware-Style):</strong> Built using a series of
            unrelated words linked by dashes or characters. This <strong
              >passphrase generator</strong
            > chooses words randomly from a vetted local dictionary list. Because
            the security scales with length, a 5-word passphrase has comparable strength
            to a 14-character random password, but remains highly memorizable.
          </li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">
          Shannon Entropy and Password Strength
        </h3>
        <p>
          Password security is measured in Shannon entropy bits. Bits of entropy
          measure the logarithmic complexity of the key. A password with 80 bits
          of entropy requires $2^{80}$ attempts to crack via a brute-force
          search. Standard online services recommend a minimum of 60 bits for
          standard users and 80+ bits for root systems or server keys.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">
          100% Local & Private Execution
        </h3>
        <p>
          To maintain confidentiality, all character selection and entropy math
          run locally in your browser's private stack memory. No data is stored,
          saved, or uploaded, protecting your keys from internet leaks.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">
          Understanding Password Entropy and Cryptographic Security
        </h3>
        <p>
          Information theory measures password strength using entropy, which
          calculates the complexity of a password in bits. Higher entropy means
          a password is mathematically harder to guess or brute-force. The
          entropy formula is: <code>E = L * log2(R)</code>, where <code>L</code> is
          the password character length and <code>R</code> is the size of the character
          pool (e.g., 95 characters for standard keyboard characters). A password
          with 16 characters containing lowercase letters, uppercase letters, digits,
          and special symbols has over 100 bits of entropy, which is considered cryptographically
          secure against supercomputer brute-force attacks.
        </p>
        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">
          The Risk of Password Reuse and Credential Stuffing
        </h3>
        <p>
          Credential stuffing is a cyberattack where automated scripts attempt
          to log into various websites using databases of leaked usernames and
          passwords from previous breaches. If you reuse the same password
          across multiple online services, a single breach at a minor site can
          expose all your other accounts (like email, banking, or social media).
          Using a password generator to create a unique, high-entropy password
          for every service, and storing them inside a secure password manager,
          represents the baseline requirement for personal cybersecurity.
        </p>
        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">
          How Long Does It Take to Crack a Weak Password?
        </h3>
        <p>
          Brute-forcing speeds have increased exponentially due to
          high-performance GPU hardware. A standard 8-character password
          consisting only of lowercase letters can be cracked instantly in under
          a fraction of a second. Even adding uppercase letters and numbers only
          raises the time to a few minutes. However, a 16-character password
          with mixed characters requires trillions of years to crack using
          modern computing resources. This highlights why length is the single
          most important factor when generating secure passwords.
        </p>
        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">
          Best Practices for Password Management
        </h3>
        <p>
          Generating secure, complex passwords represents only half the
          challenge; storing and managing them safely is equally important.
          Experts recommend: 1. Use a dedicated password manager (like Bitwarden
          or 1Password) to generate, store, and autofill credentials; 2. Enable
          multi-factor authentication (MFA) on all critical accounts, preferring
          authenticator apps or security keys over SMS; 3. Never write passwords
          down on post-it notes or store them in unsecured text files on your
          desktop.
        </p>
      </div>
    </article>

  <Sources sources={[
    { label: 'NIST — Random Number Generation Guidelines', url: 'https://csrc.nist.gov/projects/random-bit-generation' },
    { label: 'Have I Been Pwned — Password Security', url: 'https://haveibeenpwned.com/Passwords' }
  ]} />

    <!-- FAQ Accordions -->
    <section class="mt-20 pt-16 border-t border-hairline max-w-4xl">
      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty"
      >
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {
          faqs.map((faq) => (
            <details class="group ring-1 ring-inset ring-hairline rounded-xl bg-canvas overflow-hidden shadow-lvl2">
              <summary class="w-full px-6 py-4 flex items-center justify-between text-left font-sans text-sm font-bold text-ink cursor-pointer list-none marker:hidden hover:bg-canvas-soft-2 transition-colors">
                <span>{faq.question}</span>
                <svg
                  class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </summary>
              <div class="border-t border-hairline px-6 py-4 bg-canvas-soft">
                <p class="text-body text-sm font-sans leading-relaxed">
                  {faq.answer}
                </p>
              </div>
            </details>
          ))
        }
      </div>
    </section>

    <!-- Related Tools -->
    <section class="mt-20 pt-16 border-t border-hairline">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">
        Related Developer & Utility Tools
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a
          href="/dev/uuid-generator"
          class="block bg-canvas ring-1 ring-inset ring-hairline hover:ring-hairline-strong transition-all duration-200 rounded-xl p-5 hover:shadow-lvl2 shadow-lvl1 group"
        >
          <h4
            class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center justify-between"
          >
            UUID Generator
            <svg
              class="w-4 h-4 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7"></path></svg
            >
          </h4>
          <p class="text-mute text-xs font-sans mt-2">
            Generate time-ordered or random UUID primary keys bulk in your
            browser.
          </p>
        </a>
        <a
          href="/utility/qr-code-generator"
          class="block bg-canvas ring-1 ring-inset ring-hairline hover:ring-hairline-strong transition-all duration-200 rounded-xl p-5 hover:shadow-lvl2 shadow-lvl1 group"
        >
          <h4
            class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center justify-between"
          >
            QR Code Generator
            <svg
              class="w-4 h-4 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7"></path></svg
            >
          </h4>
          <p class="text-mute text-xs font-sans mt-2">
            Generate clean, watermark-free custom QR codes from URLs, texts, or
            cards.
          </p>
        </a>
      </div>
    </section>
  </div>

  <script>
    // CSPRNG dictionary wordlist for passphrase generation
    const wordlist = [
      "acid",
      "agent",
      "alias",
      "alpha",
      "amber",
      "anchor",
