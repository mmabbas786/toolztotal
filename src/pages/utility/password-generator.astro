---
import Layout from '../../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is this password generator secure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, this generator is highly secure. It uses the Web Crypto API's cryptographically secure pseudorandom number generator (CSPRNG) via crypto.getRandomValues(). Unlike standard Math.random(), which is predictable, CSPRNG produces high-entropy randomness suitable for cryptography. Additionally, all generations happen locally in your browser—no passwords are sent over the network."
      }
    },
    {
      "@type": "Question",
      "name": "What makes a password strong?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A strong password is defined by its length and complexity (entropy). A secure password should be at least 16 characters long and include a mix of uppercase and lowercase letters, numbers, and symbols. Avoiding dictionary words, names, or common patterns (like '12345') significantly increases resistance to brute-force attacks."
      }
    },
    {
      "@type": "Question",
      "name": "What is a passphrase and is it more secure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A passphrase is a sequence of random words (e.g., 'cactus-emerald-glacier-falcon'). Because of their length, passphrases have high entropy (often exceeding 60-80 bits) making them highly resistant to brute-force attacks. Crucially, they are much easier for humans to memorize than random strings of symbols like '7$dK!9_aQ'."
      }
    },
    {
      "@type": "Question",
      "name": "Are my generated passwords stored anywhere?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. ToolzTotal is a privacy-first, client-side application. Every password is computed inside your web browser's memory and is discarded the moment you close or refresh the tab. Nothing is ever sent to or stored on our servers."
      }
    },
    {
      "@type": "Question",
      "name": "How long should my password be?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For standard accounts, a minimum length of 12 to 16 characters is recommended. For critical systems, databases, or master passwords (like a password manager), a length of 20 to 32 characters or a 5-to-6-word passphrase is highly recommended to protect against advanced hardware cracking arrays."
      }
    },
    {
      "@type": "Question",
      "name": "What does 'exclude similar-looking characters' do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It removes characters that look almost identical in many fonts, such as 'i', 'I', 'l', '1', 'L', 'o', 'O', and '0'. This helps prevent confusion when transcribing or typing the password manually."
      }
    },
    {
      "@type": "Question",
      "name": "What does 'exclude ambiguous characters' do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It filters out symbols that can be difficult to read or copy-paste in command lines and code environments, such as curly braces {}, brackets [], parentheses (), slashes /, backslashes \\, quotes ' \", and backticks `."
      }
    },
    {
      "@type": "Question",
      "name": "How does this tool measure password strength?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Strength is calculated based on Shannon entropy: E = L * log2(R), where L is the password length and R is the size of the character pool. Passwords with over 80 bits of entropy are classified as 'Very Strong', while those under 40 bits are marked as 'Weak'."
      }
    },
    {
      "@type": "Question",
      "name": "Can I generate passwords in bulk?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, our Bulk Mode lets you generate up to 50 passwords or passphrases simultaneously. You can copy them individually, copy the entire list, or download them as a secure text file."
      }
    },
    {
      "@type": "Question",
      "name": "Is this password generator free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, it is completely free with no usage caps, no account gates, and no premium features. It is built as a clean, local utility for developers and security-conscious users."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout
  title="Random Password Generator - Free, Secure & Private | ToolzTotal"
  description="Generate secure, cryptographically random passwords and Diceware-style passphrases. Bulks generation and strength indicators — 100% local and free."
  faqJsonLd={faqJsonLd}
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/utility" class="hover:text-ink transition-colors">Utility</a>
      <span>/</span>
      <span class="text-ink">Password Generator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Random Password Generator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Generate cryptographically secure random passwords or multi-word passphrases instantly. Runs 100% locally in your browser using secure operating system entropy.
      </p>
    </div>

    <!-- Main Calculator Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start max-w-7xl">
      
      <!-- LEFT: Inputs & Configurations (5 cols) -->
      <div class="lg:col-span-5 space-y-6">
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <div class="border-b border-hairline pb-4">
            <h2 class="text-base font-bold text-ink font-sans">Generator Settings</h2>
            <p class="text-xs text-mute font-sans mt-1">Select the generation mode and complexity rules.</p>
          </div>

          <!-- Mode Selector Toggles -->
          <div>
            <label class="block text-xs font-mono uppercase text-mute mb-2">Generation Mode</label>
            <div class="flex rounded-lg bg-canvas-soft-2 p-0.5 border border-hairline shadow-lvl1">
              <button type="button" id="mode-random" class="flex-1 text-center py-2 text-xs font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer">
                Random Characters
              </button>
              <button type="button" id="mode-passphrase" class="flex-1 text-center py-2 text-xs font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer">
                Passphrase
              </button>
            </div>
            <input type="hidden" id="active-mode" value="random" />
          </div>

          <!-- Length Parameter -->
          <div id="settings-length-group">
            <div class="flex justify-between items-center mb-2">
              <label for="length-slider" class="text-xs font-mono uppercase text-mute">Password Length</label>
              <span id="length-val" class="text-sm font-mono font-bold text-ink bg-canvas-soft border border-hairline rounded px-2 py-0.5">16</span>
            </div>
            <input 
              type="range" 
              id="length-slider" 
              min="8" 
              max="64" 
              value="16" 
              class="w-full accent-primary h-2 bg-canvas-soft rounded-lg cursor-pointer border border-hairline"
            />
          </div>

          <!-- Passphrase Words Parameter -->
          <div id="settings-words-group" class="hidden">
            <div class="flex justify-between items-center mb-2">
              <label for="words-slider" class="text-xs font-mono uppercase text-mute">Word Count</label>
              <span id="words-val" class="text-sm font-mono font-bold text-ink bg-canvas-soft border border-hairline rounded px-2 py-0.5">4</span>
            </div>
            <input 
              type="range" 
              id="words-slider" 
              min="3" 
              max="10" 
              value="4" 
              class="w-full accent-primary h-2 bg-canvas-soft rounded-lg cursor-pointer border border-hairline"
            />
            
            <div class="mt-4">
              <label for="passphrase-separator" class="block text-xs font-mono uppercase text-mute mb-2">Word Separator</label>
              <input 
                type="text" 
                id="passphrase-separator" 
                value="-" 
                maxlength="3"
                class="w-20 h-9 px-3 bg-canvas-soft border border-hairline rounded-md text-xs font-mono text-ink text-center focus:outline-none focus:border-hairline-strong transition-colors"
              />
            </div>
          </div>

          <!-- Character Set Toggles -->
          <div id="settings-charsets" class="space-y-3">
            <label class="block text-xs font-mono uppercase text-mute">Included Characters</label>
            <div class="grid grid-cols-2 gap-3 text-xs font-sans text-body">
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" id="char-upper" checked class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline" />
                <span>Uppercase (A-Z)</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" id="char-lower" checked class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline" />
                <span>Lowercase (a-z)</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" id="char-numbers" checked class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline" />
                <span>Numbers (0-9)</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" id="char-symbols" checked class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline" />
