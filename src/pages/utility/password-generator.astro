            <label class="block text-xs font-mono uppercase text-mute">Advanced Filters</label>
            <div class="space-y-2.5 text-xs font-sans text-body">
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" id="exclude-similar" class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline" />
                <span>Exclude similar (e.g. i, l, 1, o, 0)</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" id="exclude-ambiguous" class="w-4 h-4 rounded accent-primary bg-canvas border border-hairline" />
                <span>Exclude ambiguous (e.g. { }, [ ], /)</span>
              </label>
            </div>
          </div>

          <!-- Bulk Generation -->
          <div class="pt-3 border-t border-hairline">
            <div class="flex justify-between items-center mb-2">
              <label for="bulk-slider" class="text-xs font-mono uppercase text-mute">Bulk Generation (Qty)</label>
              <span id="bulk-val" class="text-sm font-mono font-bold text-ink bg-canvas-soft border border-hairline rounded px-2 py-0.5">1</span>
            </div>
            <input 
              type="range" 
              id="bulk-slider" 
              min="1" 
              max="50" 
              value="1" 
              class="w-full accent-primary h-2 bg-canvas-soft rounded-lg cursor-pointer border border-hairline"
            />
          </div>

          <button 
            type="button" 
            id="generate-btn"
            class="w-full h-11 bg-primary text-on-primary hover:opacity-90 font-sans text-sm font-semibold rounded-lg shadow-lvl2 transition-all cursor-pointer"
          >
            Generate Password
          </button>
        </div>
      </div>

      <!-- RIGHT: Output Panels (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Output Display -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl3 space-y-6">
          <div class="border-b border-hairline pb-4 flex justify-between items-center">
            <h2 class="text-sm font-bold text-ink font-sans">Secure Result</h2>
            <span id="entropy-badge" class="text-xs font-mono text-mute">Entropy: 0 bits</span>
          </div>

          <!-- Single password display -->
          <div id="single-output-panel" class="space-y-4">
            <div class="bg-canvas-soft border border-hairline rounded-lg p-4 md:p-6 shadow-lvl1 flex items-center justify-between gap-4">
              <code id="password-output" class="text-lg md:text-xl font-mono text-ink break-all select-all tracking-wide block flex-1">Click Generate</code>
              <button type="button" id="copy-btn" class="h-9 px-4 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink rounded-lg shadow-lvl1 transition-colors flex items-center gap-1.5 cursor-pointer shrink-0">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                Copy
              </button>
            </div>

            <!-- Strength Meter -->
            <div class="space-y-2">
              <div class="flex justify-between text-xs font-mono text-mute">
                <span>Strength:</span>
                <span id="strength-label" class="font-bold text-ink uppercase">N/A</span>
              </div>
              <div class="w-full h-2 bg-canvas-soft-2 rounded-full overflow-hidden border border-hairline shadow-lvl1">
                <div id="strength-bar" class="w-0 h-full transition-all duration-300 bg-error"></div>
              </div>
            </div>
          </div>

          <!-- Bulk passwords display -->
          <div id="bulk-output-panel" class="hidden space-y-4">
            <div class="flex gap-2">
              <button type="button" id="copy-bulk-btn" class="h-8 px-3 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink text-xs font-sans rounded-md shadow-lvl1 transition-colors flex items-center gap-1 cursor-pointer">
                Copy All
              </button>
              <button type="button" id="download-bulk-btn" class="h-8 px-3 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink text-xs font-sans rounded-md shadow-lvl1 transition-colors flex items-center gap-1 cursor-pointer">
                Download List
              </button>
            </div>
            <textarea
              id="bulk-output"
              readonly
              class="w-full h-[280px] bg-canvas-soft-2 text-ink font-mono text-[13px] leading-relaxed p-4 border border-hairline rounded-lg focus:outline-none resize-none shadow-lvl1"
            ></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- SEO text block -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">About the Secure Password Generator: Cryptographic Randomness Explained</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          A <strong>random password generator</strong> is a core security prerequisite for protecting digital identity. Standard pseudorandom generator formulas in JavaScript, such as <code>Math.random()</code>, are mathematically predictable. If a malicious system knows the seed or state of the random number engine, they can duplicate the output passwords. This <strong>secure password generator</strong> uses a cryptographically secure pseudorandom number generator (CSPRNG) through the standard browser <code>crypto.getRandomValues()</code> API, ensuring true entropy.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Comparing Passwords and Multi-Word Passphrases</h3>
        <p>
          Choosing between standard passwords and dictionary passphrases depends on accessibility:
        </p>
        <ul class="list-disc pl-5 space-y-2">
          <li><strong>Random Character Passwords:</strong> Constructed using complex mixed symbol arrays (numbers, upper/lowercase, symbols). They provide high entropy per character but are extremely difficult to memorize, requiring a password manager vault.</li>
          <li><strong>Passphrases (Diceware-Style):</strong> Built using a series of unrelated words linked by dashes or characters. This <strong>passphrase generator</strong> chooses words randomly from a vetted local dictionary list. Because the security scales with length, a 5-word passphrase has comparable strength to a 14-character random password, but remains highly memorizable.</li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Shannon Entropy and Password Strength</h3>
        <p>
          Password security is measured in Shannon entropy bits. Bits of entropy measure the logarithmic complexity of the key. A password with 80 bits of entropy requires $2^{80}$ attempts to crack via a brute-force search. Standard online services recommend a minimum of 60 bits for standard users and 80+ bits for root systems or server keys.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">100% Local & Private Execution</h3>
        <p>
          To maintain confidentiality, all character selection and entropy math run locally in your browser's private stack memory. No data is stored, saved, or uploaded, protecting your keys from internet leaks.
        </p>
      </div>
    </article>

    <!-- FAQ Accordions -->
    <section class="mt-20 pt-16 border-t border-hairline max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map(faq => (
          <details class="group ring-1 ring-inset ring-hairline rounded-xl bg-canvas overflow-hidden shadow-lvl2">
            <summary class="w-full px-6 py-4 flex items-center justify-between text-left font-sans text-sm font-bold text-ink cursor-pointer list-none marker:hidden hover:bg-canvas-soft-2 transition-colors">
              <span>{faq.name}</span>
              <svg class="w-4 h-4 text-mute transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="border-t border-hairline px-6 py-4 bg-canvas-soft">
              <p class="text-body text-sm font-sans leading-relaxed">{faq.acceptedAnswer.text}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Related Tools -->
    <section class="mt-20 pt-16 border-t border-hairline">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Developer & Utility Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/dev/uuid-generator" class="block bg-canvas ring-1 ring-inset ring-hairline hover:ring-hairline-strong transition-all duration-200 rounded-xl p-5 hover:shadow-lvl2 shadow-lvl1 group">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center justify-between">
            UUID Generator
            <svg class="w-4 h-4 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-2">Generate time-ordered or random UUID primary keys bulk in your browser.</p>
        </a>
        <a href="/utility/qr-code-generator" class="block bg-canvas ring-1 ring-inset ring-hairline hover:ring-hairline-strong transition-all duration-200 rounded-xl p-5 hover:shadow-lvl2 shadow-lvl1 group">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center justify-between">
            QR Code Generator
            <svg class="w-4 h-4 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-2">Generate clean, watermark-free custom QR codes from URLs, texts, or cards.</p>
        </a>
      </div>
    </section>
  </div>

  <script>
    // CSPRNG dictionary wordlist for passphrase generation
    const wordlist = [
      "acid", "agent", "alias", "alpha", "amber", "anchor", "angel", "aqua", "arch", "arrow", "artist", "atom", "avatar", "axis", "balloon", "bamboo", "banana", "baron", "beacon", "beast", "beauty", "berry", "bison", "blade", "blaze", "blink", "bloom", "blueprint", "bolt", "bonus", "border", "bottle", "breeze", "brick", "bridge", "bronze", "bubble", "bucket", "cactus", "camera", "canvas", "canyon", "captain", "castle", "cave", "chaos", "cherry", "chief", "cinder", "circus", "clay", "cliff", "cloud", "clover", "cobalt", "comet", "copper", "coral", "cosmos", "crater", "crown", "crystal", "cube", "cycle", "dagger", "dawn", "delta", "desert", "detail", "device", "diamond", "dinosaur", "doctor", "dolphin", "dome", "dragon", "dream", "drift", "dune", "dust", "eagle", "earth", "echo", "eclipse", "element", "emerald", "engine", "enigma", "epoch", "estate", "ether", "ethics", "exile", "expert", "factor", "falcon", "family", "fancy", "fantasy", "farm", "feather", "fever", "fiber", "fiction", "field", "filter", "finch", "finger", "fire", "flash", "flight", "flower", "fluid", "flute", "flux", "forest", "fossil", "fountain", "fraction", "galaxy", "garden", "garlic", "gemini", "genius", "ghost", "giant", "glacier", "glass", "glide", "globe", "glory", "glow", "gold", "gorilla", "grace", "granite", "grape", "graph", "gravity", "green", "grid", "groove", "guide", "guitar", "gulf", "gyro"
    ];

    const modeRandomBtn = document.getElementById('mode-random') as HTMLButtonElement;
    const modePassBtn = document.getElementById('mode-passphrase') as HTMLButtonElement;
    const activeModeInput = document.getElementById('active-mode') as HTMLInputElement;

    const lengthSlider = document.getElementById('length-slider') as HTMLInputElement;
    const lengthVal = document.getElementById('length-val') as HTMLSpanElement;
    const lengthGroup = document.getElementById('settings-length-group') as HTMLDivElement;

    const wordsSlider = document.getElementById('words-slider') as HTMLInputElement;
    const wordsVal = document.getElementById('words-val') as HTMLSpanElement;
    const wordsGroup = document.getElementById('settings-words-group') as HTMLDivElement;
    const separatorInput = document.getElementById('passphrase-separator') as HTMLInputElement;

    const charsetsContainer = document.getElementById('settings-charsets') as HTMLDivElement;
    const bulkSlider = document.getElementById('bulk-slider') as HTMLInputElement;
    const bulkVal = document.getElementById('bulk-val') as HTMLSpanElement;

    const charUpper = document.getElementById('char-upper') as HTMLInputElement;
    const charLower = document.getElementById('char-lower') as HTMLInputElement;
    const charNumbers = document.getElementById('char-numbers') as HTMLInputElement;
    const charSymbols = document.getElementById('char-symbols') as HTMLInputElement;
    const excludeSimilar = document.getElementById('exclude-similar') as HTMLInputElement;
    const excludeAmbiguous = document.getElementById('exclude-ambiguous') as HTMLInputElement;

    const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
    const passwordOutput = document.getElementById('password-output') as HTMLElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const entropyBadge = document.getElementById('entropy-badge') as HTMLSpanElement;
    const strengthLabel = document.getElementById('strength-label') as HTMLSpanElement;
    const strengthBar = document.getElementById('strength-bar') as HTMLDivElement;

    const singleOutputPanel = document.getElementById('single-output-panel') as HTMLDivElement;
    const bulkOutputPanel = document.getElementById('bulk-output-panel') as HTMLDivElement;
    const bulkOutput = document.getElementById('bulk-output') as HTMLTextAreaElement;
    const copyBulkBtn = document.getElementById('copy-bulk-btn') as HTMLButtonElement;
    const downloadBulkBtn = document.getElementById('download-bulk-btn') as HTMLButtonElement;

    // Mode selection handlers
    modeRandomBtn.addEventListener('click', () => {
      activeModeInput.value = 'random';
      modeRandomBtn.className = "flex-1 text-center py-2 text-xs font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer";
      modePassBtn.className = "flex-1 text-center py-2 text-xs font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer";
      lengthGroup.classList.remove('hidden');
      charsetsContainer.classList.remove('hidden');
      wordsGroup.classList.add('hidden');
    });

    modePassBtn.addEventListener('click', () => {
      activeModeInput.value = 'passphrase';
      modePassBtn.className = "flex-1 text-center py-2 text-xs font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer";
      modeRandomBtn.className = "flex-1 text-center py-2 text-xs font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer";
      lengthGroup.classList.add('hidden');
      charsetsContainer.classList.add('hidden');
      wordsGroup.classList.remove('hidden');
    });

    // Slider inputs
    lengthSlider.addEventListener('input', () => { lengthVal.textContent = lengthSlider.value; });
    wordsSlider.addEventListener('input', () => { wordsVal.textContent = wordsSlider.value; });
    bulkSlider.addEventListener('input', () => { bulkVal.textContent = bulkSlider.value; });

    // Secure CSPRNG Index Retriever
    const getSecureRandomIndex = (max: number) => {
      const array = new Uint32Array(1);
      window.crypto.getRandomValues(array);
      return array[0] % max;
    };

    // Entropy computation
    const calculateEntropyAndStrength = (password: string, poolSize: number) => {
      if (!password) return { bits: 0, label: "N/A", pct: 0, color: "bg-error" };
      const bits = Math.round(password.length * Math.log2(poolSize));
      
      let label = "WEAK";
      let color = "bg-error";
      let pct = Math.min(100, Math.max(10, (bits / 120) * 100));

      if (bits >= 80) {
        label = "VERY STRONG";
        color = "bg-success";
      } else if (bits >= 60) {
        label = "STRONG";
        color = "bg-success";
      } else if (bits >= 40) {
        label = "FAIR";
        color = "bg-warning";
      }

      return { bits, label, pct, color };
    };

    // Password generation core logic
    const generatePassword = () => {
      const mode = activeModeInput.value;
      const bulkCount = parseInt(bulkSlider.value);
      const list: string[] = [];

      let poolSize = 0;
      let passwordPool = "";

      if (mode === 'random') {
        let upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        let lower = "abcdefghijklmnopqrstuvwxyz";
        let numbers = "0123456789";
        let symbols = "!@#$%^&*()_+-=[]{}|;:',.<>?";

        if (excludeSimilar.checked) {
          upper = upper.replace(/[IL]/g, '');
          lower = lower.replace(/[ilo]/g, '');
          numbers = numbers.replace(/[10]/g, '');
          symbols = symbols.replace(/[|]/g, '');
        }

        if (excludeAmbiguous.checked) {
          symbols = symbols.replace(/[{}()[\]/\'"\\`~;:,.<>]/g, '');
        }

        let charset = "";
        if (charUpper.checked) { charset += upper; poolSize += upper.length; }
        if (charLower.checked) { charset += lower; poolSize += lower.length; }
        if (charNumbers.checked) { charset += numbers; poolSize += numbers.length; }
        if (charSymbols.checked) { charset += symbols; poolSize += symbols.length; }

        if (!charset) {
          alert("Please select at least one character set.");
          return;
        }

        const length = parseInt(lengthSlider.value);
        for (let b = 0; b < bulkCount; b++) {
          let pass = "";
          for (let i = 0; i < length; i++) {
            pass += charset[getSecureRandomIndex(charset.length)];
          }
          list.push(pass);
        }
      } else {
        // Passphrase
        const count = parseInt(wordsSlider.value);
        const sep = separatorInput.value || "-";
        poolSize = wordlist.length;

        for (let b = 0; b < bulkCount; b++) {
          const words: string[] = [];
          for (let i = 0; i < count; i++) {
            words.push(wordlist[getSecureRandomIndex(wordlist.length)]);
          }
          list.push(words.join(sep));
        }
      }

      // Display results
      if (bulkCount === 1) {
        singleOutputPanel.classList.remove('hidden');
        bulkOutputPanel.classList.add('hidden');
        
        const finalPass = list[0];
        passwordOutput.textContent = finalPass;
        
        // Calculate entropy
        const meta = calculateEntropyAndStrength(finalPass, poolSize);
        entropyBadge.textContent = `Entropy: ${meta.bits} bits`;
        strengthLabel.textContent = meta.label;
        strengthBar.className = `h-full transition-all duration-300 ${meta.color}`;
        strengthBar.style.width = `${meta.pct}%`;
      } else {
        singleOutputPanel.classList.add('hidden');
        bulkOutputPanel.classList.remove('hidden');
        
        bulkOutput.value = list.join('\n');
        entropyBadge.textContent = `Bulk Generated: ${bulkCount}`;
      }
    };

    // Copy single password
    copyBtn.addEventListener('click', () => {
      const pass = passwordOutput.textContent;
      if (pass && pass !== "Click Generate") {
        navigator.clipboard.writeText(pass);
        const prevText = copyBtn.innerHTML;
        copyBtn.innerHTML = "✓ Copied";
        setTimeout(() => { copyBtn.innerHTML = prevText; }, 1500);
      }
    });

    // Copy bulk list
    copyBulkBtn.addEventListener('click', () => {
      const list = bulkOutput.value;
      if (list) {
        navigator.clipboard.writeText(list);
        const prevText = copyBulkBtn.textContent;
        copyBulkBtn.textContent = "✓ Copied";
        setTimeout(() => { copyBulkBtn.textContent = prevText; }, 1500);
      }
    });

    // Download bulk list
    downloadBulkBtn.addEventListener('click', () => {
      const list = bulkOutput.value;
      if (!list) return;
      const blob = new Blob([list], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `passwords_${Date.now()}.txt`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    // Bind generate button
    generateBtn.addEventListener('click', generatePassword);
    
    // Generate initial password on load
    generatePassword();
  </script>
</Layout>
