      "entropy-badge",
    ) as HTMLSpanElement;
    const strengthLabel = document.getElementById(
      "strength-label",
    ) as HTMLSpanElement;
    const strengthBar = document.getElementById(
      "strength-bar",
    ) as HTMLDivElement;

    const singleOutputPanel = document.getElementById(
      "single-output-panel",
    ) as HTMLDivElement;
    const bulkOutputPanel = document.getElementById(
      "bulk-output-panel",
    ) as HTMLDivElement;
    const bulkOutput = document.getElementById(
      "bulk-output",
    ) as HTMLTextAreaElement;
    const copyBulkBtn = document.getElementById(
      "copy-bulk-btn",
