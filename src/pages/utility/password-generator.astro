    const excludeAmbiguous = document.getElementById(
      "exclude-ambiguous",
    ) as HTMLInputElement;

    const generateBtn = document.getElementById(
      "generate-btn",
    ) as HTMLButtonElement;
    const passwordOutput = document.getElementById(
      "password-output",
    ) as HTMLElement;
