          </div>

          <button
            type="button"
            id="calculate-btn"
            class="w-full h-11 bg-primary text-on-primary hover:opacity-90 font-sans text-sm font-semibold rounded-lg shadow-lvl2 transition-all cursor-pointer"
          >
            Calculate Age
          </button>
        </div>
      </div>

      <!-- RIGHT: Results -->
      <div class="lg:col-span-7 space-y-6">
        <!-- Main Age Card -->
        <div
          class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl3 space-y-6"
