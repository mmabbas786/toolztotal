      1992: [2, 4],
      1993: [1, 23],
      1994: [2, 10],
      1995: [1, 31],
      1996: [2, 19],
      1997: [2, 7],
      1998: [1, 28],
      1999: [2, 16],
      2000: [2, 5],
      2001: [1, 24],
      2002: [2, 12],
      2003: [2, 1],
      2004: [1, 22],
      2005: [2, 9],
      2006: [1, 29],
      2007: [2, 18],
      2008: [2, 7],
      2009: [1, 26],
      2010: [2, 14],
      2011: [2, 3],
      2012: [1, 23],
      2013: [2, 10],
      2014: [1, 31],
      2015: [2, 19],
      2016: [2, 8],
      2017: [1, 28],
      2018: [2, 16],
      2019: [2, 5],
      2020: [1, 25],
      2021: [2, 12],
      2022: [2, 1],
      2023: [1, 22],
      2024: [2, 10],
      2025: [1, 29],
      2026: [2, 17],
      2027: [2, 6],
      2028: [1, 26],
      2029: [2, 13],
      2030: [2, 3],
    };

    const wZodiacs = [
      { name: "Capricorn", emoji: "♑", start: [12, 22], end: [1, 19] },
      { name: "Aquarius", emoji: "♒", start: [1, 20], end: [2, 18] },
      { name: "Pisces", emoji: "♓", start: [2, 19], end: [3, 20] },
      { name: "Aries", emoji: "♈", start: [3, 21], end: [4, 19] },
      { name: "Taurus", emoji: "♉", start: [4, 20], end: [5, 20] },
      { name: "Gemini", emoji: "♊", start: [5, 21], end: [6, 20] },
      { name: "Cancer", emoji: "♋", start: [6, 21], end: [7, 22] },
      { name: "Leo", emoji: "♌", start: [7, 23], end: [8, 22] },
      { name: "Virgo", emoji: "♍", start: [8, 23], end: [9, 22] },
      { name: "Libra", emoji: "♎", start: [9, 23], end: [10, 22] },
      { name: "Scorpio", emoji: "♏", start: [10, 23], end: [11, 21] },
      { name: "Sagittarius", emoji: "♐", start: [11, 22], end: [12, 21] },
    ];

    const chineseAnimals = [
      { name: "Rat", emoji: "🐀", meta: "Yin/Yang: Yang | Element: Water" },
      { name: "Ox", emoji: "🐂", meta: "Yin/Yang: Yin | Element: Earth" },
      { name: "Tiger", emoji: "🐅", meta: "Yin/Yang: Yang | Element: Wood" },
      { name: "Rabbit", emoji: "🐇", meta: "Yin/Yang: Yin | Element: Wood" },
      { name: "Dragon", emoji: "🐉", meta: "Yin/Yang: Yang | Element: Earth" },
      { name: "Snake", emoji: "🐍", meta: "Yin/Yang: Yin | Element: Fire" },
      { name: "Horse", emoji: "🐎", meta: "Yin/Yang: Yang | Element: Fire" },
      { name: "Goat", emoji: "🐐", meta: "Yin/Yang: Yin | Element: Earth" },
      { name: "Monkey", emoji: "🐒", meta: "Yin/Yang: Yang | Element: Metal" },
      { name: "Rooster", emoji: "🐓", meta: "Yin/Yang: Yin | Element: Metal" },
      { name: "Dog", emoji: "🐕", meta: "Yin/Yang: Yang | Element: Earth" },
      { name: "Pig", emoji: "🐖", meta: "Yin/Yang: Yin | Element: Water" },
    ];

    const weekdays = [
      "Sunday",
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
    ];

    const birthInput = document.getElementById(
      "birth-date",
    ) as HTMLInputElement;
    const targetInput = document.getElementById(
      "target-date",
    ) as HTMLInputElement;
    const calculateBtn = document.getElementById(
      "calculate-btn",
    ) as HTMLButtonElement;

    // Default target date to today
    const todayStr = new Date().toISOString().split("T")[0];
    if (targetInput) {
      targetInput.value = todayStr;
    }

    const getWesternZodiac = (month: number, day: number) => {
      for (const z of wZodiacs) {
        const [sMonth, sDay] = z.start;
        const [eMonth, eDay] = z.end;

        if (sMonth === month && day >= sDay) return z;
        if (eMonth === month && day <= eDay) return z;
      }
      return wZodiacs[0];
    };

    const getChineseZodiac = (year: number, month: number, day: number) => {
      let zodiacYear = year;
      const cny = cnyDates[year];
      if (cny) {
        const [cnyMonth, cnyDay] = cny;
        if (month < cnyMonth || (month === cnyMonth && day < cnyDay)) {
          zodiacYear = year - 1;
        }
      }
      let idx = (zodiacYear - 1900) % 12;
      if (idx < 0) idx += 12;
      return chineseAnimals[idx];
    };

    const calculateAge = () => {
      const birthVal = birthInput.value;
      const targetVal = targetInput.value;
      if (!birthVal || !targetVal) return;

      const birth = new Date(birthVal + "T00:00:00");
      const target = new Date(targetVal + "T00:00:00");

      if (target < birth) {
        alert("Target date cannot be earlier than your birth date.");
        return;
      }

      let years = target.getFullYear() - birth.getFullYear();
      let months = target.getMonth() - birth.getMonth();
      let days = target.getDate() - birth.getDate();

      if (days < 0) {
        months--;
        const prevMonth = new Date(target.getFullYear(), target.getMonth(), 0);
        days += prevMonth.getDate();
      }

      if (months < 0) {
        years--;
        months += 12;
      }

      document.getElementById("result-years")!.textContent = years.toString();
      document.getElementById("result-months")!.textContent = months.toString();
      document.getElementById("result-days")!.textContent = days.toString();

      const diffMs = target.getTime() - birth.getTime();
      const totalDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
      const totalWeeks = Math.floor(totalDays / 7);
      document.getElementById("stat-days-alive")!.textContent =
        totalDays.toLocaleString();
      document.getElementById("stat-weeks-alive")!.textContent =
        totalWeeks.toLocaleString();

      const weekday = weekdays[birth.getDay()];
      document.getElementById("birth-weekday-label")!.textContent =
        `Born on ${weekday}`;

      let nextBirthday = new Date(
        target.getFullYear(),
        birth.getMonth(),
        birth.getDate(),
        0,
        0,
        0,
      );
      if (nextBirthday < target) {
        nextBirthday.setFullYear(target.getFullYear() + 1);
      }
      const daysToBday = Math.ceil(
        (nextBirthday.getTime() - target.getTime()) / (1000 * 60 * 60 * 24),
      );
      document.getElementById("stat-next-birthday")!.textContent =
        daysToBday === 0 ? "Today! 🎉" : `${daysToBday.toLocaleString()} Days`;

      let nextHalfBirthday = new Date(
        birth.getFullYear(),
        birth.getMonth() + 6,
        birth.getDate(),
      );
      let targetHalf = new Date(
        target.getFullYear(),
        nextHalfBirthday.getMonth(),
        nextHalfBirthday.getDate(),
      );
      if (targetHalf < target) {
        targetHalf.setFullYear(target.getFullYear() + 1);
      }
      const formattedHalf = targetHalf.toLocaleDateString("en-US", {
        month: "long",
        day: "numeric",
        year: "numeric",
      });
      document.getElementById("stat-half-birthday")!.textContent =
        formattedHalf;

      const wZodiac = getWesternZodiac(birth.getMonth() + 1, birth.getDate());
      document.getElementById("western-zodiac-name")!.textContent =
        wZodiac.name;
      document.querySelector("#western-zodiac-name + p")!.textContent =
        `Element: ${wZodiac.name === "Capricorn" || wZodiac.name === "Taurus" || wZodiac.name === "Virgo" ? "Earth" : wZodiac.name === "Aries" || wZodiac.name === "Leo" || wZodiac.name === "Sagittarius" ? "Fire" : wZodiac.name === "Cancer" || wZodiac.name === "Scorpio" || wZodiac.name === "Pisces" ? "Water" : "Air"}`;

      const cZodiac = getChineseZodiac(
        birth.getFullYear(),
        birth.getMonth() + 1,
        birth.getDate(),
      );
      document.getElementById("chinese-zodiac-emoji")!.textContent =
        cZodiac.emoji;
      document.getElementById("chinese-zodiac-name")!.textContent =
        cZodiac.name;
      document.getElementById("chinese-zodiac-meta")!.textContent =
        cZodiac.meta;

      const milestones = [18, 21, 30, 50, 65];
      const milestonesContainer = document.getElementById(
        "milestones-container",
      )!;
      milestonesContainer.innerHTML = "";
      milestones.forEach((age) => {
        const milestoneDate = new Date(
          birth.getFullYear() + age,
          birth.getMonth(),
          birth.getDate(),
        );
        const formattedDate = milestoneDate.toLocaleDateString("en-US", {
          month: "long",
          day: "numeric",
          year: "numeric",
        });
        const hasPassed = milestoneDate < target;

        const row = document.createElement("div");
        row.className = `flex items-center justify-between py-2 border-b border-hairline/30 ${hasPassed ? "opacity-60 line-through" : ""}`;
        row.innerHTML = `
          <span class="text-mute font-sans">Turning ${age}:</span>
          <span class="font-mono text-ink font-semibold">${formattedDate}</span>
        `;
        milestonesContainer.appendChild(row);
      });
    };

    if (calculateBtn) {
      calculateBtn.addEventListener("click", calculateAge);
      calculateAge();
    }
  </script>

  <RelatedTools categorySlug="utility" toolSlug="age-calculator" />
