---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Terms & Conditions | ToolzTotal"
  description="Terms and Conditions of use for ToolzTotal. Understand our informational tool disclaimers and usage terms."
>
  <div class="max-w-[800px] mx-auto px-4 py-16 md:py-24">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute">
      <a href="/" class="hover:text-ink transition-colors font-sans">Home</a>
      <span>/</span>
      <span class="text-ink">Terms & Conditions</span>
    </nav>

    <article class="prose max-w-none">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-8">
        Terms & Conditions
      </h1>
      
      <p class="text-mute font-mono text-xs mb-8">Last Updated: July 5, 2026</p>
      
      <div class="space-y-8 text-body text-base font-sans leading-relaxed">
        <p>
          Welcome to <strong>ToolzTotal</strong> (the "Site"). By accessing or using our free calculators and tools, you agree to comply with and be bound by the following terms and conditions. If you do not agree to these terms, please do not use the Site.
