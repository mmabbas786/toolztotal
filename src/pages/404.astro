---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Page Not Found | ToolzTotal"
  description="The calculator page you are looking for does not exist. Return to ToolzTotal to browse our free calculators."
>
  <div class="max-w-[600px] mx-auto px-4 py-24 text-center flex flex-col items-center justify-center min-h-[60vh]">
    <div class="text-xs font-mono uppercase tracking-wider text-mute mb-6 border border-hairline bg-canvas px-3 py-1 rounded-full shadow-lvl1">
      Error Code 404
    </div>
    
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-ink font-sans mb-6">
      Page not found.
    </h1>
    
    <p class="text-body text-base font-sans leading-relaxed mb-8 max-w-md">
      The calculator or utility you're looking for doesn't exist, has been moved, or is currently under construction.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <a href="/" class="inline-flex h-10 items-center justify-center bg-primary text-on-primary hover:bg-mute font-sans text-sm font-medium px-6 rounded-full transition-all cursor-pointer shadow-lvl2">
        Return to Home Search
      </a>
      <a href="/#categories" class="text-body hover:text-ink font-sans text-sm font-medium px-4 py-2 hover:bg-canvas rounded-full transition-all">
        Browse Categories
      </a>
    </div>
  </div>
</Layout>
