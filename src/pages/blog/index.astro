---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
// Sort by pubDate descending
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const authorNames = {
  'sarah-chen': 'Sarah Chen, CFP®',
  'marcus-reyes': 'Marcus Reyes',
  'priya-krishnan': 'Priya Krishnan',
  'jordan-blake': 'Jordan Blake',
  'dr-aisha-patel': 'Dr. Aisha Patel, MD',
  'jennifer-walsh': 'Jennifer Walsh, Esq.',
  'dr-robert-hayes': 'Dr. Robert Hayes, Ed.D.',
  'editorial-team': 'ToolzTotal Editorial Team',
};

// Estimate reading time based on word count
function getReadingTime(body: string) {
  const wordsPerMinute = 200;
  const numberOfWords = body.split(/\s+/g).length;
  return Math.ceil(numberOfWords / wordsPerMinute);
}

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "ToolzTotal Blog Articles",
  "description": "Educational articles, guides, and tips on finance, mortgages, health, development, and everyday calculations.",
  "itemListElement": sortedPosts.map((post, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "url": `https://toolztotal.com/blog/${post.id}`
  }))
};

const itemListJson = JSON.stringify(itemListSchema);
---

<Layout 
  title="Calculators, Finance Guides & How-To Articles | ToolzTotal Blog"
  description="Explore the ToolzTotal Blog for detailed calculations, financial planning guides, health advice, and developer tools explanations."
  faqJsonLd={itemListJson}
  canonicalUrl="https://toolztotal.com/blog"
>
  <div class="max-w-[1200px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors font-sans">Home</a>
      <span>/</span>
      <span class="text-ink">Blog</span>
    </nav>

    <!-- Hero Header -->
    <div class="max-w-3xl mb-16">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-ink font-sans mb-6">
        The ToolzTotal Blog
      </h1>
      <p class="text-body text-lg md:text-xl font-sans leading-relaxed">
        Expert-written articles, step-by-step math breakdowns, and practical guides on personal finance, real estate, metrics calculation, and developer utilities.
      </p>
    </div>

    <!-- Blog Posts Grid -->
    {sortedPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post) => {
          const authorName = authorNames[post.data.author] || 'ToolzTotal Editor';
          const readingTime = getReadingTime(post.body);
          const categoryDisplay = post.data.category.replace('-', ' ');
          
          return (
            <article class="flex flex-col bg-canvas border border-hairline hover:border-hairline-strong transition-all duration-300 rounded-xl overflow-hidden shadow-lvl1 hover:shadow-lvl3 group">
              <!-- Image / Gradient placeholder -->
              <a href={`/blog/${post.id}`} class="block aspect-video w-full overflow-hidden bg-canvas-soft-2 relative border-b border-hairline">
                {post.data.heroImage ? (
                  <img 
                    src={post.data.heroImage} 
                    alt={post.data.title} 
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" 
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-tr from-canvas-soft to-canvas-soft-2 flex items-center justify-center p-6 text-center transition-all duration-300 group-hover:bg-gradient-to-tr group-hover:from-canvas-soft-2 group-hover:to-canvas-soft">
                    <span class="text-xl font-bold tracking-tight text-mute/30 font-sans group-hover:text-ink/10 transition-colors uppercase font-mono">
                      {categoryDisplay}
                    </span>
                  </div>
                )}
                <!-- Category Badge -->
                <span class="absolute top-4 left-4 bg-canvas/90 backdrop-blur-sm border border-hairline px-2.5 py-1 rounded-full text-[10px] font-mono uppercase tracking-wider text-ink font-semibold shadow-lvl1">
                  {categoryDisplay}
                </span>
              </a>

              <!-- Card Content -->
              <div class="flex-grow p-6 flex flex-col justify-between">
                <div class="mb-6">
                  <!-- Date and Reading Time -->
                  <div class="flex items-center gap-2 text-[10px] font-mono text-mute uppercase tracking-wider mb-3">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                    <span>·</span>
                    <span>{readingTime} min read</span>
                  </div>
                  
                  <!-- Title -->
                  <h2 class="text-lg md:text-xl font-bold text-ink font-sans group-hover:text-primary transition-colors leading-snug mb-3">
                    <a href={`/blog/${post.id}`}>
                      {post.data.title}
                    </a>
                  </h2>

                  <!-- Description -->
                  <p class="text-body text-xs md:text-sm font-sans leading-relaxed line-clamp-3">
                    {post.data.description}
                  </p>
                </div>

                <!-- Author info -->
                <div class="flex items-center gap-3 pt-4 border-t border-hairline">
                  <div class="w-8 h-8 rounded-full bg-canvas-soft-2 border border-hairline flex items-center justify-center text-ink font-mono font-bold text-[10px] shadow-lvl1">
                    {authorName.split(' ').map(n => n[0]).join('').slice(0, 2)}
                  </div>
                  <div>
                    <span class="block text-xs font-bold text-ink font-sans">{authorName}</span>
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <div class="bg-canvas border border-hairline rounded-xl p-12 text-center shadow-lvl1 max-w-xl mx-auto">
        <svg class="w-12 h-12 text-mute mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <h3 class="text-sm font-bold text-ink font-sans mb-1">No blog posts found</h3>
        <p class="text-mute text-xs font-mono">We are drafting educational contents. Please check back soon!</p>
      </div>
    )}
  </div>
</Layout>
