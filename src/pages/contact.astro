---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us | ToolzTotal"
  description="Get in touch with ToolzTotal. Suggest new calculators, report bugs, or give feedback."
>
  <div class="max-w-[800px] mx-auto px-4 py-16 md:py-24">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute">
      <a href="/" class="hover:text-ink transition-colors font-sans">Home</a>
      <span>/</span>
      <span class="text-ink">Contact Us</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Info Column -->
      <div class="lg:col-span-5 space-y-6">
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans">
          Contact Us
        </h1>
        <p class="text-body text-base font-sans leading-relaxed">
          Have an idea for a calculator or utility? Found a calculation bug? Or just want to say hi? We'd love to hear from you.
        </p>
        <div class="border-t border-hairline pt-6 space-y-3">
          <div class="text-xs font-mono uppercase tracking-wider text-mute">General Inquiries</div>
          <div class="text-sm font-bold text-ink">hello@toolztotal.com</div>
        </div>
        <div class="border-t border-hairline pt-6 space-y-3">
          <div class="text-xs font-mono uppercase tracking-wider text-mute">Open Source & Feedback</div>
          <p class="text-xs text-mute font-sans leading-relaxed">
            All code updates, feature requests, and issue tracking will soon be managed publicly via our GitHub repository.
          </p>
        </div>
      </div>

      <!-- Form Column -->
      <div class="lg:col-span-7">
        <div class="border border-hairline bg-canvas rounded-xl p-6 md:p-8 shadow-lvl3 transition-colors duration-200">
          <h2 class="text-lg font-bold text-ink font-sans mb-6">Send a Message</h2>
          <form class="space-y-4" onsubmit="event.preventDefault(); alert('Thank you! Your feedback has been simulated client-side.'); this.reset();">
            <div>
              <label for="contact-name" class="block text-xs font-mono uppercase text-mute mb-2">Name</label>
              <input 
                id="contact-name"
                type="text" 
                required 
                placeholder="Your name" 
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-xs font-mono uppercase text-mute mb-2">Email Address</label>
              <input 
                id="contact-email"
                type="email" 
                required 
                placeholder="your@email.com" 
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
              />
            </div>
            <div>
              <label for="contact-message" class="block text-xs font-mono uppercase text-mute mb-2">Message or Suggestion</label>
              <textarea 
                id="contact-message"
                required 
                rows="4" 
                placeholder="Describe the calculator you'd like us to build..." 
                class="w-full p-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 resize-y"
              ></textarea>
            </div>
            <button 
              type="submit" 
              class="w-full h-10 bg-primary text-on-primary hover:bg-mute font-sans text-sm font-medium rounded-md transition-all cursor-pointer shadow-lvl2"
            >
              Send Message
            </button>
          </form>
          <div class="text-[10px] text-mute font-sans mt-3 text-center">
            Your message will not be uploaded anywhere. This demo works local-first.
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
