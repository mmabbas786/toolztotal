  </div>

    <RelatedTools
      categorySlug="health"
      toolSlug="pregnancy-calculator"
    />
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const btnLmp = document.getElementById('btn-lmp') as HTMLButtonElement;
  const btnConception = document.getElementById('btn-conception') as HTMLButtonElement;

  const baseDateInput = document.getElementById('base-date') as HTMLInputElement;
  const cycleLengthInput = document.getElementById('cycle-length') as HTMLInputElement;
  const cycleLengthContainer = document.getElementById('cycle-length-container') as HTMLDivElement;

  const lblDate = document.getElementById('lbl-date') as HTMLLabelElement;

  const resDueDate = document.getElementById('res-due-date') as HTMLSpanElement;
  const resDueCountdown = document.getElementById('res-due-countdown') as HTMLSpanElement;
  const resGestational = document.getElementById('res-gestational') as HTMLSpanElement;
  const resTrimester = document.getElementById('res-trimester') as HTMLSpanElement;
  const resProgress = document.getElementById('res-progress') as HTMLSpanElement;

  const timelineBar = document.getElementById('timeline-bar') as HTMLDivElement;
  const milestonesTimeline = document.getElementById('milestones-timeline') as HTMLDivElement;

  // ============================================================
  // State
  // ============================================================
  let method: 'lmp' | 'conception' = 'lmp';

  // Set default input date to today
  const today = new Date();
  const yyyy = today.getFullYear();
  const mm = String(today.getMonth() + 1).padStart(2, '0');
  const dd = String(today.getDate()).padStart(2, '0');
  baseDateInput.value = `${yyyy}-${mm}-${dd}`;

  // ============================================================
  // Fetal Milestones Data
  // ============================================================
  const milestones = [
    { week: 4, title: "Implantation Complete", desc: "The embryo is about the size of a poppy seed. Basic structures like the neural tube are beginning to form." },
    { week: 8, title: "Heart Begins to Beat", desc: "Now officially a fetus, basic organ structures and visible digits/facial features are forming." },
    { week: 12, title: "First Trimester Ends", desc: "The fetus is moving hands and feet. Organs, muscles, and circulatory systems are fully formed." },
    { week: 16, title: "Bones & Sensory Progress", desc: "Skeletal mineralization begins. The baby can begin to perceive sound and voice vibrations." },
    { week: 20, title: "Midpoint & Active Movement", desc: "Anatomy scan stage. The skin develops a protective coating, and movements (quickening) are easily felt." },
    { week: 24, title: "Viability Threshold", desc: "Lungs begin forming air sacs. The nervous system and sensory coordination are developing rapidly." },
    { week: 28, title: "Third Trimester Begins", desc: "Eyes begin to open. The baby responds actively to sound, light, and external temperature changes." },
    { week: 32, title: "Surfactant & Fat Accumulation", desc: "Bones harden, though skull bones remain flexible. The body builds fat reserves to regulate temperature." },
    { week: 36, title: "Lungs Mature", desc: "The baby drops into a head-down position. Organ systems are fully ready for independent life." },
    { week: 40, title: "Full Term & Delivery", desc: "Average birth weight and size. Fetal development is complete, and the baby is ready for birth." }
  ];

  // ============================================================
  // Functions
  // ============================================================
  const updateMethodToggle = () => {
    if (method === 'lmp') {
      btnLmp.classList.add('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnLmp.classList.remove('bg-canvas', 'text-body');
      btnConception.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnConception.classList.add('bg-canvas', 'text-body');
      lblDate.textContent = "First Day of Last Period";
      cycleLengthContainer.style.display = 'block';
    } else {
      btnConception.classList.add('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnConception.classList.remove('bg-canvas', 'text-body');
      btnLmp.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnLmp.classList.add('bg-canvas', 'text-body');
      lblDate.textContent = "Conception Date";
      cycleLengthContainer.style.display = 'none';
    }
    calculate();
  };

  const calculate = () => {
    const baseDateVal = baseDateInput.value;
    if (!baseDateVal) return;

    const baseDate = new Date(baseDateVal + 'T12:00:00'); // Midday to prevent timezone shifts
    const cycleLength = parseInt(cycleLengthInput.value, 10) || 28;

    let dueDate = new Date();
    let currentAgeDays = 0;

    if (method === 'lmp') {
      // Due Date = LMP + 280 days + (Cycle length - 28)
      dueDate = new Date(baseDate.getTime() + 280 * 24 * 60 * 60 * 1000);
      dueDate = new Date(dueDate.getTime() + (cycleLength - 28) * 24 * 60 * 60 * 1000);

      // Gestational Age
      const diffTime = today.getTime() - baseDate.getTime();
      currentAgeDays = Math.floor(diffTime / (24 * 60 * 60 * 1000));
    } else {
      // Due Date = Conception + 266 days
      dueDate = new Date(baseDate.getTime() + 266 * 24 * 60 * 60 * 1000);

      // Conception date means gestational age starts 14 days prior to conception date
      const virtualLmp = new Date(baseDate.getTime() - 14 * 24 * 60 * 60 * 1000);
      const diffTime = today.getTime() - virtualLmp.getTime();
      currentAgeDays = Math.floor(diffTime / (24 * 60 * 60 * 1000));
    }

    // Format Due Date
    const options: Intl.DateTimeFormatOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    resDueDate.textContent = dueDate.toLocaleDateString('en-US', options);

    // Days remaining to due date
    const timeToDue = dueDate.getTime() - today.getTime();
    const daysRemaining = Math.max(0, Math.ceil(timeToDue / (24 * 60 * 60 * 1000)));
    resDueCountdown.textContent = daysRemaining > 0 
      ? `Days remaining: ${daysRemaining} (${Math.ceil(daysRemaining / 7)} weeks)`
      : "Your baby is due!";

    // Enforce limits for gestational calculations (0 to 280 days)
    const activeDays = Math.max(0, Math.min(280, currentAgeDays));
    const weeks = Math.floor(activeDays / 7);
    const remainingDays = activeDays % 7;

    // Gestational age output
    resGestational.textContent = `${weeks} weeks, ${remainingDays} days`;

    // Trimester
    let trimester = "First Trimester";
    if (weeks >= 14 && weeks < 28) {
      trimester = "Second Trimester";
    } else if (weeks >= 28) {
      trimester = "Third Trimester";
    }
    resTrimester.textContent = trimester;

    // Progress Percentage
    const progressPct = (activeDays / 280) * 100;
    resProgress.textContent = `${progressPct.toFixed(1)}%`;
    timelineBar.style.width = `${progressPct}%`;

    // Milestones render
    milestonesTimeline.innerHTML = '';
    milestones.forEach(m => {
      const isPast = weeks >= m.week;
      const card = document.createElement('div');
      card.className = `relative pb-1 ${isPast ? 'text-ink' : 'text-mute opacity-60'}`;
      card.innerHTML = `
        <div class="absolute -left-[23px] top-1.5 w-2 h-2 rounded-full border border-hairline-strong ${isPast ? 'bg-emerald-500' : 'bg-canvas-soft-2'}"></div>
        <h4 class="text-xs font-mono font-bold uppercase tracking-wider">Week ${m.week}: ${m.title}</h4>
        <p class="text-xs font-sans mt-0.5 leading-relaxed">${m.desc}</p>
      `;
      milestonesTimeline.appendChild(card);
    });
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnLmp.addEventListener('click', () => {
    if (method !== 'lmp') {
      method = 'lmp';
      updateMethodToggle();
    }
  });

  btnConception.addEventListener('click', () => {
    if (method !== 'conception') {
      method = 'conception';
      updateMethodToggle();
    }
  });

  baseDateInput.addEventListener('change', calculate);
  cycleLengthInput.addEventListener('input', calculate);

  // Initial Calculation
  calculate();
</script>
