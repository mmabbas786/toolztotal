---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

---

<Layout 
  title="Pregnancy Due Date Calculator - Free Baby Due Date & Milestones | ToolzTotal"
  description="Estimate your baby's due date, track pregnancy trimesters, and view weekly developmental milestones based on LMP or conception date."
  canonicalUrl="https://toolztotal.com/health/pregnancy-calculator"
>
  <ToolSchema
    toolName="Pregnancy Due Date Calculator"
    toolSlug="pregnancy-calculator"
    categoryName="Health & Fitness"
    categorySlug="health"
    description="Estimate your baby's due date, track pregnancy trimesters, and view weekly developmental milestones based on LMP or conception date."
  faqs={[
    { question: "How is my pregnancy due date calculated?", answer: "The standard way to calculate a pregnancy due date is by adding 280 days (40 weeks) to the first day of your Last Menstrual Period (LMP), assuming a standard 28-day menstrual cycle. If you calculate from your Conception Date, the due date is estimated as 266 days (38 weeks) from conception. This tool also adjusts for custom menstrual cycle lengths if you calculate by LMP." },
    { question: "What is Naegele's Rule?", answer: "Naegele's Rule is a simple clinical formula used to estimate due dates. To calculate: 1. Identify the first day of your LMP; 2. Add 7 days; 3. Subtract 3 months; 4. Add 1 year. This rule assumes a standard 28-day cycle with ovulation occurring on day 14." },
    { question: "What is the difference between Gestational Age and Fetal Age?", answer: "Gestational age measures the pregnancy starting from the first day of your Last Menstrual Period (LMP). Fetal age (or conception age) measures the actual developmental age of the fetus starting from conception. Fetal age is exactly 2 weeks shorter than gestational age because ovulation and conception typically occur about 14 days after the LMP." },
    { question: "How accurate are pregnancy due dates?", answer: "Only about 4% of babies are born on their exact estimated due date. Most babies arrive between 37 and 42 weeks of pregnancy. The due date serves as a helpful reference point, but variations are normal and expected." },
    { question: "Is my input data private?", answer: "Yes, entirely private. No calculations, dates, or cycle lengths are uploaded or stored. Everything runs strictly inside your local browser sandbox using client-side JavaScript." },
    { question: "What is the difference between gestational age and conceptional age?", answer: "Gestational age measures pregnancy from the first day of your last menstrual period (LMP), including about two weeks before conception. Conceptional (or fetal) age measures the actual age of the fetus from the date of conception, making it approximately two weeks shorter than gestational age." },
    { question: "Why do doctors calculate pregnancy from the last menstrual period?", answer: "Doctors use the first day of the last menstrual period (LMP) because it is a clear, memorable date for most women. Pinpointing the exact day of ovulation or conception is highly difficult in natural pregnancies, making the LMP a reliable standard starting point." },
    { question: "How is a due date calculated for an IVF pregnancy?", answer: "For In Vitro Fertilization (IVF) pregnancies, the due date is calculated using the exact date of the embryo transfer. The formula adds 266 days to the transfer date for a day-3 embryo, or 263 days for a day-5 blastocyst, matching the precise developmental stage of the embryo." },
    { question: "What is Naegele's Rule and how does it work?", answer: "Naegele's Rule is a simple method used to calculate a pregnancy due date based on the Last Menstrual Period. The rule involves taking the first day of the LMP, subtracting three calendar months, adding seven days, and adding one year (e.g., LMP of May 10 results in a due date of February 17)." },
    { question: "Is a baby born on their exact due date?", answer: "Only about 4% of babies are born on their exact due date. A normal, full-term pregnancy can deliver anywhere between 37 and 42 weeks of gestation, with the majority of babies arriving within a two-week window surrounding the calculated date." }
  ]}
  />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categoryName="Health & Fitness"
      categorySlug="health"
      toolName="Pregnancy Due Date Calculator"
      toolSlug="pregnancy-calculator"
    />


    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Pregnancy Due Date Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Estimate your baby's due date, current gestational age, and trimester progress. View your week-by-week timeline and key developmental milestones.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Inputs (5 cols) -->
      <div class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Pregnancy Dates</h2>
        
        <!-- Calculation Method Toggle -->
        <div>
          <label class="block text-xs font-mono uppercase text-mute mb-2">Calculate Based On</label>
          <div class="grid grid-cols-2 gap-2">
            <button id="btn-lmp" class="h-10 border border-hairline bg-canvas-soft-2 text-ink rounded-lg font-sans text-sm font-semibold transition-colors cursor-pointer border-hairline-strong shadow-lvl1">First Day of LMP</button>
            <button id="btn-conception" class="h-10 border border-hairline bg-canvas text-body rounded-lg font-sans text-sm transition-colors cursor-pointer hover:border-hairline-strong shadow-lvl1">Conception Date</button>
          </div>
        </div>

        <!-- Date Input -->
        <div>
          <label id="lbl-date" for="base-date" class="block text-xs font-mono uppercase text-mute mb-2">First Day of Last Period</label>
          <input 
            type="date" 
            id="base-date" 
            class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
          />
        </div>

        <!-- Cycle Length (only for LMP) -->
        <div id="cycle-length-container">
          <label for="cycle-length" class="block text-xs font-mono uppercase text-mute mb-2">Average Cycle Length</label>
          <div class="relative">
            <input 
              type="number" 
              id="cycle-length" 
              value="28" 
              min="20" 
              max="45"
              class="w-full h-10 pl-3 pr-16 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-xs font-mono">days</span>
          </div>
        </div>
      </div>

      <!-- Right Column: Results (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Your Timeline Estimates</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Estimated Due Date -->
            <div class="bg-canvas-soft border border-hairline rounded-lg p-5 flex flex-col justify-center">
              <span class="text-xs font-mono uppercase text-mute mb-1">Estimated Due Date</span>
              <span id="res-due-date" class="text-2xl md:text-3xl font-black text-ink font-sans tracking-tight">—</span>
              <span id="res-due-countdown" class="text-xs text-mute font-sans mt-2">Days remaining: —</span>
            </div>

            <!-- Stats Block -->
            <div class="space-y-4">
              <div class="flex justify-between items-center py-2 border-b border-hairline">
                <span class="text-sm text-body font-sans">Gestational Age</span>
                <span id="res-gestational" class="text-base font-bold text-ink font-sans">—</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-hairline">
                <span class="text-sm text-body font-sans">Current Trimester</span>
                <span id="res-trimester" class="text-base font-bold text-ink font-sans">—</span>
              </div>
              <div class="flex justify-between items-center py-2">
                <span class="text-sm text-body font-sans">Pregnancy Progress</span>
                <span id="res-progress" class="text-base font-bold text-ink font-sans">—</span>
              </div>
            </div>
          </div>

          <!-- Progress Bar visualizer -->
          <div class="space-y-2 pt-4 border-t border-hairline">
            <div class="flex justify-between text-xs font-mono text-mute">
              <span>Week 0</span>
              <span>Conception</span>
              <span>Due Date</span>
            </div>
            <div class="h-3 w-full bg-canvas-soft-2 rounded-full overflow-hidden flex shadow-lvl1">
              <div id="timeline-bar" class="h-full bg-emerald-500 transition-all duration-300" style="width: 0%;"></div>
            </div>
          </div>

          <!-- Weekly Milestones List -->
          <div class="space-y-4 pt-4 border-t border-hairline">
            <h3 class="text-sm font-bold text-ink font-sans">Pregnancy Milestones Timeline</h3>
            <div id="milestones-timeline" class="space-y-4 border-l-2 border-hairline pl-4 ml-2">
              <!-- Milestones populated dynamically -->
            </div>
          </div>

          <!-- Disclaimer warning block -->
          <div class="p-4 rounded-lg bg-warning-soft border border-warning-deep/20 text-warning-deep flex gap-3 text-xs md:text-sm font-sans leading-relaxed">
            <svg class="w-5 h-5 shrink-0 text-warning-deep" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <p>
              <strong>Disclaimer:</strong> This tool provides general estimates for informational purposes only and is not medical advice. Individual results vary based on factors this calculator does not account for. Consult a healthcare provider for personalized guidance.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">Calculating Gestational Age and Trimester Timeline Milestones</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          Estimating a pregnancy timeline is essential for tracking fetal development, planning prenatal checkups, and preparing for the birth of your baby. Clinical due dates are based on a standard pregnancy duration of <strong>280 days (40 weeks)</strong> from the start of the Last Menstrual Period (LMP).
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Naegele's Rule and Cycle Length Adjustments</h3>
        <p>
          The standard method used by doctors is based on <strong>Naegele's Rule</strong>. This formula estimates the due date using the LMP:
          <br />
          <strong class="block my-2 text-center text-ink font-mono text-sm">Due Date = LMP + 7 days - 3 months + 1 year</strong>
          This calculation assumes a standard 28-day menstrual cycle, with ovulation and conception occurring on day 14.
        </p>
        <p>
          However, cycle lengths vary. For individuals with longer or shorter cycles, ovulation occurs later or earlier. Our calculator adjusts the calculation using a custom cycle length:
          <br />
          <strong class="block my-2 text-center text-ink font-mono text-sm">Due Date = LMP + 280 days + (Cycle Length - 28 days)</strong>
          This adjustment helps refine the due date estimation when cycle length is known.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Gestational Age vs. Fetal Age</h3>
        <p>
          A common point of confusion is the difference between <strong>Gestational Age</strong> and <strong>Fetal Age</strong>:
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li>
            <strong>Gestational Age:</strong> Measured from the first day of the Last Menstrual Period (LMP). This is the standard medical definition used by obstetricians, even though conception has not yet occurred in the first two weeks.
          </li>
          <li>
            <strong>Fetal Age:</strong> Measured from the actual date of conception. Fetal age is exactly 2 weeks shorter than gestational age, reflecting the actual age of the developing fetus.
          </li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">The Three Trimesters of Pregnancy</h3>
        <p>
          Pregnancy is divided into three trimesters, each characterized by specific developmental phases:
        </p>
        <ul class="list-disc pl-5 space-y-3 font-sans text-sm">
          <li>
            <strong>First Trimester (Weeks 1 to 13):</strong> Rapid cellular differentiation. Conception occurs, and the heart, brain, spinal cord, and limbs begin to form. Key milestones include hearing the heartbeat and transition to the fetal stage.
          </li>
          <li>
            <strong>Second Trimester (Weeks 14 to 27):</strong> Growth and skeletal development. Organs mature, and movements become noticeable. Milestones include finding out the baby's biological sex (around week 20) and reaching viability (around week 24).
          </li>
          <li>
            <strong>Third Trimester (Weeks 28 to 40+):</strong> Weight gain and lung maturation. The baby prepares for birth by building fat reserves and developing lung surfactant. Delivery usually occurs between weeks 37 and 42.
          </li>
        </ul>
      
<h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Gestational Age vs. Fetal Age Explained</h3>
        <p>
          One of the most confusing aspects of pregnancy tracking is the difference between gestational age and fetal age. Gestational age is calculated from the first day of your Last Menstrual Period (LMP). Because ovulation typically occurs about two weeks after menstruation begins, gestational age adds roughly two weeks of time when you were not yet pregnant. Fetal age, on the other hand, measures the actual time that has elapsed since conception occurred. Medical providers globally use gestational age as the standard metric for all pregnancy calculations, due to the difficulty of pinpointing the exact date of conception for most natural pregnancies.
        </p>
        <p>
          Your calculated due date represents the end of the 40th week of gestational age (280 days). However, this number is a statistical estimate rather than an exact deadline. Only about 4% of babies are born on their exact due dates, with the vast majority arriving within a window of two weeks before or one week after the estimated date.
        </p>
        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Ultrasound Redating in the First Trimester</h3>
        <p>
          Early pregnancy calculators rely heavily on date-based formulas like Naegele's Rule, which assumes a standard 28-day menstrual cycle. However, cycle lengths vary between women and from month to month. To verify the accuracy of the date-based due date, your doctor will perform a first-trimester dating ultrasound (typically between weeks 8 and 14). By measuring the baby's Crown-Rump Length (CRL), the ultrasound can determine gestational age with a high degree of accuracy. If there is a discrepancy of more than 5 to 7 days between the ultrasound dating and your LMP calculation, the ultrasound date will override the LMP date.
        </p>
      </div>
    </article>

    <!-- FAQ Section -->
    
    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How is my pregnancy due date calculated?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            The standard way to calculate a pregnancy due date is by adding 280 days (40 weeks) to the first day of your Last Menstrual Period (LMP), assuming a standard 28-day menstrual cycle. If you calculate from your Conception Date, the due date is estimated as 266 days (38 weeks) from conception. This tool also adjusts for custom menstrual cycle lengths if you calculate by LMP.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is Naegele's Rule?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Naegele's Rule is a simple clinical formula used to estimate due dates. To calculate: 1. Identify the first day of your LMP; 2. Add 7 days; 3. Subtract 3 months; 4. Add 1 year. This rule assumes a standard 28-day cycle with ovulation occurring on day 14.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is the difference between Gestational Age and Fetal Age?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Gestational age measures the pregnancy starting from the first day of your Last Menstrual Period (LMP). Fetal age (or conception age) measures the actual developmental age of the fetus starting from conception. Fetal age is exactly 2 weeks shorter than gestational age because ovulation and conception typically occur about 14 days after the LMP.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How accurate are pregnancy due dates?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Only about 4% of babies are born on their exact estimated due date. Most babies arrive between 37 and 42 weeks of pregnancy. The due date serves as a helpful reference point, but variations are normal and expected.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Is my input data private?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes, entirely private. No calculations, dates, or cycle lengths are uploaded or stored. Everything runs strictly inside your local browser sandbox using client-side JavaScript.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is the difference between gestational age and conceptional age?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Gestational age measures pregnancy from the first day of your last menstrual period (LMP), including about two weeks before conception. Conceptional (or fetal) age measures the actual age of the fetus from the date of conception, making it approximately two weeks shorter than gestational age.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Why do doctors calculate pregnancy from the last menstrual period?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Doctors use the first day of the last menstrual period (LMP) because it is a clear, memorable date for most women. Pinpointing the exact day of ovulation or conception is highly difficult in natural pregnancies, making the LMP a reliable standard starting point.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How is a due date calculated for an IVF pregnancy?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            For In Vitro Fertilization (IVF) pregnancies, the due date is calculated using the exact date of the embryo transfer. The formula adds 266 days to the transfer date for a day-3 embryo, or 263 days for a day-5 blastocyst, matching the precise developmental stage of the embryo.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is Naegele's Rule and how does it work?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Naegele's Rule is a simple method used to calculate a pregnancy due date based on the Last Menstrual Period. The rule involves taking the first day of the LMP, subtracting three calendar months, adding seven days, and adding one year (e.g., LMP of May 10 results in a due date of February 17).
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Is a baby born on their exact due date?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Only about 4% of babies are born on their exact due date. A normal, full-term pregnancy can deliver anywhere between 37 and 42 weeks of gestation, with the majority of babies arriving within a two-week window surrounding the calculated date.
          </div>
        </details>
      </div>
    </section>

    <!-- Related Tools Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Related Tools">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Health Calculators</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/health/bmi-calculator" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            BMI Calculator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Check Body Mass Index, BMI Prime, and weight zones.</p>
        </a>
        <a href="/health/calorie-calculator" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Calorie Calculator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Estimate total daily energy expenditure and BMR.</p>
        </a>
        <a href="/health/macro-calculator" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Macro Calculator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Compute custom protein, carb, and fat distributions.</p>
        </a>
      </div>
