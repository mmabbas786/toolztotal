<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const btnMetric = document.getElementById('btn-metric') as HTMLButtonElement;
  const btnImperial = document.getElementById('btn-imperial') as HTMLButtonElement;
  const btnMale = document.getElementById('btn-male') as HTMLButtonElement;
  const btnFemale = document.getElementById('btn-female') as HTMLButtonElement;

  const heightInput = document.getElementById('height') as HTMLInputElement;
  const frameSelect = document.getElementById('frame-size') as HTMLSelectElement;
  const lblHeight = document.getElementById('lbl-height') as HTMLLabelElement;

  const resRobinson = document.getElementById('res-robinson') as HTMLSpanElement;
  const resDevine = document.getElementById('res-devine') as HTMLSpanElement;
  const resMiller = document.getElementById('res-miller') as HTMLSpanElement;
  const resHamwi = document.getElementById('res-hamwi') as HTMLSpanElement;
  const resBmiRange = document.getElementById('res-bmi-range') as HTMLSpanElement;

  const unitRobinson = document.getElementById('unit-robinson') as HTMLSpanElement;
  const unitDevine = document.getElementById('unit-devine') as HTMLSpanElement;
  const unitMiller = document.getElementById('unit-miller') as HTMLSpanElement;
  const unitHamwi = document.getElementById('unit-hamwi') as HTMLSpanElement;

  // ============================================================
  // State
  // ============================================================
  let unitSystem: 'metric' | 'imperial' = 'metric';
  let sex: 'male' | 'female' = 'male';

  // ============================================================
  // Functions
  // ============================================================
  const updateUnitToggle = () => {
    if (unitSystem === 'metric') {
      btnMetric.classList.add('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnMetric.classList.remove('bg-canvas', 'text-body');
      btnImperial.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnImperial.classList.add('bg-canvas', 'text-body');
      lblHeight.textContent = "Height (cm)";

      const h = parseFloat(heightInput.value);
      if (h) heightInput.value = Math.round(h * 2.54).toString();
      
      unitRobinson.textContent = "kg";
      unitDevine.textContent = "kg";
      unitMiller.textContent = "kg";
      unitHamwi.textContent = "kg";
    } else {
      btnImperial.classList.add('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnImperial.classList.remove('bg-canvas', 'text-body');
      btnMetric.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnMetric.classList.add('bg-canvas', 'text-body');
      lblHeight.textContent = "Height (in)";

      const h = parseFloat(heightInput.value);
      if (h) heightInput.value = Math.round(h / 2.54).toString();

      unitRobinson.textContent = "lbs";
      unitDevine.textContent = "lbs";
      unitMiller.textContent = "lbs";
      unitHamwi.textContent = "lbs";
    }
    calculate();
  };

  const updateSexToggle = () => {
    if (sex === 'male') {
      btnMale.classList.add('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnMale.classList.remove('bg-canvas', 'text-body');
      btnFemale.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnFemale.classList.add('bg-canvas', 'text-body');
    } else {
      btnFemale.classList.add('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnFemale.classList.remove('bg-canvas', 'text-body');
      btnMale.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btnMale.classList.add('bg-canvas', 'text-body');
    }
    calculate();
  };

  const calculate = () => {
    let height = parseFloat(heightInput.value);
    const frame = frameSelect.value;

    if (isNaN(height) || height <= 0) return;

    // Internally standard math converts all heights to inches
    let heightIn = height;
    let heightCm = height;
    if (unitSystem === 'metric') {
      heightIn = height / 2.54;
    } else {
      heightCm = height * 2.54;
    }

    const inchesOver5Ft = heightIn - 60; // relative to 60 inches

    // Base calculations in kg
    let devine = 0;
    let robinson = 0;
    let miller = 0;
    let hamwi = 0;

    if (sex === 'male') {
      devine = 50.0 + 2.3 * inchesOver5Ft;
      robinson = 52.0 + 1.9 * inchesOver5Ft;
      miller = 56.2 + 1.41 * inchesOver5Ft;
      hamwi = 48.0 + 2.7 * inchesOver5Ft;
    } else {
      devine = 45.5 + 2.3 * inchesOver5Ft;
      robinson = 49.0 + 1.7 * inchesOver5Ft;
      miller = 53.1 + 1.36 * inchesOver5Ft;
      hamwi = 45.5 + 2.2 * inchesOver5Ft;
    }

    // Apply frame size adjustments (-10% for small, +10% for large)
    let multiplier = 1.0;
    if (frame === 'small') multiplier = 0.9;
    if (frame === 'large') multiplier = 1.1;

    devine *= multiplier;
    robinson *= multiplier;
    miller *= multiplier;
    hamwi *= multiplier;

    // WHO BMI 18.5 - 24.9 ranges in kg
    const heightM = heightCm / 100;
    let bmiMin = 18.5 * (heightM * heightM);
    let bmiMax = 24.9 * (heightM * heightM);

    // Convert output to Lbs if imperial system is active
    if (unitSystem === 'imperial') {
      const kgToLbs = 2.20462;
      devine *= kgToLbs;
      robinson *= kgToLbs;
      miller *= kgToLbs;
      hamwi *= kgToLbs;
      bmiMin *= kgToLbs;
      bmiMax *= kgToLbs;
    }

    // Format outputs
    resDevine.textContent = Math.round(devine).toString();
    resRobinson.textContent = Math.round(robinson).toString();
    resMiller.textContent = Math.round(miller).toString();
    resHamwi.textContent = Math.round(hamwi).toString();
    resBmiRange.textContent = `${Math.round(bmiMin)} - ${Math.round(bmiMax)} ${unitSystem === 'metric' ? 'kg' : 'lbs'}`;
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnMetric.addEventListener('click', () => {
    if (unitSystem !== 'metric') {
      unitSystem = 'metric';
      updateUnitToggle();
    }
  });

  btnImperial.addEventListener('click', () => {
    if (unitSystem !== 'imperial') {
      unitSystem = 'imperial';
      updateUnitToggle();
    }
  });

  btnMale.addEventListener('click', () => {
    if (sex !== 'male') {
      sex = 'male';
      updateSexToggle();
    }
  });

  btnFemale.addEventListener('click', () => {
    if (sex !== 'female') {
      sex = 'female';
      updateSexToggle();
    }
  });

  heightInput.addEventListener('input', calculate);
  frameSelect.addEventListener('change', calculate);

  // Initial Calculation
  calculate();
</script>
