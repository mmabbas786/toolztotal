---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is BMR and how does it differ from TDEE?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BMR (Basal Metabolic Rate) is the minimum number of calories your body needs to perform essential life-sustaining functions—such as breathing, circulation, cell production, and nutrient processing—at rest in a neutral temperature environment. TDEE (Total Daily Energy Expenditure) is the total number of calories you burn per day, calculated by multiplying your BMR by an activity factor that accounts for physical movement, exercise, and the thermic effect of food."
      }
    },
    {
      "@type": "Question",
      "name": "Which formula is used for calculating calorie needs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This calculator uses the Mifflin-St Jeor equation, which is widely recognized as the most accurate formula for estimating BMR in modern clinical settings. The formula calculates BMR for men as: 10 * weight (kg) + 6.25 * height (cm) - 5 * age (y) + 5. For women, it is calculated as: 10 * weight (kg) + 6.25 * height (cm) - 5 * age (y) - 161."
      }
    },
    {
      "@type": "Question",
      "name": "How is the activity level multiplier determined?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your activity level multiplier represents physical exertion. We use standard physical activity level (PAL) factors: Sedentary (1.2) for little to no exercise; Lightly Active (1.375) for light exercise 1–3 days/week; Moderately Active (1.55) for moderate exercise 3–5 days/week; Very Active (1.725) for hard exercise 6–7 days/week; and Extra Active (1.9) for very heavy labor, professional sports, or double training sessions."
      }
    },
    {
      "@type": "Question",
      "name": "How many calories should I cut or add to change my weight?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To lose weight safely (cutting), a daily caloric deficit of 500 calories is generally recommended, which targets roughly 1 pound of fat loss per week. To gain muscle weight (bulking), a surplus of 300 to 500 calories above maintenance is typical to minimize fat gain while supporting protein synthesis. Always monitor your health and energy levels, and make adjustments gradually."
      }
    },
    {
      "@type": "Question",
      "name": "Is my data private when using this calorie calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, entirely private. ToolzTotal operates client-side inside your browser sandbox. None of your physical statistics, age, gender, or target goals are ever sent to a server or stored. You do not need to create an account or sign up to use this tool."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Calorie Calculator - Free Daily Caloric & TDEE Target Estimator | ToolzTotal"
  description="Calculate your daily calorie needs (TDEE) and BMR using the Mifflin-St Jeor equation. Free client-side tool with activity multiplier and macro breakdown."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/health/calorie-calculator"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/health" class="hover:text-ink transition-colors">Health & Fitness</a>
      <span>/</span>
      <span class="text-ink">Calorie Calculator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Calorie & TDEE Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Estimate your Basal Metabolic Rate (BMR) and Total Daily Energy Expenditure (TDEE) using the clinically-proven Mifflin-St Jeor equation. Receive customized macro splits for weight loss, maintenance, or muscle gain.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Inputs (5 cols) -->
      <div class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Your Details</h2>
        
        <!-- Unit Toggle -->
        <div>
          <label class="block text-xs font-mono uppercase text-mute mb-2">Unit System</label>
          <div class="grid grid-cols-2 gap-2">
            <button id="btn-metric" class="h-10 border border-hairline bg-canvas-soft-2 text-ink rounded-lg font-sans text-sm font-semibold transition-colors cursor-pointer border-hairline-strong shadow-lvl1">Metric (kg/cm)</button>
            <button id="btn-imperial" class="h-10 border border-hairline bg-canvas text-body rounded-lg font-sans text-sm transition-colors cursor-pointer hover:border-hairline-strong shadow-lvl1">Imperial (lbs/in)</button>
          </div>
        </div>

        <!-- Gender -->
        <div>
          <label class="block text-xs font-mono uppercase text-mute mb-2">Biological Sex</label>
          <div class="grid grid-cols-2 gap-2">
            <button id="btn-male" class="h-10 border border-hairline bg-canvas-soft-2 text-ink rounded-lg font-sans text-sm font-semibold transition-colors cursor-pointer border-hairline-strong shadow-lvl1">Male</button>
            <button id="btn-female" class="h-10 border border-hairline bg-canvas text-body rounded-lg font-sans text-sm transition-colors cursor-pointer hover:border-hairline-strong shadow-lvl1">Female</button>
          </div>
        </div>

        <!-- Grid for Age, Weight, Height -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- Age -->
          <div>
            <label for="age" class="block text-xs font-mono uppercase text-mute mb-2">Age</label>
            <input 
              type="number" 
              id="age" 
              value="30" 
              min="1" 
              max="120"
              class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
          </div>
          <!-- Weight -->
          <div>
            <label for="weight" id="lbl-weight" class="block text-xs font-mono uppercase text-mute mb-2">Weight (kg)</label>
            <input 
              type="number" 
              id="weight" 
              value="80" 
              min="1" 
              class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
          </div>
          <!-- Height -->
          <div>
            <label for="height" id="lbl-height" class="block text-xs font-mono uppercase text-mute mb-2">Height (cm)</label>
            <input 
              type="number" 
              id="height" 
              value="180" 
              min="1" 
              class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
          </div>
        </div>

        <!-- Activity Level -->
        <div>
          <label for="activity" class="block text-xs font-mono uppercase text-mute mb-2">Activity Level</label>
          <select 
            id="activity" 
            class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
          >
            <option value="1.2">Sedentary (Little to no exercise)</option>
            <option value="1.375">Lightly Active (Light exercise 1-3 days/wk)</option>
            <option value="1.55" selected>Moderately Active (Moderate exercise 3-5 days/wk)</option>
            <option value="1.725">Very Active (Hard exercise 6-7 days/wk)</option>
            <option value="1.9">Extra Active (Very heavy physical labor or double training)</option>
          </select>
        </div>

        <!-- Goal Selection -->
        <div>
          <label class="block text-xs font-mono uppercase text-mute mb-2">Fitness Goal</label>
          <div class="grid grid-cols-3 gap-2">
            <button id="goal-lose" class="h-10 border border-hairline bg-canvas text-body rounded-lg font-sans text-xs transition-colors cursor-pointer hover:border-hairline-strong shadow-lvl1">Lose Weight</button>
            <button id="goal-maintain" class="h-10 border border-hairline bg-canvas-soft-2 text-ink rounded-lg font-sans text-xs font-semibold transition-colors cursor-pointer border-hairline-strong shadow-lvl1">Maintain</button>
            <button id="goal-gain" class="h-10 border border-hairline bg-canvas text-body rounded-lg font-sans text-xs transition-colors cursor-pointer hover:border-hairline-strong shadow-lvl1">Gain Weight</button>
          </div>
        </div>
      </div>

      <!-- Right Column: Results (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Your Caloric Estimates</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- TDEE Target -->
            <div class="bg-canvas-soft border border-hairline rounded-lg p-5 flex flex-col justify-center">
              <span class="text-xs font-mono uppercase text-mute mb-1">Target Intake Needs</span>
              <div class="flex items-baseline gap-1.5">
