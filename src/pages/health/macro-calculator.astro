    <RelatedTools
      categorySlug="health"
      toolSlug="macro-calculator"
    />

  <ContentFooter category="health" />
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const caloriesInput = document.getElementById('calories') as HTMLInputElement;

  const btnBalanced = document.getElementById('preset-balanced') as HTMLButtonElement;
  const btnAthletic = document.getElementById('preset-athletic') as HTMLButtonElement;
  const btnKeto = document.getElementById('preset-keto') as HTMLButtonElement;

  const sliderProtein = document.getElementById('slider-protein') as HTMLInputElement;
  const sliderCarbs = document.getElementById('slider-carbs') as HTMLInputElement;
  const sliderFat = document.getElementById('slider-fat') as HTMLInputElement;

  const sliderProteinLbl = document.getElementById('slider-protein-lbl') as HTMLSpanElement;
  const sliderCarbsLbl = document.getElementById('slider-carbs-lbl') as HTMLSpanElement;
  const sliderFatLbl = document.getElementById('slider-fat-lbl') as HTMLSpanElement;

  const ratioTotalBox = document.getElementById('ratio-total-box') as HTMLDivElement;
  const ratioTotalVal = document.getElementById('ratio-total-val') as HTMLSpanElement;

  const resProteinGrams = document.getElementById('res-protein-grams') as HTMLSpanElement;
  const resProteinCalories = document.getElementById('res-protein-calories') as HTMLSpanElement;
  const resCarbsGrams = document.getElementById('res-carbs-grams') as HTMLSpanElement;
  const resCarbsCalories = document.getElementById('res-carbs-calories') as HTMLSpanElement;
  const resFatGrams = document.getElementById('res-fat-grams') as HTMLSpanElement;
  const resFatCalories = document.getElementById('res-fat-calories') as HTMLSpanElement;

  const visualProtein = document.getElementById('visual-protein') as HTMLDivElement;
  const visualCarbs = document.getElementById('visual-carbs') as HTMLDivElement;
  const visualFat = document.getElementById('visual-fat') as HTMLDivElement;

  // ============================================================
  // State
  // ============================================================
  let proteinPct = 30;
  let carbsPct = 40;
  let fatPct = 30;

  // ============================================================
  // Preset Values
  // ============================================================
  const applyPreset = (p: number, c: number, f: number) => {
    proteinPct = p;
    carbsPct = c;
    fatPct = f;

    sliderProtein.value = p.toString();
    sliderCarbs.value = c.toString();
    sliderFat.value = f.toString();

    sliderProteinLbl.textContent = `${p}%`;
    sliderCarbsLbl.textContent = `${c}%`;
    sliderFatLbl.textContent = `${f}%`;

    calculate();
  };

  const updatePresetUI = (activeBtn: HTMLButtonElement) => {
    const btns = [btnBalanced, btnAthletic, btnKeto];
    btns.forEach(btn => {
      btn.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btn.classList.add('bg-canvas', 'text-body');
    });
    activeBtn.classList.add('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
    activeBtn.classList.remove('bg-canvas', 'text-body');
  };

  const calculate = () => {
    const calories = parseFloat(caloriesInput.value);
    if (isNaN(calories) || calories <= 0) return;

    const totalPct = proteinPct + carbsPct + fatPct;
    ratioTotalVal.textContent = `${totalPct}%`;

    if (totalPct !== 100) {
      ratioTotalBox.classList.remove('bg-emerald-500/10', 'text-emerald-500', 'border-emerald-500/20');
      ratioTotalBox.classList.add('bg-error-soft', 'text-error-deep', 'border-error-deep/20');
      
      // Zero out calculations
      resProteinGrams.textContent = "—";
      resProteinCalories.textContent = "0 kcal";
      resCarbsGrams.textContent = "—";
      resCarbsCalories.textContent = "0 kcal";
      resFatGrams.textContent = "—";
      resFatCalories.textContent = "0 kcal";

      visualProtein.style.width = "0%";
      visualCarbs.style.width = "0%";
      visualFat.style.width = "0%";
      return;
    }

    ratioTotalBox.classList.add('bg-emerald-500/10', 'text-emerald-500', 'border-emerald-500/20');
    ratioTotalBox.classList.remove('bg-error-soft', 'text-error-deep', 'border-error-deep/20');

    // Calculations
    const pKcal = calories * (proteinPct / 100);
    const cKcal = calories * (carbsPct / 100);
    const fKcal = calories * (fatPct / 100);

    const pGrams = Math.round(pKcal / 4);
    const cGrams = Math.round(cKcal / 4);
    const fGrams = Math.round(fKcal / 9);

    // Update Text DOM
    resProteinGrams.textContent = `${pGrams}g`;
    resProteinCalories.textContent = `${Math.round(pKcal)} kcal`;
    resCarbsGrams.textContent = `${cGrams}g`;
    resCarbsCalories.textContent = `${Math.round(cKcal)} kcal`;
    resFatGrams.textContent = `${fGrams}g`;
    resFatCalories.textContent = `${Math.round(fKcal)} kcal`;

    // Update Visual Chart
    visualProtein.style.width = `${proteinPct}%`;
    visualCarbs.style.width = `${carbsPct}%`;
    visualFat.style.width = `${fatPct}%`;
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnBalanced.addEventListener('click', () => {
    applyPreset(30, 40, 30);
    updatePresetUI(btnBalanced);
  });

  btnAthletic.addEventListener('click', () => {
    applyPreset(40, 30, 30);
    updatePresetUI(btnAthletic);
  });

  btnKeto.addEventListener('click', () => {
    applyPreset(30, 5, 65);
    updatePresetUI(btnKeto);
  });

  // Manual Sliders
  sliderProtein.addEventListener('input', (e) => {
    const val = parseInt((e.target as HTMLInputElement).value, 10);
    proteinPct = val;
    sliderProteinLbl.textContent = `${val}%`;
    
    // Clear active preset buttons
    const btns = [btnBalanced, btnAthletic, btnKeto];
    btns.forEach(btn => {
      btn.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btn.classList.add('bg-canvas', 'text-body');
    });

    calculate();
  });

  sliderCarbs.addEventListener('input', (e) => {
    const val = parseInt((e.target as HTMLInputElement).value, 10);
    carbsPct = val;
    sliderCarbsLbl.textContent = `${val}%`;
    
    const btns = [btnBalanced, btnAthletic, btnKeto];
    btns.forEach(btn => {
      btn.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btn.classList.add('bg-canvas', 'text-body');
    });

    calculate();
  });

  sliderFat.addEventListener('input', (e) => {
    const val = parseInt((e.target as HTMLInputElement).value, 10);
    fatPct = val;
    sliderFatLbl.textContent = `${val}%`;
    
    const btns = [btnBalanced, btnAthletic, btnKeto];
    btns.forEach(btn => {
      btn.classList.remove('bg-canvas-soft-2', 'text-ink', 'font-semibold', 'border-hairline-strong');
      btn.classList.add('bg-canvas', 'text-body');
    });

    calculate();
  });

  caloriesInput.addEventListener('input', calculate);

  // Initial Calculation
  calculate();
</script>
