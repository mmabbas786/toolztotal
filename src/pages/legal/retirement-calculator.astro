<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const currentAgeIn = document.getElementById('current-age') as HTMLInputElement;
  const retireAgeIn = document.getElementById('retirement-age') as HTMLInputElement;
  const initialSavingsIn = document.getElementById('initial-savings') as HTMLInputElement;
  const contributionIn = document.getElementById('monthly-contribution') as HTMLInputElement;
  const returnIn = document.getElementById('expected-return') as HTMLInputElement;
  const inflationIn = document.getElementById('inflation-rate') as HTMLInputElement;

  const valReturn = document.getElementById('val-expected-return') as HTMLSpanElement;
  const valInflation = document.getElementById('val-inflation-rate') as HTMLSpanElement;

  const resNominalFv = document.getElementById('res-nominal-fv') as HTMLSpanElement;
  const resRealFv = document.getElementById('res-real-fv') as HTMLSpanElement;
  const resAnnual = document.getElementById('res-annual-withdrawal') as HTMLSpanElement;
  const resMonthly = document.getElementById('res-monthly-withdrawal') as HTMLSpanElement;

  // ============================================================
  // Functions
  // ============================================================
  const calculateRetirement = () => {
    const currentAge = parseFloat(currentAgeIn.value) || 0;
    const retireAge = parseFloat(retireAgeIn.value) || 0;
    const initial = parseFloat(initialSavingsIn.value) || 0;
    const monthly = parseFloat(contributionIn.value) || 0;
    const rate = (parseFloat(returnIn.value) || 0) / 100;
    const inflation = (parseFloat(inflationIn.value) || 0) / 100;

    // Update labels
    valReturn.textContent = returnIn.value + "%";
    valInflation.textContent = inflationIn.value + "%";

    const years = Math.max(0, retireAge - currentAge);
    const months = years * 12;

    if (months <= 0) {
      resNominalFv.textContent = "$0";
      resRealFv.textContent = "$0";
      resAnnual.textContent = "$0 / yr";
      resMonthly.textContent = "$0 / mo";
      return;
    }

    // Monthly interest rates
    const rNominal = rate / 12;
    const rReal = (rate - inflation) / 12;

    // nominal fv = PV * (1 + r)^n + PMT * [((1 + r)^n - 1) / r]
    let nominalFv = initial * Math.pow(1 + rNominal, months);
    if (rNominal > 0) {
      nominalFv += monthly * ((Math.pow(1 + rNominal, months) - 1) / rNominal);
    } else {
      nominalFv += monthly * months;
    }

    // real fv (adjusted for inflation)
    let realFv = initial * Math.pow(1 + rReal, months);
    if (rReal > 0) {
      realFv += monthly * ((Math.pow(1 + rReal, months) - 1) / rReal);
    } else {
      realFv += monthly * months;
    }

    // Safe withdrawals (4% Rule) based on inflation-adjusted Nest Egg
    const annualWithdrawal = realFv * 0.04;
    const monthlyWithdrawal = annualWithdrawal / 12;

    resNominalFv.textContent = "$" + nominalFv.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    resRealFv.textContent = "$" + realFv.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    resAnnual.textContent = "$" + annualWithdrawal.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + " / yr";
    resMonthly.textContent = "$" + monthlyWithdrawal.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 }) + " / mo";
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  [currentAgeIn, retireAgeIn, initialSavingsIn, contributionIn].forEach(inp => {
    inp.addEventListener('input', calculateRetirement);
  });

  [returnIn, inflationIn].forEach(slide => {
    slide.addEventListener('input', calculateRetirement);
  });

  // Initial Calculation
  calculateRetirement();
</script>
