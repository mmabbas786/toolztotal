<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const weeklySalaryIn = document.getElementById('weekly-salary') as HTMLInputElement;
  const yearsServiceIn = document.getElementById('years-service') as HTMLInputElement;
  const weeksPerYearIn = document.getElementById('weeks-per-year') as HTMLInputElement;
  const ptoPayoutIn = document.getElementById('pto-payout') as HTMLInputElement;
  const healthIn = document.getElementById('health-continuation') as HTMLInputElement;

  const warnSizeCheck = document.getElementById('warn-emp-size') as HTMLInputElement;
  const warnLayoffCheck = document.getElementById('warn-layoff-size') as HTMLInputElement;

  const resTotalPackage = document.getElementById('res-total-package') as HTMLSpanElement;
  const resBaseSeverance = document.getElementById('res-base-severance') as HTMLSpanElement;
  const resPto = document.getElementById('res-pto') as HTMLSpanElement;
  const resHealth = document.getElementById('res-health') as HTMLSpanElement;
  const warnResultBox = document.getElementById('warn-result-box') as HTMLDivElement;

  // ============================================================
  // Functions
  // ============================================================
  const calculateSeverance = () => {
    const salary = parseFloat(weeklySalaryIn.value) || 0;
    const years = parseFloat(yearsServiceIn.value) || 0;
    const weeks = parseFloat(weeksPerYearIn.value) || 0;
    const pto = parseFloat(ptoPayoutIn.value) || 0;
    const health = parseFloat(healthIn.value) || 0;

    const baseSeverance = salary * years * weeks;
    const totalPackage = baseSeverance + pto + health;

    resBaseSeverance.textContent = "$" + baseSeverance.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    resPto.textContent = "$" + pto.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    resHealth.textContent = "$" + health.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    resTotalPackage.textContent = "$" + totalPackage.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });

    // Show WARN act eligibility alerts
    if (warnSizeCheck.checked && warnLayoffCheck.checked) {
      warnResultBox.classList.remove('hidden');
    } else {
      warnResultBox.classList.add('hidden');
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  [weeklySalaryIn, yearsServiceIn, weeksPerYearIn, ptoPayoutIn, healthIn].forEach(inp => {
    inp.addEventListener('input', calculateSeverance);
  });

  [warnSizeCheck, warnLayoffCheck].forEach(chk => {
    chk.addEventListener('change', calculateSeverance);
  });

  // Initial Calculation
  calculateSeverance();
</script>
