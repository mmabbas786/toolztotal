---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

---

<Layout 
  title="Overtime Pay Calculator - FLSA 1.5x Overtime Solver | ToolzTotal"
  description="Calculate overtime pay under Fair Labor Standards Act (FLSA) regulations. Toggles standard 1.5x and double-time. Simple client-side tool."
  canonicalUrl="https://toolztotal.com/legal/overtime-calculator"
>
  <ToolSchema
    toolName="Overtime Pay Calculator"
    toolSlug="overtime-calculator"
    categoryName="Legal & Employment"
    categorySlug="legal"
    description="Calculate overtime pay under Fair Labor Standards Act (FLSA) regulations. Toggles standard 1.5x and double-time. Simple client-side tool."
  faqs={[
    { question: "Double-Time Hours (2.0x)", answer: "Double-Time Hours Worked" },
    { question: "How is FLSA overtime pay calculated?", answer: "Under the federal Fair Labor Standards Act (FLSA), overtime pay is calculated as 1.5 times the regular hourly rate for all hours worked past 40 hours in a single workweek." },
    { question: "What is the double-time pay rule?", answer: "Double-time pay is twice the regular hourly rate. Under federal guidelines, it is not required. However, some states like California mandate double-time for hours worked past 12 in a single workday, or past 8 hours on the 7th consecutive workday in a workweek." },
    { question: "What is the difference between exempt and non-exempt status?", answer: "Non-exempt employees are legally protected under the FLSA and must receive overtime pay. Exempt employees are excluded from FLSA overtime protections, typically falling under administrative, professional, executive, or computer job definitions and meeting minimum salary thresholds." },
    { question: "Can I negotiate my overtime hours?", answer: "Private-sector employees covered under non-exempt provisions cannot waive their overtime rights. Working overtime requires pay at standard FLSA overtime rate scales." },
    { question: "Does this tool share my pay information?", answer: "No. Like all tools on ToolzTotal, our overtime calculator runs completely client-side in your local browser sandbox. None of your rates or hours are uploaded to a server." },
    { question: "What is the difference between exempt and non-exempt employees?", answer: "Non-exempt employees are covered by FLSA overtime rules and must receive overtime pay for hours worked over 40 in a week. Exempt employees are salaried workers who meet specific duty criteria and are excluded from overtime pay." },
    { question: "How is overtime calculated for workers with fluctuating schedules?", answer: "Overtime is calculated on a workweek basis. Regardless of schedule variations, non-exempt employees must receive time-and-a-half pay for all hours worked over 40 in any single, fixed 7-day period." },
    { question: "Does federal law require daily overtime pay after 8 hours?", answer: "Federal law does not require daily overtime pay. Overtime is calculated weekly for hours over 40. However, states like California and Alaska require overtime pay after 8 hours of work in a single day, regardless of weekly totals." },
    { question: "Do salivary/hourly bonuses count toward my regular rate for overtime calculations?", answer: "Yes, non-discretionary bonuses, performance incentives, and commissions must be included in your regular rate of pay before calculating overtime, which raises your overtime hourly rate." },
    { question: "Can an employer offer comp time instead of cash overtime?", answer: "Private-sector employers must pay overtime in cash. Offering compensatory time off ('comp time') in place of overtime pay is generally illegal for private companies, though public sector agencies are sometimes permitted to offer it." }
  ]}
  />

