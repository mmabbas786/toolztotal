<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const rateIn = document.getElementById('hourly-rate') as HTMLInputElement;
  const regHoursIn = document.getElementById('regular-hours') as HTMLInputElement;
  const otHoursIn = document.getElementById('overtime-hours') as HTMLInputElement;
  const doubleHoursIn = document.getElementById('double-hours') as HTMLInputElement;

  const resRegRate = document.getElementById('res-reg-rate') as HTMLSpanElement;
  const resRegPay = document.getElementById('res-reg-pay') as HTMLSpanElement;
  const resOtRate = document.getElementById('res-ot-rate') as HTMLSpanElement;
  const resOtPay = document.getElementById('res-ot-pay') as HTMLSpanElement;
  const resDoublePay = document.getElementById('res-double-pay') as HTMLSpanElement;
  const resTotalPay = document.getElementById('res-total-pay') as HTMLSpanElement;

  // ============================================================
  // Functions
  // ============================================================
  const calculateOvertime = () => {
    const rate = parseFloat(rateIn.value) || 0;
    const regHours = parseFloat(regHoursIn.value) || 0;
    const otHours = parseFloat(otHoursIn.value) || 0;
    const doubleHours = parseFloat(doubleHoursIn.value) || 0;

    const regPay = regHours * rate;
    const otRate = rate * 1.5;
    const otPay = otHours * otRate;
    const doubleRate = rate * 2.0;
    const doublePay = doubleHours * doubleRate;

    const totalPay = regPay + otPay + doublePay;

    resRegRate.textContent = "$" + rate.toFixed(2) + " / hr";
    resRegPay.textContent = "$" + regPay.toFixed(2);
    resOtRate.textContent = "$" + otRate.toFixed(2) + " / hr";
    resOtPay.textContent = "$" + otPay.toFixed(2);
    resDoublePay.textContent = "$" + doublePay.toFixed(2);
    resTotalPay.textContent = "$" + totalPay.toFixed(2);
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  [rateIn, regHoursIn, otHoursIn, doubleHoursIn].forEach(inp => {
    inp.addEventListener('input', calculateOvertime);
  });

  // Initial Calculation
  calculateOvertime();
</script>
