---
import Layout from '../../layouts/Layout.astro';
import { toolCatalog } from '../../data/tools';

export function getStaticPaths() {
  return toolCatalog.map(category => ({
    params: { category: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const liveTools = category.tools.filter(t => t.status === 'live');
const upcomingTools = category.tools.filter(t => t.status === 'coming-soon');
---

<Layout 
  title={`${category.name} Calculators & Tools | ToolzTotal`}
  description={`Free, fast, and client-side ${category.name.toLowerCase()} calculators and tools. No signup, no ads, just instant answers.`}
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-16 md:py-24">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <span class="text-ink">{category.name}</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-3xl mb-16">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">{category.name}</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-6">
        {category.name} calculators and tools.
      </h1>
      <p class="text-body text-lg md:text-xl font-sans leading-relaxed">
        {category.description} Built to run completely client-side in your browser for total privacy and speed.
      </p>
    </div>

    <!-- Live Tools Section -->
    {category.tools.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {category.tools.map(tool => (
          <a 
            href={`/${category.slug}/${tool.slug}`}
            class="group block bg-canvas border border-hairline hover:border-hairline-strong transition-all duration-300 rounded-lg p-6 hover:shadow-lvl3 shadow-lvl2 relative overflow-hidden"
          >
            <div class="flex items-start justify-between mb-4">
              {tool.status === 'live' ? (
                <div class="flex items-center gap-2">
                  <span class="relative flex h-1.5 w-1.5 flex-shrink-0">
                    <span class="live-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="live-glow-dot relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500 dark:bg-emerald-400"></span>
                  </span>
                  <span class="text-[9px] font-mono text-emerald-700 dark:text-emerald-400 uppercase tracking-wider font-bold">Live</span>
                </div>
              ) : (
                <span class="text-xs font-mono px-2 py-0.5 rounded bg-canvas-soft-2 text-mute border border-hairline uppercase tracking-wider">
                  Coming Soon
                </span>
              )}
              <svg class="w-4 h-4 text-mute group-hover:text-primary transition-colors transform group-hover:translate-x-1 duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-ink mb-2 font-sans group-hover:text-primary transition-colors">{tool.name}</h3>
            <p class="text-body text-sm font-sans leading-relaxed mb-4">{tool.description}</p>
            <div class="text-xs text-mute font-mono">/{category.slug}/{tool.slug}</div>
          </a>
        ))}
      </div>
    ) : (
      <div class="border border-hairline border-dashed rounded-lg bg-canvas p-12 text-center max-w-xl mx-auto shadow-lvl2">
        <div class="w-12 h-12 rounded-full bg-canvas-soft-2 border border-hairline flex items-center justify-center mx-auto mb-6">
          <svg class="w-6 h-6 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-ink mb-3 font-sans">No tools launched yet</h3>
        <p class="text-body text-sm font-sans leading-relaxed mb-8">
          We are currently designing and building high-performance, client-side tools for the <strong>{category.name}</strong> category.
        </p>

        <!-- Newsletter simulation signup -->
        <div class="w-full">
          <form class="flex flex-col sm:flex-row gap-2" onsubmit="event.preventDefault(); alert('Thank you! You will be notified when tools launch in this category.'); this.reset();">
            <input 
              type="email" 
              required 
              placeholder="Enter your email" 
              class="flex-grow h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
            <button 
              type="submit" 
              class="h-10 bg-primary text-on-primary hover:bg-mute font-sans text-sm font-medium px-4 rounded-md transition-all cursor-pointer whitespace-nowrap"
            >
              Notify Me
            </button>
          </form>
          <p class="text-[11px] text-mute font-sans mt-2.5">No spam. No signup required, we just save a cookie request or notify via localStorage alerts.</p>
        </div>
      </div>
    )}

    <!-- Category Switcher Section -->
    <div class="mt-24 pt-16 border-t border-hairline">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Explore Other Categories</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {toolCatalog.filter(c => c.slug !== category.slug).map(c => (
          <a 
            href={`/${c.slug}`}
            class="block bg-canvas border border-hairline hover:border-hairline-strong transition-all duration-200 rounded-lg p-4 shadow-lvl1"
          >
            <h4 class="text-sm font-bold text-ink font-sans mb-1">{c.name}</h4>
            <p class="text-mute text-xs font-sans truncate">{c.description}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
