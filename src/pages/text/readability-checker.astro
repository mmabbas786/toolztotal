<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

  const metricFre = document.getElementById('metric-fre') as HTMLSpanElement;
  const labelFre = document.getElementById('label-fre') as HTMLSpanElement;

  const metricFkgl = document.getElementById('metric-fkgl') as HTMLSpanElement;
  const labelFkgl = document.getElementById('label-fkgl') as HTMLSpanElement;

  const metricFog = document.getElementById('metric-fog') as HTMLSpanElement;
  const metricSmog = document.getElementById('metric-smog') as HTMLSpanElement;
  const metricCl = document.getElementById('metric-cl') as HTMLSpanElement;

  const statAsl = document.getElementById('stat-asl') as HTMLSpanElement;
  const statComplex = document.getElementById('stat-complex') as HTMLSpanElement;
  const statAsw = document.getElementById('stat-asw') as HTMLSpanElement;
  const statSentences = document.getElementById('stat-sentences') as HTMLSpanElement;

  // ============================================================
  // Heuristic Syllable counter helper
  // ============================================================
  const countSyllables = (word: string) => {
    word = word.toLowerCase().trim();
    if (word.length <= 3) return 1;
    // Remove silent endings
    word = word.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '');
    word = word.replace(/^y/, '');
    const vowels = word.match(/[aeiouy]{1,2}/g);
    return vowels ? vowels.length : 1;
  };

  // ============================================================
  // Functions
  // ============================================================
  const analyzeReadability = () => {
    const text = textInput.value;
    const cleanText = text.trim();

    if (!cleanText) {
      resetDashboard();
      return;
    }

    // 1. Sentences split (by . ! ?)
    const sentences = cleanText.split(/[.!?]+/).filter(s => s.trim().length > 0);
    const sentenceCount = sentences.length || 1;
    statSentences.textContent = sentenceCount.toString();

    // 2. Words split
    const words = cleanText.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?"']/g, "").split(/\s+/).filter(Boolean);
    const wordCount = words.length || 1;

    // 3. Letters split (pure alphabetic characters)
    const lettersCount = cleanText.replace(/[^a-zA-Z]/g, '').length;

    // 4. Syllable metrics
    let totalSyllables = 0;
    let complexCount = 0;

    words.forEach(w => {
      const syl = countSyllables(w);
      totalSyllables += syl;
      if (syl >= 3) {
        complexCount++;
      }
    });

    statComplex.textContent = complexCount.toLocaleString();

    const asl = wordCount / sentenceCount;
    const asw = totalSyllables / wordCount;

    statAsl.textContent = `${asl.toFixed(1)} words`;
    statAsw.textContent = asw.toFixed(2);

    // ==========================================
    // Readability Index Calculations
    // ==========================================

    // Flesch Reading Ease (0-100 scale)
    const freVal = 206.835 - (1.015 * asl) - (84.6 * asw);
    const fre = Math.max(0, Math.min(100, freVal));
    metricFre.textContent = fre.toFixed(1);

    // Flesch Reading Ease text label
    let freLabel = "N/A";
    if (fre >= 90) freLabel = "Very Easy (5th Grade)";
    else if (fre >= 80) freLabel = "Easy (6th Grade)";
    else if (fre >= 70) freLabel = "Fairly Easy (7th Grade)";
    else if (fre >= 60) freLabel = "Standard (8th-9th Grade)";
    else if (fre >= 50) freLabel = "Fairly Difficult (10th-12th Grade)";
    else if (fre >= 30) freLabel = "Difficult (College)";
    else freLabel = "Very Confusing (Graduate)";
    labelFre.textContent = freLabel;

    // Flesch-Kincaid Grade Level
    const fkglVal = (0.39 * asl) + (11.8 * asw) - 15.59;
    const fkgl = Math.max(0, fkglVal);
    metricFkgl.textContent = fkgl.toFixed(1);

    // Flesch-Kincaid text label
    let fkglLabel = "Easy";
    if (fkgl >= 13) fkglLabel = "College Graduate Level";
    else if (fkgl >= 9) fkglLabel = "High School Level";
    else if (fkgl >= 6) fkglLabel = "Middle School Level";
    else fkglLabel = "Elementary Level";
    labelFkgl.textContent = fkglLabel;

    // Gunning Fog Index
    const fog = 0.4 * (asl + 100 * (complexCount / wordCount));
    metricFog.textContent = Math.max(0, fog).toFixed(1);

    // SMOG Grade (Simple Measure of Gobbledygook)
    const smogVal = 1.0430 * Math.sqrt(complexCount * (30 / sentenceCount)) + 3.1291;
    metricSmog.textContent = Math.max(0, smogVal).toFixed(1);

    // Coleman-Liau Index
    const l = (lettersCount / wordCount) * 100;
    const s = (sentenceCount / wordCount) * 100;
    const cl = (0.0588 * l) - (0.296 * s) - 15.8;
    metricCl.textContent = Math.max(0, cl).toFixed(1);
  };

  const resetDashboard = () => {
    metricFre.textContent = "0.0";
    labelFre.textContent = "N/A";
    metricFkgl.textContent = "0.0";
    labelFkgl.textContent = "Grade Level";
    metricFog.textContent = "0.0";
    metricSmog.textContent = "0.0";
    metricCl.textContent = "0.0";

    statAsl.textContent = "0.0 words";
    statComplex.textContent = "0";
    statAsw.textContent = "0.00";
    statSentences.textContent = "0";
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  textInput.addEventListener('input', analyzeReadability);
  btnClear.addEventListener('click', () => {
    textInput.value = '';
    analyzeReadability();
  });

  // Initial Calculation
  analyzeReadability();
</script>
