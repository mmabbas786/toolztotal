---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does the word counter calculate reading time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The word counter estimates reading time by dividing the total word count by an average reading speed of 225 words per minute (WPM). This is the standard speed benchmark for adult silent readers."
      }
    },
    {
      "@type": "Question",
      "name": "What is speaking time and how is it calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Speaking time estimates how long it takes to read a text aloud, calculated by dividing the total word count by an average speaking speed of 130 words per minute (WPM). This benchmark is ideal for speechwriters and video script creators."
      }
    },
    {
      "@type": "Question",
      "name": "Does this word counter include spaces in the character count?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, our tool provides two separate character counts: one that counts every single keystroke including spaces, tabs, and line breaks, and another that counts characters excluding spaces to measure pure textual letters."
      }
    },
    {
      "@type": "Question",
      "name": "What is keyword density and why does it matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Keyword density measures the percentage frequency of a specific word or phrase relative to the total word count. Monitoring keyword density is vital for SEO to ensure target keywords are present without triggering search engine spam filters."
      }
    },
    {
      "@type": "Question",
      "name": "Is my text data stored or shared?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, never. Like all tools on ToolzTotal, our word counter runs 100% client-side inside your local browser. None of your text, drafts, or scripts are uploaded to a server or stored."
      }
    },
    {
      "@type": "Question",
      "name": "What is the recommended word count for SEO blog articles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For search engine optimization, the recommended length is between 1,500 and 2,500 words. Long-form articles provide a more comprehensive answer to search queries, which search engines favor, and naturally contain more relevant keywords."
      }
    },
    {
      "@type": "Question",
      "name": "How does this tool handle hyphenated words and contractions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This tool counts hyphenated words (e.g., 'state-of-the-art') as a single word, as they are joined by a hyphen. Contractions (e.g., 'don't', 'it's') are also counted as single words, matching standard word processor conventions."
      }
    },
    {
      "@type": "Question",
      "name": "Why do word counts vary between Google Docs, Word, and online tools?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Different programs use slightly different parsing rules. For example, some tools count hyphenated words, symbols, or numbers as individual words, while others exclude them. This client-side counter uses clean regular expressions to provide consistent results."
      }
    },
    {
      "@type": "Question",
      "name": "What is the optimal word length for a standard college essay?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard college essays typically range from 1,000 to 2,500 words, depending on the assignment requirements. A 1,000-word essay translates to roughly 4 pages when double-spaced using a standard font."
      }
    },
    {
      "@type": "Question",
      "name": "How many pages is 1,000 words?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 1,000-word document is approximately 2 pages when single-spaced, or 4 pages when double-spaced, using standard formatting (1-inch margins, 12pt Times New Roman font)."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Word Counter - Free Character Count & Density Tool | ToolzTotal"
  description="Count words, characters, sentences, paragraphs in real-time. Calculate estimated reading and speaking times, and keyword density."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/text/word-counter"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/text" class="hover:text-ink transition-colors">Text & Content</a>
      <span>/</span>
      <span class="text-ink">Word Counter</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Word Counter
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Count words, characters, sentences, and paragraphs in real-time. Evaluate reading speeds, speaking durations, and check keyword density statistics instantly.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Input Panel (7 cols) -->
      <div class="lg:col-span-7 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <div class="flex items-center justify-between border-b border-hairline pb-3">
          <h2 class="text-lg font-bold text-ink font-sans">Draft Editor</h2>
          <button id="btn-clear" class="text-xs font-mono text-mute hover:text-red-500 cursor-pointer transition-colors">Clear text</button>
        </div>
        
        <!-- Text Area -->
        <div>
          <textarea 
            id="text-input" 
            rows="12"
            placeholder="Type, paste, or draft your text here to begin counting..."
            class="w-full p-4 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 resize-y min-h-[250px]"
          >The brown fox jumps over the lazy dog. Writing is fun and easy. Readability metrics are important.</textarea>
        </div>
      </div>

      <!-- Right Column: Metrics (5 cols) -->
      <div class="lg:col-span-5 space-y-6">
        
        <!-- Core Counts Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2">Metrics Summary</h2>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="p-3 bg-canvas-soft border border-hairline rounded-lg">
              <span class="text-[10px] font-mono text-mute uppercase block mb-1">Words</span>
              <span id="metric-words" class="text-2xl font-black text-ink font-sans">0</span>
            </div>
            <div class="p-3 bg-canvas-soft border border-hairline rounded-lg">
              <span class="text-[10px] font-mono text-mute uppercase block mb-1">Characters</span>
              <span id="metric-chars" class="text-2xl font-black text-ink font-sans">0</span>
            </div>
            <div class="p-3 bg-canvas-soft border border-hairline rounded-lg">
              <span class="text-[10px] font-mono text-mute uppercase block mb-1">Sentences</span>
              <span id="metric-sentences" class="text-2xl font-black text-ink font-sans">0</span>
            </div>
            <div class="p-3 bg-canvas-soft border border-hairline rounded-lg">
              <span class="text-[10px] font-mono text-mute uppercase block mb-1">Paragraphs</span>
              <span id="metric-paragraphs" class="text-2xl font-black text-ink font-sans">0</span>
            </div>
          </div>
        </div>

        <!-- Times & Readability Estimates -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2">Read Times & Difficulty</h2>
          
          <div class="space-y-3">
            <div class="flex justify-between items-center py-2 border-b border-hairline text-sm">
              <span class="text-body font-sans">Reading Time (225 WPM)</span>
              <span id="metric-read-time" class="font-bold text-ink font-mono">0s</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-hairline text-sm">
              <span class="text-body font-sans">Speaking Time (130 WPM)</span>
              <span id="metric-speak-time" class="font-bold text-ink font-mono">0s</span>
            </div>
            <div class="flex justify-between items-center py-2 text-sm">
              <span class="text-body font-sans">Flesch Reading Ease (Est.)</span>
              <span id="metric-readability" class="font-bold text-ink font-mono">0.0</span>
            </div>
          </div>
        </div>

        <!-- Keyword Density Checklist -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2">Top Keywords Density</h2>
          
          <div id="density-box" class="space-y-2 max-h-48 overflow-y-auto pr-1">
            <p class="text-xs text-mute font-sans">Type text in editor to calculate keyword density.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">Analyzing Text Length and Readability Metrics for Digital Copywriters</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          In content marketing and copywriting, text length and readability are key factors that influence reader engagement and search engine optimization. Simply drafting text without considering length constraints can lead to high bounce rates and poor index rankings.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Understanding Word, Sentence, and Paragraph Metrics</h3>
        <p>
          A balanced text layout uses structured pacing to hold reader interest:
        </p>
        <ul class="list-disc pl-5 space-y-3 font-sans text-sm">
          <li><strong>Word Count:</strong> The core length index. Standard essays usually require 1,000 to 2,000 words, while typical SEO articles perform best in the 1,500 to 2,500 range.</li>
          <li><strong>Character Count:</strong> Vital for formatting page metadata (e.g. 60 characters for SEO titles) or copy for social networks (e.g. 280 characters for Twitter).</li>
          <li><strong>Sentence Length:</strong> Long sentences are harder to parse. Keep sentences under 20 words on average to make your writing clear and accessible.</li>
          <li><strong>Paragraph Spacing:</strong> Online readers skim content. Breaking text into small 2–3 sentence paragraphs prevents blocks of text from overwhelming readers.</li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Calculating Reading and Speaking Speed Estimates</h3>
        <p>
          Our word counter uses standard research speeds to estimate content consumption time:
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li><strong>Silent Reading Speed:</strong> The average adult reads silently at about **225 words per minute (WPM)**. Calculating reading time helps set expectations for long-form articles.</li>
          <li><strong>Speaking/Speech Speed:</strong> Reading text aloud averages about **130 words per minute (WPM)**. Speaking calculations are valuable for speechwriters, podcasters, and YouTube script creators.</li>
        </ul>
      
<h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Recommended Word Counts across Industries</h3>
        <p>
          Target word counts vary depending on the medium and publishing requirements. For bloggers and SEO professionals, long-form content (ranging from 1,500 to 2,500 words) tends to rank higher on search engines because it provides a more comprehensive answer to a searcher's query. In contrast, social media platforms require much shorter lengths, often focusing on character limits rather than word counts. Standard college essays typically target 1,000 to 2,000 words, while book manuscripts measure length in tens of thousands of words. Understanding these target ranges helps you structure drafts to match industry expectations.
        </p>
        <p>
          Additionally, tracking text statistics is useful for editing. Keeping an eye on your average sentence length and reading time helps you maintain a clear, engaging tone that fits your target audience.
        </p>
        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Walkthrough: Verifying a Manuscript Draft</h3>
        <p>
          Let's walk through how to use this tool to verify and edit a manuscript draft. Suppose you are preparing an article submission that must be under 800 words.
        </p>
        <p>
          First, copy the plain text of your draft and paste it into the editor. Avoid copying unnecessary headers, references, or footnotes, as they will inflate the word count. Next, check the analysis dashboard to review the total word count, character count, and estimated reading time. If you exceed the limit, use the dashboard to identify long sentences and repetitive phrases to edit down, ensuring your draft is polished and within guidelines.
        </p>
        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Why Word Counting Matters for Kindle Self-Publishing</h3>
        <p>
          For self-published authors formatting books for platforms like Amazon Kindle Direct Publishing (KDP), word counts represent the primary foundation for layout and retail pricing calculations. Unlike print books, reflowable digital Kindle files do not have fixed page layouts. Amazon calculates estimated page numbers using a standardized formula (typically 250 to 300 words per page). Keeping a close eye on your total word count ensures you can accurately project print costs and format paperbacks correctly.
        </p>
        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Balancing Word Count and Readability Scores</h3>
        <p>
          While hitting a target word count is important, it should not come at the expense of content quality. Artificially inflating your word count by adding repetitive phrases or filler words reduces readability and increases user bounce rates. Instead, reach word goals by exploring subtopics in greater detail and using structured bullet points. This keeps your writing clean and engaging while satisfying search engine indexing criteria.
        </p>
      
<h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">The Importance of Clear Writing in Digital Communication</h3>
        <p>
          In today's fast-paced digital environment, clear and concise communication is essential for engaging your audience and conveying your message effectively. Whether you are drafting a blog post, a social media update, an email newsletter, or an academic essay, keeping your text clean, structured, and easy to read improves accessibility and user retention. Use formatting elements like headers and bulleted lists to break up long blocks of text, helping your readers parse key information quickly.
        </p>
      </div>
    </article>

    <!-- FAQ Section -->
    
    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How does the word counter calculate reading time?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            The word counter estimates reading time by dividing the total word count by an average reading speed of 225 words per minute (WPM). This is the standard speed benchmark for adult silent readers.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is speaking time and how is it calculated?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Speaking time estimates how long it takes to read a text aloud, calculated by dividing the total word count by an average speaking speed of 130 words per minute (WPM). This benchmark is ideal for speechwriters and video script creators.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Does this word counter include spaces in the character count?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes, our tool provides two separate character counts: one that counts every single keystroke including spaces, tabs, and line breaks, and another that counts characters excluding spaces to measure pure textual letters.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is keyword density and why does it matter?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Keyword density measures the percentage frequency of a specific word or phrase relative to the total word count. Monitoring keyword density is vital for SEO to ensure target keywords are present without triggering search engine spam filters.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Is my text data stored or shared?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            No, never. Like all tools on ToolzTotal, our word counter runs 100% client-side inside your local browser. None of your text, drafts, or scripts are uploaded to a server or stored.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is the recommended word count for SEO blog articles?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            For search engine optimization, the recommended length is between 1,500 and 2,500 words. Long-form articles provide a more comprehensive answer to search queries, which search engines favor, and naturally contain more relevant keywords.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How does this tool handle hyphenated words and contractions?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            This tool counts hyphenated words (e.g., 'state-of-the-art') as a single word, as they are joined by a hyphen. Contractions (e.g., 'don't', 'it's') are also counted as single words, matching standard word processor conventions.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Why do word counts vary between Google Docs, Word, and online tools?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Different programs use slightly different parsing rules. For example, some tools count hyphenated words, symbols, or numbers as individual words, while others exclude them. This client-side counter uses clean regular expressions to provide consistent results.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is the optimal word length for a standard college essay?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Standard college essays typically range from 1,000 to 2,500 words, depending on the assignment requirements. A 1,000-word essay translates to roughly 4 pages when double-spaced using a standard font.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How many pages is 1,000 words?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            A 1,000-word document is approximately 2 pages when single-spaced, or 4 pages when double-spaced, using standard formatting (1-inch margins, 12pt Times New Roman font).
          </div>
        </details>
      </div>
    </section>

    <!-- Related Tools Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Related Tools">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Text Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/text/character-counter" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Character Counter
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Check specific social platform character limit caps and warnings.</p>
        </a>
        <a href="/text/readability-checker" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Readability Score Checker
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Determine sentence complexity and Flesch grade metrics.</p>
        </a>
        <a href="/text/keyword-density-checker" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Keyword Density Checker
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Scan copy for single and multi-word keyword density tables.</p>
        </a>
      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

  const metricWords = document.getElementById('metric-words') as HTMLSpanElement;
  const metricChars = document.getElementById('metric-chars') as HTMLSpanElement;
  const metricSentences = document.getElementById('metric-sentences') as HTMLSpanElement;
  const metricParagraphs = document.getElementById('metric-paragraphs') as HTMLSpanElement;

  const metricReadTime = document.getElementById('metric-read-time') as HTMLSpanElement;
  const metricSpeakTime = document.getElementById('metric-speak-time') as HTMLSpanElement;
  const metricReadability = document.getElementById('metric-readability') as HTMLSpanElement;

  const densityBox = document.getElementById('density-box') as HTMLDivElement;

  // ============================================================
  // Syllables heuristic function
  // ============================================================
  const getSyllables = (word: string) => {
    word = word.toLowerCase().trim();
    if (word.length <= 3) return 1;
    // Remove silent endings
    word = word.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '');
    word = word.replace(/^y/, '');
    const vowels = word.match(/[aeiouy]{1,2}/g);
    return vowels ? vowels.length : 1;
  };

  // ============================================================
  // Functions
  // ============================================================
  const countText = () => {
    const text = textInput.value;
    
    // Core statistics counts
    const charCount = text.length;
    
    // Split sentences using clean punctuation dividers (. ! ?)
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
    const sentenceCount = sentences.length;

    // Split paragraphs using line breaks
    const paragraphs = text.split(/\n+/).filter(p => p.trim().length > 0);
    const paragraphCount = paragraphs.length;

    // Split words
    const words = text.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?"']/g, "").split(/\s+/).filter(Boolean);
    const wordCount = words.length;

    // Set UI counts
    metricWords.textContent = wordCount.toLocaleString();
    metricChars.textContent = charCount.toLocaleString();
    metricSentences.textContent = sentenceCount.toString();
    metricParagraphs.textContent = paragraphCount.toString();

    // Times Calculation (Reading = 225 WPM, Speaking = 130 WPM)
    const readSeconds = Math.round((wordCount / 225) * 60);
    const speakSeconds = Math.round((wordCount / 130) * 60);

    const formatTime = (sec: number) => {
      if (sec < 60) return `${sec}s`;
      const min = Math.floor(sec / 60);
      const remainingSec = sec % 60;
      return `${min}m ${remainingSec}s`;
    };

    metricReadTime.textContent = formatTime(readSeconds);
    metricSpeakTime.textContent = formatTime(speakSeconds);

    // Flesch Reading Ease Index estimation
    if (wordCount > 0 && sentenceCount > 0) {
      let totalSyllables = 0;
      words.forEach(w => {
        totalSyllables += getSyllables(w);
      });

      const asl = wordCount / sentenceCount;
      const asw = totalSyllables / wordCount;
      const fre = 206.835 - (1.015 * asl) - (84.6 * asw);
      
      metricReadability.textContent = Math.max(0, Math.min(100, fre)).toFixed(1);
    } else {
      metricReadability.textContent = "0.0";
    }

    // Keyword Density breakdown
    calculateKeywordDensity(words);
  };

  const calculateKeywordDensity = (words: string[]) => {
    if (words.length === 0) {
      densityBox.innerHTML = '<p class="text-xs text-mute font-sans">Type text in editor to calculate keyword density.</p>';
      return;
    }

    // Filters common stop words for clean density reporting
    const stopWords = ['the', 'and', 'a', 'of', 'to', 'is', 'in', 'it', 'you', 'that', 'this', 'on', 'for', 'are', 'with', 'as', 'an', 'be', 'at'];
    const filtered = words.filter(w => !stopWords.includes(w) && w.length > 2);

    const freqMap: Record<string, number> = {};
    filtered.forEach(w => {
      freqMap[w] = (freqMap[w] || 0) + 1;
    });

    const sorted = Object.entries(freqMap)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 5);

    if (sorted.length === 0) {
      densityBox.innerHTML = '<p class="text-xs text-mute font-sans">No significant keywords found.</p>';
      return;
    }

    densityBox.innerHTML = '';
    sorted.forEach(([word, count]) => {
      const pct = ((count / words.length) * 100).toFixed(1);
      const row = document.createElement('div');
      row.className = "flex justify-between items-center py-1.5 border-b border-hairline text-xs font-sans";
      row.innerHTML = `
        <span class="font-mono text-ink">${word}</span>
        <span class="text-mute font-mono">${count} times (${pct}%)</span>
      `;
      densityBox.appendChild(row);
    });
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  textInput.addEventListener('input', countText);
  btnClear.addEventListener('click', () => {
    textInput.value = '';
    countText();
  });

  // Initial call
  countText();
</script>
