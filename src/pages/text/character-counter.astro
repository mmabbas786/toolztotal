---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the character limit for Twitter (X)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For free accounts, Twitter (X) limits posts to 280 characters. Paid subscribers of X Premium have extended limits up to 25,000 characters."
      }
    },
    {
      "@type": "Question",
      "name": "How many characters are allowed in Instagram captions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Instagram allows captions up to 2,200 characters. However, captions clip after roughly 125 characters in the user feed, so placing primary calls-to-action early is recommended."
      }
    },
    {
      "@type": "Question",
      "name": "What is the post length limit on LinkedIn?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "LinkedIn allows posts up to 3,000 characters. For personal branding articles or organic updates, keeping text within 1,500 to 2,000 characters yields optimal readable engagement."
      }
    },
    {
      "@type": "Question",
      "name": "Do carriage returns count as characters?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, standard carriage returns (line breaks) are parsed as whitespace characters (represented as \\n or \\r\\n) and count towards total character counts on most web forms and social networks."
      }
    },
    {
      "@type": "Question",
      "name": "Is my text data safe and secure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. This character counter operates 100% client-side inside your browser engine. ToolzTotal never stores, uploads, or logs your drafts."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Character Counter - Free Online Char Limit Checker | ToolzTotal"
  description="Count characters (with & without spaces), words, lines, paragraphs. Live checklists for social limits (Twitter/X, Instagram, LinkedIn)."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/text/character-counter"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/text" class="hover:text-ink transition-colors">Text & Content</a>
      <span>/</span>
      <span class="text-ink">Character Counter</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Character Counter
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Track text length restrictions dynamically. Count characters with or without spaces, lines, and monitor limits for Twitter (X), Instagram, LinkedIn, and Pinterest.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Input Panel (7 cols) -->
      <div class="lg:col-span-7 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <div class="flex items-center justify-between border-b border-hairline pb-3">
          <h2 class="text-lg font-bold text-ink font-sans">Draft Editor</h2>
          <button id="btn-clear" class="text-xs font-mono text-mute hover:text-red-500 cursor-pointer transition-colors">Clear text</button>
        </div>
        
        <!-- Text Area -->
        <div>
          <textarea 
            id="text-input" 
            rows="12"
            placeholder="Start typing to analyze character limits..."
            class="w-full p-4 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 resize-y min-h-[250px]"
          >Crafting optimized social updates requires sticking to strict character limits to prevent truncations.</textarea>
        </div>
      </div>

      <!-- Right Column: Limits and Metrics (5 cols) -->
      <div class="lg:col-span-5 space-y-6">
        
        <!-- Core Counts Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2">Core Metrics</h2>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="p-3 bg-canvas-soft border border-hairline rounded-lg">
              <span class="text-[10px] font-mono text-mute uppercase block mb-1">Chars (With Spaces)</span>
              <span id="metric-chars-space" class="text-2xl font-black text-ink font-sans">0</span>
            </div>
            <div class="p-3 bg-canvas-soft border border-hairline rounded-lg">
              <span class="text-[10px] font-mono text-mute uppercase block mb-1">Chars (No Spaces)</span>
              <span id="metric-chars-nospace" class="text-2xl font-black text-ink font-sans">0</span>
            </div>
            <div class="p-3 bg-canvas-soft border border-hairline rounded-lg">
              <span class="text-[10px] font-mono text-mute uppercase block mb-1">Words</span>
              <span id="metric-words" class="text-2xl font-black text-ink font-sans">0</span>
            </div>
            <div class="p-3 bg-canvas-soft border border-hairline rounded-lg">
              <span class="text-[10px] font-mono text-mute uppercase block mb-1">Lines</span>
              <span id="metric-lines" class="text-2xl font-black text-ink font-sans">0</span>
            </div>
          </div>
        </div>

        <!-- Social Media Limit Checkpoints -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-4">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2">Social Limits Checklist</h2>
          
          <div class="space-y-4">
            <!-- Twitter -->
            <div>
              <div class="flex justify-between text-xs font-mono text-mute mb-1.5">
                <span>TWITTER / X (280 chars)</span>
                <span id="status-tw">280 left</span>
              </div>
              <div class="h-2 w-full bg-canvas-soft-2 rounded-full overflow-hidden shadow-lvl1">
                <div id="bar-tw" class="h-full bg-emerald-500 rounded-full" style="width: 0%;"></div>
              </div>
            </div>

            <!-- Pinterest -->
            <div>
              <div class="flex justify-between text-xs font-mono text-mute mb-1.5">
                <span>PINTEREST DESCRIPTION (500 chars)</span>
                <span id="status-pin">500 left</span>
              </div>
              <div class="h-2 w-full bg-canvas-soft-2 rounded-full overflow-hidden shadow-lvl1">
                <div id="bar-pin" class="h-full bg-emerald-500 rounded-full" style="width: 0%;"></div>
              </div>
            </div>

            <!-- Instagram -->
            <div>
              <div class="flex justify-between text-xs font-mono text-mute mb-1.5">
                <span>INSTAGRAM CAPTION (2200 chars)</span>
                <span id="status-ig">2200 left</span>
              </div>
              <div class="h-2 w-full bg-canvas-soft-2 rounded-full overflow-hidden shadow-lvl1">
                <div id="bar-ig" class="h-full bg-emerald-500 rounded-full" style="width: 0%;"></div>
              </div>
            </div>

            <!-- LinkedIn -->
            <div>
              <div class="flex justify-between text-xs font-mono text-mute mb-1.5">
                <span>LINKEDIN POST (3000 chars)</span>
                <span id="status-li">3000 left</span>
              </div>
              <div class="h-2 w-full bg-canvas-soft-2 rounded-full overflow-hidden shadow-lvl1">
                <div id="bar-li" class="h-full bg-emerald-500 rounded-full" style="width: 0%;"></div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">Optimizing Content for Platform Restrictions: The Strategy of Character Limits</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          In contemporary communications, message length is heavily policed by platform frameworks. Copywriters, community managers, and marketing leaders must shape content tags to fit platform boundaries. If your posts exceed character limits, network APIs reject publication, or interface designs hide your links.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Character Count With vs. Without Spaces</h3>
        <p>
          Understanding how platforms count text length is crucial:
        </p>
        <ul class="list-disc pl-5 space-y-3 font-sans text-sm">
          <li>
            <strong>Counting With Spaces:</strong> Social network databases count every single character, including spacebars, line breaks, and punctuation. If Twitter limits posts to 280 characters, spaces are counted, meaning that concise sentence structures are vital.
          </li>
          <li>
            <strong>Counting Without Spaces:</strong> Removing whitespace measures pure textual volume. Academics and translation professionals use space-free counts to estimate editing fees and word length profiles.
          </li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Key Social Media Limit Benchmarks</h3>
        <p>
          Our character checker monitors these benchmarks in real-time:
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li><strong>Twitter / X (280 characters):</strong> Keeps updates punchy. If you exceed 280 characters, the tweet draft button disables for standard profiles.</li>
          <li><strong>Pinterest Description (500 characters):</strong> Pins need descriptions to rank in Pinterest search. Visual boards clip text after 500 characters.</li>
          <li><strong>Instagram Caption (2,200 characters):</strong> Generous caption limit, but caption text is hidden behind a "more" link after 125 characters, requiring key hooks at the beginning.</li>
          <li><strong>LinkedIn Post (3,000 characters):</strong> Ideal for thought leadership articles. Remaining space updates prevent publishing errors on long updates.</li>
        </ul>
      </div>
    </article>

    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            What is the character limit for Twitter (X)?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            For free accounts, Twitter (X) limits posts to 280 characters. Paid subscribers of X Premium have extended limits up to 25,000 characters.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How many characters are allowed in Instagram captions?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Instagram allows captions up to 2,200 characters. However, captions clip after roughly 125 characters in the user feed, so placing primary calls-to-action early is recommended.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            What is the post length limit on LinkedIn?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            LinkedIn allows posts up to 3,000 characters. For personal branding articles or organic updates, keeping text within 1,500 to 2,000 characters yields optimal readable engagement.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Do carriage returns count as characters?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes, standard carriage returns (line breaks) are parsed as whitespace characters (represented as \n or \\r\\n) and count towards total character counts on most web forms and social networks.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Is my text data safe and secure?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. This character counter operates 100% client-side inside your browser engine. ToolzTotal never stores, uploads, or logs your drafts.
          </div>
        </details>

      </div>
    </section>

    <!-- Related Tools Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Related Tools">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Text Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/text/word-counter" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Word Counter
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Count words, characters, sentences, paragraphs in real-time.</p>
        </a>
        <a href="/text/readability-checker" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Readability Score Checker
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Determine sentence complexity and Flesch grade metrics.</p>
        </a>
        <a href="/text/case-converter" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Case Converter
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Convert text cases including camelCase, snake_case, PascalCase.</p>
        </a>
      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

  const metricCharsSpace = document.getElementById('metric-chars-space') as HTMLSpanElement;
  const metricCharsNoSpace = document.getElementById('metric-chars-nospace') as HTMLSpanElement;
  const metricWords = document.getElementById('metric-words') as HTMLSpanElement;
  const metricLines = document.getElementById('metric-lines') as HTMLSpanElement;

  // Social Limits labels
  const statusTw = document.getElementById('status-tw') as HTMLSpanElement;
  const barTw = document.getElementById('bar-tw') as HTMLDivElement;

  const statusPin = document.getElementById('status-pin') as HTMLSpanElement;
  const barPin = document.getElementById('bar-pin') as HTMLDivElement;

  const statusIg = document.getElementById('status-ig') as HTMLSpanElement;
  const barIg = document.getElementById('bar-ig') as HTMLDivElement;

  const statusLi = document.getElementById('status-li') as HTMLSpanElement;
  const barLi = document.getElementById('bar-li') as HTMLDivElement;

  // ============================================================
  // Functions
  // ============================================================
  const updateCounts = () => {
    const text = textInput.value;
    const lenWithSpace = text.length;

    // Characters without spaces
    const lenNoSpace = text.replace(/\s/g, '').length;

    // Word counts
    const words = text.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?"']/g, "").split(/\s+/).filter(Boolean);
    const wordCount = words.length;

    // Lines count
    const lineCount = text.split(/\n/).length;

    // Set UI metrics
    metricCharsSpace.textContent = lenWithSpace.toLocaleString();
    metricCharsNoSpace.textContent = lenNoSpace.toLocaleString();
    metricWords.textContent = wordCount.toLocaleString();
    metricLines.textContent = lineCount.toString();

    // Evaluate social checklists
    updateLimit(lenWithSpace, 280, statusTw, barTw);
    updateLimit(lenWithSpace, 500, statusPin, barPin);
    updateLimit(lenWithSpace, 2200, statusIg, barIg);
    updateLimit(lenWithSpace, 3000, statusLi, barLi);
  };

  const updateLimit = (current: number, limit: number, status: HTMLSpanElement, bar: HTMLDivElement) => {
    const remaining = limit - current;
    const percent = Math.min(100, (current / limit) * 100);

    bar.style.width = `${percent}%`;

    if (remaining < 0) {
      status.textContent = `${Math.abs(remaining)} over limit`;
      status.className = "text-[10px] font-mono text-red-500 font-semibold";
      bar.className = "h-full bg-red-500 rounded-full";
    } else {
      status.textContent = `${remaining} left`;
      status.className = "text-[10px] font-mono text-mute";
      bar.className = "h-full bg-emerald-500 rounded-full";
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  textInput.addEventListener('input', updateCounts);
  btnClear.addEventListener('click', () => {
    textInput.value = '';
    updateCounts();
  });

  // Initial call
  updateCounts();
</script>
