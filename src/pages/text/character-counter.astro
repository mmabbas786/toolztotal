<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

  const metricCharsSpace = document.getElementById('metric-chars-space') as HTMLSpanElement;
  const metricCharsNoSpace = document.getElementById('metric-chars-nospace') as HTMLSpanElement;
  const metricWords = document.getElementById('metric-words') as HTMLSpanElement;
  const metricLines = document.getElementById('metric-lines') as HTMLSpanElement;

  // Social Limits labels
  const statusTw = document.getElementById('status-tw') as HTMLSpanElement;
  const barTw = document.getElementById('bar-tw') as HTMLDivElement;

  const statusPin = document.getElementById('status-pin') as HTMLSpanElement;
  const barPin = document.getElementById('bar-pin') as HTMLDivElement;

  const statusIg = document.getElementById('status-ig') as HTMLSpanElement;
  const barIg = document.getElementById('bar-ig') as HTMLDivElement;

  const statusLi = document.getElementById('status-li') as HTMLSpanElement;
  const barLi = document.getElementById('bar-li') as HTMLDivElement;

  // ============================================================
  // Functions
  // ============================================================
  const updateCounts = () => {
    const text = textInput.value;
    const lenWithSpace = text.length;

    // Characters without spaces
    const lenNoSpace = text.replace(/\s/g, '').length;

    // Word counts
    const words = text.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?"']/g, "").split(/\s+/).filter(Boolean);
    const wordCount = words.length;

    // Lines count
    const lineCount = text.split(/\n/).length;

    // Set UI metrics
    metricCharsSpace.textContent = lenWithSpace.toLocaleString();
    metricCharsNoSpace.textContent = lenNoSpace.toLocaleString();
    metricWords.textContent = wordCount.toLocaleString();
    metricLines.textContent = lineCount.toString();

    // Evaluate social checklists
    updateLimit(lenWithSpace, 280, statusTw, barTw);
    updateLimit(lenWithSpace, 500, statusPin, barPin);
    updateLimit(lenWithSpace, 2200, statusIg, barIg);
    updateLimit(lenWithSpace, 3000, statusLi, barLi);
  };

  const updateLimit = (current: number, limit: number, status: HTMLSpanElement, bar: HTMLDivElement) => {
    const remaining = limit - current;
    const percent = Math.min(100, (current / limit) * 100);

    bar.style.width = `${percent}%`;

    if (remaining < 0) {
      status.textContent = `${Math.abs(remaining)} over limit`;
      status.className = "text-[10px] font-mono text-red-500 font-semibold";
      bar.className = "h-full bg-red-500 rounded-full";
    } else {
      status.textContent = `${remaining} left`;
      status.className = "text-[10px] font-mono text-mute";
      bar.className = "h-full bg-emerald-500 rounded-full";
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  textInput.addEventListener('input', updateCounts);
  btnClear.addEventListener('click', () => {
    textInput.value = '';
    updateCounts();
  });

  // Initial call
  updateCounts();
</script>
