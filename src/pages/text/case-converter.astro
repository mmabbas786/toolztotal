        </a>
      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

  const btnLower = document.getElementById('btn-lower') as HTMLButtonElement;
  const btnUpper = document.getElementById('btn-upper') as HTMLButtonElement;
  const btnSentence = document.getElementById('btn-sentence') as HTMLButtonElement;
  const btnTitle = document.getElementById('btn-title') as HTMLButtonElement;

  const btnCamel = document.getElementById('btn-camel') as HTMLButtonElement;
  const btnPascal = document.getElementById('btn-pascal') as HTMLButtonElement;
  const btnSnake = document.getElementById('btn-snake') as HTMLButtonElement;
  const btnKebab = document.getElementById('btn-kebab') as HTMLButtonElement;
  const btnScreaming = document.getElementById('btn-screaming') as HTMLButtonElement;

  const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;

  // ============================================================
  // Split words helper
  // ============================================================
  const splitWords = (text: string) => {
    return text.replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?"']/g, " ").split(/\s+/).filter(Boolean);
  };

  // ============================================================
  // Conversions
  // ============================================================
  const transform = (type: string) => {
    const text = textInput.value;
    if (!text.trim()) return;

    let res = "";

    switch(type) {
      case 'lower':
        res = text.toLowerCase();
        break;
      case 'upper':
        res = text.toUpperCase();
        break;
      case 'sentence':
        // Capitalize first letter of sentences
        res = text.toLowerCase().replace(/(^\s*|[.!?]\s+)([a-z])/g, (m, g1, g2) => g1 + g2.toUpperCase());
        break;
      case 'title':
        // Capitalize first letter of every word
        res = text.toLowerCase().replace(/\b([a-z])/g, m => m.toUpperCase());
        break;
      case 'camel':
        {
          const words = splitWords(text);
          res = words.map((w, idx) => idx === 0 ? w.toLowerCase() : w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join('');
        }
        break;
      case 'pascal':
        {
          const words = splitWords(text);
          res = words.map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join('');
        }
        break;
      case 'snake':
        {
          const words = splitWords(text);
          res = words.map(w => w.toLowerCase()).join('_');
        }
        break;
      case 'kebab':
        {
          const words = splitWords(text);
          res = words.map(w => w.toLowerCase()).join('-');
        }
        break;
      case 'screaming':
        {
          const words = splitWords(text);
          res = words.map(w => w.toUpperCase()).join('_');
        }
        break;
    }

    textInput.value = res;
  };

  const copyText = () => {
    const val = textInput.value;
    if (val) {
      navigator.clipboard.writeText(val).then(() => {
        const oldHtml = btnCopy.innerHTML;
        btnCopy.innerHTML = `
          <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Text Copied!
        `;
        setTimeout(() => {
          btnCopy.innerHTML = oldHtml;
        }, 1500);
      });
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnLower.addEventListener('click', () => transform('lower'));
  btnUpper.addEventListener('click', () => transform('upper'));
  btnSentence.addEventListener('click', () => transform('sentence'));
  btnTitle.addEventListener('click', () => transform('title'));

  btnCamel.addEventListener('click', () => transform('camel'));
  btnPascal.addEventListener('click', () => transform('pascal'));
  btnSnake.addEventListener('click', () => transform('snake'));
  btnKebab.addEventListener('click', () => transform('kebab'));
  btnScreaming.addEventListener('click', () => transform('screaming'));

  btnCopy.addEventListener('click', copyText);
  btnClear.addEventListener('click', () => textInput.value = '');
</script>
