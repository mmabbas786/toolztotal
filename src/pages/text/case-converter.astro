            <button id="btn-camel" class="h-9 border border-hairline bg-canvas hover:border-hairline-strong text-body rounded-lg font-sans text-xs transition-colors cursor-pointer shadow-lvl1">camelCase</button>
            <button id="btn-pascal" class="h-9 border border-hairline bg-canvas hover:border-hairline-strong text-body rounded-lg font-sans text-xs transition-colors cursor-pointer shadow-lvl1">PascalCase</button>
