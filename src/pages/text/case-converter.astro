---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is camelCase and where is it used?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "camelCase is a casing convention where words are joined without spaces, and each word starts with a capital letter except for the first word (e.g. 'myVariableName'). It is widely used in languages like JavaScript, Java, and C++ for variable and function names."
      }
    },
    {
      "@type": "Question",
      "name": "What is snake_case and where is it preferred?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "snake_case joins words together using underscores instead of spaces, with all letters in lowercase (e.g. 'my_variable_name'). It is the standard naming convention for variables, functions, and files in Python and Rust, as well as database keys."
      }
    },
    {
      "@type": "Question",
      "name": "How does kebab-case differ from snake_case?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "kebab-case replaces spaces with hyphens instead of underscores (e.g. 'my-style-class'). It is commonly used in CSS class naming, HTML tags, and URL slugs because search engines parse hyphens as word delimiters."
      }
    },
    {
      "@type": "Question",
      "name": "What is PascalCase and when should I use it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PascalCase is similar to camelCase, but the first letter of the first word is capitalized (e.g. 'MyClassName'). It is the standard naming convention for class names and component identifiers in modern programming frameworks."
      }
    },
    {
      "@type": "Question",
      "name": "How is my text conversion privacy maintained?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All case conversions are processed instantly client-side using JavaScript in your browser. None of your text, code snippets, or configuration structures are uploaded to a server."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Case Converter - Convert camelCase, snake_case & kebab-case | ToolzTotal"
  description="Convert text casing between Sentence case, UPPERCASE, lowercase, camelCase, PascalCase, snake_case, kebab-case, and SCREAMING_SNAKE_CASE."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/text/case-converter"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/text" class="hover:text-ink transition-colors">Text & Content</a>
      <span>/</span>
      <span class="text-ink">Case Converter</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
