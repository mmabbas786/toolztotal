---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between APA, MLA, and Chicago citation styles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "APA (American Psychological Association) is used in the social sciences and education. MLA (Modern Language Association) is standard in the humanities and literature. Chicago style is widely preferred in history and fine arts, offering both footnotes and author-date reference options."
      }
    },
    {
      "@type": "Question",
      "name": "Does this generator support automatic ISBN or DOI lookups?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. To remain a lightweight, privacy-first, 100% static site, this citation generator supports manual metadata entry only, bypassing external API network calls."
      }
    },
    {
      "@type": "Question",
      "name": "How is an APA 7th edition book citation formatted?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In APA 7, a book is formatted as: Lastname, F. M. (Year). Title. Publisher. URL (if electronic). The title is italicized and formatted in sentence case."
      }
    },
    {
      "@type": "Question",
      "name": "How is an MLA 9th edition book citation formatted?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In MLA 9, a book is formatted as: Lastname, Firstname. Title. Publisher, Year. The title is italicized and formatted in title case."
      }
    },
    {
      "@type": "Question",
      "name": "Is my research data stored on ToolzTotal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Like all tools on our site, this citation builder operates completely client-side in your browser. None of your entry fields, research titles, or generated references are uploaded to a server."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Citation Generator - Free APA, MLA & Chicago Formatter | ToolzTotal"
  description="Generate accurate citations in APA 7th, MLA 9th, and Chicago 17th formats instantly. Manual entry only with instant copy."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/education/citation-generator"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/education" class="hover:text-ink transition-colors">Education</a>
      <span>/</span>
      <span class="text-ink">Citation Generator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Citation Generator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Generate bibliographies and references manually. Supports APA 7th, MLA 9th, and Chicago 17th formatting styles. Copy output directly to your document.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Manual Entry Inputs (6 cols) -->
      <div class="lg:col-span-6 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Book/Source Metadata</h2>
        
        <!-- Title -->
        <div>
          <label for="source-title" class="block text-xs font-mono uppercase text-mute mb-2">Book / Source Title *</label>
          <input 
            type="text" 
            id="source-title" 
            placeholder="e.g. The Great Gatsby"
            value="The Great Gatsby"
            class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
          />
        </div>

        <!-- Author Name -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="author-first" class="block text-xs font-mono uppercase text-mute mb-2">Author First Name</label>
            <input 
              type="text" 
              id="author-first" 
              placeholder="e.g. F. Scott"
              value="F. Scott"
              class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
          </div>
          <div>
            <label for="author-last" class="block text-xs font-mono uppercase text-mute mb-2">Author Last Name *</label>
            <input 
              type="text" 
              id="author-last" 
              placeholder="e.g. Fitzgerald"
              value="Fitzgerald"
              class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
          </div>
        </div>

        <!-- Publisher & Year -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="publisher" class="block text-xs font-mono uppercase text-mute mb-2">Publisher *</label>
            <input 
              type="text" 
              id="publisher" 
              placeholder="e.g. Charles Scribner's Sons"
              value="Charles Scribner's Sons"
              class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
          </div>
          <div>
            <label for="pub-year" class="block text-xs font-mono uppercase text-mute mb-2">Publication Year *</label>
            <input 
              type="number" 
              id="pub-year" 
              placeholder="e.g. 1925"
              value="1925"
              class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
            />
          </div>
        </div>

        <!-- Optional fields details -->
        <details class="group border border-hairline rounded-lg bg-canvas-soft overflow-hidden">
          <summary class="px-4 py-3 cursor-pointer text-xs font-mono uppercase text-body hover:text-ink transition-colors select-none flex items-center justify-between list-none">
            <span>Optional Info (City & URL)</span>
            <svg class="w-4 h-4 text-mute transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="p-4 border-t border-hairline bg-canvas space-y-4">
            <div>
              <label for="pub-city" class="block text-xs font-mono uppercase text-mute mb-2">Publication City (Chicago Style)</label>
              <input 
                type="text" 
                id="pub-city" 
                placeholder="e.g. New York"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
              />
            </div>
            <div>
              <label for="source-url" class="block text-xs font-mono uppercase text-mute mb-2">Source URL</label>
              <input 
                type="url" 
                id="source-url" 
                placeholder="e.g. https://example.com"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
              />
            </div>
          </div>
        </details>
      </div>

      <!-- Right Column: Citation Output (6 cols) -->
      <div class="lg:col-span-6 space-y-6">
        
        <!-- Output Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Formatted Citation</h2>
          
          <!-- Format Tabs -->
          <div class="flex gap-2 border-b border-hairline pb-3">
            <button id="tab-cit-apa" class="px-4 py-1.5 text-xs font-mono border-b-2 border-primary font-semibold text-ink cursor-pointer">APA 7th</button>
            <button id="tab-cit-mla" class="px-4 py-1.5 text-xs font-mono text-mute hover:text-ink cursor-pointer">MLA 9th</button>
            <button id="tab-cit-chicago" class="px-4 py-1.5 text-xs font-mono text-mute hover:text-ink cursor-pointer">Chicago 17th</button>
          </div>

          <!-- Citation text preview box -->
          <div class="relative bg-canvas-soft border border-hairline rounded-lg p-5 min-h-24 shadow-lvl1">
            <div id="citation-result" class="text-sm font-sans text-ink leading-relaxed break-words select-all pr-12">
              Generating citation...
            </div>
            
            <button 
              id="btn-copy-citation" 
              title="Copy Citation"
              class="absolute right-3 top-3 w-8 h-8 rounded border border-hairline bg-canvas hover:border-hairline-strong text-mute hover:text-ink transition-colors flex items-center justify-center cursor-pointer shadow-lvl1"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-5 4h6m-6 4h6m-2 4h4" />
              </svg>
            </button>
          </div>
        </div>

      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">Academic References: Formatting Styles of APA, MLA, and Chicago</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          Citing references is a cornerstone of academic writing. Properly acknowledging sources is essential for upholding research integrity, allowing readers to trace study origins, and avoiding plagiarism. However, academic organizations enforce differing citation conventions.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Comparing standard Citation Styles</h3>
        <ul class="list-disc pl-5 space-y-3 font-sans text-sm">
          <li>
            <strong>APA 7th Edition (Social Sciences):</strong> Developed by the American Psychological Association, APA style places strong emphasis on the publication year to highlight the timeline of research. The title is written in sentence case and italicized:
            <br />
            <em class="block text-mute font-mono text-xs my-2">Lastname, F. M. (Year). Title of book. Publisher.</em>
          </li>
          <li>
            <strong>MLA 9th Edition (Humanities & Literature):</strong> Created by the Modern Language Association, MLA prioritizes formatting consistency for literary analysis. The author's full name is listed, and the title is capitalized in title case and italicized:
            <br />
            <em class="block text-mute font-mono text-xs my-2">Lastname, Firstname. Title of Book. Publisher, Year.</em>
          </li>
          <li>
            <strong>Chicago 17th Edition (History & Fine Arts):</strong> Preferred in historical sciences. The format includes publication city details and structures citations as:
            <br />
            <em class="block text-mute font-mono text-xs my-2">Lastname, Firstname. Title of Book. City: Publisher, Year.</em>
          </li>
        </ul>
      </div>
    </article>

    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            What is the difference between APA, MLA, and Chicago citation styles?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            APA (American Psychological Association) is used in the social sciences and education. MLA (Modern Language Association) is standard in the humanities and literature. Chicago style is widely preferred in history and fine arts, offering both footnotes and author-date reference options.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Does this generator support automatic ISBN or DOI lookups?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            No. To remain a lightweight, privacy-first, 100% static site, this citation generator supports manual metadata entry only, bypassing external API network calls.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How is an APA 7th edition book citation formatted?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            In APA 7, a book is formatted as: Lastname, F. M. (Year). Title. Publisher. URL (if electronic). The title is italicized and formatted in sentence case.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How is an MLA 9th edition book citation formatted?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            In MLA 9, a book is formatted as: Lastname, Firstname. Title. Publisher, Year. The title is italicized and formatted in title case.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Is my research data stored on ToolzTotal?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            No. Like all tools on our site, this citation builder operates completely client-side in your browser. None of your entry fields, research titles, or generated references are uploaded to a server.
          </div>
        </details>

      </div>
    </section>

    <!-- Related Tools Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Related Tools">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Educational Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/education/gpa-calculator" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            GPA Calculator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Calculate semester and weighted GPA across multiple scales.</p>
        </a>
        <a href="/education/final-grade-calculator" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Final Grade Calculator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Solve what grade you need on your final exam to pass.</p>
        </a>
        <a href="/education/grade-calculator" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Grade Calculator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Calculate weighted averages for class syllabus categories.</p>
        </a>
      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const sourceTitleIn = document.getElementById('source-title') as HTMLInputElement;
  const authorFirstIn = document.getElementById('author-first') as HTMLInputElement;
  const authorLastIn = document.getElementById('author-last') as HTMLInputElement;
  const publisherIn = document.getElementById('publisher') as HTMLInputElement;
  const pubYearIn = document.getElementById('pub-year') as HTMLInputElement;
  const pubCityIn = document.getElementById('pub-city') as HTMLInputElement;
  const sourceUrlIn = document.getElementById('source-url') as HTMLInputElement;

  const tabApa = document.getElementById('tab-cit-apa') as HTMLButtonElement;
  const tabMla = document.getElementById('tab-cit-mla') as HTMLButtonElement;
  const tabChicago = document.getElementById('tab-cit-chicago') as HTMLButtonElement;

  const citationResult = document.getElementById('citation-result') as HTMLDivElement;
  const btnCopyCitation = document.getElementById('btn-copy-citation') as HTMLButtonElement;

  // ============================================================
  // State
  // ============================================================
  let activeStyle: 'apa' | 'mla' | 'chicago' = 'apa';

  // ============================================================
  // Functions
  // ============================================================
  const generateCitation = () => {
    const title = sourceTitleIn.value.trim();
    const first = authorFirstIn.value.trim();
    const last = authorLastIn.value.trim();
    const publisher = publisherIn.value.trim();
    const year = pubYearIn.value.trim();
    const city = pubCityIn.value.trim();
    const url = sourceUrlIn.value.trim();

    if (!title || !last || !publisher || !year) {
      citationResult.textContent = "Please fill in all required fields marked with * to generate a citation.";
      return;
    }

    // Format author names
    let authorText = last;
    if (first) {
      if (activeStyle === 'apa') {
        // Initials only for APA (e.g. Fitzgerald, F. S.)
        const initials = first.split(/\s+/).map(n => n.charAt(0) + '.').join(' ');
        authorText = `${last}, ${initials}`;
      } else {
        // Full first name for MLA and Chicago
        authorText = `${last}, ${first}`;
      }
    }

    let citationHtml = "";

    if (activeStyle === 'apa') {
      // APA: Lastname, F. M. (Year). Title of book. Publisher. URL
      citationHtml = `${authorText} (${year}). <span class="italic">${title}</span>. ${publisher}.`;
      if (url) {
        citationHtml += ` <a href="${url}" class="text-primary hover:underline break-all" target="_blank">${url}</a>`;
      }
    } else if (activeStyle === 'mla') {
      // MLA: Lastname, Firstname. Title of Book. Publisher, Year. URL
      citationHtml = `${authorText}. <span class="italic">${title}</span>. ${publisher}, ${year}.`;
      if (url) {
        citationHtml += ` <a href="${url}" class="text-primary hover:underline break-all" target="_blank">${url}</a>`;
      }
    } else {
      // Chicago: Lastname, Firstname. Title of Book. City: Publisher, Year. URL
      const cityText = city ? `${city}: ` : "";
      citationHtml = `${authorText}. <span class="italic">${title}</span>. ${cityText}${publisher}, ${year}.`;
      if (url) {
        citationHtml += ` <a href="${url}" class="text-primary hover:underline break-all" target="_blank">${url}</a>`;
      }
    }

    citationResult.innerHTML = citationHtml;
  };

  const handleTabClick = (style: 'apa' | 'mla' | 'chicago') => {
    activeStyle = style;
    [tabApa, tabMla, tabChicago].forEach(b => {
      b.classList.remove('border-b-2', 'border-primary', 'font-semibold', 'text-ink');
      b.classList.add('text-mute');
    });

    const activeBtn = style === 'apa' ? tabApa : style === 'mla' ? tabMla : tabChicago;
    activeBtn.classList.add('border-b-2', 'border-primary', 'font-semibold', 'text-ink');
    activeBtn.classList.remove('text-mute');

    generateCitation();
  };

  const copyCitation = () => {
    // Extract text content only (stripping HTML tags like <span> or <a>)
    const text = citationResult.textContent || "";
    if (text && !text.startsWith("Please")) {
      navigator.clipboard.writeText(text).then(() => {
        const oldHtml = btnCopyCitation.innerHTML;
        btnCopyCitation.innerHTML = `
          <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        `;
        setTimeout(() => {
          btnCopyCitation.innerHTML = oldHtml;
        }, 1500);
      });
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  [sourceTitleIn, authorFirstIn, authorLastIn, publisherIn, pubYearIn, pubCityIn, sourceUrlIn].forEach(inp => {
    inp.addEventListener('input', generateCitation);
  });

  tabApa.addEventListener('click', () => handleTabClick('apa'));
  tabMla.addEventListener('click', () => handleTabClick('mla'));
  tabChicago.addEventListener('click', () => handleTabClick('chicago'));

  btnCopyCitation.addEventListener('click', copyCitation);

  // Initial render
  generateCitation();
</script>
