          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Citation Generator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Create bibliographies in APA, MLA, and Chicago styles.</p>
        </a>
      </div>
    </section>

  </div>

    <RelatedTools
      categorySlug="education"
      toolSlug="grade-calculator"
    />

  <ContentFooter category="education" />
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const btnAddCategory = document.getElementById('btn-add-category') as HTMLButtonElement;
  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;
  const btnPrint = document.getElementById('btn-print') as HTMLButtonElement;
  const categoriesContainer = document.getElementById('categories-container') as HTMLDivElement;

  const resWeightedGrade = document.getElementById('res-weighted-grade') as HTMLSpanElement;
  const resGradeLetter = document.getElementById('res-grade-letter') as HTMLSpanElement;
  const resTotalWeights = document.getElementById('res-total-weights') as HTMLSpanElement;

  const weightWarning = document.getElementById('weight-warning') as HTMLDivElement;
  const warningTotalWeight = document.getElementById('warning-total-weight') as HTMLSpanElement;

  // ============================================================
  // Functions
  // ============================================================
  const addCategoryRow = (name = "", weight = 20, score = 90) => {
    const id = 'cat-' + Date.now() + Math.random().toString(36).substr(2, 5);
    const row = document.createElement('div');
    row.id = id;
    row.className = "category-row grid grid-cols-12 gap-3 items-center p-3 bg-canvas-soft border border-hairline rounded-lg shadow-lvl1";
    
    row.innerHTML = `
      <!-- Category Name -->
      <div class="col-span-5">
        <input 
          type="text" 
          placeholder="e.g. Homework, Exams" 
          value="${name}"
          class="cat-name w-full h-8 px-2 bg-canvas border border-hairline rounded text-xs focus:outline-none focus:border-hairline-strong text-ink shadow-lvl1"
        />
      </div>

      <!-- Category Weight (%) -->
      <div class="col-span-3">
        <input 
          type="number" 
          placeholder="Weight (%)" 
          value="${weight}"
          min="0"
          max="100"
          class="cat-weight w-full h-8 px-2 bg-canvas border border-hairline rounded text-xs focus:outline-none focus:border-hairline-strong text-ink shadow-lvl1"
        />
      </div>

      <!-- Category Score (%) -->
      <div class="col-span-3">
        <input 
          type="number" 
          placeholder="Score (%)" 
          value="${score}"
          min="0"
          max="150"
          class="cat-score w-full h-8 px-2 bg-canvas border border-hairline rounded text-xs focus:outline-none focus:border-hairline-strong text-ink shadow-lvl1"
        />
      </div>

      <!-- Delete Button -->
      <div class="col-span-1 text-right">
        <button class="btn-delete text-mute hover:text-red-500 text-sm font-bold cursor-pointer transition-colors print:hidden">&times;</button>
      </div>
    `;

    // Hook listeners
    row.querySelector('.cat-weight')?.addEventListener('input', calculateGrades);
    row.querySelector('.cat-score')?.addEventListener('input', calculateGrades);
    row.querySelector('.btn-delete')?.addEventListener('click', () => {
      row.remove();
      calculateGrades();
    });

    categoriesContainer.appendChild(row);
  };

  const calculateGrades = () => {
    const rows = categoriesContainer.querySelectorAll('.category-row');
    
    let totalWeight = 0;
    let totalWeightedScore = 0;

    rows.forEach(row => {
      const weightIn = row.querySelector('.cat-weight') as HTMLInputElement;
      const scoreIn = row.querySelector('.cat-score') as HTMLInputElement;

      const weight = parseFloat(weightIn.value) || 0;
      const score = parseFloat(scoreIn.value) || 0;

      if (weight <= 0) return;

      totalWeight += weight;
      totalWeightedScore += score * (weight / 100);
    });

    resTotalWeights.textContent = totalWeight + "%";

    let finalGrade = 0;

    if (totalWeight > 0) {
      // Normalization check if weight != 100%
      // Normalized Grade = [Sum of (Score * Weight)] / Total Weight
      finalGrade = (totalWeightedScore / (totalWeight / 100));
      resWeightedGrade.textContent = finalGrade.toFixed(1) + "%";

      // Class Letter grade mapping
      let letter = "F";
      if (finalGrade >= 97) letter = "A+";
      else if (finalGrade >= 93) letter = "A";
      else if (finalGrade >= 90) letter = "A-";
      else if (finalGrade >= 87) letter = "B+";
      else if (finalGrade >= 83) letter = "B";
      else if (finalGrade >= 80) letter = "B-";
      else if (finalGrade >= 77) letter = "C+";
      else if (finalGrade >= 73) letter = "C";
      else if (finalGrade >= 70) letter = "C-";
      else if (finalGrade >= 67) letter = "D+";
      else if (finalGrade >= 60) letter = "D";
      else letter = "F";
      
      resGradeLetter.textContent = `Letter Grade: ${letter}`;
    } else {
      resWeightedGrade.textContent = "0.0%";
      resGradeLetter.textContent = "N/A";
    }

    // Toggle weights warnings
    if (totalWeight > 0 && totalWeight !== 100) {
      weightWarning.classList.remove('hidden');
      warningTotalWeight.textContent = totalWeight + "%";
    } else {
      weightWarning.classList.add('hidden');
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnAddCategory.addEventListener('click', () => addCategoryRow("", 20, 90));
  
  btnReset.addEventListener('click', () => {
    categoriesContainer.innerHTML = '';
    // Seed default rows
    addCategoryRow("Homework", 20, 95);
    addCategoryRow("Quizzes", 30, 85);
    addCategoryRow("Exams", 50, 80);
    calculateGrades();
  });

  btnPrint.addEventListener('click', () => {
    window.print();
  });

  // Seed default categories
  addCategoryRow("Homework", 20, 95);
  addCategoryRow("Quizzes", 30, 85);
  addCategoryRow("Exams", 50, 80);

  // Initial Calculation
  calculateGrades();
</script>
