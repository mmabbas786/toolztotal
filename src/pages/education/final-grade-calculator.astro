---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How is the final exam grade requirement calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The final grade requirement is solved using basic algebra: Required Grade = [Target - Current * (1 - Weight)] / Weight. All weights and grade values are parsed as percentages."
      }
    },
    {
      "@type": "Question",
      "name": "What does a required final exam grade over 100% mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If the solver outputs a required grade exceeding 100%, it means it is mathematically impossible to reach your target grade with standard scores. You would need extra credit assignments or a curve on the final exam."
      }
    },
    {
      "@type": "Question",
      "name": "How does final exam weight affect grade stability?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The higher the weight of the final exam, the more volatile your final grade will be. An exam weighted 30% has triple the impact on your final score compared to an exam weighted 10%, meaning that small drops in your final score can significantly shift your class grade."
      }
    },
    {
      "@type": "Question",
      "name": "Can I calculate my class grade without a final exam?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. If your course does not have a final exam, you can set the final exam weight to 0%. This will make your current grade equal to your final grade."
      }
    },
    {
      "@type": "Question",
      "name": "Is my academic information private?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, completely. Like all tools on ToolzTotal, our final grade calculator operates entirely in your local browser sandbox. None of your coursework, current grades, or targets are uploaded to a server."
      }
    },
    {
      "@type": "Question",
      "name": "What is the formula for final grade calculations?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The final grade formula is: Required Exam Score = [Target Grade - (Current Grade &times; (1 - Exam Weight))] / Exam Weight, where weights are represented as decimals (e.g., 20% becomes 0.20)."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate my final grade if my syllabus uses points instead of weights?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For points-based systems, add the points you have earned to your estimated exam points, and divide by the total points possible in the course: Final Grade = (Points Earned + Exam Points) / Total Possible Points."
      }
    },
    {
      "@type": "Question",
      "name": "What exam score do I need if I have a borderline grade?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If you have a borderline grade (e.g., 89.5% aiming for an A), use this calculator to find the exact exam score required. A small change in your final exam performance can push you over the threshold."
      }
    },
    {
      "@type": "Question",
      "name": "How does a zero on a homework assignment affect my overall grade?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A zero affects your grade based on the category's weight. If homework is weighted at 10% of your grade and you miss one assignment out of ten, it will lower your overall course grade by roughly 1%, which is minor but cumulative."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between weighted grades and straight points?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Weighted grades calculate your average by grouping assignments into categories that contribute a set percentage to your final grade. Straight points systems sum all points earned and divide by total points possible, treating all points equally."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
