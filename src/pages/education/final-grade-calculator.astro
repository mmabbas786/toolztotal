  // DOM Elements
  // ============================================================
  const currentGradeIn = document.getElementById('current-grade') as HTMLInputElement;
  const targetGradeIn = document.getElementById('target-grade') as HTMLInputElement;
  const finalWeightIn = document.getElementById('final-weight') as HTMLInputElement;

  const resultBox = document.getElementById('result-box') as HTMLDivElement;
  const resFinalNeeded = document.getElementById('res-final-needed') as HTMLSpanElement;
  const resStatusMsg = document.getElementById('res-status-msg') as HTMLParagraphElement;

  // ============================================================
  // Functions
  // ============================================================
  const calculateFinalRequirement = () => {
    const current = parseFloat(currentGradeIn.value) || 0;
    const target = parseFloat(targetGradeIn.value) || 0;
    const weight = (parseFloat(finalWeightIn.value) || 0) / 100;

    if (weight <= 0) {
      resFinalNeeded.textContent = "N/A";
      resStatusMsg.textContent = "Please enter a final exam weight greater than 0%.";
      resultBox.className = "p-6 border border-hairline rounded-lg text-center space-y-2 bg-canvas shadow-lvl1";
      return;
    }

    // Solve algebraic: Target = Current * (1 - Weight) + Final * Weight
    // Final = [Target - Current * (1 - Weight)] / Weight
    const needed = (target - current * (1 - weight)) / weight;
    resFinalNeeded.textContent = needed.toFixed(1) + "%";

    // Style card and set status messages based on difficulty threshold
    if (needed > 100) {
      resultBox.className = "p-6 border border-red-500/20 rounded-lg text-center space-y-2 bg-red-500/5 shadow-lvl1";
      resFinalNeeded.className = "text-4xl md:text-5xl font-black text-red-500 font-sans block";
      resStatusMsg.textContent = `⚠️ You need over 100% on the final to reach a ${target}%. Extra credit assignments or a curved exam are required.`;
    } else if (needed >= 90) {
      resultBox.className = "p-6 border border-yellow-500/20 rounded-lg text-center space-y-2 bg-yellow-500/5 shadow-lvl1";
      resFinalNeeded.className = "text-4xl md:text-5xl font-black text-yellow-600 dark:text-yellow-500 font-sans block";
      resStatusMsg.textContent = `🎯 You need a strong score of ${needed.toFixed(1)}% to reach your target. Study hard!`;
    } else if (needed <= 0) {
      resultBox.className = "p-6 border border-emerald-500/20 rounded-lg text-center space-y-2 bg-emerald-500/5 shadow-lvl1";
      resFinalNeeded.className = "text-4xl md:text-5xl font-black text-emerald-500 font-sans block";
      resFinalNeeded.textContent = "0.0%";
      resStatusMsg.textContent = `🎉 You have already secured your target grade! You don't need any points on the final to get a ${target}%.`;
    } else {
      resultBox.className = "p-6 border border-emerald-500/20 rounded-lg text-center space-y-2 bg-emerald-500/5 shadow-lvl1";
      resFinalNeeded.className = "text-4xl md:text-5xl font-black text-emerald-500 font-sans block";
      resStatusMsg.textContent = `👍 Achieving a ${needed.toFixed(1)}% is highly feasible. Review your notes and you should be fine.`;
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  [currentGradeIn, targetGradeIn, finalWeightIn].forEach(inp => {
    inp.addEventListener('input', calculateFinalRequirement);
  });

  // Initial Calculation
  calculateFinalRequirement();
</script>
