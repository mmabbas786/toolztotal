    <div class="w-full mb-6 flex flex-wrap items-center gap-2 px-4 py-2.5 bg-canvas ring-1 ring-inset ring-hairline rounded-xl shadow-lvl3">
      <div class="inline-flex rounded-lg bg-canvas-soft p-0.5 ring-1 ring-inset ring-hairline shadow-lvl1">
        <button type="button" id="action-format" class="action-btn px-3 py-1.5 text-xs font-mono rounded-md bg-primary text-on-primary shadow-lvl1 cursor-pointer">Beautify</button>
