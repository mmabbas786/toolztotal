  <!-- Client Script -->
  <script>
    // ---- DOM refs ----
    const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
    const outputArea = document.getElementById('output-area') as HTMLDivElement;
    const inputStatus = document.getElementById('input-status') as HTMLSpanElement;
    const outputStatus = document.getElementById('output-status') as HTMLSpanElement;
    const charCount = document.getElementById('char-count') as HTMLSpanElement;
    const lineNumbers = document.getElementById('line-numbers') as HTMLDivElement;
    const lineNumsInner = document.getElementById('line-nums-inner') as HTMLDivElement;

    const actionFormat = document.getElementById('action-format') as HTMLButtonElement;
    const actionMinify = document.getElementById('action-minify') as HTMLButtonElement;
    const actionValidate = document.getElementById('action-validate') as HTMLButtonElement;

    const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;
    const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;
    const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

    const treeToggle = document.getElementById('tree-toggle') as HTMLButtonElement;
    const treeChevron = document.getElementById('tree-chevron') as SVGElement;
    const treeContainer = document.getElementById('tree-container') as HTMLDivElement;
    const treeRoot = document.getElementById('tree-root') as HTMLDivElement;

    const schemaToggle = document.getElementById('schema-toggle') as HTMLButtonElement;
    const schemaChevron = document.getElementById('schema-chevron') as SVGElement;
    const schemaContainer = document.getElementById('schema-container') as HTMLDivElement;
    const schemaInput = document.getElementById('schema-input') as HTMLTextAreaElement;
    const schemaResult = document.getElementById('schema-result') as HTMLDivElement;
    const btnValidateSchema = document.getElementById('btn-validate-schema') as HTMLButtonElement;

    const actionBtns = document.querySelectorAll('.action-btn') as NodeListOf<HTMLButtonElement>;

    // ---- state ----
    let currentAction: 'format' | 'minify' | 'validate' = 'format';

    // ---- helpers ----
    function setActiveAction(active: HTMLButtonElement) {
      actionBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl1');
        b.classList.add('text-mute');
      });
      active.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl1');
      active.classList.remove('text-mute');
    }

    function getActionName(btn: HTMLButtonElement): 'format' | 'minify' | 'validate' {
      if (btn === actionFormat) return 'format';
      if (btn === actionMinify) return 'minify';
      return 'validate';
    }

    function updateLineNumbers(text: string) {
      const lines = text.split('\n');
      const count = lines.length;
      let html = '';
      for (let i = 1; i <= count; i++) {
        html += i + '\n';
      }
      lineNumsInner.textContent = html;
    }

    function countChars(text: string) {
      charCount.textContent = `${text.length} char${text.length !== 1 ? 's' : ''}`;
    }

    // ---- syntax highlighting ----
    function highlightJSON(json: string): string {
      return json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"([^"\\]*(\\.[^"\\]*)*)"(?=\s*:)/g, '<span class="json-key">"$1"</span>')
        .replace(/:(\s*)"([^"\\]*(\\.[^"\\]*)*)"/g, ':<span class="json-string">"$2"</span>')
        .replace(/:(\s*)(true|false)/g, ':<span class="json-bool">$2</span>')
        .replace(/:(\s*)null/g, ':<span class="json-null">null</span>')
        .replace(/:(\s*)(-?\d+(?:\.\d+)?(?:[eE][+-]?\d+)?)/g, ':<span class="json-num">$2</span>')
        .replace(/([{}\[\]])/g, '<span class="json-brace">$1</span>');
    }

    // ---- tree view ----
    function buildTree(value: unknown, indent: number = 0): string {
      const pad = '  '.repeat(indent);
      if (value === null) return `<span class="json-null">null</span>`;
      if (typeof value === 'boolean') return `<span class="json-bool">${value}</span>`;
      if (typeof value === 'number') return `<span class="json-num">${value}</span>`;
      if (typeof value === 'string') {
        const escaped = value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        return `<span class="json-string">"${escaped}"</span>`;
      }
      if (Array.isArray(value)) {
        if (value.length === 0) return '<span class="json-brace">[</span><span class="json-brace">]</span>';
        let html = `<span class="json-brace json-toggle" data-expanded="true">[</span><span class="json-ellipsis hidden">...</span>\n`;
        html += `<div class="json-children">`;
        for (let i = 0; i < value.length; i++) {
          const comma = i < value.length - 1 ? ',' : '';
          html += `${pad}  ${buildTree(value[i], indent + 1)}${comma}\n`;
        }
        html += `${pad}</div><span class="json-brace">]</span>`;
        return html;
      }
      if (typeof value === 'object') {
        const keys = Object.keys(value);
        if (keys.length === 0) return '<span class="json-brace">{</span><span class="json-brace">}</span>';
        let html = `<span class="json-brace json-toggle" data-expanded="true">{</span><span class="json-ellipsis hidden">...</span>\n`;
        html += `<div class="json-children">`;
        for (let i = 0; i < keys.length; i++) {
          const k = keys[i];
          const comma = i < keys.length - 1 ? ',' : '';
          const escapedKey = k.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          html += `${pad}  <span class="json-key">"${escapedKey}"</span>: ${buildTree(value[k], indent + 1)}${comma}\n`;
        }
        html += `${pad}</div><span class="json-brace">}</span>`;
        return html;
      }
      return String(value);
    }

    function renderTreeView(jsonStr: string) {
      try {
        const parsed = JSON.parse(jsonStr);
        const html = buildTree(parsed);
        treeRoot.innerHTML = html;

        // attach toggle listeners for collapsible nodes
        treeRoot.querySelectorAll('.json-toggle').forEach(el => {
          el.addEventListener('click', (e) => {
            e.stopPropagation();
            const toggle = e.currentTarget as HTMLElement;
            const parentBlock = toggle.parentElement as HTMLElement;
            if (!parentBlock) return;
            const children = parentBlock.querySelector(':scope > .json-children') as HTMLElement;
            const ellipsis = parentBlock.querySelector(':scope > .json-ellipsis') as HTMLElement;
            if (!children) return;
            const isExpanded = toggle.getAttribute('data-expanded') === 'true';
            if (isExpanded) {
              children.classList.add('hidden');
              if (ellipsis) ellipsis.classList.remove('hidden');
              toggle.setAttribute('data-expanded', 'false');
            } else {
              children.classList.remove('hidden');
              if (ellipsis) ellipsis.classList.add('hidden');
              toggle.setAttribute('data-expanded', 'true');
            }
          });
        });
      } catch {
        treeRoot.textContent = 'Parse valid JSON to see the tree view.';
      }
    }

    // ---- schema validation ----
    function validateAgainstSchema(data: unknown, schema: any): string[] {
      const errors: string[] = [];

      function checkType(val: unknown, expectedType: string, path: string) {
        const typeMap: Record<string, string> = {
          string: 'string',
          number: 'number',
          integer: 'number',
          boolean: 'boolean',
          'null': 'object',
          array: 'array',
          object: 'object'
        };
        if (expectedType === 'integer') {
          if (typeof val !== 'number' || !Number.isInteger(val)) {
            errors.push(`${path}: expected integer, got ${typeof val}`);
          }
          return;
        }
        if (expectedType === 'array') {
          if (!Array.isArray(val)) {
            errors.push(`${path}: expected array, got ${typeof val}`);
          }
          return;
        }
        const actualType = typeof val;
        const expectedJsType = typeMap[expectedType] || expectedType;
        if (actualType !== expectedJsType) {
          errors.push(`${path}: expected ${expectedType}, got ${actualType}`);
        }
      }

      function validateSub(obj: unknown, schemaNode: any, path: string) {
        if (!schemaNode || typeof schemaNode !== 'object') return;

        // type check
        if (schemaNode.type) {
          if (Array.isArray(schemaNode.type)) {
            // check any of the types
            const actualType = Array.isArray(obj) ? 'array' : typeof obj;
            if (!schemaNode.type.includes(actualType)) {
              errors.push(`${path}: expected one of [${schemaNode.type.join(', ')}], got ${actualType === 'array' ? 'array' : typeof obj}`);
            }
          } else {
            checkType(obj, schemaNode.type, path);
          }
        }

        // enum check
        if (schemaNode.enum && Array.isArray(schemaNode.enum)) {
          if (!schemaNode.enum.includes(obj)) {
            errors.push(`${path}: value must be one of [${schemaNode.enum.join(', ')}]`);
          }
        }

        if (typeof obj !== 'object' || obj === null) return;

        // required check
        if (schemaNode.required && Array.isArray(schemaNode.required) && !Array.isArray(obj)) {
          for (const reqKey of schemaNode.required) {
            if (!(reqKey in (obj as Record<string, unknown>))) {
              errors.push(`${path}: missing required field "${reqKey}"`);
            }
          }
        }

        // properties check
        if (schemaNode.properties && typeof schemaNode.properties === 'object' && !Array.isArray(obj)) {
          for (const [key, propSchema] of Object.entries(schemaNode.properties as Record<string, unknown>)) {
            const subPath = path ? `${path}.${key}` : key;
            if (key in (obj as Record<string, unknown>)) {
              validateSub((obj as Record<string, unknown>)[key], propSchema, subPath);
            }
          }
        }

        // additionalProperties check
        if (schemaNode.additionalProperties === false && !Array.isArray(obj) && typeof obj === 'object') {
          const allowed = new Set(Object.keys(schemaNode.properties || {}));
          for (const key of Object.keys(obj as Record<string, unknown>)) {
            if (!allowed.has(key)) {
              errors.push(`${path}: unexpected property "${key}" (additionalProperties not allowed)`);
            }
          }
        }

        // items check for arrays
        if (schemaNode.items && Array.isArray(obj)) {
          const itemsSchema = schemaNode.items;
          for (let i = 0; i < (obj as unknown[]).length; i++) {
            validateSub((obj as unknown[])[i], itemsSchema, `${path}[${i}]`);
          }
        }

        // minLength / maxLength
        if (typeof obj === 'string') {
          if (schemaNode.minLength !== undefined && (obj as string).length < schemaNode.minLength) {
            errors.push(`${path}: minLength ${schemaNode.minLength}, got ${(obj as string).length}`);
          }
          if (schemaNode.maxLength !== undefined && (obj as string).length > schemaNode.maxLength) {
            errors.push(`${path}: maxLength ${schemaNode.maxLength}, got ${(obj as string).length}`);
          }
        }

        // minimum / maximum
        if (typeof obj === 'number') {
          if (schemaNode.minimum !== undefined && (obj as number) < schemaNode.minimum) {
            errors.push(`${path}: minimum ${schemaNode.minimum}, got ${obj}`);
          }
          if (schemaNode.maximum !== undefined && (obj as number) > schemaNode.maximum) {
            errors.push(`${path}: maximum ${schemaNode.maximum}, got ${obj}`);
          }
        }

        // minItems / maxItems
        if (Array.isArray(obj)) {
          if (schemaNode.minItems !== undefined && (obj as unknown[]).length < schemaNode.minItems) {
            errors.push(`${path}: minItems ${schemaNode.minItems}, got ${(obj as unknown[]).length}`);
          }
          if (schemaNode.maxItems !== undefined && (obj as unknown[]).length > schemaNode.maxItems) {
            errors.push(`${path}: maxItems ${schemaNode.maxItems}, got ${(obj as unknown[]).length}`);
          }
        }
      }

      validateSub(data, schema, '');
      return errors;
    }

    function runSchemaValidation() {
      const rawInput = jsonInput.value.trim();
      const rawSchema = schemaInput.value.trim();
      if (!rawInput || !rawSchema) {
        schemaResult.innerHTML = '<span class="text-mute">Enter both JSON input and a schema, then click Validate.</span>';
        return;
      }

      let parsedInput: unknown;
      let parsedSchema: unknown;

      try {
        parsedInput = JSON.parse(rawInput);
      } catch (e: any) {
        schemaResult.innerHTML = `<span class="text-error">Input is not valid JSON: ${escapeHtml(e.message)}</span>`;
        return;
      }

      try {
        parsedSchema = JSON.parse(rawSchema);
      } catch (e: any) {
        schemaResult.innerHTML = `<span class="text-error">Schema is not valid JSON: ${escapeHtml(e.message)}</span>`;
        return;
      }

      if (typeof parsedSchema !== 'object' || parsedSchema === null || Array.isArray(parsedSchema)) {
        schemaResult.innerHTML = '<span class="text-error">Schema must be a JSON object.</span>';
        return;
      }

      const errs = validateAgainstSchema(parsedInput, parsedSchema);
      if (errs.length === 0) {
        schemaResult.innerHTML = '<span class="text-emerald-600 dark:text-emerald-400 font-bold">&#10003; Valid &#8212; JSON matches the schema.</span>';
      } else {
        let html = '<span class="text-error font-bold">Validation errors found:</span><ul class="list-disc pl-5 mt-2 space-y-1 text-error">';
        for (const err of errs) {
          html += `<li>${escapeHtml(err)}</li>`;
        }
        html += '</ul>';
        schemaResult.innerHTML = html;
      }
    }

    // ---- escape ----
    function escapeHtml(str: string) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // ---- core process ----
    function processJSON(action: 'format' | 'minify' | 'validate') {
      const raw = jsonInput.value;
      const trimmed = raw.trim();

      updateLineNumbers(raw);
      countChars(raw);

      if (!trimmed) {
        outputArea.innerHTML = '<span class="text-mute/50">Enter JSON to see the output.</span>';
        inputStatus.textContent = 'waiting for input';
        outputStatus.textContent = 'ready';
        return;
      }

      inputStatus.textContent = `${raw.length} chars`;

      let parsed: unknown;
      try {
        parsed = JSON.parse(trimmed);
      } catch (e: any) {
        const msg = e.message || 'Invalid JSON';
        outputArea.innerHTML = `<span class="text-error font-mono">&#10007; ${escapeHtml(msg)}</span>`;
        outputStatus.textContent = 'error';
        return;
      }

      outputStatus.textContent = 'valid';

      if (action === 'validate') {
        outputArea.innerHTML = `<span class="text-emerald-600 dark:text-emerald-400 font-mono font-bold text-sm">&#10003; Valid JSON</span>`;
        return;
      }

      if (action === 'minify') {
        const minified = JSON.stringify(parsed);
        outputArea.textContent = minified;
        return;
      }

      // format
      const formatted = JSON.stringify(parsed, null, 2);
      const highlighted = highlightJSON(formatted);
      outputArea.innerHTML = highlighted;
    }

    // ---- action switching ----
    function setAction(action: 'format' | 'minify' | 'validate') {
      currentAction = action;
      processJSON(action);

      // update tree: only in format mode
      if (action === 'format') {
        const raw = jsonInput.value.trim();
        if (raw) {
          try { JSON.parse(raw); renderTreeView(raw); } catch {}
        }
      }
    }

    function handleActionClick(btn: HTMLButtonElement) {
      setActiveAction(btn);
      const action = getActionName(btn);
      setAction(action);

      // hide tree/schema sections when not in format mode
      if (action !== 'format') {
        treeContainer.classList.add('hidden');
        treeToggle.setAttribute('aria-expanded', 'false');
        treeChevron.classList.remove('rotate-180');
      }
    }

    actionFormat.addEventListener('click', () => handleActionClick(actionFormat));
    actionMinify.addEventListener('click', () => handleActionClick(actionMinify));
    actionValidate.addEventListener('click', () => handleActionClick(actionValidate));

    // ---- input events ----
    jsonInput.addEventListener('input', () => {
      processJSON(currentAction);
      const raw = jsonInput.value.trim();
      if (currentAction === 'format' && raw) {
        try { JSON.parse(raw); renderTreeView(raw); } catch {}
      }
    });

    jsonInput.addEventListener('scroll', () => {
      lineNumbers.scrollTop = jsonInput.scrollTop;
    });

    // ---- copy ----
    btnCopy.addEventListener('click', async () => {
      let text = outputArea.textContent || '';
      if (!text || text.startsWith('Enter') || text.startsWith('\u2717')) return;
      try {
        await navigator.clipboard.writeText(text);
        outputStatus.textContent = 'copied!';
        setTimeout(() => { outputStatus.textContent = 'ready'; }, 1500);
      } catch {
        outputStatus.textContent = 'copy failed';
      }
    });

    // ---- download ----
    btnDownload.addEventListener('click', () => {
      let content = outputArea.textContent || '';
      if (!content || content.startsWith('Enter') || content.startsWith('\u2717')) return;
      const blob = new Blob([content], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'formatted.json';
      a.style.display = 'none';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    // ---- clear ----
    btnClear.addEventListener('click', () => {
      jsonInput.value = '';
      outputArea.innerHTML = '<span class="text-mute/50 text-sm">Formatted output will appear here.</span>';
      inputStatus.textContent = 'waiting for input';
      outputStatus.textContent = 'ready';
      charCount.textContent = '0 chars';
      lineNumsInner.textContent = '1';
      treeRoot.textContent = 'Parse valid JSON to see the tree view.';
      schemaResult.innerHTML = '<span class="text-mute text-sm">Enter a schema and click Validate to check your JSON against it.</span>';
    });

    // ---- tree toggle ----
    treeToggle.addEventListener('click', () => {
      const expanded = treeToggle.getAttribute('aria-expanded') === 'true';
      treeToggle.setAttribute('aria-expanded', (!expanded).toString());
      treeContainer.classList.toggle('hidden', expanded);
      treeChevron.classList.toggle('rotate-180', !expanded);
      if (!expanded) {
        const raw = jsonInput.value.trim();
        if (raw) {
          try { JSON.parse(raw); renderTreeView(raw); } catch {}
        }
      }
    });

    // ---- schema toggle ----
    schemaToggle.addEventListener('click', () => {
      const expanded = schemaToggle.getAttribute('aria-expanded') === 'true';
      schemaToggle.setAttribute('aria-expanded', (!expanded).toString());
      schemaContainer.classList.toggle('hidden', expanded);
      schemaChevron.classList.toggle('rotate-180', !expanded);
    });

    btnValidateSchema.addEventListener('click', runSchemaValidation);

    // ---- resize synchronization ----
    if (typeof ResizeObserver !== 'undefined') {
      const ro = new ResizeObserver(entries => {
        for (const entry of entries) {
          outputArea.style.height = `${jsonInput.offsetHeight}px`;
        }
      });
      ro.observe(jsonInput);
    }

    // ---- init ----
    const SAMPLE_JSON = JSON.stringify({"name": "JSON Formatter", "version": 1.0, "features": ["format", "minify", "validate"], "active": true, "meta": {"author": "ToolzTotal", "license": "MIT", "tags": ["developer", "json", "utility"]}}, null, 2);
    jsonInput.value = SAMPLE_JSON;
    updateLineNumbers(SAMPLE_JSON);
    countChars(SAMPLE_JSON);
    processJSON('format');
    renderTreeView(SAMPLE_JSON);
  </script>

  <!-- Syntax highlight styles -->
  <style is:global>
    .json-key { color: #0070f3; }
    .json-string { color: #067d17; }
    .json-num { color: #d9730d; }
    .json-bool { color: #7928ca; }
    .json-null { color: #7928ca; }
    .json-brace { color: #888888; }
    .json-toggle { cursor: pointer; user-select: none; }
    .json-toggle:hover { opacity: 0.7; }
    .json-children { margin-left: 1.5em; border-left: 1px solid var(--color-hairline); padding-left: 0.5em; }
    .json-ellipsis { cursor: pointer; color: var(--color-mute); user-select: none; }
    .json-ellipsis:hover { color: var(--color-body); }
    .text-error { color: var(--color-error); }
  </style>
</Layout>
