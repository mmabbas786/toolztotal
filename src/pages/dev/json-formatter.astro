  description="Format, validate, minify, and pretty-print JSON in real-time. Collapsible tree view, syntax highlighting, schema validation — all client-side and free."
  faqJsonLd={faqJsonLd}
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
