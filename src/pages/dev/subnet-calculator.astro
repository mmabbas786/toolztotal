---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is CIDR notation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Classless Inter-Domain Routing (CIDR) notation expresses IP subnets by appending a slash followed by the prefix bit length (e.g. /24) to the base IP address. The number indicates how many leading bits of the address represent the network routing prefix."
      }
    },
    {
      "@type": "Question",
      "name": "How are usable hosts in a subnet calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For IPv4, the number of usable hosts is computed as 2^(32 - Prefix) - 2. We subtract 2 because the first address is reserved for the Network ID and the last address is reserved for the Broadcast Address."
      }
    },
    {
      "@type": "Question",
      "name": "What is a wildcard mask?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A wildcard mask is the bitwise inverse of a subnet mask, used in routing protocols and access control lists (ACLs). For example, a subnet mask of 255.255.255.0 has a wildcard mask of 0.0.0.255."
      }
    },
    {
      "@type": "Question",
      "name": "How does IPv6 subnetting differ from IPv4?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "IPv6 addresses are 128-bit hex strings, compared to 32-bit IPv4 decimals. Because IPv6 networks are vast (with /64 being the standard local subnet size), they do not utilize broadcast addresses and have virtually unlimited usable hosts."
      }
    },
    {
      "@type": "Question",
      "name": "Is my network topology private?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Like all developer utilities on ToolzTotal, our subnet calculator executes entirely client-side inside your browser sandbox. No IP addresses, subnets, or gateway details are sent to any external server."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Subnet Calculator - Free IPv4 & IPv6 CIDR Solver | ToolzTotal"
  description="Calculate network address, broadcast, subnet mask, usable host ranges, and wildcard masks for IPv4/IPv6 CIDR blocks. Clean static developer tool."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/dev/subnet-calculator"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/dev" class="hover:text-ink transition-colors">Developer Tools</a>
      <span>/</span>
      <span class="text-ink">Subnet Calculator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Subnet Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Calculate IPv4 and IPv6 CIDR subnet metrics. Determine net ID, usable host boundaries, subnet masks, and inverse wildcard masks instantly.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Inputs (5 cols) -->
      <div class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Subnet Settings</h2>
        
        <!-- IP Address -->
        <div>
          <label for="ip-address" class="block text-xs font-mono uppercase text-mute mb-2">Base IP Address</label>
          <input 
            type="text" 
            id="ip-address" 
            placeholder="e.g. 192.168.1.0"
            value="192.168.1.0"
            class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1"
          />
        </div>

        <!-- CIDR prefix select -->
        <div>
          <label for="cidr-prefix" class="block text-xs font-mono uppercase text-mute mb-2">CIDR Prefix</label>
          <select id="cidr-prefix" class="w-full h-10 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none text-ink shadow-lvl1 cursor-pointer">
            <!-- IPv4 CIDRs -->
            <optgroup label="IPv4 (Classful & Classless)">
              {Array.from({ length: 31 }, (_, i) => 32 - i).map(p => (
                <option value={p} selected={p === 24}>/{p}</option>
              ))}
            </optgroup>
          </select>
        </div>

        <!-- Reset -->
        <div class="flex justify-end pt-4 border-t border-hairline">
          <button id="btn-reset" class="text-xs font-mono text-mute hover:text-red-500 cursor-pointer transition-colors">Reset</button>
        </div>
      </div>

      <!-- Right Column: Outputs (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Results Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Subnet Breakdown</h2>
          
          <div class="p-6 bg-canvas-soft border border-hairline rounded-lg text-center space-y-1 shadow-lvl1">
            <span class="text-[10px] font-mono text-mute uppercase block mb-1">Total Usable Hosts</span>
            <span id="res-usable-hosts" class="text-4xl md:text-5xl font-black text-ink font-sans block">254</span>
          </div>

          <!-- Network specifications breakdown -->
          <div class="space-y-3 text-xs font-mono text-mute pt-2 border-t border-hairline">
            <div class="flex justify-between">
              <span>SUBNET MASK:</span>
              <span id="res-mask" class="font-bold text-ink">255.255.255.0</span>
            </div>
            <div class="flex justify-between">
              <span>WILDCARD MASK:</span>
              <span id="res-wildcard" class="font-bold text-ink">0.0.0.255</span>
            </div>
            <div class="flex justify-between">
              <span>NETWORK ADDRESS:</span>
              <span id="res-network" class="font-bold text-ink">192.168.1.0</span>
            </div>
            <div class="flex justify-between">
              <span>BROADCAST ADDRESS:</span>
              <span id="res-broadcast" class="font-bold text-ink">192.168.1.255</span>
            </div>
            <div class="flex justify-between">
              <span>USABLE IP RANGE:</span>
              <span id="res-range" class="font-bold text-ink text-right">192.168.1.1 - 192.168.1.254</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">IP Subnetting and CIDR Architectures: Understanding Usable Host Math</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          Subnetting is the practice of partitioning a single physical network into multiple logical sub-networks. This improves security, isolates broadcast domains, and optimizes IP address allocation.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Calculating Usable Hosts (IPv4)</h3>
        <p>
          To find the total usable hosts in any IPv4 CIDR subnet block, you raise 2 to the power of the host bits (32 minus prefix length), and subtract 2:
          <br />
          <strong class="block my-2 text-center text-ink font-mono text-xs">Usable Hosts = 2<sup>(32 - CIDR Prefix)</sup> - 2</strong>
          For a standard class C subnet (e.g. 192.168.1.0/24):
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li>Host bits: $32 - 24 = 8$ bits</li>
          <li>Total IP Addresses: $2^8 = 256$ addresses</li>
          <li>Usable Hosts: $256 - 2 = 254$ hosts</li>
          <li>We subtract 2 because the first address (**192.168.1.0**) defines the network ID, and the last address (**192.168.1.255**) acts as the local broadcast vector.</li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Wildcard Masks</h3>
        <p>
          A **wildcard mask** is the bitwise inverse of a subnet mask. Where a subnet mask uses binary 1s to define network portions and 0s for host portions, a wildcard mask reverses this. For a standard `/24` network mask of **255.255.255.0**, the wildcard inverse is **0.0.0.255**, signifying that the last octet is variable.
        </p>
      </div>
    </article>

    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            What is CIDR notation?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Classless Inter-Domain Routing (CIDR) notation expresses IP subnets by appending a slash followed by the prefix bit length (e.g. /24) to the base IP address. The number indicates how many leading bits of the address represent the network routing prefix.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How are usable hosts in a subnet calculated?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            For IPv4, the number of usable hosts is computed as 2^(32 - Prefix) - 2. We subtract 2 because the first address is reserved for the Network ID and the last address is reserved for the Broadcast Address.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            What is a wildcard mask?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            A wildcard mask is the bitwise inverse of a subnet mask, used in routing protocols and access control lists (ACLs). For example, a subnet mask of 255.255.255.0 has a wildcard mask of 0.0.0.255.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How does IPv6 subnetting differ from IPv4?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            IPv6 addresses are 128-bit hex strings, compared to 32-bit IPv4 decimals. Because IPv6 networks are vast (with /64 being the standard local subnet size), they do not utilize broadcast addresses and have virtually unlimited usable hosts.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Is my network topology private?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. Like all developer utilities on ToolzTotal, our subnet calculator executes entirely client-side inside your browser sandbox. No IP addresses, subnets, or gateway details are sent to any external server.
          </div>
        </details>

      </div>
    </section>

    <!-- Related Tools Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Related Tools">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Developer Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/dev/json-formatter" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            JSON Formatter & Validator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Format, validate, and check schemas for JSON files.</p>
        </a>
        <a href="/dev/diff-checker" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Diff Checker
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Compare code and text strings side-by-side.</p>
        </a>
        <a href="/dev/css-minifier" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            CSS Minifier / Beautifier
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Minify and beautify stylesheets with visual diff compression metrics.</p>
        </a>
      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const ipIn = document.getElementById('ip-address') as HTMLInputElement;
  const prefixSelect = document.getElementById('cidr-prefix') as HTMLSelectElement;

  const resUsable = document.getElementById('res-usable-hosts') as HTMLSpanElement;
  const resMask = document.getElementById('res-mask') as HTMLSpanElement;
  const resWildcard = document.getElementById('res-wildcard') as HTMLSpanElement;
  const resNetwork = document.getElementById('res-network') as HTMLSpanElement;
  const resBroadcast = document.getElementById('res-broadcast') as HTMLSpanElement;
  const resRange = document.getElementById('res-range') as HTMLSpanElement;

  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;

  // ============================================================
  // Functions
  // ============================================================
  const ipToLong = (ip: string): number => {
    const parts = ip.split('.').map(Number);
    if (parts.length !== 4 || parts.some(isNaN)) return 0;
    return ((parts[0] << 24) >>> 0) + (parts[1] << 16) + (parts[2] << 8) + parts[3];
  };

  const longToIp = (long: number): string => {
    return [
      (long >>> 24) & 255,
      (long >>> 16) & 255,
      (long >>> 8) & 255,
      long & 255
    ].join('.');
  };

  const calculateSubnet = () => {
    const ipVal = ipIn.value.trim();
    const prefix = parseInt(prefixSelect.value);

    // Simple IP validator
    const ipv4Regex = /^((25[0-5]|(2[0-4]|1\d|[1-9]|)\d)\.?\b){4}$/;
    if (!ipv4Regex.test(ipVal)) {
      resUsable.textContent = "Error";
      resMask.textContent = "Invalid IP Address format";
      resWildcard.textContent = "N/A";
      resNetwork.textContent = "N/A";
      resBroadcast.textContent = "N/A";
      resRange.textContent = "N/A";
      return;
    }

    const ipLong = ipToLong(ipVal);
    
    // Subnet mask long
    // Prefix 24: mask is 24 leading 1s, 8 0s: 11111111 11111111 11111111 00000000 -> 0xffffff00
    const maskLong = prefix === 0 ? 0 : (~0 << (32 - prefix)) >>> 0;
    const wildcardLong = (~maskLong) >>> 0;

    const netLong = (ipLong & maskLong) >>> 0;
    const broadLong = (netLong | wildcardLong) >>> 0;

    let usableCount = 0;
    let firstUsable = "N/A";
    let lastUsable = "N/A";

    if (prefix < 31) {
      usableCount = Math.pow(2, 32 - prefix) - 2;
      firstUsable = longToIp(netLong + 1);
      lastUsable = longToIp(broadLong - 1);
    } else if (prefix === 31) {
      // /31 point-to-point links (RFC 3021)
      usableCount = 2;
      firstUsable = longToIp(netLong);
      lastUsable = longToIp(broadLong);
    } else {
      // /32 single host
      usableCount = 1;
      firstUsable = longToIp(netLong);
      lastUsable = longToIp(broadLong);
    }

    resUsable.textContent = usableCount.toLocaleString();
    resMask.textContent = longToIp(maskLong);
    resWildcard.textContent = longToIp(wildcardLong);
    resNetwork.textContent = longToIp(netLong);
    resBroadcast.textContent = longToIp(broadLong);
    
    if (prefix <= 30) {
      resRange.textContent = `${firstUsable} - ${lastUsable}`;
    } else {
      resRange.textContent = firstUsable;
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  ipIn.addEventListener('input', calculateSubnet);
  prefixSelect.addEventListener('change', calculateSubnet);

  btnReset.addEventListener('click', () => {
    ipIn.value = '192.168.1.0';
    prefixSelect.value = '24';
    calculateSubnet();
  });

  // Initial Calculation
  calculateSubnet();
</script>
