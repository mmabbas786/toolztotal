---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a JWT token?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "JSON Web Token (JWT) is an open standard (RFC 7519) for securely transmitting information between parties as a JSON object. JWTs are commonly used for authentication and information exchange in modern web applications and APIs."
      }
    },
    {
      "@type": "Question",
      "name": "How do I decode a JWT without a secret?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can decode the payload and header of any JWT without verification using base64url decoding. The payload is not encrypted, only signed. However, decoding without verification means you cannot trust the claims — use verification in production."
      }
    },
    {
      "@type": "Question",
      "name": "What are the three parts of a JWT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A JWT consists of three base64url-encoded parts separated by dots: Header (algorithm and token type), Payload (claims/data), and Signature (verification hash). Example: xxxxx.yyyyy.zzzzz"
      }
    },
    {
      "@type": "Question",
      "name": "What do the JWT claims mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard claims include: iss (issuer), sub (subject), aud (audience), exp (expiration time), iat (issued at), nbf (not before). Custom claims can be added by the issuer for application-specific data."
      }
    },
    {
      "@type": "Question",
      "name": "Is JWT safe to use for authentication?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "JWTs are safe when used correctly. Always verify the signature using the secret/public key, check expiration (exp claim), validate the issuer (iss), and transmit only over HTTPS. Never store sensitive data in the payload since it is only base64-encoded, not encrypted."
      }
    },
    {
      "@type": "Question",
      "name": "Why is my JWT showing as expired or invalid?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common causes: the exp timestamp has passed, the token is not yet valid (nbf claim), the signature doesn't match, or the token was issued by a different server than expected. Check the exp and iat values in the decoded payload."
      }
    }
  ]
});
---

<Layout
  title="JWT Decoder & Validator - Decode, Inspect, Verify JWTs | ToolzTotal"
  description="Decode and validate JSON Web Tokens (JWT) entirely in your browser. Inspect the header, payload claims, and signature of any JWT safely and privately."
