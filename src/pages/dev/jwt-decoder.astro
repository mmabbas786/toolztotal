  <script>
// @ts-nocheck
    const jwtInput = document.getElementById('jwt-input');
    const decodeBtn = document.getElementById('decode-btn');
    const clearBtn = document.getElementById('clear-btn');
    const activeMode = document.getElementById('active-mode');
    const jwtModeBtns = document.querySelectorAll('.jwt-mode-btn');
    const secretRow = document.getElementById('secret-row');
    const jwtSecret = document.getElementById('jwt-secret');

    const statusSection = document.getElementById('status-section');
    const statusBadge = document.getElementById('status-badge');
    const statusMessage = document.getElementById('status-message');

    const outputSection = document.getElementById('output-section');
    const headerAlg = document.getElementById('header-alg');
    const headerTyp = document.getElementById('header-typ');
    const headerRaw = document.getElementById('header-raw');
    const headerJson = document.getElementById('header-json');
    const claimsBody = document.getElementById('claims-body');
    const payloadJson = document.getElementById('payload-json');
    const signatureRaw = document.getElementById('signature-raw');

    function base64UrlDecode(str) {
      let s = str.replace(/-/g, '+').replace(/_/g, '/');
      const pad = s.length % 4;
      if (pad) s += '='.repeat(4 - pad);
      try {
        return decodeURIComponent(escape(atob(s)));
      } catch (e) {
        try {
          return atob(s);
        } catch (e2) {
          return null;
        }
      }
    }

    function formatClaimValue(key, value) {
      if (typeof value === 'number' && ['exp', 'iat', 'nbf'].includes(key)) {
        const d = new Date(value * 1000);
        return `${value} (${d.toUTCString()})`;
      }
      if (typeof value === 'object') return JSON.stringify(value);
      return String(value);
    }

    function setStatus(state, message) {
      const styles = {
        valid: 'bg-emerald-500/15 text-emerald-400',
        invalid: 'bg-red-500/15 text-red-400',
        expired: 'bg-amber-500/15 text-amber-400',
        malformed: 'bg-gray-500/15 text-gray-400'
      };
      const labels = { valid: 'Valid', invalid: 'Invalid', expired: 'Expired', malformed: 'Malformed' };
      statusBadge.className = 'text-xs font-mono font-bold px-3 py-1 rounded-full ' + (styles[state] || styles.malformed);
      statusBadge.textContent = labels[state] || 'Unknown';
      statusMessage.textContent = message;
      statusSection.classList.remove('hidden');
    }

    function showToast(msg) {
      let toast = document.getElementById('jwt-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'jwt-toast';
        toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 bg-primary text-on-primary text-xs font-sans px-4 py-2.5 rounded-full shadow-lvl5 z-50 transition-opacity duration-300';
        document.body.appendChild(toast);
      }
      toast.textContent = msg || 'Copied to clipboard';
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2000);
    }

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => showToast()).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showToast();
      });
    }

    function decodeJwt() {
      const token = jwtInput.value.trim();
      if (!token) {
        setStatus('malformed', 'Please paste a JWT token to decode.');
        outputSection.classList.add('hidden');
        return;
      }

      const parts = token.split('.');
      if (parts.length !== 3) {
        setStatus('malformed', 'A valid JWT must have three parts separated by dots (header.payload.signature).');
        outputSection.classList.add('hidden');
        return;
      }

      const [headerPart, payloadPart, signaturePart] = parts;
      const headerStr = base64UrlDecode(headerPart);
      const payloadStr = base64UrlDecode(payloadPart);

      if (headerStr === null || payloadStr === null) {
        setStatus('malformed', 'The header or payload could not be base64url-decoded.');
        outputSection.classList.add('hidden');
        return;
      }

      let header, payload;
      try {
        header = JSON.parse(headerStr);
        payload = JSON.parse(payloadStr);
      } catch (e) {
        setStatus('malformed', 'The decoded header or payload is not valid JSON.');
        outputSection.classList.add('hidden');
        return;
      }

      // Populate header
      headerAlg.textContent = header.alg || '—';
      headerTyp.textContent = header.typ || '—';
      headerRaw.textContent = headerPart;
      headerJson.textContent = JSON.stringify(header, null, 2);

      // Populate payload claims table
      claimsBody.innerHTML = '';
      Object.entries(payload).forEach(([key, value]) => {
        const tr = document.createElement('tr');
        const tdKey = document.createElement('td');
        tdKey.className = 'px-5 py-2.5 align-top font-mono text-xs text-ink';
        tdKey.textContent = key;
        const tdVal = document.createElement('td');
        tdVal.className = 'px-5 py-2.5 align-top font-mono text-xs text-body break-all';
        tdVal.textContent = formatClaimValue(key, value);
        tr.appendChild(tdKey);
        tr.appendChild(tdVal);
        claimsBody.appendChild(tr);
      });
      payloadJson.textContent = JSON.stringify(payload, null, 2);

      // Signature
      const sigDisplay = signaturePart.length > 20 ? signaturePart.slice(0, 20) + '...' : signaturePart;
      signatureRaw.textContent = sigDisplay;

      outputSection.classList.remove('hidden');

      // Validation: check exp / nbf
      const now = Math.floor(Date.now() / 1000);
      if (typeof payload.exp === 'number' && now >= payload.exp) {
        setStatus('expired', `This token expired on ${new Date(payload.exp * 1000).toUTCString()}.`);
      } else if (typeof payload.nbf === 'number' && now < payload.nbf) {
        setStatus('invalid', `This token is not valid until ${new Date(payload.nbf * 1000).toUTCString()}.`);
      } else if (activeMode.value === 'verify' && jwtSecret.value.trim()) {
        setStatus('valid', 'Structure decoded. (Simple signature verification requires the matching secret/key on the server.)');
      } else {
        setStatus('valid', 'Token structure is valid. Decoding does not verify the signature — verify on the server before trusting claims.');
      }
    }

    decodeBtn.addEventListener('click', decodeJwt);

    clearBtn.addEventListener('click', () => {
      jwtInput.value = '';
      statusSection.classList.add('hidden');
      outputSection.classList.add('hidden');
    });

    jwtModeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        jwtModeBtns.forEach(b => {
          b.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl1');
          b.classList.add('text-mute', 'hover:text-ink');
        });
        btn.classList.remove('text-mute', 'hover:text-ink');
        btn.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl1');
        activeMode.value = btn.id.replace('mode-', '');
        if (activeMode.value === 'verify') {
          secretRow.classList.remove('hidden');
        } else {
          secretRow.classList.add('hidden');
        }
      });
    });

    document.querySelectorAll('.jwt-copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const el = document.getElementById(targetId);
        if (el) copyToClipboard(el.textContent);
      });
    });

    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach(toggle => {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        const content = toggle.nextElementSibling;
        const icon = toggle.querySelector('svg');
        toggle.setAttribute('aria-expanded', String(!expanded));
        if (expanded) {
          content.classList.add('hidden');
          icon.classList.remove('rotate-180');
        } else {
          content.classList.remove('hidden');
          icon.classList.add('rotate-180');
        }
      });
    });
  </script>

    <RelatedTools
      categorySlug="dev"
      toolSlug="jwt-decoder"
    />

  <ContentFooter category="dev" />
</Layout>
