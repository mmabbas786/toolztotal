---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does CSS minification work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CSS minification strips unnecessary elements from stylesheets to reduce file sizes. This includes removing comments (both block and single-line), collapsing multiple spaces/indentations, removing trailing semicolons, and shortening hex codes."
      }
    },
    {
      "@type": "Question",
      "name": "What is the benefit of minifying CSS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Minified CSS files load faster over networks. Reducing asset weight directly enhances web performance metrics, specifically optimizing Core Web Vitals like Largest Contentful Paint (LCP) and First Contentful Paint (FCP)."
      }
    },
    {
      "@type": "Question",
      "name": "Does this tool strip SCSS and LESS comments?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. This minifier strips standard SCSS/LESS single-line comments (prefixed with '//') as well as standard CSS block comments (/* ... */)."
      }
    },
    {
      "@type": "Question",
      "name": "What is CSS beautification?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "CSS beautification is the process of formatting a minified or messy stylesheet. It adds standardized indentations, line breaks, and whitespace to make code readable and maintainable."
      }
    },
    {
      "@type": "Question",
      "name": "Is my proprietary CSS code secure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Like all developer utilities on ToolzTotal, our CSS formatter runs 100% client-side in your local browser sandbox. None of your source code is transmitted to external servers."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="CSS Minifier & Beautifier - Compress & Format Stylesheets | ToolzTotal"
  description="Minify or beautify your CSS stylesheet, strip comments, and visualize code compression metrics. Clean static developer tool."
  faqJsonLd={faqJsonLd}
  canonicalUrl="https://toolztotal.com/dev/css-minifier"
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/dev" class="hover:text-ink transition-colors">Developer Tools</a>
      <span>/</span>
      <span class="text-ink">CSS Minifier</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free CSS Minifier / Beautifier
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Minify or format your CSS stylesheets. Strip SCSS/LESS comments, remove excess whitespace, and inspect compression metrics dynamically.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Inputs & Editor (7 cols) -->
      <div class="lg:col-span-7 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        
        <div class="flex items-center justify-between border-b border-hairline pb-3">
          <h2 class="text-lg font-bold text-ink font-sans">CSS Editor</h2>
          
          <div class="flex gap-2">
            <!-- Mode Toggle Toggles -->
            <button id="btn-mode-minify" class="h-8 px-3 bg-primary text-on-primary rounded text-xs font-mono font-semibold cursor-pointer shadow-lvl1">Minify</button>
            <button id="btn-mode-beautify" class="h-8 px-3 border border-hairline hover:border-hairline-strong bg-canvas rounded text-xs font-mono text-body cursor-pointer shadow-lvl1">Beautify</button>
          </div>
        </div>

        <!-- Code Input -->
        <div class="space-y-2">
          <label for="css-input" class="block text-xs font-mono uppercase text-mute">Input Raw CSS Code</label>
          <textarea 
            id="css-input" 
            rows="12" 
            placeholder="/* Enter your CSS code here */" 
            class="w-full p-4 bg-canvas-soft border border-hairline rounded-lg text-xs font-mono focus:outline-none focus:border-hairline-strong text-ink shadow-lvl1 whitespace-pre overflow-auto"
          ></textarea>
        </div>

        <!-- Action Row -->
        <div class="flex justify-between items-center pt-4 border-t border-hairline">
          <button id="btn-reset" class="text-xs font-mono text-mute hover:text-red-500 cursor-pointer transition-colors">Clear</button>
          <button id="btn-process" class="h-8 px-4 bg-primary hover:bg-mute text-on-primary rounded text-xs font-sans font-semibold transition-colors cursor-pointer shadow-lvl1">Run Process</button>
        </div>
      </div>

      <!-- Right Column: Output & Stats (5 cols) -->
      <div class="lg:col-span-5 space-y-6">
        
        <!-- Output Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 shadow-lvl2 space-y-6">
          <h2 class="text-base font-bold text-ink font-sans border-b border-hairline pb-2 flex items-center justify-between">
            <span>Output Code</span>
            <button 
              id="btn-copy" 
              class="h-7 px-3 border border-hairline hover:border-hairline-strong bg-canvas rounded text-xs font-mono text-mute hover:text-ink cursor-pointer transition-colors shadow-lvl1"
            >
              Copy
            </button>
          </h2>

          <div class="bg-canvas-soft border border-hairline rounded-lg p-4 min-h-[150px] max-h-[300px] overflow-auto shadow-lvl1">
            <pre class="text-xs font-mono text-ink whitespace-pre-wrap break-all select-all" id="code-output">Process pending...</pre>
          </div>

          <!-- Stats list -->
          <div class="space-y-3 text-xs font-mono text-mute pt-4 border-t border-hairline">
            <div class="flex justify-between">
              <span>ORIGINAL SIZE:</span>
              <span id="stat-orig-size" class="font-bold text-ink">88 chars</span>
            </div>
            <div class="flex justify-between">
              <span>COMPRESSED SIZE:</span>
              <span id="stat-comp-size" class="font-bold text-ink">39 chars</span>
            </div>
            <div class="flex justify-between">
              <span>REDUCTION RATIO:</span>
              <span id="stat-reduction" class="font-bold text-emerald-500">55.7%</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">Optimizing Web Deliverables: The Mechanics of CSS Minification and Formatting</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          Stylesheets control the entire layout and visual presentation of modern websites. However, developers write CSS with generous indentations, block explanations, and whitespace to keep files maintainable. While helpful during staging, these design artifacts increase size packages unnecessarily.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">How Minifiers Optimize CSS</h3>
        <p>
          Minification parsing algorithms execute three core adjustments:
        </p>
        <ul class="list-disc pl-5 space-y-3 font-sans text-sm">
          <li><strong>Comment Stripping:</strong> Removes block annotations (`/* ... */`) and single-line SCSS/LESS helper comments (`// ...`), preserving copyright markers if configured.</li>
          <li><strong>Whitespace Compression:</strong> Replaces consecutive line breaks, tab stops, and space margins with zero spaces, parsing curly braces directly.</li>
          <li><strong>Shorthand Normalization:</strong> Collapses zero values (e.g. converting `0px` to `0`), and shortens hex color descriptors where applicable (e.g. converting `#ffffff` to `#fff`).</li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Beautification Formatting</h3>
        <p>
          When auditing production assets or third-party libraries, minified stylesheets appear as continuous strings. Beautification normalizes these assets by reinstating indentations, standardizing spacing after semicolons and colons, and injecting clear vertical blocks.
        </p>
      </div>
    </article>

    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            How does CSS minification work?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            CSS minification strips unnecessary elements from stylesheets to reduce file sizes. This includes removing comments (both block and single-line), collapsing multiple spaces/indentations, removing trailing semicolons, and shortening hex codes.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            What is the benefit of minifying CSS?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Minified CSS files load faster over networks. Reducing asset weight directly enhances web performance metrics, specifically optimizing Core Web Vitals like Largest Contentful Paint (LCP) and First Contentful Paint (FCP).
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Does this tool strip SCSS and LESS comments?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. This minifier strips standard SCSS/LESS single-line comments (prefixed with '//') as well as standard CSS block comments (/* ... */).
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            What is CSS beautification?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            CSS beautification is the process of formatting a minified or messy stylesheet. It adds standardized indentations, line breaks, and whitespace to make code readable and maintainable.
          </div>
        </details>

        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors">
            Is my proprietary CSS code secure?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. Like all developer utilities on ToolzTotal, our CSS formatter runs 100% client-side in your local browser sandbox. None of your source code is transmitted to external servers.
          </div>
        </details>

      </div>
    </section>

    <!-- Related Tools Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Related Tools">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Developer Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/dev/json-formatter" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            JSON Formatter & Validator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Format, validate, and check schemas for JSON files.</p>
        </a>
        <a href="/dev/diff-checker" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Diff Checker
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Compare code and text strings side-by-side.</p>
        </a>
        <a href="/dev/subnet-calculator" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Subnet Calculator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Calculate CIDR network IP subnet parameters.</p>
        </a>
      </div>
    </section>

  </div>
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const cssIn = document.getElementById('css-input') as HTMLTextAreaElement;
  const btnMinify = document.getElementById('btn-mode-minify') as HTMLButtonElement;
  const btnBeautify = document.getElementById('btn-mode-beautify') as HTMLButtonElement;
  
  const btnProcess = document.getElementById('btn-process') as HTMLButtonElement;
  const btnClear = document.getElementById('btn-reset') as HTMLButtonElement;
  const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;

  const codeOutput = document.getElementById('code-output') as HTMLPreElement;
  
  const statOrig = document.getElementById('stat-orig-size') as HTMLSpanElement;
  const statComp = document.getElementById('stat-comp-size') as HTMLSpanElement;
  const statReduction = document.getElementById('stat-reduction') as HTMLSpanElement;

  // ============================================================
  // State
  // ============================================================
  let activeMode: 'minify' | 'beautify' = 'minify';

  // ============================================================
  // Functions
  // ============================================================
  const processCSS = () => {
    const raw = cssIn.value;
    statOrig.textContent = raw.length + " chars";

    let result = "";
    if (activeMode === 'minify') {
      // 1. Strip block comments
      let css = raw.replace(/\/\*[\s\S]*?\*\//g, '');
      
      // 2. Strip single-line comments (SCSS style //)
      css = css.replace(/(?:^|[^:])\/\/.*$/gm, '');

      // 3. Collapse multiple whitespace and linebreaks
      css = css.replace(/\s+/g, ' ');

      // 4. Remove spacing near braces/colons/commas
      css = css.replace(/\s*([\{\}:;,])\s*/g, '$1');

      // 5. Shorten color hex codes where possible (#ffffff -> #fff)
      css = css.replace(/#([a-fA-F0-9])\1([a-fA-F0-9])\2([a-fA-F0-9])\3\b/g, '#$1$2$3');

      // 6. Remove trailing semicolons in blocks
      css = css.replace(/;}/g, '}');

      // 7. Strip zero units (0px -> 0)
      css = css.replace(/\b0(px|em|%|rem|in|cm|mm|pc|pt|ex|ch|vh|vw|vmin|vmax)\b/g, '0');

      result = css.trim();
    } else {
      // Beautify formatting rules
      let css = raw.replace(/\s+/g, ' '); // Collapse all space
      
      // Strip comments for clean formatting
      css = css.replace(/\/\*[\s\S]*?\*\//g, '');
      css = css.replace(/(?:^|[^:])\/\/.*$/gm, '');

      css = css.replace(/\{/g, ' {\n  ');
      css = css.replace(/\}/g, '\n}\n');
      css = css.replace(/;/g, ';\n  ');
      css = css.replace(/,\s*/g, ', ');
      css = css.replace(/:\s*/g, ': ');
      
      // Clean up spacing indentations
      css = css.replace(/\n\s*\n/g, '\n');
      css = css.replace(/  \}/g, '}');

      result = css.trim();
    }

    codeOutput.textContent = result;
    
    // Stats calculation
    const compLen = result.length;
    statComp.textContent = compLen + " chars";

    const diff = raw.length - compLen;
    const reduction = raw.length > 0 ? (diff / raw.length) * 100 : 0;
    
    if (reduction >= 0) {
      statReduction.textContent = reduction.toFixed(1) + "%";
      statReduction.className = "font-bold text-emerald-500";
    } else {
      // Negative reduction means code expanded (beautified)
      statReduction.textContent = Math.abs(reduction).toFixed(1) + "% expansion";
      statReduction.className = "font-bold text-ink";
    }
  };

  const handleModeChange = (mode: 'minify' | 'beautify') => {
    activeMode = mode;
    if (mode === 'minify') {
      btnMinify.className = "h-8 px-3 bg-primary text-on-primary rounded text-xs font-mono font-semibold cursor-pointer shadow-lvl1";
      btnBeautify.className = "h-8 px-3 border border-hairline hover:border-hairline-strong bg-canvas rounded text-xs font-mono text-body cursor-pointer shadow-lvl1";
    } else {
      btnBeautify.className = "h-8 px-3 bg-primary text-on-primary rounded text-xs font-mono font-semibold cursor-pointer shadow-lvl1";
      btnMinify.className = "h-8 px-3 border border-hairline hover:border-hairline-strong bg-canvas rounded text-xs font-mono text-body cursor-pointer shadow-lvl1";
    }
    processCSS();
  };

  const copyCode = () => {
    const codeText = codeOutput.textContent || "";
    if (codeText && !codeText.startsWith("Process")) {
      navigator.clipboard.writeText(codeText).then(() => {
        const oldText = btnCopy.textContent;
        btnCopy.textContent = "Copied!";
        setTimeout(() => {
          btnCopy.textContent = oldText;
        }, 1500);
      });
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnMinify.addEventListener('click', () => handleModeChange('minify'));
  btnBeautify.addEventListener('click', () => handleModeChange('beautify'));
  
  btnProcess.addEventListener('click', processCSS);
  
  btnClear.addEventListener('click', () => {
    cssIn.value = "";
    codeOutput.textContent = "Cleared.";
    statOrig.textContent = "0 chars";
    statComp.textContent = "0 chars";
    statReduction.textContent = "0.0%";
  });

  btnCopy.addEventListener('click', copyCode);

  // Set default initial value
  cssIn.value = `body {\n  background-color: #ffffff;\n  color: #333333; /* block comment */\n  margin: 0px;\n}`;

  // Initial Calculation
  processCSS();
</script>
