  <script>
    // ============================================================
    // DOM Refs
    // ============================================================
    const colorPicker = document.getElementById('color-picker-input') as HTMLInputElement;
    const previewSwatch = document.getElementById('color-preview-swatch') as HTMLDivElement;
    const previewLabel = document.getElementById('color-preview-label') as HTMLSpanElement;

    const hexInput = document.getElementById('hex-input') as HTMLInputElement;
    const rInput = document.getElementById('r-input') as HTMLInputElement;
    const gInput = document.getElementById('g-input') as HTMLInputElement;
    const bInput = document.getElementById('b-input') as HTMLInputElement;
    const hInput = document.getElementById('h-input') as HTMLInputElement;
    const sInput = document.getElementById('s-input') as HTMLInputElement;
    const lInput = document.getElementById('l-input') as HTMLInputElement;

    const fgColorPicker = document.getElementById('fg-color-picker') as HTMLInputElement;
    const bgColorPicker = document.getElementById('bg-color-picker') as HTMLInputElement;
    const fgHexInput = document.getElementById('fg-hex-input') as HTMLInputElement;
    const bgHexInput = document.getElementById('bg-hex-input') as HTMLInputElement;
    const contrastRatioEl = document.getElementById('contrast-ratio') as HTMLSpanElement;
    const contrastLevels = document.getElementById('contrast-levels') as HTMLDivElement;

    const paletteContainer = document.getElementById('palette-container') as HTMLDivElement;
    const gradientStops = document.getElementById('gradient-stops') as HTMLDivElement;
    const addStopBtn = document.getElementById('add-stop') as HTMLButtonElement;
    const stopCount = document.getElementById('stop-count') as HTMLSpanElement;
    const directionBtns = document.querySelectorAll('.direction-btn') as NodeListOf<HTMLButtonElement>;
    const customAngle = document.getElementById('custom-angle') as HTMLInputElement;
    const applyAngle = document.getElementById('apply-angle') as HTMLButtonElement;
    const gradientPreview = document.getElementById('gradient-preview') as HTMLDivElement;
    const gradientCss = document.getElementById('gradient-css') as HTMLDivElement;
    const copyGradientBtn = document.getElementById('copy-gradient') as HTMLButtonElement;

    const copyBtns = document.querySelectorAll('.copy-btn') as NodeListOf<HTMLButtonElement>;

    let debounceTimer: number | null = null;
    let currentDirection = 'to right';
    let isUpdating = false;

    // ============================================================
    // Color Conversion Functions
    // ============================================================
    function hexToRgb(hex: string): { r: number; g: number; b: number } | null {
      let h = hex.trim();
      if (h.startsWith('#')) h = h.slice(1);
      if (h.length === 3) h = h[0] + h[0] + h[1] + h[1] + h[2] + h[2];
      if (!/^[0-9a-fA-F]{6}$/.test(h)) return null;
      return {
        r: parseInt(h.slice(0, 2), 16),
        g: parseInt(h.slice(2, 4), 16),
        b: parseInt(h.slice(4, 6), 16),
      };
    }

    function rgbToHex(r: number, g: number, b: number): string {
      const toHex = (n: number) => Math.round(Math.min(255, Math.max(0, n))).toString(16).padStart(2, '0');
      return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
    }

    function rgbToHsl(r: number, g: number, b: number): { h: number; s: number; l: number } {
      const rn = r / 255, gn = g / 255, bn = b / 255;
      const max = Math.max(rn, gn, bn), min = Math.min(rn, gn, bn);
      const delta = max - min;
      let h = 0, s = 0, l = (max + min) / 2;
      if (delta !== 0) {
        s = l > 0.5 ? delta / (2 - max - min) : delta / (max + min);
        if (max === rn) h = ((gn - bn) / delta + (gn < bn ? 6 : 0)) / 6;
        else if (max === gn) h = ((bn - rn) / delta + 2) / 6;
        else h = ((rn - gn) / delta + 4) / 6;
      }
      return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
    }

    function hslToRgb(h: number, s: number, l: number): { r: number; g: number; b: number } {
      const hn = h / 360, sn = s / 100, ln = l / 100;
      const c = (1 - Math.abs(2 * ln - 1)) * sn;
      const x = c * (1 - Math.abs((hn * 6) % 2 - 1));
      const m = ln - c / 2;
      let r = 0, g = 0, b = 0;
      const hp = hn * 6;
      const hInt = Math.floor(hp);
      if (hInt === 0) { r = c; g = x; b = 0; }
      else if (hInt === 1) { r = x; g = c; b = 0; }
      else if (hInt === 2) { r = 0; g = c; b = x; }
      else if (hInt === 3) { r = 0; g = x; b = c; }
      else if (hInt === 4) { r = x; g = 0; b = c; }
      else { r = c; g = 0; b = x; }
      return { r: Math.round((r + m) * 255), g: Math.round((g + m) * 255), b: Math.round((b + m) * 255) };
    }

    // ============================================================
    // WCAG Contrast
    // ============================================================
    function relativeLuminance(r: number, g: number, b: number): number {
      const linearize = (c: number) => {
        const s = c / 255;
        return s <= 0.03928 ? s / 12.92 : Math.pow((s + 0.055) / 1.055, 2.4);
      };
      return 0.2126 * linearize(r) + 0.7152 * linearize(g) + 0.0722 * linearize(b);
    }

    function calcContrastRatio(r1: number, g1: number, b1: number, r2: number, g2: number, b2: number): number {
      const l1 = relativeLuminance(r1, g1, b1);
      const l2 = relativeLuminance(r2, g2, b2);
      const lighter = Math.max(l1, l2);
      const darker = Math.min(l1, l2);
      return (lighter + 0.05) / (darker + 0.05);
    }

    // ============================================================
    // Palette Generation
    // ============================================================
    function generatePalette(hex: string) {
      const rgb = hexToRgb(hex);
      if (!rgb) return;
      const hsl = rgbToHsl(rgb.r, rgb.g, rgb.b);

      const groups = paletteContainer.querySelectorAll('.palette-group') as NodeListOf<HTMLElement>;

      // Complementary
      const compH = (hsl.h + 180) % 360;
      const compRgb = hslToRgb(compH, hsl.s, hsl.l);
      const compHex = rgbToHex(compRgb.r, compRgb.g, compRgb.b);
      renderSwatch(groups[0].querySelector('.palette-swatches') as HTMLElement, [hex, compHex]);

      // Analogous
      const ana1Rgb = hslToRgb((hsl.h - 30 + 360) % 360, hsl.s, hsl.l);
      const ana2Rgb = hslToRgb((hsl.h + 30) % 360, hsl.s, hsl.l);
      renderSwatch(groups[1].querySelector('.palette-swatches') as HTMLElement, [
        rgbToHex(ana1Rgb.r, ana1Rgb.g, ana1Rgb.b),
        hex,
        rgbToHex(ana2Rgb.r, ana2Rgb.g, ana2Rgb.b),
      ]);

      // Triadic
      const tri1Rgb = hslToRgb((hsl.h + 120) % 360, hsl.s, hsl.l);
      const tri2Rgb = hslToRgb((hsl.h + 240) % 360, hsl.s, hsl.l);
      renderSwatch(groups[2].querySelector('.palette-swatches') as HTMLElement, [
        hex,
        rgbToHex(tri1Rgb.r, tri1Rgb.g, tri1Rgb.b),
        rgbToHex(tri2Rgb.r, tri2Rgb.g, tri2Rgb.b),
      ]);

      // Monochromatic
      const shades: string[] = [];
      for (let li = 20; li <= 80; li += 15) {
        const sRgb = hslToRgb(hsl.h, hsl.s, li);
        shades.push(rgbToHex(sRgb.r, sRgb.g, sRgb.b));
      }
      renderSwatchRow(groups[3].querySelector('.palette-swatches') as HTMLElement, shades);
    }

    function renderSwatch(container: HTMLElement, hexes: string[]) {
      container.innerHTML = '';
      hexes.forEach(h => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'w-full h-8 rounded-lg border border-hairline cursor-pointer transition-transform hover:scale-105 shadow-lvl1';
        btn.style.background = h;
        btn.title = h;
        btn.addEventListener('click', () => copyToClipboard(h));
        container.appendChild(btn);
      });
    }

    function renderSwatchRow(container: HTMLElement, hexes: string[]) {
      container.innerHTML = '';
      hexes.forEach(h => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'w-10 h-10 rounded-lg border border-hairline cursor-pointer transition-transform hover:scale-105 shadow-lvl1';
        btn.style.background = h;
        btn.title = h;
        btn.addEventListener('click', () => copyToClipboard(h));
        container.appendChild(btn);
      });
    }

    // ============================================================
    // Gradient Builder
    // ============================================================
    function getGradientDirection(): string {
      const activeDir = document.querySelector('.direction-btn.bg-primary') as HTMLButtonElement;
      if (activeDir && activeDir.dataset.direction) {
        return activeDir.dataset.direction;
      }
      return currentDirection;
    }

    function buildGradientCss(): { css: string; background: string } {
      const stops = gradientStops.querySelectorAll('.gradient-stop') as NodeListOf<HTMLElement>;
      const parts: string[] = [];
      stops.forEach(s => {
        const color = (s.querySelector('.stop-hex') as HTMLInputElement).value;
        const pos = (s.querySelector('.stop-position') as HTMLInputElement).value;
        parts.push(pos ? `${color} ${pos}%` : color);
      });
      const dir = getGradientDirection();
      const bg = `linear-gradient(${dir}, ${parts.join(', ')})`;
      return { css: `background: ${bg};`, background: bg };
    }

    function updateGradient() {
      const result = buildGradientCss();
      gradientPreview.style.background = result.background;
      gradientCss.textContent = result.css;
    }

    function renderGradientStops() {
      const stops = gradientStops.querySelectorAll('.gradient-stop') as NodeListOf<HTMLElement>;
      stops.forEach((s, i) => {
        s.dataset.index = String(i);
        const removeBtn = s.querySelector('.remove-stop') as HTMLButtonElement;
        if (removeBtn) {
          removeBtn.style.display = stops.length <= 2 ? 'none' : '';
        }
      });
      stopCount.textContent = `${stops.length} stop${stops.length === 1 ? '' : 's'}`;
      updateGradient();
    }

    function addGradientStop() {
      const stops = gradientStops.querySelectorAll('.gradient-stop') as NodeListOf<HTMLElement>;
      if (stops.length >= 4) return;
      const last = stops[stops.length - 1];
      const lastColor = (last.querySelector('.stop-hex') as HTMLInputElement).value;
      const lastPos = parseInt((last.querySelector('.stop-position') as HTMLInputElement).value) || 100;
      const newPos = Math.min(100, lastPos - 10);

      const div = document.createElement('div');
      div.className = 'gradient-stop flex items-center gap-3';
      div.innerHTML = `
        <input type="color" class="stop-color w-10 h-10 rounded-lg border border-hairline cursor-pointer p-0.5 bg-canvas-soft shrink-0" value="${lastColor}" style="appearance: none; -webkit-appearance: none; border: none;" />
        <input type="text" class="stop-hex flex-1 h-10 px-3 bg-canvas-soft-2 border border-hairline rounded-lg text-sm font-mono text-ink focus:outline-none focus:border-hairline-strong transition-colors shadow-lvl1" value="${lastColor}" maxlength="7" autocomplete="off" spellcheck="false" />
        <input type="number" class="stop-position w-16 h-10 px-3 bg-canvas-soft-2 border border-hairline rounded-lg text-sm font-mono text-ink focus:outline-none focus:border-hairline-strong transition-colors shadow-lvl1" value="${newPos}" min="0" max="100" autocomplete="off" />
        <span class="text-mute text-[10px] font-mono">%</span>
        <button type="button" class="remove-stop h-8 w-8 border border-hairline bg-canvas hover:border-error text-mute hover:text-error rounded-lg text-xs transition-colors cursor-pointer shadow-lvl1 flex items-center justify-center" title="Remove stop">&times;</button>
      `;
      gradientStops.insertBefore(div, last.nextSibling);

      attachStopListeners(div);
      renderGradientStops();
    }

    function attachStopListeners(stop: HTMLElement) {
      const color = stop.querySelector('.stop-color') as HTMLInputElement;
      const hex = stop.querySelector('.stop-hex') as HTMLInputElement;
      const pos = stop.querySelector('.stop-position') as HTMLInputElement;
      const remove = stop.querySelector('.remove-stop') as HTMLButtonElement;

      color.addEventListener('input', () => {
        hex.value = color.value;
        updateGradient();
      });
      hex.addEventListener('input', () => {
        const rgb = hexToRgb(hex.value);
        if (rgb) {
          color.value = rgbToHex(rgb.r, rgb.g, rgb.b);
          updateGradient();
        }
      });
      pos.addEventListener('input', updateGradient);
      remove.addEventListener('click', () => {
        const all = gradientStops.querySelectorAll('.gradient-stop') as NodeListOf<HTMLElement>;
        if (all.length <= 2) return;
        stop.remove();
        renderGradientStops();
      });
    }

    // ============================================================
    // Copy to Clipboard
    // ============================================================
    async function copyToClipboard(text: string) {
      try {
        await navigator.clipboard.writeText(text);
      } catch { }
    }

    // ============================================================
    // Update All From Color
    // ============================================================
    function updateAllFromHex(hex: string) {
      if (isUpdating) return;
      isUpdating = true;

      const rgb = hexToRgb(hex);
      if (!rgb) { isUpdating = false; return; }

      const hsl = rgbToHsl(rgb.r, rgb.g, rgb.b);

      hexInput.value = hex;
      rInput.value = String(rgb.r);
      gInput.value = String(rgb.g);
      bInput.value = String(rgb.b);
      hInput.value = String(hsl.h);
      sInput.value = String(hsl.s);
      lInput.value = String(hsl.l);

      colorPicker.value = hex;
      previewSwatch.style.background = hex;
      previewLabel.textContent = hex;

      // Update contrast foreground if it matches
      fgColorPicker.value = hex;
      fgHexInput.value = hex;
      updateContrast();

      generatePalette(hex);
      updateGradient();

      isUpdating = false;
    }

    function updateFromRgb() {
      if (isUpdating) return;
      const r = parseInt(rInput.value) || 0;
      const g = parseInt(gInput.value) || 0;
      const b = parseInt(bInput.value) || 0;
      const hex = rgbToHex(r, g, b);
      updateAllFromHex(hex);
    }

    function updateFromHsl() {
      if (isUpdating) return;
      const h = parseInt(hInput.value) || 0;
      const s = parseInt(sInput.value) || 0;
      const l = parseInt(lInput.value) || 0;
      const rgb = hslToRgb(h, s, l);
      const hex = rgbToHex(rgb.r, rgb.g, rgb.b);
      updateAllFromHex(hex);
    }

    // ============================================================
    // Contrast Update
    // ============================================================
    function updateContrast() {
      const fgRgb = hexToRgb(fgHexInput.value);
      const bgRgb = hexToRgb(bgHexInput.value);
      if (!fgRgb || !bgRgb) return;

      const ratio = calcContrastRatio(fgRgb.r, fgRgb.g, fgRgb.b, bgRgb.r, bgRgb.g, bgRgb.b);
      contrastRatioEl.textContent = ratio.toFixed(2);

      const levels: Record<string, number> = {
        'aa-normal': 4.5,
        'aa-large': 3,
        'aaa-normal': 7,
        'aaa-large': 4.5,
      };

      contrastLevels.querySelectorAll('[data-level]').forEach(el => {
        const level = (el as HTMLElement).dataset.level as string;
        const threshold = levels[level];
        const pass = ratio >= threshold;
        const indicator = el.querySelector('.indicator') as HTMLElement;
        if (pass) {
          indicator.className = 'indicator w-4 h-4 rounded-full flex items-center justify-center text-[10px] font-bold bg-emerald-500 text-white';
          indicator.textContent = '✓';
        } else {
          indicator.className = 'indicator w-4 h-4 rounded-full flex items-center justify-center text-[10px] font-bold bg-error text-white';
          indicator.textContent = '✗';
        }
      });
    }

    // ============================================================
    // Debounce
    // ============================================================
    function debounce(fn: () => void, ms = 100) {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(fn, ms);
    }

    // ============================================================
    // Event Listeners
    // ============================================================
    // Color picker
    colorPicker.addEventListener('input', () => updateAllFromHex(colorPicker.value));

    // HEX input
    hexInput.addEventListener('input', () => {
      const val = hexInput.value;
      if (/^#[0-9a-fA-F]{6}$/.test(val) || /^#[0-9a-fA-F]{3}$/.test(val)) {
        debounce(() => updateAllFromHex(val));
      } else if (/^[0-9a-fA-F]{6}$/.test(val) || /^[0-9a-fA-F]{3}$/.test(val)) {
        debounce(() => updateAllFromHex('#' + val));
      }
    });

    // RGB inputs
    [rInput, gInput, bInput].forEach(inp => {
      inp.addEventListener('input', () => debounce(updateFromRgb));
    });

    // HSL inputs
    [hInput, sInput, lInput].forEach(inp => {
      inp.addEventListener('input', () => debounce(updateFromHsl));
    });

    // Contrast inputs
    fgColorPicker.addEventListener('input', () => {
      fgHexInput.value = fgColorPicker.value;
      updateContrast();
    });
    fgHexInput.addEventListener('input', () => {
      const val = fgHexInput.value;
      if (/^#[0-9a-fA-F]{6}$/.test(val)) {
        fgColorPicker.value = val;
        updateContrast();
      }
    });
    bgColorPicker.addEventListener('input', () => {
      bgHexInput.value = bgColorPicker.value;
      updateContrast();
    });
    bgHexInput.addEventListener('input', () => {
      const val = bgHexInput.value;
      if (/^#[0-9a-fA-F]{6}$/.test(val)) {
        bgColorPicker.value = val;
        updateContrast();
      }
    });

    // Copy buttons
    copyBtns.forEach(btn => {
      btn.addEventListener('click', async () => {
        const type = (btn as HTMLElement).dataset.copy;
        let text = '';
        if (type === 'hex') text = hexInput.value;
        else if (type === 'rgb') {
          const r = parseInt(rInput.value) || 0;
          const g = parseInt(gInput.value) || 0;
          const b = parseInt(bInput.value) || 0;
          text = `rgb(${r}, ${g}, ${b})`;
        } else if (type === 'hsl') {
          const h = parseInt(hInput.value) || 0;
          const s = parseInt(sInput.value) || 0;
          const l = parseInt(lInput.value) || 0;
          text = `hsl(${h}, ${s}%, ${l}%)`;
        }
        if (text) {
          await copyToClipboard(text);
          const orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = orig; }, 1200);
        }
      });
    });

    // Direction toggles
    directionBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        directionBtns.forEach(b => {
          b.classList.remove('bg-primary', 'text-on-primary', 'border-primary');
          b.classList.add('bg-canvas', 'text-body', 'border-hairline');
        });
        btn.classList.remove('bg-canvas', 'text-body', 'border-hairline');
        btn.classList.add('bg-primary', 'text-on-primary', 'border-primary');
        currentDirection = btn.dataset.direction || 'to right';
        updateGradient();
      });
    });

    // Custom angle
    applyAngle.addEventListener('click', () => {
      const angle = parseInt(customAngle.value) || 0;
      directionBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-on-primary', 'border-primary');
        b.classList.add('bg-canvas', 'text-body', 'border-hairline');
      });
      currentDirection = `${angle}deg`;
      updateGradient();
    });

    customAngle.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') applyAngle.click();
    });

    // Gradient stops
    addStopBtn.addEventListener('click', addGradientStop);
    gradientStops.querySelectorAll('.gradient-stop').forEach(s => attachStopListeners(s as HTMLElement));

    // Copy gradient CSS
    copyGradientBtn.addEventListener('click', async () => {
      const text = gradientCss.textContent || '';
      if (text) {
        await copyToClipboard(text);
        const orig = copyGradientBtn.textContent;
        copyGradientBtn.textContent = 'Copied!';
        setTimeout(() => { copyGradientBtn.textContent = orig; }, 1200);
      }
    });

    // ============================================================
    // Init
    // ============================================================
    updateAllFromHex('#ff6600');
    generatePalette('#ff6600');
    renderGradientStops();
    updateContrast();
  </script>

  <style is:global>
    input[type="color"]::-webkit-color-swatch-wrapper { padding: 2px; }
    input[type="color"]::-webkit-color-swatch { border: none; border-radius: 8px; }
    input[type="color"]::-moz-color-swatch { border: none; border-radius: 8px; }
  </style>
</Layout>
