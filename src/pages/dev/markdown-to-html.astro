        <button type="button" id="view-preview" class="view-btn px-3 py-1.5 text-[11px] font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer">Preview</button>
        <button type="button" id="view-source" class="view-btn px-3 py-1.5 text-[11px] font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer">Source</button>
