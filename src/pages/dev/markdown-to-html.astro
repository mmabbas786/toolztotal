  <script>
// @ts-nocheck
    const mdInput = document.getElementById('md-input');
    const mdPreview = document.getElementById('md-preview');
    const mdChars = document.getElementById('md-chars');
    const mdWords = document.getElementById('md-words');
    const mdLines = document.getElementById('md-lines');
    const mdRead = document.getElementById('md-read');
    const mdPanes = document.getElementById('md-panes');
    const activeView = document.getElementById('active-view');
    const viewBtns = document.querySelectorAll('.view-btn');

    function escapeHtml(s) {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function parseMarkdown(md) {
      let html = md
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/^###### (.*$)/gim, '<h6>$1</h6>')
        .replace(/^##### (.*$)/gim, '<h5>$1</h5>')
        .replace(/^#### (.*$)/gim, '<h4>$1</h4>')
        .replace(/^### (.*$)/gim, '<h3>$1</h3>')
        .replace(/^## (.*$)/gim, '<h2>$1</h2>')
        .replace(/^# (.*$)/gim, '<h1>$1</h1>')
        .replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>')
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/~~(.*?)~~/g, '<del>$1</del>')
        .replace(/!\[(.*?)\]\((.*?)\)/g, '<img src="$2" alt="$1">')
        .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
        .replace(/```(\w+)?\n([\s\S]*?)```/g, '<pre><code class="language-$1">$2</code></pre>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/^\> (.*$)/gim, '<blockquote>$1</blockquote>')
        .replace(/^---$/gim, '<hr>')
        .replace(/((?:\|.*?\|\n)+)/g, function(match) {
          const rows = match.trim().split('\n');
          let tableHtml = '<table>';
          rows.forEach((row, i) => {
            const cells = row.split('|').filter(c => c.trim() !== '');
            tableHtml += i === 0 ? '<thead><tr>' : '<tr>';
            cells.forEach(cell => {
              const tag = i === 0 ? 'th' : 'td';
              tableHtml += `<${tag}>${cell.trim()}</${tag}>`;
            });
            tableHtml += '</tr>';
            if (i === 0) tableHtml += '</thead><tbody>';
          });
          tableHtml += '</tbody></table>';
          return tableHtml;
        })
        .replace(/^\d+\. (.*$)/gim, '<li class="ordered">$1</li>')
        .replace(/^\- \[x\] (.*$)/gim, '<li class="task done"><input type="checkbox" checked disabled> $1</li>')
        .replace(/^\- \[ \] (.*$)/gim, '<li class="task"><input type="checkbox" disabled> $1</li>')
        .replace(/^\- (.*$)/gim, '<li class="unordered">$1</li>');
      // wrap consecutive <li> into lists
      html = html.replace(/(<li[^>]*>[\s\S]*?<\/li>)(?:\s*(<li[^>]*>[\s\S]*?<\/li>))+/g, function(block) {
        const isOrdered = block.includes('class="ordered"');
        return `<${isOrdered ? 'ol' : 'ul'}>${block}</${isOrdered ? 'ol' : 'ul'}>`;
      });
      return html;
    }

    function updateStats(text) {
      mdChars.textContent = `Characters: ${text.length}`;
      const words = text.trim() ? text.trim().split(/\s+/).length : 0;
      mdWords.textContent = `Words: ${words}`;
      mdLines.textContent = `Lines: ${text ? text.split('\n').length : 0}`;
      mdRead.textContent = `Read time: ${Math.max(1, Math.ceil(words / 200))} min`;
    }

    function render() {
      const text = mdInput.value;
      mdPreview.innerHTML = parseMarkdown(text);
      updateStats(text);
    }

    function showToast(msg) {
      let toast = document.getElementById('md-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'md-toast';
        toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 bg-primary text-on-primary text-xs font-sans px-4 py-2.5 rounded-full shadow-lvl5 z-50 transition-opacity duration-300';
        document.body.appendChild(toast);
      }
      toast.textContent = msg || 'Copied to clipboard';
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2000);
    }

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => showToast()).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showToast();
      });
    }

    mdInput.addEventListener('input', render);

    document.getElementById('md-copy-html').addEventListener('click', () => {
      copyToClipboard(parseMarkdown(mdInput.value));
    });
    document.getElementById('md-copy-md').addEventListener('click', () => {
      copyToClipboard(mdInput.value);
    });
    document.getElementById('md-download').addEventListener('click', () => {
      const blob = new Blob([parseMarkdown(mdInput.value)], { type: 'text/html' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'converted.html';
      a.click();
      URL.revokeObjectURL(url);
    });
    document.getElementById('md-clear').addEventListener('click', () => {
      mdInput.value = '';
      render();
    });
    document.getElementById('md-sample').addEventListener('click', () => {
      mdInput.value = `# Welcome to Markdown\n\nThis is **bold**, this is *italic*, and this is ~~strikethrough~~.\n\n## Lists\n\n- [x] Write Markdown\n- [ ] Render HTML\n- [ ] Ship it\n\n## Table\n\n| Name | Role |\n| --- | --- |\n| Ada | Engineer |\n| Linus | Maintainer |\n\n> Blockquotes are great for callouts.\n\n\`\`\`js\nconsole.log('hello world');\n\`\`\`\n\nVisit [ToolzTotal](https://toolztotal.com) for more tools.`;
      render();
    });

    function setView(view) {
      activeView.value = view;
      viewBtns.forEach(b => {
        const active = b.id === `view-${view}`;
        b.classList.toggle('bg-primary', active);
        b.classList.toggle('text-on-primary', active);
        b.classList.toggle('shadow-lvl2', active);
        b.classList.toggle('text-mute', !active);
        b.classList.toggle('hover:text-ink', !active);
      });
      mdPanes.className = 'grid gap-4 ' + (view === 'split' ? 'grid-cols-1 lg:grid-cols-2' : 'grid-cols-1');
      if (view === 'preview') {
        mdInput.parentElement.style.display = 'none';
        mdPreview.parentElement.style.display = '';
      } else if (view === 'source') {
        mdInput.parentElement.style.display = '';
        mdPreview.parentElement.style.display = 'none';
      } else {
        mdInput.parentElement.style.display = '';
        mdPreview.parentElement.style.display = '';
      }
    }

    viewBtns.forEach(btn => btn.addEventListener('click', () => setView(btn.id.replace('view-', ''))));

    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach(toggle => {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        const content = toggle.nextElementSibling;
        const icon = toggle.querySelector('svg');
        toggle.setAttribute('aria-expanded', String(!expanded));
        if (expanded) {
          content.classList.add('hidden');
          icon.classList.remove('rotate-180');
        } else {
          content.classList.remove('hidden');
          icon.classList.add('rotate-180');
        }
      });
    });

    setView('split');
    render();
  </script>

    <RelatedTools
      categorySlug="dev"
      toolSlug="markdown-to-html"
    />

  <ContentFooter category="dev" />
</Layout>
