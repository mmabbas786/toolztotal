---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What Markdown syntax is supported?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This tool supports standard Markdown (CommonMark) including: headings (# to ######), bold (**text**), italic (*text*), strikethrough (~~text~~), links ([text](url)), images (![alt](url)), code (backticks), code blocks (triple backticks), blockquotes (>), lists (ordered and unordered), tables, horizontal rules (---), and task lists (- [ ] and - [x])."
      }
    },
    {
      "@type": "Question",
      "name": "Is the Markdown conversion secure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. This tool runs entirely in your browser. However, if you copy the HTML output and render it on a website, be aware that Markdown can contain HTML tags. Always sanitize HTML output on your server using a library like DOMPurify or sanitize-html before rendering user-generated content."
      }
    },
    {
      "@type": "Question",
      "name": "Can I preview the rendered HTML?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The right panel shows a live split-pane preview of the rendered HTML as you type. You can toggle between preview-only and source-only modes, or use side-by-side view."
      }
    },
    {
      "@type": "Question",
      "name": "How do I copy the HTML output?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Click the 'Copy HTML' button in the toolbar to copy the raw HTML to your clipboard. You can also click 'Copy Markdown' to copy the source text, or download the HTML as a .html file."
      }
    },
    {
      "@type": "Question",
      "name": "Does this support GitHub Flavored Markdown?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. In addition to standard Markdown, this tool supports GFM extensions including: tables, task lists, strikethrough, and autolinks. This is useful for README files, GitHub issues, and documentation."
      }
    }
  ]
});
---

<Layout
  title="Markdown to HTML Converter - Live Preview & Export | ToolzTotal"
  description="Convert Markdown to HTML with a live split-pane preview, GFM support, stats, and one-click copy or download. Fully client-side."
  canonicalUrl="https://toolztotal.com/dev/markdown-to-html"
  faqJsonLd={faqSchema}
>
  <ToolSchema
    toolName="Markdown to HTML"
    toolSlug="markdown-to-html"
    categoryName="Developer Tools"
    categorySlug="dev"
    description="Convert Markdown to HTML with a live split-pane preview, GFM support, stats, and one-click copy or download. Fully client-side."
  />

  <div class="max-w-[1200px] mx-auto px-4 md:px-6 py-12 md:py-20">

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 ring-1 ring-inset ring-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Markdown to HTML Converter
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Write Markdown on the left, see clean HTML on the right — live. Supports CommonMark plus GitHub
        Flavored Markdown, with copy, download, and a stats bar. Everything runs locally.
      </p>
    </div>

    <!-- Toolbar -->
    <div class="flex flex-wrap items-center gap-2 mb-4">
      <button type="button" id="md-copy-html" class="h-9 px-3 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink font-sans text-xs rounded-md shadow-lvl1 transition-colors flex items-center gap-1.5 cursor-pointer">
        Copy HTML
      </button>
      <button type="button" id="md-copy-md" class="h-9 px-3 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink font-sans text-xs rounded-md shadow-lvl1 transition-colors flex items-center gap-1.5 cursor-pointer">
        Copy Markdown
      </button>
      <button type="button" id="md-download" class="h-9 px-3 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink font-sans text-xs rounded-md shadow-lvl1 transition-colors flex items-center gap-1.5 cursor-pointer">
