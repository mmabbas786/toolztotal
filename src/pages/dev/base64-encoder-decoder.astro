  <!-- Client Script -->
  <script>
// @ts-nocheck
    // ---- DOM refs ----
    const inputArea = document.getElementById('input-area') as HTMLTextAreaElement;
    const outputArea = document.getElementById('output-area') as HTMLDivElement;
    const inputStatus = document.getElementById('input-status') as HTMLSpanElement;
    const outputStatus = document.getElementById('output-status') as HTMLSpanElement;
    const charCount = document.getElementById('char-count') as HTMLSpanElement;
    const inputContainer = document.getElementById('input-container') as HTMLDivElement;

    const modeEncode = document.getElementById('mode-encode') as HTMLButtonElement;
    const modeDecode = document.getElementById('mode-decode') as HTMLButtonElement;
    const modeBtns = document.querySelectorAll('.mode-btn') as NodeListOf<HTMLButtonElement>;

    const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
    const fileInfo = document.getElementById('file-info') as HTMLDivElement;
    const fileName = document.getElementById('file-name') as HTMLSpanElement;
    const fileSize = document.getElementById('file-size') as HTMLSpanElement;
    const fileClear = document.getElementById('file-clear') as HTMLButtonElement;

    const imagePreviewContainer = document.getElementById('image-preview-container') as HTMLDivElement;
    const imagePreview = document.getElementById('image-preview') as HTMLImageElement;

    const btnUpload = document.getElementById('btn-upload') as HTMLButtonElement;
    const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;
    const btnDownload = document.getElementById('btn-download') as HTMLButtonElement;
    const btnSwap = document.getElementById('btn-swap') as HTMLButtonElement;
    const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

    const infoCard = document.getElementById('info-card') as HTMLDivElement;
    const infoInputSize = document.getElementById('info-input-size') as HTMLSpanElement;
    const infoOutputSize = document.getElementById('info-output-size') as HTMLSpanElement;
    const infoSizeChange = document.getElementById('info-size-change') as HTMLSpanElement;
    const infoMode = document.getElementById('info-mode') as HTMLSpanElement;

    // ---- state ----
    let currentMode: 'encode' | 'decode' = 'encode';
    let currentFile: File | null = null;
    let currentDataUri: string | null = null;
    let lastOutputText = '';

    // ---- helpers ----
    function formatBytes(bytes: number): string {
      if (bytes === 0) return '0 bytes';
      const k = 1024;
      const sizes = ['bytes', 'KB', 'MB', 'GB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      const val = bytes / Math.pow(k, i);
      return val.toFixed(i > 0 ? 2 : 0) + ' ' + sizes[i];
    }

    function updateCharCount(text: string) {
      charCount.textContent = `${text.length} char${text.length !== 1 ? 's' : ''}`;
    }

    function updateInfo(inputSize: number, outputSize: number, mode: string) {
      infoInputSize.textContent = formatBytes(inputSize);
      infoOutputSize.textContent = formatBytes(outputSize);
      const change = inputSize > 0 ? ((outputSize - inputSize) / inputSize * 100).toFixed(1) : '0';
      infoSizeChange.textContent = `${change > 0 ? '+' : ''}${change}%`;
      infoMode.textContent = mode.charAt(0).toUpperCase() + mode.slice(1);
      infoCard.classList.remove('hidden');
    }

    function setModePill(active: HTMLButtonElement) {
      modeBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl1');
        b.classList.add('text-mute', 'hover:text-ink');
        b.setAttribute('aria-selected', 'false');
      });
      active.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl1');
      active.classList.remove('text-mute', 'hover:text-ink');
      active.setAttribute('aria-selected', 'true');
    }

    // ---- escape HTML ----
    function escapeHtml(str: string) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // ---- encode logic ----
    function encodeText(text: string): string {
      try {
        return btoa(unescape(encodeURIComponent(text)));
      } catch {
        return btoa(text);
      }
    }

    function decodeBase64(str: string): string {
      try {
        const cleaned = str.replace(/^data:[^;]+;base64,/, '');
        const binary = atob(cleaned);
        const bytes = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) {
          bytes[i] = binary.charCodeAt(i);
        }
        return new TextDecoder().decode(bytes);
      } catch {
        return '';
      }
    }

    function isDataUri(str: string): boolean {
      return /^data:\w+\/\w+;base64,/.test(str.trim());
    }

    function getMimeFromDataUri(uri: string): string {
      const match = uri.match(/^data:(\w+\/\w+);base64,/);
      return match ? match[1] : '';
    }

    function isImageMime(mime: string): boolean {
      return ['image/png', 'image/jpeg', 'image/gif', 'image/webp', 'image/svg+xml', 'image/bmp'].includes(mime);
    }

    // ---- process ----
    function process() {
      const raw = inputArea.value;
      updateCharCount(raw);

      if (!raw.trim()) {
        outputArea.innerHTML = '<span class="text-mute/50 text-sm">' + (currentMode === 'encode' ? 'Encoded output will appear here.' : 'Decoded output will appear here.') + '</span>';
        outputStatus.textContent = 'ready';
        imagePreviewContainer.classList.add('hidden');
        lastOutputText = '';
        return;
      }

      inputStatus.textContent = `${raw.length} chars`;

      if (currentMode === 'encode') {
        // Encode mode
        const encoded = encodeText(raw);
        outputArea.textContent = encoded;
        outputStatus.textContent = 'encoded';
        lastOutputText = encoded;

        // Show preview for data URIs if user pasted one
        if (isDataUri(raw)) {
          const mime = getMimeFromDataUri(raw);
          if (isImageMime(mime)) {
            imagePreview.src = raw;
            imagePreviewContainer.classList.remove('hidden');
          } else {
            imagePreviewContainer.classList.add('hidden');
          }
        } else {
          imagePreviewContainer.classList.add('hidden');
        }

        updateInfo(raw.length, encoded.length, 'encode');
      } else {
        // Decode mode
        const trimmed = raw.trim();
        let decoded: string;
        let isImage = false;
        let mimeType = '';

        // Check if it's a data URI
        if (isDataUri(trimmed)) {
          mimeType = getMimeFromDataUri(trimmed);
          isImage = isImageMime(mimeType);
          try {
            const base64Part = trimmed.replace(/^data:[^;]+;base64,/, '');
            atob(base64Part);
            decoded = decodeBase64(trimmed);
          } catch {
            outputArea.innerHTML = '<span class="text-error text-sm font-mono">Invalid Base64 string</span>';
            outputStatus.textContent = 'error';
            imagePreviewContainer.classList.add('hidden');
            lastOutputText = '';
            return;
          }
        } else {
          try {
            atob(trimmed);
            decoded = decodeBase64(trimmed);
          } catch {
            outputArea.innerHTML = '<span class="text-error text-sm font-mono">Invalid Base64 string</span>';
            outputStatus.textContent = 'error';
            imagePreviewContainer.classList.add('hidden');
            lastOutputText = '';
            return;
          }
        }

        outputArea.textContent = decoded;
        outputStatus.textContent = 'decoded';
        lastOutputText = decoded;

        if (isImage && isDataUri(trimmed)) {
          imagePreview.src = trimmed;
          imagePreviewContainer.classList.remove('hidden');
        } else {
          imagePreviewContainer.classList.add('hidden');
        }

        updateInfo(trimmed.length, decoded.length, 'decode');
      }
    }

    // ---- mode switching ----
    function switchMode(mode: 'encode' | 'decode') {
      currentMode = mode;
      setModePill(mode === 'encode' ? modeEncode : modeDecode);

      inputArea.value = '';
      outputArea.innerHTML = '<span class="text-mute/50 text-sm">' + (mode === 'encode' ? 'Encoded output will appear here.' : 'Decoded output will appear here.') + '</span>';
      outputStatus.textContent = 'ready';
      inputStatus.textContent = 'waiting for input';
      charCount.textContent = '0 chars';
      imagePreviewContainer.classList.add('hidden');
      currentFile = null;
      currentDataUri = null;
      fileInfo.classList.add('hidden');
      dropZone.classList.add('hidden');
      lastOutputText = '';
      infoCard.classList.add('hidden');

      // Update upload button and placeholder
      if (mode === 'encode') {
        btnUpload.classList.remove('hidden');
        inputArea.placeholder = 'Enter text to encode, or drag & drop an image/file...';
      } else {
        btnUpload.classList.add('hidden');
        inputArea.placeholder = 'Paste Base64 string here to decode...';
      }
    }

    modeEncode.addEventListener('click', () => switchMode('encode'));
    modeDecode.addEventListener('click', () => switchMode('decode'));

    // ---- swap ----
    btnSwap.addEventListener('click', () => {
      const outputText = lastOutputText;
      const targetMode = currentMode === 'encode' ? 'decode' : 'encode';
      switchMode(targetMode);
      if (outputText) {
        inputArea.value = outputText;
        process();
      }
    });

    // ---- input events ----
    inputArea.addEventListener('input', () => {
      currentFile = null;
      currentDataUri = null;
      fileInfo.classList.add('hidden');
      process();
    });

    // ---- file drag-and-drop ----
    let dragCounter = 0;

    function handleFile(file: File) {
      currentFile = file;
      fileName.textContent = file.name;

      const sizes = ['B', 'KB', 'MB', 'GB'];
      const i = Math.floor(Math.log(file.size) / Math.log(1024));
      const sz = (file.size / Math.pow(1024, i)).toFixed(i > 0 ? 1 : 0) + ' ' + sizes[i];
      fileSize.textContent = sz;

      fileInfo.classList.remove('hidden');

      const reader = new FileReader();
      reader.onload = (e) => {
        const dataUri = e.target?.result as string;
        currentDataUri = dataUri;
        inputArea.value = dataUri;
        dropZone.classList.add('hidden');
        process();
      };
      reader.readAsDataURL(file);
    }

    btnUpload.addEventListener('click', () => {
      const fileInput = document.createElement('input');
      fileInput.type = 'file';
      fileInput.accept = '*/*';
      fileInput.onchange = () => {
        if (fileInput.files && fileInput.files.length > 0) {
          handleFile(fileInput.files[0]);
        }
      };
      fileInput.click();
    });

    inputContainer.addEventListener('dragenter', (e) => {
      if (currentMode !== 'encode') return;
      e.preventDefault();
      dragCounter++;
      if (dragCounter === 1) {
        dropZone.classList.remove('hidden');
        dropZone.classList.add('border-primary');
      }
    });

    inputContainer.addEventListener('dragover', (e) => {
      if (currentMode !== 'encode') return;
      e.preventDefault();
    });

    inputContainer.addEventListener('dragleave', (e) => {
      if (currentMode !== 'encode') return;
      e.preventDefault();
      dragCounter--;
      if (dragCounter <= 0) {
        dragCounter = 0;
        dropZone.classList.add('hidden');
        dropZone.classList.remove('border-primary');
      }
    });

    inputContainer.addEventListener('drop', (e) => {
      if (currentMode !== 'encode') return;
      e.preventDefault();
      dragCounter = 0;
      dropZone.classList.add('hidden');
      dropZone.classList.remove('border-primary');
      if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
        handleFile(e.dataTransfer.files[0]);
      }
    });

    document.addEventListener('dragover', (e) => e.preventDefault());
    document.addEventListener('drop', (e) => e.preventDefault());

    // ---- file clear ----
    fileClear.addEventListener('click', () => {
      currentFile = null;
      currentDataUri = null;
      fileInfo.classList.add('hidden');
      inputArea.value = '';
      outputArea.innerHTML = '<span class="text-mute/50 text-sm">Encoded output will appear here.</span>';
      outputStatus.textContent = 'ready';
      inputStatus.textContent = 'waiting for input';
      charCount.textContent = '0 chars';
      imagePreviewContainer.classList.add('hidden');
      lastOutputText = '';
      infoCard.classList.add('hidden');
    });

    // ---- copy ----
    btnCopy.addEventListener('click', async () => {
      const text = lastOutputText;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        outputStatus.textContent = 'copied!';
        setTimeout(() => { outputStatus.textContent = currentMode === 'encode' ? 'encoded' : 'decoded'; }, 1500);
      } catch {
        outputStatus.textContent = 'copy failed';
      }
    });

    // ---- download ----
    btnDownload.addEventListener('click', () => {
      const content = lastOutputText;
      if (!content) return;

      let mimeType = 'text/plain';
      let ext = 'txt';
      let filename = currentMode === 'encode' ? 'encoded-base64' : 'decoded-output';

      if (currentMode === 'encode' && currentDataUri && isDataUri(currentDataUri)) {
        mimeType = getMimeFromDataUri(currentDataUri);
        const mimeToExt: Record<string, string> = {
          'image/png': 'png', 'image/jpeg': 'jpg', 'image/gif': 'gif',
          'image/webp': 'webp', 'image/svg+xml': 'svg', 'image/bmp': 'bmp',
          'application/pdf': 'pdf', 'application/json': 'json',
        };
        ext = mimeToExt[mimeType] || 'bin';
        filename = 'base64-data-uri.' + ext;
      } else if (currentMode === 'decode') {
        if (isDataUri(content)) {
          mimeType = getMimeFromDataUri(content) || 'text/plain';
          const mimeToExt: Record<string, string> = {
            'image/png': 'png', 'image/jpeg': 'jpg', 'image/gif': 'gif',
            'image/webp': 'webp', 'image/svg+xml': 'svg', 'image/bmp': 'bmp',
          };
          ext = mimeToExt[mimeType] || 'bin';
          filename = 'decoded-file.' + ext;
        }
      }

      const blob = new Blob([content], { type: mimeType });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.style.display = 'none';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    // ---- clear ----
    btnClear.addEventListener('click', () => {
      inputArea.value = '';
      outputArea.innerHTML = '<span class="text-mute/50 text-sm">' + (currentMode === 'encode' ? 'Encoded output will appear here.' : 'Decoded output will appear here.') + '</span>';
      outputStatus.textContent = 'ready';
      inputStatus.textContent = 'waiting for input';
      charCount.textContent = '0 chars';
      imagePreviewContainer.classList.add('hidden');
      currentFile = null;
      currentDataUri = null;
      fileInfo.classList.add('hidden');
      if (currentMode === 'encode') dropZone.classList.remove('hidden');
      lastOutputText = '';
      infoCard.classList.add('hidden');
    });

    // ---- FAQ accordion ----
    document.querySelectorAll('details').forEach(detail => {
      const summary = detail.querySelector('summary');
      if (summary) {
        summary.addEventListener('click', (e) => {
          e.preventDefault();
          const isOpen = detail.hasAttribute('open');
          if (isOpen) {
            detail.removeAttribute('open');
          } else {
            detail.setAttribute('open', '');
          }
        });
      }
    });

    // ---- resize synchronization ----
    if (typeof ResizeObserver !== 'undefined') {
      const ro = new ResizeObserver(entries => {
        for (const entry of entries) {
          outputArea.style.height = `${inputArea.offsetHeight}px`;
        }
      });
      ro.observe(inputArea);
    }

    // ---- init ----
    switchMode('encode');
  </script>

