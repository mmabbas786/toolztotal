  <style is:global>
    .diff-line { display: flex; min-height: 1.6em; border-bottom: 1px solid var(--color-hairline); }
    .diff-line:last-child { border-bottom: none; }
    .diff-ln { width: 44px; min-width: 44px; text-align: right; padding: 1px 8px 1px 4px; font-size: 11px; color: var(--color-mute); user-select: none; border-right: 1px solid var(--color-hairline); background: var(--color-canvas-soft); }
    .diff-content { flex: 1; padding: 1px 12px; white-space: pre-wrap; word-break: break-all; font-size: 13px; }
    .diff-equal { background: var(--color-canvas); }
    .diff-equal .diff-content { color: var(--color-ink); }
    .diff-add { background: color-mix(in srgb, #22c55e 12%, transparent); }
    .diff-add .diff-content { color: var(--color-ink); }
    .diff-del { background: color-mix(in srgb, #ef4444 12%, transparent); }
    .diff-del .diff-content { color: var(--color-ink); }
    .diff-replace { background: color-mix(in srgb, #f59e0b 10%, transparent); }
    .diff-replace .diff-content { color: var(--color-ink); }
    .wd-add { background: color-mix(in srgb, #22c55e 35%, transparent); border-radius: 2px; padding: 0 1px; }
    .wd-del { background: color-mix(in srgb, #ef4444 35%, transparent); border-radius: 2px; padding: 0 1px; text-decoration: line-through; }
    .inline-sign { width: 22px; min-width: 22px; text-align: center; font-weight: 700; font-size: 13px; user-select: none; }
    .inline-plus { color: #22c55e; }
    .inline-minus { color: #ef4444; }
  </style>

  <script>
    // ---- DOM refs ----
    const textOriginal = document.getElementById('text-original') as HTMLTextAreaElement;
    const textChanged = document.getElementById('text-changed') as HTMLTextAreaElement;
    const originalLines = document.getElementById('original-lines') as HTMLSpanElement;
    const changedLines = document.getElementById('changed-lines') as HTMLSpanElement;

    const viewSide = document.getElementById('view-side') as HTMLButtonElement;
    const viewInline = document.getElementById('view-inline') as HTMLButtonElement;
    const viewBtns = document.querySelectorAll('.view-btn') as NodeListOf<HTMLButtonElement>;

    const optIgnoreWS = document.getElementById('opt-ignore-whitespace') as HTMLInputElement;
    const optIgnoreCase = document.getElementById('opt-ignore-case') as HTMLInputElement;

    const btnSwap = document.getElementById('btn-swap') as HTMLButtonElement;
    const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;

    const diffStats = document.getElementById('diff-stats') as HTMLDivElement;
    const statAdditions = document.getElementById('stat-additions') as HTMLSpanElement;
    const statDeletions = document.getElementById('stat-deletions') as HTMLSpanElement;
    const statUnchanged = document.getElementById('stat-unchanged') as HTMLSpanElement;

    const diffOutputSide = document.getElementById('diff-output-side') as HTMLDivElement;
    const diffOutputInline = document.getElementById('diff-output-inline') as HTMLDivElement;
    const diffSideLeft = document.getElementById('diff-side-left') as HTMLDivElement;
    const diffSideRight = document.getElementById('diff-side-right') as HTMLDivElement;
    const diffInlineContent = document.getElementById('diff-inline-content') as HTMLDivElement;
    const diffTiming = document.getElementById('diff-timing') as HTMLSpanElement;
    const inlineTiming = document.getElementById('inline-timing') as HTMLSpanElement;

    // ---- LCS-based diff ----
    function lcsLength(x: string[], y: string[]): number[][] {
      const m = x.length;
      const n = y.length;
      const dp: number[][] = Array.from({ length: m + 1 }, () => new Uint16Array(n + 1));
      for (let i = 1; i <= m; i++) {
        for (let j = 1; j <= n; j++) {
          dp[i][j] = x[i - 1] === y[j - 1] ? dp[i - 1][j - 1] + 1 : Math.max(dp[i - 1][j], dp[i][j - 1]);
        }
      }
      return dp as number[][];
    }

    interface DiffOp {
      type: 'equal' | 'insert' | 'delete' | 'replace';
      aIndex: number;
      bIndex: number;
      textA: string;
      textB: string;
    }

    function backtrack(
      dp: number[][], x: string[], y: string[], i: number, j: number,
      aStart: number, bStart: number, ops: DiffOp[]
    ) {
      if (i === 0 && j === 0) return;

      const ai = aStart + i - 1;
      const bj = bStart + j - 1;

      if (i > 0 && j > 0 && x[i - 1] === y[j - 1]) {
        backtrack(dp, x, y, i - 1, j - 1, aStart, bStart, ops);
        ops.push({ type: 'equal', aIndex: ai, bIndex: bj, textA: x[i - 1], textB: y[j - 1] });
      } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {
        backtrack(dp, x, y, i, j - 1, aStart, bStart, ops);
        ops.push({ type: 'insert', aIndex: -1, bIndex: bj, textA: '', textB: y[j - 1] });
      } else if (i > 0) {
        backtrack(dp, x, y, i - 1, j, aStart, bStart, ops);
        ops.push({ type: 'delete', aIndex: ai, bIndex: -1, textA: x[i - 1], textB: '' });
      }
    }

    function computeDiff(a: string[], b: string[]): DiffOp[] {
      const m = a.length;
      const n = b.length;

      if (m === 0 && n === 0) return [];
      if (m === 0) return b.map((t, j) => ({ type: 'insert' as const, aIndex: -1, bIndex: j, textA: '', textB: t }));
      if (n === 0) return a.map((t, i) => ({ type: 'delete' as const, aIndex: i, bIndex: -1, textA: t, textB: '' }));

      // Split into smaller chunks for efficiency
      const ops: DiffOp[] = [];
      let ai = 0, bj = 0;

      // Find common prefix
      while (ai < m && bj < n && a[ai] === b[bj]) {
        ops.push({ type: 'equal', aIndex: ai, bIndex: bj, textA: a[ai], textB: b[bj] });
        ai++; bj++;
      }

      // Find common suffix
      let ae = m - 1, be = n - 1;
      while (ae >= ai && be >= bj && a[ae] === b[be]) {
        ae--; be--;
      }

      const suffix: DiffOp[] = [];
      let sae = ae + 1, sbe = be + 1;
      while (sae < m && sbe < n && a[sae] === b[sbe]) {
        suffix.push({ type: 'equal', aIndex: sae, bIndex: sbe, textA: a[sae], textB: b[sbe] });
        sae++; sbe++;
      }

      // Diff the middle section
      const midA = a.slice(ai, ae + 1);
      const midB = b.slice(bj, be + 1);

      if (midA.length === 0 && midB.length === 0) {
        // nothing to do
      } else if (midA.length === 0) {
        for (let j = 0; j < midB.length; j++) {
          ops.push({ type: 'insert', aIndex: -1, bIndex: bj + j, textA: '', textB: midB[j] });
        }
      } else if (midB.length === 0) {
        for (let i = 0; i < midA.length; i++) {
          ops.push({ type: 'delete', aIndex: ai + i, bIndex: -1, textA: midA[i], textB: '' });
        }
      } else if (midA.length * midB.length <= 10000) {
        const dp = lcsLength(midA, midB);
        const midOps: DiffOp[] = [];
        backtrack(dp, midA, midB, midA.length, midB.length, ai, bj, midOps);

        // Merge adjacent delete+insert into replace
        const merged: DiffOp[] = [];
        for (let k = 0; k < midOps.length; k++) {
          const op = midOps[k];
          if (op.type === 'delete' && k + 1 < midOps.length && midOps[k + 1].type === 'insert') {
            const next = midOps[k + 1];
            merged.push({ type: 'replace', aIndex: op.aIndex, bIndex: next.bIndex, textA: op.textA, textB: next.textB });
            k++;
          } else {
            merged.push(op);
          }
        }
        ops.push(...merged);
      } else {
        // Fallback for large inputs: simple line-by-line
        const maxLen = Math.max(midA.length, midB.length);
        for (let k = 0; k < maxLen; k++) {
          if (k < midA.length && k < midB.length) {
            if (midA[k] === midB[k]) {
              ops.push({ type: 'equal', aIndex: ai + k, bIndex: bj + k, textA: midA[k], textB: midB[k] });
            } else {
              ops.push({ type: 'replace', aIndex: ai + k, bIndex: bj + k, textA: midA[k], textB: midB[k] });
            }
          } else if (k < midA.length) {
            ops.push({ type: 'delete', aIndex: ai + k, bIndex: -1, textA: midA[k], textB: '' });
          } else {
            ops.push({ type: 'insert', aIndex: -1, bIndex: bj + k, textA: '', textB: midB[k] });
          }
        }
      }

      ops.push(...suffix);
      return ops;
    }

    // ---- Word-level diff ----
    function wordDiff(a: string, b: string): { text: string; type: 'equal' | 'add' | 'del' }[] {
      if (a === b) return [{ text: a, type: 'equal' }];
      const wordsA = a.split(/(\s+)/);
      const wordsB = b.split(/(\s+)/);
      const result: { text: string; type: 'equal' | 'add' | 'del' }[] = [];

      const m = wordsA.length, n = wordsB.length;
      if (m === 0 && n === 0) return result;
      if (m === 0) return wordsB.map(w => ({ text: w, type: 'add' as const }));

      const dp: number[][] = Array.from({ length: m + 1 }, () => new Uint16Array(n + 1));
      for (let i = 1; i <= m; i++) {
        for (let j = 1; j <= n; j++) {
          dp[i][j] = wordsA[i - 1] === wordsB[j - 1] ? dp[i - 1][j - 1] + 1 : Math.max(dp[i - 1][j], dp[i][j - 1]);
        }
      }

      function backtrackWords(i: number, j: number) {
        if (i === 0 && j === 0) return;
        if (i > 0 && j > 0 && wordsA[i - 1] === wordsB[j - 1]) {
          backtrackWords(i - 1, j - 1);
          result.push({ text: wordsA[i - 1], type: 'equal' });
        } else if (j > 0 && (i === 0 || dp[i][j - 1] >= dp[i - 1][j])) {
          backtrackWords(i, j - 1);
          result.push({ text: wordsB[j - 1], type: 'add' });
        } else if (i > 0) {
          backtrackWords(i - 1, j);
          result.push({ text: wordsA[i - 1], type: 'del' });
        }
      }

      backtrackWords(m, n);
      return result;
    }

    function escapeHtml(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    function normalizeLine(s: string, ignoreWS: boolean, ignoreCase: boolean): string {
      let r = s;
      if (ignoreWS) r = r.trim().replace(/\s+/g, ' ');
      if (ignoreCase) r = r.toLowerCase();
      return r;
    }

    // ---- Main diff engine ----
    function runDiff() {
      const rawA = textOriginal.value;
      const rawB = textChanged.value;
      const ignoreWS = optIgnoreWS.checked;
      const ignoreCase = optIgnoreCase.checked;

      originalLines.textContent = rawA ? `${rawA.split('\n').length} lines` : '0 lines';
      changedLines.textContent = rawB ? `${rawB.split('\n').length} lines` : '0 lines';

      const start = performance.now();
      const linesA = rawA === '' ? [] : rawA.split('\n');
      const linesB = rawB === '' ? [] : rawB.split('\n');

      // Normalize for comparison
      const normA = linesA.map(l => normalizeLine(l, ignoreWS, ignoreCase));
      const normB = linesB.map(l => normalizeLine(l, ignoreWS, ignoreCase));

      const ops = computeDiff(normA, normB);

      // Calculate stats
      let additions = 0, deletions = 0, unchanged = 0;
      for (const op of ops) {
        if (op.type === 'equal') unchanged++;
        else if (op.type === 'insert') additions++;
        else if (op.type === 'delete') deletions++;
        else if (op.type === 'replace') { additions++; deletions++; }
      }

      const hasContent = ops.length > 0;
      if (hasContent) {
        diffStats.classList.remove('hidden');
        statAdditions.textContent = `${additions} addition${additions !== 1 ? 's' : ''}`;
        statDeletions.textContent = `${deletions} deletion${deletions !== 1 ? 's' : ''}`;
        statUnchanged.textContent = `${unchanged} unchanged`;
      } else {
        diffStats.classList.add('hidden');
      }

      const elapsed = Math.round((performance.now() - start) * 100) / 100;
      const timing = `Computed in ${elapsed}ms`;

      // ---- Render side-by-side ----
      let leftHtml = '', rightHtml = '';
      for (const op of ops) {
        const cls = op.type === 'equal' ? 'diff-equal' : op.type === 'insert' ? 'diff-add' : op.type === 'delete' ? 'diff-del' : 'diff-replace';

        if (op.type === 'replace' && op.textA && op.textB) {
          const wordPartsA = wordDiff(op.textA, op.textB);
          const wordPartsB = wordDiff(op.textA, op.textB);
          leftHtml += `<div class="diff-line ${cls}"><span class="diff-ln">${op.aIndex + 1}</span><span class="diff-content">`;
          for (const part of wordPartsA) {
            if (part.type === 'del') leftHtml += `<span class="wd-del">${escapeHtml(part.text)}</span>`;
            else if (part.type === 'add') { /* skip in left */ }
            else leftHtml += escapeHtml(part.text);
          }
          leftHtml += '</span></div>';

          const lnB = op.bIndex + 1;
          rightHtml += `<div class="diff-line ${cls}"><span class="diff-ln">${lnB}</span><span class="diff-content">`;
          for (const part of wordPartsB) {
            if (part.type === 'add') rightHtml += `<span class="wd-add">${escapeHtml(part.text)}</span>`;
            else if (part.type === 'del') { /* skip in right */ }
            else rightHtml += escapeHtml(part.text);
          }
          rightHtml += '</span></div>';
        } else {
          if (op.type !== 'insert') {
            leftHtml += `<div class="diff-line ${cls}"><span class="diff-ln">${op.aIndex + 1}</span><span class="diff-content">${escapeHtml(op.textA)}</span></div>`;
          } else {
            leftHtml += `<div class="diff-line diff-add"><span class="diff-ln">&nbsp;</span><span class="diff-content">&nbsp;</span></div>`;
          }

          if (op.type !== 'delete') {
            rightHtml += `<div class="diff-line ${cls}"><span class="diff-ln">${op.bIndex + 1}</span><span class="diff-content">${escapeHtml(op.textB)}</span></div>`;
          } else {
            rightHtml += `<div class="diff-line diff-del"><span class="diff-ln">&nbsp;</span><span class="diff-content">&nbsp;</span></div>`;
          }
        }
      }

      diffSideLeft.innerHTML = leftHtml || '<div class="p-4 text-mute text-xs">No content to display.</div>';
      diffSideRight.innerHTML = rightHtml || '<div class="p-4 text-mute text-xs">No content to display.</div>';
      diffTiming.textContent = timing;

      // ---- Render inline ----
      let inlineHtml = '';
      for (const op of ops) {
        const cls = op.type === 'equal' ? 'diff-equal' : op.type === 'insert' ? 'diff-add' : op.type === 'delete' ? 'diff-del' : 'diff-replace';
        const sign = op.type === 'insert' ? '+' : op.type === 'delete' ? '-' : ' ';
        const signCls = op.type === 'insert' ? 'inline-plus' : op.type === 'delete' ? 'inline-minus' : '';

        if (op.type === 'replace' && op.textA && op.textB) {
          const wordParts = wordDiff(op.textA, op.textB);
          inlineHtml += `<div class="diff-line ${cls}"><span class="diff-ln">${op.aIndex + 1}</span><span class="inline-sign ${signCls}">&minus;</span><span class="diff-content">`;
          for (const part of wordParts) {
            if (part.type === 'del') inlineHtml += `<span class="wd-del">${escapeHtml(part.text)}</span>`;
            else if (part.type !== 'add') inlineHtml += escapeHtml(part.text);
          }
          inlineHtml += '</span></div>';
          inlineHtml += `<div class="diff-line ${cls}"><span class="diff-ln">${op.bIndex + 1}</span><span class="inline-sign ${signCls}">+</span><span class="diff-content">`;
          for (const part of wordParts) {
            if (part.type === 'add') inlineHtml += `<span class="wd-add">${escapeHtml(part.text)}</span>`;
            else if (part.type !== 'del') inlineHtml += escapeHtml(part.text);
          }
          inlineHtml += '</span></div>';
        } else {
          if (op.type !== 'insert') {
            inlineHtml += `<div class="diff-line ${cls}"><span class="diff-ln">${op.aIndex + 1}</span><span class="inline-sign ${signCls}">${escapeHtml(sign)}</span><span class="diff-content">${escapeHtml(op.textA)}</span></div>`;
          }
          if (op.type !== 'delete') {
            inlineHtml += `<div class="diff-line ${cls}"><span class="diff-ln">${op.bIndex + 1}</span><span class="inline-sign ${signCls}">${escapeHtml(sign)}</span><span class="diff-content">${escapeHtml(op.textB)}</span></div>`;
          }
        }
      }

      diffInlineContent.innerHTML = inlineHtml || '<div class="p-4 text-mute text-xs">No content to display.</div>';
      inlineTiming.textContent = timing;
    }

    // ---- View toggle ----
    function setActiveView(active: HTMLButtonElement) {
      viewBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl1');
        b.classList.add('text-mute', 'hover:text-ink');
      });
      active.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl1');
      active.classList.remove('text-mute', 'hover:text-ink');
    }

    viewSide.addEventListener('click', () => {
      setActiveView(viewSide);
      diffOutputSide.classList.remove('hidden');
      diffOutputInline.classList.add('hidden');
    });

    viewInline.addEventListener('click', () => {
      setActiveView(viewInline);
      diffOutputSide.classList.add('hidden');
      diffOutputInline.classList.remove('hidden');
    });

    // ---- Swap ----
    btnSwap.addEventListener('click', () => {
      const tmp = textOriginal.value;
      textOriginal.value = textChanged.value;
      textChanged.value = tmp;
      runDiff();
    });

    // ---- Clear ----
    btnClear.addEventListener('click', () => {
      textOriginal.value = '';
      textChanged.value = '';
      diffSideLeft.innerHTML = '';
      diffSideRight.innerHTML = '';
      diffInlineContent.innerHTML = '';
      diffStats.classList.add('hidden');
      originalLines.textContent = '0 lines';
      changedLines.textContent = '0 lines';
      diffTiming.textContent = '';
      inlineTiming.textContent = '';
    });

    // ---- Auto-run on input ----
    let debounceTimer: number | null = null;
    function debouncedDiff() {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(runDiff, 200);
    }

    textOriginal.addEventListener('input', debouncedDiff);
    textChanged.addEventListener('input', debouncedDiff);
    optIgnoreWS.addEventListener('change', debouncedDiff);
    optIgnoreCase.addEventListener('change', debouncedDiff);

    // ---- resize synchronization ----
    if (typeof ResizeObserver !== 'undefined') {
      let isSyncing = false;
      const ro = new ResizeObserver(entries => {
        if (isSyncing) return;
        isSyncing = true;
        for (const entry of entries) {
          const h = (entry.target as HTMLElement).offsetHeight;
          if (entry.target === textOriginal) {
            textChanged.style.height = `${h}px`;
          } else if (entry.target === textChanged) {
            textOriginal.style.height = `${h}px`;
          }
        }
        isSyncing = false;
      });
      ro.observe(textOriginal);
      ro.observe(textChanged);
    }

    // ---- Init with sample data ----
    textOriginal.value = `function greet(name) {
  console.log("Hello, " + name + "!");
  return true;
}

const PI = 3.14;
let count = 0;

if (count > 10) {
  console.log("Too many!");
}`;

    textChanged.value = `function greet(name) {
  console.log(\`Hello, \${name}!\`);
  return true;
}

const PI = 3.14159;
let counter = 0;

if (counter > 5) {
  console.log("Too many!");
  alert("Limit reached");
}`;

    runDiff();
  </script>
</Layout>
