---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a cryptographic hash function?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A hash function takes input data of any size and produces a fixed-size string of characters (the hash). Good hash functions are one-way (cannot reverse the hash to get the original input), deterministic (same input = same output), and avalanche (small input change = completely different hash)."
      }
    },
    {
      "@type": "Question",
      "name": "Which hash algorithm should I use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For security: use SHA-256 or SHA-3. SHA-1 and MD5 are considered cryptographically broken due to collision vulnerabilities. MD5 should never be used for security purposes. SHA-256 is the current industry standard for digital signatures, certificates, and blockchain."
      }
    },
    {
      "@type": "Question",
      "name": "What is a hash collision?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A collision occurs when two different inputs produce the same hash output. Good hash functions make collisions computationally infeasible. MD5 and SHA-1 have known collision attacks, meaning two different files can be crafted to have the same hash. SHA-256 has no known practical collision attacks."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use this tool to hash passwords?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Password hashing requires specialized algorithms like bcrypt, Argon2, or PBKDF2 that are intentionally slow to resist brute-force attacks. This tool generates fast cryptographic hashes suitable for checksums and file verification, not password storage."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between hashing and encryption?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hashing is one-way: you cannot recover the original data from the hash. Encryption is two-way: you can decrypt encrypted data back to its original form using a key. Use hashing for integrity verification and passwords; use encryption when you need to retrieve the original data."
      }
    }
  ]
});
