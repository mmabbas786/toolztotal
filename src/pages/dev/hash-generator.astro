        b = ii(b, c, d, a, x[k+9],  S44, 0xEB86D391);
        a = addUnsigned(a, AA);
        b = addUnsigned(b, BB);
        c = addUnsigned(c, CC);
        d = addUnsigned(d, DD);
      }
      return wordToHex(a) + wordToHex(b) + wordToHex(c) + wordToHex(d);
    }

    async function compute(dataBytes, isFile) {
      hashResults.innerHTML = '';
      const textVal = isFile ? null : hashInput.value;
      for (const algo of selectedAlgos) {
        let result = '';
        try {
          if (algo === 'MD5') {
            if (isFile && currentFileBytes) {
              let bin = '';
              for (let i = 0; i < currentFileBytes.length; i++) bin += String.fromCharCode(currentFileBytes[i]);
              result = md5(bin);
            } else {
              result = md5(textVal || '');
            }
          } else {
            result = await shaHash(algo, dataBytes);
          }
        } catch (e) {
          result = 'Error computing ' + algo;
        }
        const card = document.createElement('div');
        card.className = 'bg-canvas-soft border border-hairline rounded-lg p-4 shadow-lvl1 flex items-center justify-between gap-4';
        const left = document.createElement('div');
        left.className = 'min-w-0';
        const label = document.createElement('span');
        label.className = 'text-[10px] font-mono uppercase text-mute';
        label.textContent = algo;
        const code = document.createElement('code');
        code.className = 'block text-sm font-mono text-ink break-all select-all mt-1';
        code.textContent = result;
        left.appendChild(label);
        left.appendChild(code);
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'hash-copy-btn h-8 w-8 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink rounded-md shadow-lvl1 transition-colors flex items-center justify-center flex-shrink-0 cursor-pointer';
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>';
        btn.setAttribute('data-hash', result);
        btn.addEventListener('click', () => copyToClipboard(result));
        card.appendChild(left);
        card.appendChild(btn);
        hashResults.appendChild(card);
      }
    }

    let currentFileBytes = null;

    function recompute() {
      if (currentFileBytes) {
        compute(currentFileBytes, true);
      } else {
        const text = hashInput.value;
        compute(utf8Bytes(text), false);
      }
    }

    function updateSize() {
      const bytes = utf8Bytes(hashInput.value);
      hashSize.textContent = `${bytes.length} bytes`;
    }

    function showToast(msg) {
      let toast = document.getElementById('hash-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'hash-toast';
        toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 bg-primary text-on-primary text-xs font-sans px-4 py-2.5 rounded-full shadow-lvl5 z-50 transition-opacity duration-300';
        document.body.appendChild(toast);
      }
      toast.textContent = msg || 'Copied to clipboard';
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2000);
    }

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => showToast()).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showToast();
      });
    }

    hashInput.addEventListener('input', () => {
      currentFileBytes = null;
      hashFileName.textContent = '';
      updateSize();
      recompute();
    });

    hashClearText.addEventListener('click', () => {
      hashInput.value = '';
      currentFileBytes = null;
      hashFileName.textContent = '';
      updateSize();
      recompute();
    });

    hashDrop.addEventListener('click', () => {
      const input = document.createElement('input');
      input.type = 'file';
      input.onchange = () => {
        if (input.files && input.files[0]) handleFile(input.files[0]);
      };
      input.click();
    });

    function handleFile(file) {
      hashFileName.textContent = file.name;
      const reader = new FileReader();
      reader.onload = (e) => {
        const buf = e.target.result;
        currentFileBytes = new Uint8Array(buf);
        compute(currentFileBytes, true);
      };
      reader.readAsArrayBuffer(file);
    }

    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach(toggle => {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        const content = toggle.nextElementSibling;
        const icon = toggle.querySelector('svg');
        toggle.setAttribute('aria-expanded', String(!expanded));
        if (expanded) {
          content.classList.add('hidden');
          icon.classList.remove('rotate-180');
        } else {
          content.classList.remove('hidden');
          icon.classList.add('rotate-180');
        }
      });
    });

    updateSize();
    recompute();
  </script>

