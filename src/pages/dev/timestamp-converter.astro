  <script>
// @ts-nocheck
    const activeMode = document.getElementById('active-mode');
    const tsModeBtns = document.querySelectorAll('.ts-mode-btn');
    const tsInputRow = document.getElementById('ts-input-row');
    const dateInputRow = document.getElementById('date-input-row');
    const tsInput = document.getElementById('ts-input');
    const tsNow = document.getElementById('ts-now');
    const dateInput = document.getElementById('date-input');
    const dateNow = document.getElementById('date-now');
    const tzSelect = document.getElementById('tz-select');
    const tsOutput = document.getElementById('ts-output');
    const tsFormatList = document.getElementById('ts-format-list');
    const tsDetected = document.getElementById('ts-detected');
    const tsCopyAll = document.getElementById('ts-copy-all');

    const detectedTz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';

    function pad(n) { return String(n).padStart(2, '0'); }

    function formatLocal(d, tz) {
      return new Intl.DateTimeFormat('en-US', {
        timeZone: tz,
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit', second: '2-digit',
        hour12: false
      }).format(d);
    }

    function relativeTime(targetMs) {
      const diff = targetMs - Date.now();
      const abs = Math.abs(diff);
      const units = [
        ['year', 31536000000], ['month', 2592000000], ['day', 86400000],
        ['hour', 3600000], ['minute', 60000], ['second', 1000]
      ];
      for (const [name, ms] of units) {
        const v = Math.floor(abs / ms);
        if (v >= 1) {
          return diff >= 0 ? `in ${v} ${name}${v > 1 ? 's' : ''}` : `${v} ${name}${v > 1 ? 's' : ''} ago`;
        }
      }
      return 'just now';
    }

    function setMode(mode) {
      activeMode.value = mode;
      tsModeBtns.forEach(b => {
        const active = b.id === `mode-${mode}`;
        b.classList.toggle('bg-primary', active);
        b.classList.toggle('text-on-primary', active);
        b.classList.toggle('shadow-lvl1', active);
        b.classList.toggle('text-mute', !active);
        b.classList.toggle('hover:text-ink', !active);
      });
      if (mode === 'ts') {
        tsInputRow.classList.remove('hidden');
        dateInputRow.classList.add('hidden');
      } else {
        tsInputRow.classList.add('hidden');
        dateInputRow.classList.remove('hidden');
      }
      run();
    }

    tsModeBtns.forEach(btn => btn.addEventListener('click', () => setMode(btn.id.replace('mode-', ''))));

    function tsToDate() {
      const raw = tsInput.value.trim();
      if (!raw || isNaN(Number(raw))) {
        tsOutput.classList.add('hidden');
        tsDetected.textContent = '';
        return;
      }
      let ts = Number(raw);
      let unit = 'milliseconds';
      if (raw.length <= 11) { ts = ts * 1000; unit = 'seconds'; }
      const d = new Date(ts);
      if (isNaN(d.getTime())) { tsOutput.classList.add('hidden'); return; }
      tsDetected.textContent = `Detected as ${unit} (${raw.length} digits)`;
      const tz = tzSelect.value === 'auto' ? detectedTz : tzSelect.value;
      const rows = [
        ['ISO 8601', d.toISOString()],
        ['UTC', d.toUTCString()],
        [`Local (${tz})`, formatLocal(d, tz)],
        ['Relative', relativeTime(d.getTime())],
        ['Unix (seconds)', Math.floor(d.getTime() / 1000)],
        ['Unix (milliseconds)', d.getTime()]
      ];
      renderRows(rows);
    }

    function dateToTs() {
      const raw = dateInput.value;
      if (!raw) { tsOutput.classList.add('hidden'); return; }
      const d = new Date(raw);
      if (isNaN(d.getTime())) { tsOutput.classList.add('hidden'); return; }
      const tz = tzSelect.value === 'auto' ? detectedTz : tzSelect.value;
      const rows = [
        ['Unix (seconds)', Math.floor(d.getTime() / 1000)],
        ['Unix (milliseconds)', d.getTime()],
        ['ISO 8601', d.toISOString()],
        ['UTC', d.toUTCString()],
        [`Local (${tz})`, formatLocal(d, tz)],
        ['Relative', relativeTime(d.getTime())]
      ];
      renderRows(rows);
    }

    function renderRows(rows) {
      tsFormatList.innerHTML = '';
      let allText = '';
      rows.forEach(([label, value]) => {
        allText += `${label}: ${value}\n`;
        const card = document.createElement('div');
        card.className = 'bg-canvas-soft border border-hairline rounded-lg p-4 shadow-lvl1 flex items-center justify-between gap-4';
        const left = document.createElement('div');
        left.className = 'min-w-0';
        const lab = document.createElement('span');
        lab.className = 'text-[10px] font-mono uppercase text-mute';
        lab.textContent = label;
        const val = document.createElement('code');
        val.className = 'block text-sm font-mono text-ink break-all select-all mt-1';
        val.textContent = String(value);
        left.appendChild(lab);
        left.appendChild(val);
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'h-8 w-8 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink rounded-md shadow-lvl1 transition-colors flex items-center justify-center flex-shrink-0 cursor-pointer';
        btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>';
        btn.addEventListener('click', () => copyToClipboard(String(value)));
        card.appendChild(left);
        card.appendChild(btn);
        tsFormatList.appendChild(card);
      });
      tsOutput.classList.remove('hidden');
      tsCopyAll.onclick = () => copyToClipboard(allText.trim());
    }

    function showToast(msg) {
      let toast = document.getElementById('ts-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'ts-toast';
        toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 bg-primary text-on-primary text-xs font-sans px-4 py-2.5 rounded-full shadow-lvl5 z-50 transition-opacity duration-300';
        document.body.appendChild(toast);
      }
      toast.textContent = msg || 'Copied to clipboard';
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 2000);
    }

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => showToast()).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showToast();
      });
    }

    function toLocalInputValue(d) {
      return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    function run() {
      if (activeMode.value === 'ts') tsToDate();
      else dateToTs();
    }

    tsInput.addEventListener('input', tsToDate);
    dateInput.addEventListener('input', dateToTs);
    tzSelect.addEventListener('change', run);
    tsNow.addEventListener('click', () => {
      const now = Math.floor(Date.now() / 1000);
      tsInput.value = String(now);
      tsToDate();
    });
    dateNow.addEventListener('click', () => {
      dateInput.value = toLocalInputValue(new Date());
      dateToTs();
    });

    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach(toggle => {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        const content = toggle.nextElementSibling;
        const icon = toggle.querySelector('svg');
        toggle.setAttribute('aria-expanded', String(!expanded));
        if (expanded) {
          content.classList.add('hidden');
          icon.classList.remove('rotate-180');
        } else {
          content.classList.remove('hidden');
          icon.classList.add('rotate-180');
        }
      });
    });

    // init
    tsInput.value = String(Math.floor(Date.now() / 1000));
    dateInput.value = toLocalInputValue(new Date());
    setMode('ts');
  </script>

    <RelatedTools
      categorySlug="dev"
      toolSlug="timestamp-converter"
    />

  <ContentFooter category="dev" />
</Layout>
