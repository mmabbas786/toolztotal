    </section>

    <!-- Related Developer Tools -->
    <section class="mt-20 pt-16 border-t border-hairline">
      <h2 class="text-xs font-mono uppercase tracking-wider text-mute mb-6">Related Developer Tools</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
