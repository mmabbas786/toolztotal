---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a Unix timestamp?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A Unix timestamp (also called Epoch time or Unix Epoch time) is the number of seconds (or milliseconds) that have elapsed since January 1, 1970, 00:00:00 UTC, not counting leap seconds. It is the standard way computers represent time."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between Unix timestamp in seconds and milliseconds?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Unix timestamps can be expressed in seconds (10 digits, e.g., 1710000000) or milliseconds (13 digits, e.g., 1710000000000). JavaScript Date uses milliseconds. Many APIs use seconds. This tool handles both automatically."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Year 2038 problem?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "32-bit signed integers max out at 2,147,483,647 seconds, which is January 19, 2038, 03:14:07 UTC. Systems using 32-bit signed time_t will overflow after this date. Modern 64-bit systems don't have this problem."
      }
    },
    {
      "@type": "Question",
      "name": "How do I convert a timestamp to a human-readable date?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiply seconds by 1000 to get milliseconds, then use Date constructor: new Date(timestamp * 1000). The Date object provides methods to format the date in any timezone, including ISO strings, locale strings, and custom formats."
      }
    },
    {
      "@type": "Question",
      "name": "Can timestamps represent future dates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Unix timestamps can represent any date from 1970 to approximately year 292,277,026,596 for 64-bit systems. Future timestamps are commonly used for scheduling, token expiration (like JWTs), and countdown timers."
      }
    }
  ]
});
---

<Layout
  title="Unix Timestamp Converter - Seconds & Milliseconds to Date | ToolzTotal"
  description="Convert Unix timestamps to dates and dates to timestamps. Supports seconds and milliseconds, multiple formats, timezone detection, and relative time — fully client-side."
  canonicalUrl="https://toolztotal.com/dev/timestamp-converter"
  faqJsonLd={faqSchema}
>
  <ToolSchema
    toolName="Timestamp Converter"
    toolSlug="timestamp-converter"
    categoryName="Developer Tools"
    categorySlug="dev"
    description="Convert Unix timestamps to dates and dates to timestamps. Supports seconds and milliseconds, multiple formats, timezone detection, and relative time — fully client-side."
  />

  <div class="max-w-[1000px] mx-auto px-4 md:px-6 py-12 md:py-20">

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 ring-1 ring-inset ring-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Unix Timestamp Converter
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Convert between Unix timestamps (seconds or milliseconds) and human-readable dates. Auto-detects your
        timezone, shows ISO/UTC/local formats, and computes relative time — all in your browser.
      </p>
    </div>

    <!-- Workspace -->
    <div class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl p-6 md:p-8 shadow-lvl3 space-y-6">

      <!-- Mode Tabs -->
      <div>
        <label class="block text-xs font-mono uppercase text-mute mb-3">Mode</label>
        <div class="flex rounded-lg bg-canvas-soft-2 p-1 border border-hairline shadow-lvl1 w-fit gap-1">
          <button type="button" id="mode-ts" class="ts-mode-btn px-4 py-2 text-xs font-sans font-semibold whitespace-nowrap rounded-md bg-primary text-on-primary shadow-lvl1 cursor-pointer transition-all">
            Timestamp &rarr; Date
          </button>
          <button type="button" id="mode-date" class="ts-mode-btn px-4 py-2 text-xs font-sans font-semibold whitespace-nowrap rounded-md text-mute hover:text-ink cursor-pointer transition-all">
            Date &rarr; Timestamp
          </button>
        </div>
        <input type="hidden" id="active-mode" value="ts" />
      </div>

      <!-- Timestamp input -->
      <div id="ts-input-row">
        <label for="ts-input" class="block text-xs font-mono uppercase text-mute mb-2">Unix Timestamp</label>
        <div class="flex gap-3 flex-wrap">
          <input
            type="number"
            id="ts-input"
            class="flex-1 min-w-[200px] bg-canvas-soft border border-hairline rounded-lg px-4 py-3 text-sm font-mono text-ink focus:outline-none focus:ring-1 focus:ring-primary shadow-lvl1 tabular-nums [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
            placeholder="e.g. 1710000000"
          />
          <button type="button" id="ts-now" class="h-[42px] px-4 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink font-sans text-xs rounded-md shadow-lvl1 transition-colors cursor-pointer whitespace-nowrap">
