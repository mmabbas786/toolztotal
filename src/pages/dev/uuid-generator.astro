  </div>

  <script>
// @ts-nocheck
    // DOM refs
    const versionBtns = document.querySelectorAll('.version-btn');
    const activeVersion = document.getElementById('active-version');
    const bulkCount = document.getElementById('bulk-count');
    const countDec = document.getElementById('count-dec');
    const countInc = document.getElementById('count-inc');
    const caseBtns = document.querySelectorAll('.case-btn');
    const activeCase = document.getElementById('active-case');
    const dashBtns = document.querySelectorAll('.dash-btn');
    const activeDashes = document.getElementById('active-dashes');
    const generateBtn = document.getElementById('generate-btn');
    const resultsSection = document.getElementById('results-section');
    const singleDisplay = document.getElementById('single-display');
    const uuidOutput = document.getElementById('uuid-output');
    const bulkDisplay = document.getElementById('bulk-display');
    const bulkGrid = document.getElementById('bulk-grid');
    const copyAllBtn = document.getElementById('copy-all-btn');
    const copyToast = document.getElementById('copy-toast');
    const resultsCountLabel = document.getElementById('results-count-label');
    const resultsTimestamp = document.getElementById('results-timestamp');
    const infoCard = document.getElementById('info-card');
    const infoVersionBadge = document.getElementById('info-version-badge');
    const infoDescription = document.getElementById('info-description');
    const infoRfcLink = document.getElementById('info-rfc-link');
    const infoUuidsCount = document.getElementById('info-uuids-count');
    const infoGenTime = document.getElementById('info-gen-time');

    // UUID constants
    const UUID_EPOCH_OFFSET = 122192928000000000n; // BigInt — gregorian offset to Unix epoch in 100ns units
    const VARIANT_BITS = 0x80;

    function randomBytes(n) {
      const bytes = new Uint8Array(n);
      crypto.getRandomValues(bytes);
      return bytes;
    }

    function hex(b, upper) {
      return upper ? b.toString(16).padStart(2, '0').toUpperCase() : b.toString(16).padStart(2, '0');
    }

    function bytesToHex(bytes, dashes, upper) {
      const h = Array.from(bytes).map(b => hex(b, upper)).join('');
      if (!dashes) return h;
      return h.slice(0, 8) + '-' + h.slice(8, 12) + '-' + h.slice(12, 16) + '-' + h.slice(16, 20) + '-' + h.slice(20, 32);
    }

    function generateV4(upper, dashes) {
      const bytes = randomBytes(16);
      bytes[6] = (bytes[6] & 0x0f) | 0x40;
      bytes[8] = (bytes[8] & 0x3f) | VARIANT_BITS;
      return bytesToHex(bytes, dashes, upper);
    }

    function generateV1(upper, dashes) {
      // All timestamp math in BigInt to preserve 60-bit precision.
      // JS bitwise ops coerce to 32-bit signed int, so >> on values > 2^31 gives wrong results.
      const now = BigInt(Date.now());
      const ts100ns = now * 10000n + UUID_EPOCH_OFFSET; // 100ns ticks since UUID epoch (1582-10-15)

      // Extract the three timestamp fields per RFC 4122 §4.1.3
      const timeLow  = ts100ns & 0xffffffffn;          // bits 0-31
      const timeMid  = (ts100ns >> 32n) & 0xffffn;     // bits 32-47
      const timeHi   = (ts100ns >> 48n) & 0x0fffn;    // bits 48-59

      const clockSeqHi  = (0x10 & 0x3f) | VARIANT_BITS;
      const clockSeqLow = randomBytes(1)[0] & 0xff;
      const node = randomBytes(6);

      // Convert BigInt fields to Number only here at the byte boundary
      const tl = Number(timeLow);
      const tm = Number(timeMid);
      const th = Number(timeHi);

      const bytes = new Uint8Array(16);
      bytes[0] = (tl >> 24) & 0xff;
      bytes[1] = (tl >> 16) & 0xff;
      bytes[2] = (tl >> 8)  & 0xff;
      bytes[3] =  tl        & 0xff;
      bytes[4] = (tm >> 8)  & 0xff;
      bytes[5] =  tm        & 0xff;
      bytes[6] = ((th >> 8) & 0x0f) | 0x10; // version nibble = 1
      bytes[7] =  th        & 0xff;
      bytes[8] =  clockSeqHi;
      bytes[9] =  clockSeqLow;
      bytes[10] = node[0];
      bytes[11] = node[1];
      bytes[12] = node[2];
      bytes[13] = node[3];
      bytes[14] = node[4];
      bytes[15] = node[5];

      return bytesToHex(bytes, dashes, upper);
    }

    function generateV7(upper, dashes) {
      const now = Date.now();
      const tsHigh = (now >> 16) & 0xffffffff;
      const tsLow = now & 0xffff;
      const rand = randomBytes(10);

      const bytes = new Uint8Array(16);
      bytes[0] = (tsHigh >> 24) & 0xff;
      bytes[1] = (tsHigh >> 16) & 0xff;
      bytes[2] = (tsHigh >> 8) & 0xff;
      bytes[3] = tsHigh & 0xff;
      bytes[4] = (tsLow >> 8) & 0xff;
      bytes[5] = tsLow & 0xff;
      bytes[6] = (rand[0] & 0x0f) | 0x70;
      bytes[7] = rand[1];
      bytes[8] = (rand[2] & 0x3f) | VARIANT_BITS;
      bytes[9] = rand[3];
      bytes[10] = rand[4];
      bytes[11] = rand[5];
      bytes[12] = rand[6];
      bytes[13] = rand[7];
      bytes[14] = rand[8];
      bytes[15] = rand[9];

      return bytesToHex(bytes, dashes, upper);
    }

    function generate(version, upper, dashes, count) {
      const uuids = [];
      const fn = version === 'v1' ? generateV1 : version === 'v7' ? generateV7 : generateV4;
      for (let i = 0; i < count; i++) {
        uuids.push(fn(upper, dashes));
      }
      return uuids;
    }

    function showToast(msg) {
      copyToast.textContent = msg || 'Copied to clipboard';
      copyToast.classList.remove('hidden');
      setTimeout(() => copyToast.classList.add('hidden'), 2000);
    }

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text).then(() => showToast()).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showToast();
      });
    }

    // Pill toggle helper
    function activatePill(btns, activeId, valueInput) {
      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => {
            b.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl2');
            b.classList.add('text-mute', 'hover:text-ink');
          });
          btn.classList.remove('text-mute', 'hover:text-ink');
          btn.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl2');
          if (valueInput) valueInput.value = btn.id.replace(/^(case|dash|ver)-/, '');
        });
      });
    }

    activatePill(versionBtns, null, activeVersion);
    activatePill(caseBtns, null, activeCase);
    activatePill(dashBtns, null, activeDashes);

    // Bulk count controls
    countDec.addEventListener('click', () => {
      let v = parseInt(bulkCount.value) || 1;
      if (v > 1) bulkCount.value = String(v - 1);
    });
    countInc.addEventListener('click', () => {
      let v = parseInt(bulkCount.value) || 1;
      if (v < 100) bulkCount.value = String(v + 1);
    });
    bulkCount.addEventListener('change', () => {
      let v = parseInt(bulkCount.value) || 1;
      if (v < 1) v = 1;
      if (v > 100) v = 100;
      bulkCount.value = String(v);
    });

    // Version info data
    const versionInfo = {
      v1: {
        badge: 'UUID v1 (Time-Based)',
        desc: 'UUID v1 generates time-based identifiers using the current timestamp (100-ns intervals since October 15, 1582) combined with a random clock sequence and node identifier. These are chronologically sortable.',
        rfc: 'https://datatracker.ietf.org/doc/html/rfc4122'
      },
      v4: {
        badge: 'UUID v4 (Random)',
        desc: 'UUID v4 generates purely random identifiers using 122 bits of entropy from the Web Crypto API. Each UUID is statistically unique and suitable for most applications including database keys, session tokens, and API resource identifiers.',
        rfc: 'https://datatracker.ietf.org/doc/html/rfc4122'
      },
      v7: {
        badge: 'UUID v7 (Time-Ordered)',
        desc: 'UUID v7 (RFC 9562) combines a 48-bit Unix timestamp with random data. It provides time-ordering like v1 without exposing system information, making it ideal for database primary keys and distributed systems.',
        rfc: 'https://datatracker.ietf.org/doc/html/rfc9562'
      }
    };

    function updateInfo(version, count, genTime) {
      const info = versionInfo[version];
      infoVersionBadge.textContent = info.badge;
      infoDescription.textContent = info.desc;
      infoRfcLink.textContent = version === 'v7' ? '9562' : '4122';
      infoRfcLink.href = info.rfc;
      infoUuidsCount.textContent = `UUIDs: ${count}`;
      infoGenTime.textContent = `Generated in ${genTime}ms`;
    }

    // Generate action
    generateBtn.addEventListener('click', () => {
      const ver = activeVersion.value;
      const upper = activeCase.value === 'upper';
      const dashes = activeDashes.value === 'on';
      const count = parseInt(bulkCount.value) || 1;
      const start = performance.now();
      const uuids = generate(ver, upper, dashes, count);
      const elapsed = Math.round((performance.now() - start) * 100) / 100;

      const now = new Date();
      const ts = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });

      resultsSection.classList.remove('hidden');
      resultsTimestamp.textContent = `Generated at ${ts}`;
      resultsCountLabel.textContent = count === 1 ? 'Generated UUID' : `Generated UUIDs (${count})`;

      if (count === 1) {
        singleDisplay.classList.remove('hidden');
        bulkDisplay.classList.add('hidden');
        uuidOutput.textContent = uuids[0];
        const cb = singleDisplay.querySelector('.copy-btn');
        cb.setAttribute('data-uuid', uuids[0]);
      } else {
        singleDisplay.classList.add('hidden');
        bulkDisplay.classList.remove('hidden');
        bulkGrid.innerHTML = '';
        uuids.forEach(u => {
          const div = document.createElement('div');
          div.className = 'flex items-center justify-between gap-3 bg-canvas-soft border border-hairline rounded-lg p-3 shadow-lvl1';
          const code = document.createElement('code');
          code.className = 'text-xs font-mono text-ink break-all select-all flex-1 min-w-0';
          code.textContent = u;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'copy-btn h-7 w-7 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink rounded-md shadow-lvl1 transition-colors flex items-center justify-center flex-shrink-0 cursor-pointer';
          btn.setAttribute('data-uuid', u);
          btn.innerHTML = '<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>';
          btn.addEventListener('click', () => copyToClipboard(u));
          div.appendChild(code);
          div.appendChild(btn);
          bulkGrid.appendChild(div);
        });
      }

      updateInfo(ver, count, elapsed);
      infoCard.classList.remove('hidden');

      // Copy All
      const allText = uuids.join('\n');
      copyAllBtn.onclick = () => copyToClipboard(allText);
    });

    // Copy single UUID
    document.addEventListener('click', (e) => {
      const copyBtn = e.target.closest('.copy-btn');
      if (copyBtn && !copyBtn.closest('#copy-all-btn')) {
        const uuid = copyBtn.getAttribute('data-uuid');
        if (uuid) copyToClipboard(uuid);
      }
    });

    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach(toggle => {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        const content = toggle.nextElementSibling;
        const icon = toggle.querySelector('svg');
        toggle.setAttribute('aria-expanded', String(!expanded));
        if (expanded) {
          content.classList.add('hidden');
          icon.classList.remove('rotate-180');
        } else {
          content.classList.remove('hidden');
          icon.classList.add('rotate-180');
        }
      });
    });
  </script>

