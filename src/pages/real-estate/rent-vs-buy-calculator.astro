      const toggleRentBreakdown = document.getElementById('toggle-rent-breakdown');
      const rentChevron = document.getElementById('rent-chevron');
      const rentBreakdownContainer = document.getElementById('rent-breakdown-container');
      const rentYearlyBreakdown = document.getElementById('rent-yearly-breakdown');
      const toggleBuyBreakdown = document.getElementById('toggle-buy-breakdown');
      const buyChevron = document.getElementById('buy-chevron');
      const buyBreakdownContainer = document.getElementById('buy-breakdown-container');
      const bdBuyPi = document.getElementById('bd-buy-pi');
      const bdBuyTaxIns = document.getElementById('bd-buy-tax-ins');
      const bdBuyTotal = document.getElementById('bd-buy-total');
      const buyYearlyBreakdown = document.getElementById('buy-yearly-breakdown');

      // Chart
      const chartGrid = document.getElementById('chart-grid');
      const chartAxes = document.getElementById('chart-axes');
      const chartLines = document.getElementById('chart-lines');
      const chartLegend = document.getElementById('chart-legend');
      const chartBreakeven = document.getElementById('chart-breakeven');

      // State
      let currentTermYears = 30;

      // Format Helpers
      const fmt = (val) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0,
        }).format(val);
      };

      const fmtCents = (val) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        }).format(val);
      };

      const fmtPct = (val) => {
        return val.toFixed(2) + '%';
      };

      // Inline Amortization Functions
      const getMonthlyPayment = (principal, annualRate, termMonths) => {
        if (principal <= 0 || termMonths <= 0) return 0;
        const r = annualRate / 100 / 12;
        if (r === 0) return principal / termMonths;
        const factor = Math.pow(1 + r, termMonths);
        return principal * (r * factor) / (factor - 1);
      };

      const getRemainingBalance = (principal, annualRate, termMonths, paymentsMade) => {
        if (principal <= 0 || paymentsMade <= 0) return principal;
        const r = annualRate / 100 / 12;
        const monthlyPI = getMonthlyPayment(principal, annualRate, termMonths);
        let balance = principal;
        const n = Math.min(paymentsMade, termMonths);
        for (let m = 1; m <= n; m++) {
          if (balance <= 0) return 0;
          const interestPayment = balance * r;
          const principalPayment = Math.min(balance, monthlyPI - interestPayment);
          balance = Math.max(0, balance - principalPayment);
        }
        return balance;
      };

      const getTotalInterestPaid = (principal, annualRate, termMonths, paymentsMade) => {
        if (principal <= 0 || paymentsMade <= 0) return 0;
        const r = annualRate / 100 / 12;
        const monthlyPI = getMonthlyPayment(principal, annualRate, termMonths);
        let balance = principal;
        let totalInterest = 0;
        const n = Math.min(paymentsMade, termMonths);
        for (let m = 1; m <= n; m++) {
          if (balance <= 0) break;
          const interestPayment = balance * r;
          const principalPayment = Math.min(balance, monthlyPI - interestPayment);
          balance = Math.max(0, balance - principalPayment);
          totalInterest += interestPayment;
        }
        return totalInterest;
      };

      // Core Calculation
      const calculate = () => {
        // Read inputs
        const monthlyRent = Math.max(0, parseFloat(monthlyRentInput.value) || 0);
        const rentIncrease = Math.max(0, parseFloat(rentIncreaseInput.value) || 0) / 100;
        const homePrice = Math.max(0, parseFloat(homePriceInput.value) || 0);
        const downPaymentPct = Math.min(100, Math.max(0, parseFloat(downPaymentInput.value) || 0)) / 100;
        const interestRate = Math.max(0, parseFloat(interestRateInput.value) || 0) / 100;
        const termYears = currentTermYears;
        const annualTaxInsMaintPct = Math.max(0, parseFloat(annualTaxInsMaintInput.value) || 0) / 100;
        const appreciation = parseFloat(appreciationInput.value) || 0;
        const appreciationRate = appreciation / 100;
        const investReturn = Math.max(0, parseFloat(investReturnInput.value) || 0) / 100;
        const timeHorizon = Math.max(1, Math.min(50, Math.round(parseFloat(timeHorizonInput.value) || 1)));
        const closingCostsPct = Math.max(0, parseFloat(closingCostsInput.value) || 0) / 100;
        const sellerCostsPct = Math.max(0, parseFloat(sellerCostsInput.value) || 0) / 100;

        // Compute buy constants
        const downPaymentAmount = homePrice * downPaymentPct;
        const loanAmount = homePrice - downPaymentAmount;
        const termMonths = termYears * 12;
        const monthlyPI = getMonthlyPayment(loanAmount, interestRate * 100, termMonths);
        const monthlyTaxInsMaint = (homePrice * annualTaxInsMaintPct) / 12;
        const monthlyBuyCost = monthlyPI + monthlyTaxInsMaint;
        const closingCostsAmount = homePrice * closingCostsPct;

        // Build year-by-year data
        const rentData = [];
        const buyData = [];
        let cumulativeRentCost = 0;
        let cumulativeBuyCost = closingCostsAmount;

        // Rent scenario: track investment portfolio
        let rentPortfolio = 0;
        let totalRentPaid = 0;

        // Buy scenario: track equity
        let cumulativeBuyOutlay = closingCostsAmount;
        let totalInterestPaid = 0;
        let totalPrincipalPaid = 0;

        for (let year = 1; year <= timeHorizon; year++) {
          // Rent cost for this year (annual)
          const yearlyRent = monthlyRent * 12 * Math.pow(1 + rentIncrease, year - 1);
          cumulativeRentCost += yearlyRent;
          totalRentPaid += yearlyRent;

          // Monthly rent for this year (for display)
          const monthlyRentThisYear = monthlyRent * Math.pow(1 + rentIncrease, year - 1);

          // Buy costs for this year
          const yearlyBuyCost = monthlyBuyCost * 12;
          cumulativeBuyCost += yearlyBuyCost;
          cumulativeBuyOutlay += yearlyBuyCost;

          // Interest & principal for this year
          const paymentsSoFar = year * 12;
          const interestUpToYear = getTotalInterestPaid(loanAmount, interestRate * 100, termMonths, paymentsSoFar);
          const principalPaidSoFar = getTotalPrincipalPaid(loanAmount, interestRate * 100, termMonths, paymentsSoFar);
          totalInterestPaid = interestUpToYear;
          totalPrincipalPaid = principalPaidSoFar;

          // Remaining balance
          const remainingBalance = getRemainingBalance(loanAmount, interestRate * 100, termMonths, paymentsSoFar);

          // Home value
          const homeValue = homePrice * Math.pow(1 + appreciationRate, year);
          const equity = Math.max(0, homeValue - remainingBalance);
          const sellerCosts = homeValue * sellerCostsPct;
          const netEquity = Math.max(0, equity - sellerCosts);

          // Buy net worth = home equity - remaining costs (closing already included)
          const buyNetWorthValue = netEquity - downPaymentAmount - closingCostsAmount;

          // Rent scenario: invest down payment + monthly savings
          const monthlyBuyCostPerMonth = monthlyBuyCost;
          const monthlyRentCostPerMonth = monthlyRentThisYear;
          const monthlySavings = monthlyBuyCostPerMonth - monthlyRentCostPerMonth;

          // Investment return on portfolio (annual compounding for simplicity)
          // At the start of year, the portfolio grows by investReturn
          // Then add monthly savings throughout the year
          rentPortfolio = rentPortfolio * (1 + investReturn);

          // Add down payment on year 1
          if (year === 1) {
            rentPortfolio += downPaymentAmount;
          }

          // Add monthly savings (approximate mid-year contribution)
          for (let m = 0; m < 12; m++) {
            if (monthlySavings > 0) {
              rentPortfolio += monthlySavings;
              rentPortfolio *= Math.pow(1 + investReturn, 1 / 12);
            } else {
              rentPortfolio += monthlySavings; // negative or zero
            }
          }

          // Rent net worth = portfolio value
          const rentNetWorthValue = rentPortfolio;

          // Store data
          rentData.push({
            year,
            monthlyRent: monthlyRentThisYear,
            yearlyRent,
            cumulativeCost: cumulativeRentCost,
            netWorth: rentNetWorthValue,
          });

          buyData.push({
            year,
            monthlyBuyCost,
            yearlyBuyCost,
            cumulativeCost: cumulativeBuyCost,
            equity,
            netEquity,
            netWorth: buyNetWorthValue,
            homeValue,
            remainingBalance,
            totalInterestPaid,
            totalPrincipalPaid,
          });
        }

        // Final values
        const finalRentData = rentData[rentData.length - 1];
        const finalBuyData = buyData[buyData.length - 1];

        // Total cost of renting = cumulative rent (no equity recovery)
        const totalRentCost = finalRentData.cumulativeCost;
        const totalBuyCost = finalBuyData.cumulativeCost;
        const rentFinalNW = finalRentData.netWorth;
        const buyFinalNW = finalBuyData.netWorth;

        // Determine which is cheaper
        const rentIsCheaper = rentFinalNW > buyFinalNW;

        // Find break-even year
        let breakEvenYear = null;
        for (let y = 0; y < timeHorizon; y++) {
          const rnw = rentData[y].netWorth;
          const bnw = buyData[y].netWorth;
          if (bnw >= rnw) {
            breakEvenYear = y + 1;
            break;
          }
        }

        // Update horizon label
        resultHorizonLabel.textContent = timeHorizon;

        // Update primary comparison
        rentTotalCost.textContent = fmt(totalRentCost);
        rentNetWorth.textContent = fmt(rentFinalNW);
        buyTotalCost.textContent = fmt(totalBuyCost);
        buyNetWorth.textContent = fmt(buyFinalNW);

        // Difference
        const diff = Math.abs(rentFinalNW - buyFinalNW);
        if (rentIsCheaper) {
          comparisonResult.className = 'bg-emerald-50 dark:bg-emerald-950/20 border border-emerald-200 dark:border-emerald-800 rounded-lg p-4 flex items-center justify-between shadow-lvl1';
          differenceAmount.textContent = `Renting saves ${fmt(diff)}`;
          differenceAmount.className = 'text-lg font-bold text-emerald-600 font-sans tabular-nums';
        } else {
          comparisonResult.className = 'bg-violet-50 dark:bg-violet-950/20 border border-violet-200 dark:border-violet-800 rounded-lg p-4 flex items-center justify-between shadow-lvl1';
          differenceAmount.textContent = `Buying saves ${fmt(diff)}`;
          differenceAmount.className = 'text-lg font-bold text-violet-600 font-sans tabular-nums';
        }

        // Break-even message
        if (breakEvenYear !== null && breakEvenYear <= timeHorizon) {
          if (breakEvenYear === 1) {
            breakEvenMessage.innerHTML = 'Buying is cheaper from <strong>year 1</strong>. Home equity and appreciation outweigh the upfront costs immediately.';
          } else {
            breakEvenMessage.innerHTML = `Renting is cheaper for the first <strong>${breakEvenYear - 1} year${breakEvenYear - 1 === 1 ? '' : 's'}</strong>. After that, buying becomes more financially favorable.`;
          }
        } else if (buyData.length > 0 && buyData[0].netWorth >= rentData[0].netWorth) {
          breakEvenMessage.innerHTML = 'Buying is cheaper from <strong>year 1</strong>. Home equity and appreciation outweigh the upfront costs immediately.';
        } else {
          breakEvenMessage.innerHTML = 'Renting remains cheaper throughout this time horizon. Consider a longer time frame or lower home purchase costs.';
        }

        // Update comparison table
        const avgMonthlyRent = totalRentCost / (timeHorizon * 12);
        compRentMonthly.textContent = fmtCents(avgMonthlyRent);
        compBuyMonthly.textContent = fmtCents(monthlyBuyCost);
        compRentTotal.textContent = fmt(totalRentCost);
        compBuyTotal.textContent = fmt(totalBuyCost);
        compBuyInterest.textContent = fmt(totalInterestPaid);
        compBuyPrincipal.textContent = fmt(totalPrincipalPaid);
        compBuyEquity.textContent = fmt(finalBuyData.equity);
        compRentPortfolio.textContent = fmt(rentFinalNW);
        compRentNetWorth.textContent = fmt(rentFinalNW);
        compBuyNetWorth.textContent = fmt(buyFinalNW);

        // Update buy breakdown
        bdBuyPi.textContent = fmtCents(monthlyPI);
        bdBuyTaxIns.textContent = fmtCents(monthlyTaxInsMaint);
        bdBuyTotal.textContent = fmtCents(monthlyBuyCost);

        // Update rent yearly breakdown
        let rentHtml = '';
        rentData.forEach(d => {
          rentHtml += `<div class="flex items-center justify-between py-1 border-b border-hairline last:border-0">
            <span class="text-mute">Year ${d.year}</span>
            <span class="font-semibold text-ink">${fmtCents(d.monthlyRent)}/mo</span>
          </div>`;
        });
        rentYearlyBreakdown.innerHTML = rentHtml;

        // Update buy yearly breakdown
        let buyHtml = '';
        buyData.forEach(d => {
          buyHtml += `<div class="flex items-center justify-between py-1 border-b border-hairline last:border-0">
            <span class="text-mute">Year ${d.year}</span>
            <span class="font-semibold text-ink">Equity: ${fmt(d.equity)}</span>
          </div>`;
        });
        buyYearlyBreakdown.innerHTML = buyHtml;

        // Render Chart
        renderChart(rentData, buyData, timeHorizon, breakEvenYear);
      };

      // Helper: total principal paid
      const getTotalPrincipalPaid = (principal, annualRate, termMonths, paymentsMade) => {
        if (principal <= 0 || paymentsMade <= 0) return 0;
        const r = annualRate / 100 / 12;
        const monthlyPI = getMonthlyPayment(principal, annualRate, termMonths);
        let balance = principal;
        let totalPrincipal = 0;
        const n = Math.min(paymentsMade, termMonths);
        for (let m = 1; m <= n; m++) {
          if (balance <= 0) break;
          const interestPayment = balance * r;
          const principalPayment = Math.min(balance, monthlyPI - interestPayment);
          balance = Math.max(0, balance - principalPayment);
          totalPrincipal += principalPayment;
        }
        return totalPrincipal;
      };

      // Chart Rendering
      const renderChart = (rentData, buyData, timeHorizon, breakEvenYear) => {
        // Clear chart
        chartGrid.innerHTML = '';
        chartAxes.innerHTML = '';
        chartLines.innerHTML = '';
        chartLegend.innerHTML = '';
        chartBreakeven.innerHTML = '';

        const width = 600;
        const height = 220;
        const padding = { top: 20, right: 20, bottom: 30, left: 60 };
        const chartW = width - padding.left - padding.right;
        const chartH = height - padding.top - padding.bottom;

        // Find min/max values for scaling
        let allVals = [];
        rentData.forEach(d => allVals.push(d.netWorth));
        buyData.forEach(d => allVals.push(d.netWorth));
        allVals.push(0);
        const minVal = Math.min(...allVals);
        const maxVal = Math.max(...allVals);
        const valRange = Math.max(maxVal - minVal, 1);
        const valPadding = valRange * 0.1;
        const yMin = minVal - valPadding;
        const yMax = maxVal + valPadding;
        const yRange = yMax - yMin;

        const xScale = (year) => padding.left + ((year - 1) / Math.max(timeHorizon - 1, 1)) * chartW;
        const yScale = (val) => padding.top + chartH - ((val - yMin) / yRange) * chartH;

        // Grid lines (horizontal)
        const gridLines = 5;
        for (let i = 0; i <= gridLines; i++) {
          const y = padding.top + (chartH / gridLines) * i;
          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          line.setAttribute('x1', padding.left);
          line.setAttribute('x2', width - padding.right);
          line.setAttribute('y1', y);
          line.setAttribute('y2', y);
          line.setAttribute('stroke', 'var(--color-hairline)');
          line.setAttribute('stroke-width', '1');
          line.setAttribute('stroke-dasharray', '4,4');
          chartGrid.appendChild(line);

          // Y-axis labels
          const valAtLine = yMax - (yRange / gridLines) * i;
          const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          text.setAttribute('x', padding.left - 8);
          text.setAttribute('y', y + 3);
          text.setAttribute('text-anchor', 'end');
          text.setAttribute('class', 'text-[9px] font-mono');
          text.setAttribute('fill', 'var(--color-mute)');
          text.textContent = fmt(valAtLine);
          chartAxes.appendChild(text);
        }

        // X-axis labels
        const xLabelStep = Math.max(1, Math.floor(timeHorizon / 6));
        for (let year = 1; year <= timeHorizon; year += xLabelStep) {
          const x = xScale(year);
          const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          text.setAttribute('x', x);
          text.setAttribute('y', height - 5);
          text.setAttribute('text-anchor', 'middle');
          text.setAttribute('class', 'text-[9px] font-mono');
          text.setAttribute('fill', 'var(--color-mute)');
          text.textContent = 'Yr ' + year;
          chartAxes.appendChild(text);
        }

        // Build path strings
        let rentPath = '';
        let buyPath = '';

        rentData.forEach((d, i) => {
          const x = xScale(d.year);
          const y = yScale(d.netWorth);
          if (i === 0) {
            rentPath = `M ${x} ${y}`;
          } else {
            rentPath += ` L ${x} ${y}`;
          }
        });

        buyData.forEach((d, i) => {
          const x = xScale(d.year);
          const y = yScale(d.netWorth);
          if (i === 0) {
            buyPath = `M ${x} ${y}`;
          } else {
            buyPath += ` L ${x} ${y}`;
          }
        });

        // Rent line (emerald)
        if (rentPath) {
          const rentLine = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          rentLine.setAttribute('d', rentPath);
          rentLine.setAttribute('fill', 'none');
          rentLine.setAttribute('stroke', '#10b981');
          rentLine.setAttribute('stroke-width', '2');
          rentLine.setAttribute('stroke-linejoin', 'round');
          rentLine.setAttribute('stroke-linecap', 'round');
          chartLines.appendChild(rentLine);

          // Data points (every 2 years to avoid clutter)
          rentData.forEach((d, i) => {
            if (i % 2 !== 0 && i !== rentData.length - 1) return;
            const cx = xScale(d.year);
            const cy = yScale(d.netWorth);
            const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            circle.setAttribute('cx', cx);
            circle.setAttribute('cy', cy);
            circle.setAttribute('r', '3');
            circle.setAttribute('fill', '#10b981');
            chartLines.appendChild(circle);
          });
        }

        // Buy line (violet)
        if (buyPath) {
          const buyLine = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          buyLine.setAttribute('d', buyPath);
          buyLine.setAttribute('fill', 'none');
          buyLine.setAttribute('stroke', '#8b5cf6');
          buyLine.setAttribute('stroke-width', '2');
          buyLine.setAttribute('stroke-linejoin', 'round');
          buyLine.setAttribute('stroke-linecap', 'round');
          chartLines.appendChild(buyLine);

          // Data points
          buyData.forEach((d, i) => {
            if (i % 2 !== 0 && i !== buyData.length - 1) return;
            const cx = xScale(d.year);
            const cy = yScale(d.netWorth);
            const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            circle.setAttribute('cx', cx);
            circle.setAttribute('cy', cy);
            circle.setAttribute('r', '3');
            circle.setAttribute('fill', '#8b5cf6');
            chartLines.appendChild(circle);
          });
        }

        // Zero line
        if (yMin < 0 && yMax > 0) {
          const zeroY = yScale(0);
          const zeroLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          zeroLine.setAttribute('x1', padding.left);
          zeroLine.setAttribute('x2', width - padding.right);
          zeroLine.setAttribute('y1', zeroY);
          zeroLine.setAttribute('y2', zeroY);
          zeroLine.setAttribute('stroke', 'var(--color-hairline-strong)');
          zeroLine.setAttribute('stroke-width', '1');
          chartAxes.appendChild(zeroLine);
        }

        // Break-even marker
        if (breakEvenYear !== null && breakEvenYear <= timeHorizon) {
          const beX = xScale(breakEvenYear);
          const beLine = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          beLine.setAttribute('x1', beX);
          beLine.setAttribute('x2', beX);
          beLine.setAttribute('y1', padding.top);
          beLine.setAttribute('y2', height - padding.bottom);
          beLine.setAttribute('stroke', '#f59e0b');
          beLine.setAttribute('stroke-width', '1.5');
          beLine.setAttribute('stroke-dasharray', '4,3');
          chartBreakeven.appendChild(beLine);

          const beLabel = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          beLabel.setAttribute('x', beX);
          beLabel.setAttribute('y', padding.top - 5);
          beLabel.setAttribute('text-anchor', 'middle');
          beLabel.setAttribute('class', 'text-[8px] font-mono');
          beLabel.setAttribute('fill', '#f59e0b');
          beLabel.textContent = 'Break-even Yr ' + breakEvenYear;
          chartBreakeven.appendChild(beLabel);
        }

        // Legend
        const legendGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        legendGroup.setAttribute('transform', `translate(${padding.left}, ${height - padding.bottom + 8})`);

        const legendItems = [
          { label: 'Rent (Portfolio)', color: '#10b981' },
          { label: 'Buy (Net Worth)', color: '#8b5cf6' },
        ];

        legendItems.forEach((item, i) => {
          const lx = i * 140;
          const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          rect.setAttribute('x', lx);
          rect.setAttribute('y', 0);
          rect.setAttribute('width', '10');
          rect.setAttribute('height', '10');
          rect.setAttribute('rx', '2');
          rect.setAttribute('fill', item.color);
          legendGroup.appendChild(rect);

          const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          text.setAttribute('x', lx + 14);
          text.setAttribute('y', 9);
          text.setAttribute('class', 'text-[8px] font-mono');
          text.setAttribute('fill', 'var(--color-mute)');
          text.textContent = item.label;
          legendGroup.appendChild(text);
        });

        chartLegend.appendChild(legendGroup);
      };

      // Breakown toggle handlers
      toggleRentBreakdown.addEventListener('click', () => {
        const expanded = toggleRentBreakdown.getAttribute('aria-expanded') === 'true';
        toggleRentBreakdown.setAttribute('aria-expanded', (!expanded).toString());
        rentChevron.classList.toggle('rotate-180', !expanded);
        rentBreakdownContainer.classList.toggle('hidden', expanded);
      });

      toggleBuyBreakdown.addEventListener('click', () => {
        const expanded = toggleBuyBreakdown.getAttribute('aria-expanded') === 'true';
        toggleBuyBreakdown.setAttribute('aria-expanded', (!expanded).toString());
        buyChevron.classList.toggle('rotate-180', !expanded);
        buyBreakdownContainer.classList.toggle('hidden', expanded);
      });

      // Term buttons
      termBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const years = parseInt(btn.dataset.years, 10);
          currentTermYears = years;
          loanTermInput.value = years.toString();

          termBtns.forEach(b => {
            b.classList.remove('border-hairline-strong', 'bg-primary', 'text-on-primary', 'shadow-lvl2');
            b.classList.add('border-hairline', 'bg-canvas', 'text-body');
          });
          btn.classList.remove('border-hairline', 'bg-canvas', 'text-body');
          btn.classList.add('border-hairline-strong', 'bg-primary', 'text-on-primary', 'shadow-lvl2');
        });
      });

      // Calculate button & auto-inputs
      const triggerCalculate = () => calculate();

      calculateBtn.addEventListener('click', triggerCalculate);

      const autoInputs = [
        monthlyRentInput, rentIncreaseInput, homePriceInput, downPaymentInput,
        interestRateInput, annualTaxInsMaintInput, appreciationInput,
        investReturnInput, timeHorizonInput, closingCostsInput, sellerCostsInput,
      ];

      autoInputs.forEach(input => {
        input.addEventListener('input', triggerCalculate);
      });

      // Initial run
      calculate();
    })();
  </script>

    <RelatedTools
      categorySlug="real-estate"
      toolSlug="rent-vs-buy-calculator"
    />

  <ContentFooter category="real-estate" />
</Layout>
