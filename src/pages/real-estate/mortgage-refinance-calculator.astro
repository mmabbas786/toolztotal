  <!-- Client-Side Calculator Logic -->
  <script>
    (() => {
      // DOM Elements - Inputs
      const currentBalanceInput = document.getElementById('current-balance');
      const currentRateInput = document.getElementById('current-rate');
      const currentTermInput = document.getElementById('current-term');
      const currTermBtns = document.querySelectorAll('.curr-term-btn');
      const newRateInput = document.getElementById('new-rate');
      const newTermInput = document.getElementById('new-term');
      const newTermBtns = document.querySelectorAll('.new-term-btn');
      const closingCostsInput = document.getElementById('closing-costs');
      const calculateBtn = document.getElementById('calculate-btn');

      // DOM Elements - Results
      const monthlySavingsEl = document.getElementById('monthly-savings');
      const savingsStatusEl = document.getElementById('savings-status');
      const breakEvenMonthsEl = document.getElementById('break-even-months');
      const breakEvenBar = document.getElementById('break-even-bar');
      const breakEvenNote = document.getElementById('break-even-note');

      const compCurrPayment = document.getElementById('comp-curr-payment');
      const compNewPayment = document.getElementById('comp-new-payment');
      const compDiffPayment = document.getElementById('comp-diff-payment');
      const compCurrInterest = document.getElementById('comp-curr-interest');
      const compNewInterest = document.getElementById('comp-new-interest');
      const compDiffInterest = document.getElementById('comp-diff-interest');
      const compCurrTotal = document.getElementById('comp-curr-total');
      const compNewTotal = document.getElementById('comp-new-total');
      const compDiffTotal = document.getElementById('comp-diff-total');
      const compCurrPayoff = document.getElementById('comp-curr-payoff');
      const compNewPayoff = document.getElementById('comp-new-payoff');

      const summaryMonthlySavings = document.getElementById('summary-monthly-savings');
      const summaryInterestSavings = document.getElementById('summary-interest-savings');
      const summaryBreakEven = document.getElementById('summary-break-even');
      const breakEvenDescription = document.getElementById('break-even-description');

      // State
      let currentTermYears = 25;
      let newTermYears = 30;

      // Format Helpers
      const fmt = (val) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0,
        }).format(val);
      };

      const fmtCents = (val) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        }).format(val);
      };

      const getPayoffDate = (monthsToAdd) => {
        const date = new Date();
        date.setMonth(date.getMonth() + monthsToAdd);
        return date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
      };

      // Inline Amortization Functions
      const getMonthlyPayment = (principal, annualRate, termMonths) => {
        if (principal <= 0 || termMonths <= 0) return 0;
        const r = annualRate / 100 / 12;
        if (r === 0) return principal / termMonths;
        const factor = Math.pow(1 + r, termMonths);
        return principal * (r * factor) / (factor - 1);
      };

      const getTotalInterest = (principal, annualRate, termMonths) => {
        if (principal <= 0 || termMonths <= 0) return 0;
        const r = annualRate / 100 / 12;
        const monthlyPI = getMonthlyPayment(principal, annualRate, termMonths);
        if (monthlyPI === 0) return 0;
        let balance = principal;
        let totalInterest = 0;
        for (let m = 1; m <= termMonths; m++) {
          if (balance <= 0) break;
          const interestPayment = balance * r;
          const principalPayment = Math.min(balance, monthlyPI - interestPayment);
          balance = Math.max(0, balance - principalPayment);
          totalInterest += interestPayment;
        }
        return totalInterest;
      };

      const getPayoffMonths = (principal, annualRate, termMonths) => {
        if (principal <= 0 || termMonths <= 0) return 0;
        const r = annualRate / 100 / 12;
        const monthlyPI = getMonthlyPayment(principal, annualRate, termMonths);
        if (monthlyPI === 0) return 0;
        let balance = principal;
        for (let m = 1; m <= termMonths; m++) {
          if (balance <= 0) return m - 1;
          const interestPayment = balance * r;
          const principalPayment = Math.min(balance, monthlyPI - interestPayment);
          balance = Math.max(0, balance - principalPayment);
        }
        return termMonths;
      };

      // Core Calculation
      const calculate = () => {
        const balance = Math.max(0, parseFloat(currentBalanceInput.value) || 0);
        const currentRate = Math.max(0, parseFloat(currentRateInput.value) || 0);
        const currentRemainingMonths = currentTermYears * 12;
        const newRate = Math.max(0, parseFloat(newRateInput.value) || 0);
        const newTermMonths = newTermYears * 12;
        const closingCosts = Math.max(0, parseFloat(closingCostsInput.value) || 0);

        if (balance <= 0) {
          monthlySavingsEl.textContent = '$0';
          savingsStatusEl.textContent = 'Enter a valid loan balance to calculate savings.';
          return;
        }

        // Current loan calculations
        const currentMonthlyPI = getMonthlyPayment(balance, currentRate, currentRemainingMonths);
        const currentTotalInterest = getTotalInterest(balance, currentRate, currentRemainingMonths);
        const currentPayoffMonths = getPayoffMonths(balance, currentRate, currentRemainingMonths);
        const currentTotalPayments = currentMonthlyPI * currentPayoffMonths;

        // New loan calculations
        const newMonthlyPI = getMonthlyPayment(balance, newRate, newTermMonths);
        const newTotalInterest = getTotalInterest(balance, newRate, newTermMonths);
        const newPayoffMonths = getPayoffMonths(balance, newRate, newTermMonths);
        const newTotalPayments = newMonthlyPI * newPayoffMonths;

        // Savings
        const monthlySavings = currentMonthlyPI - newMonthlyPI;
        const totalInterestSavings = currentTotalInterest - newTotalInterest;
        const isPositive = monthlySavings > 0;

        // Break-even
        let breakEvenMonths = null;
        if (monthlySavings > 0 && closingCosts > 0) {
          breakEvenMonths = Math.ceil(closingCosts / monthlySavings);
        }

        // Update Monthly Savings Display
        if (isPositive) {
          monthlySavingsEl.textContent = fmtCents(monthlySavings);
          monthlySavingsEl.className = 'text-4xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-2 tabular-nums text-emerald-600';
          savingsStatusEl.textContent = 'You save this much every month by refinancing.';
          savingsStatusEl.className = 'text-sm font-sans mb-6 text-emerald-600';
        } else {
          monthlySavingsEl.textContent = fmtCents(Math.abs(monthlySavings));
          monthlySavingsEl.className = 'text-4xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-2 tabular-nums text-red-500';
          savingsStatusEl.textContent = 'Refinancing may not save you money with these terms.';
          savingsStatusEl.className = 'text-sm font-sans mb-6 text-red-500';
        }

        // Break-Even Display
        if (breakEvenMonths !== null) {
          breakEvenMonthsEl.textContent = breakEvenMonths + (breakEvenMonths === 1 ? ' month' : ' months');
          breakEvenNote.textContent = `You break even in ${breakEvenMonths} month${breakEvenMonths === 1 ? '' : 's'} — after that, you save ${fmtCents(monthlySavings)}/mo.`;

          // Visual progress bar (cap at 120 months for display)
          const maxDisplay = 120;
          const percent = Math.min(100, (breakEvenMonths / maxDisplay) * 100);
          breakEvenBar.style.width = `${percent}%`;
        } else if (monthlySavings <= 0) {
          breakEvenMonthsEl.textContent = 'N/A';
          breakEvenNote.textContent = 'Monthly savings must be positive to calculate a break-even point.';
          breakEvenBar.style.width = '0%';
        } else {
          breakEvenMonthsEl.textContent = '0 months';
          breakEvenNote.textContent = 'With no closing costs, you break even immediately.';
          breakEvenBar.style.width = '100%';
        }

        // Side-by-Side Comparison Table
        compCurrPayment.textContent = fmtCents(currentMonthlyPI);
        compNewPayment.textContent = fmtCents(newMonthlyPI);
        const diffPayment = currentMonthlyPI - newMonthlyPI;
        compDiffPayment.textContent = (diffPayment >= 0 ? '' : '−') + fmtCents(Math.abs(diffPayment));
        compDiffPayment.className = diffPayment >= 0 ? 'py-2.5 px-3 text-right text-emerald-600 font-medium' : 'py-2.5 px-3 text-right text-red-500 font-medium';

        compCurrInterest.textContent = fmt(currentTotalInterest);
        compNewInterest.textContent = fmt(newTotalInterest);
        const diffInterest = currentTotalInterest - newTotalInterest;
        compDiffInterest.textContent = (diffInterest >= 0 ? '' : '−') + fmt(Math.abs(diffInterest));
        compDiffInterest.className = diffInterest >= 0 ? 'py-2.5 px-3 text-right text-emerald-600 font-medium' : 'py-2.5 px-3 text-right text-red-500 font-medium';

        compCurrTotal.textContent = fmt(currentTotalPayments);
        compNewTotal.textContent = fmt(newTotalPayments);
        const diffTotal = currentTotalPayments - newTotalPayments;
        compDiffTotal.textContent = (diffTotal >= 0 ? '' : '−') + fmt(Math.abs(diffTotal));
        compDiffTotal.className = diffTotal >= 0 ? 'py-2.5 px-3 text-right text-emerald-600 font-medium' : 'py-2.5 px-3 text-right text-red-500 font-medium';

        compCurrPayoff.textContent = getPayoffDate(currentPayoffMonths);
        compNewPayoff.textContent = getPayoffDate(newPayoffMonths);

        // Savings Summary Card
        summaryMonthlySavings.textContent = isPositive ? fmtCents(monthlySavings) : '$0';
        summaryMonthlySavings.className = isPositive ? 'text-lg font-bold text-emerald-600 font-sans tabular-nums' : 'text-lg font-bold text-ink font-sans tabular-nums';

        summaryInterestSavings.textContent = diffInterest >= 0 ? fmt(diffInterest) : `−${fmt(Math.abs(diffInterest))}`;
        summaryInterestSavings.className = diffInterest >= 0 ? 'text-lg font-bold text-emerald-600 font-sans tabular-nums' : 'text-lg font-bold text-ink font-sans tabular-nums';

        summaryBreakEven.textContent = breakEvenMonths !== null ? `${breakEvenMonths} mo` : 'N/A';

        if (breakEvenMonths !== null) {
          breakEvenDescription.textContent = `After ${breakEvenMonths} months, you save ${fmtCents(monthlySavings)}/mo. Total interest savings over the full term: ${fmt(totalInterestSavings)}.`;
        } else if (monthlySavings <= 0) {
          breakEvenDescription.textContent = 'Your monthly payment is higher with the new loan. Consider adjusting terms or checking current market rates for better options.';
        } else {
          breakEvenDescription.textContent = 'Your monthly payment decreases with the new loan, saving you money immediately.';
        }
      };

      // Term Button Helpers
      const updateCurrTermState = (years) => {
        currentTermYears = years;
        currentTermInput.value = years.toString();
        currTermBtns.forEach(btn => {
          const yr = parseInt(btn.dataset.years, 10);
          if (yr === years) {
            btn.classList.add('bg-primary', 'text-on-primary', 'border-hairline-strong', 'shadow-lvl2');
            btn.classList.remove('bg-canvas', 'text-body', 'border-hairline', 'hover:bg-canvas-soft-2');
          } else {
            btn.classList.remove('bg-primary', 'text-on-primary', 'border-hairline-strong', 'shadow-lvl2');
            btn.classList.add('bg-canvas', 'text-body', 'border-hairline', 'hover:bg-canvas-soft-2');
          }
        });
      };

      const updateNewTermState = (years) => {
        newTermYears = years;
        newTermInput.value = years.toString();
        newTermBtns.forEach(btn => {
          const yr = parseInt(btn.dataset.years, 10);
          if (yr === years) {
            btn.classList.add('bg-primary', 'text-on-primary', 'border-hairline-strong', 'shadow-lvl2');
            btn.classList.remove('bg-canvas', 'text-body', 'border-hairline', 'hover:bg-canvas-soft-2');
          } else {
            btn.classList.remove('bg-primary', 'text-on-primary', 'border-hairline-strong', 'shadow-lvl2');
            btn.classList.add('bg-canvas', 'text-body', 'border-hairline', 'hover:bg-canvas-soft-2');
          }
        });
      };

      // Event Listeners
      currTermBtns.forEach(btn => {
        btn.addEventListener('click', () => updateCurrTermState(parseInt(btn.dataset.years, 10)));
      });

      newTermBtns.forEach(btn => {
        btn.addEventListener('click', () => updateNewTermState(parseInt(btn.dataset.years, 10)));
      });

      calculateBtn.addEventListener('click', calculate);

      // Auto-calculate on Enter key
      const inputFields = [
        currentBalanceInput, currentRateInput, newRateInput, closingCostsInput
      ];
      inputFields.forEach(input => {
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') calculate();
        });
      });

      // Initial load
      updateCurrTermState(25);
      updateNewTermState(30);
      calculate();
    })();
  </script>
</Layout>
