      const maintenancePctGroup = document.getElementById('maintenance-pct-group');
      const maintenanceDollarGroup = document.getElementById('maintenance-dollar-group');
      const maintenancePctEl = document.getElementById('maintenance-pct');
      const maintenanceDollarEl = document.getElementById('maintenance-dollar');
      const managementFeeEl = document.getElementById('management-fee');
      const hoaEl = document.getElementById('hoa');
      const otherExpensesEl = document.getElementById('other-expenses');
      const calculateBtn = document.getElementById('calculate-btn');

      // Metric Elements
      const metricMonthlyCf = document.getElementById('metric-monthly-cf');
      const metricCapRate = document.getElementById('metric-cap-rate');
      const metricCashOnCash = document.getElementById('metric-cash-on-cash');
      const metricDscr = document.getElementById('metric-dscr');

      // Bar Elements
      const barIncomeLabel = document.getElementById('bar-income-label');
      const barIncomeFill = document.getElementById('bar-income-fill');
      const barExpensesLabel = document.getElementById('bar-expenses-label');
      const barExpensesFill = document.getElementById('bar-expenses-fill');
      const barNetLabel = document.getElementById('bar-net-label');

      // Detail Elements
      const detailGrossRent = document.getElementById('detail-gross-rent');
      const detailVacancyLoss = document.getElementById('detail-vacancy-loss');
      const detailEffectiveRent = document.getElementById('detail-effective-rent');
      const detailMortgage = document.getElementById('detail-mortgage');
      const detailTax = document.getElementById('detail-tax');
      const detailInsurance = document.getElementById('detail-insurance');
      const detailMaintenance = document.getElementById('detail-maintenance');
      const detailManagement = document.getElementById('detail-management');
      const detailHoa = document.getElementById('detail-hoa');
      const detailOther = document.getElementById('detail-other');
      const detailTotalExpenses = document.getElementById('detail-total-expenses');
      const detailCashFlow = document.getElementById('detail-cash-flow');

      // Annual Elements
      const annualNoi = document.getElementById('annual-noi');
      const annualMortgage = document.getElementById('annual-mortgage');
      const annualCashFlow = document.getElementById('annual-cash-flow');
      const annualCashInvested = document.getElementById('annual-cash-invested');
      const annualCapRate = document.getElementById('annual-cap-rate');
      const annualCocReturn = document.getElementById('annual-coc-return');
      const annualDscr = document.getElementById('annual-dscr');

      // Maintenance Mode Toggle
      let maintIsPct = true;

      const setMaintenanceMode = (isPct) => {
        maintIsPct = isPct;
        maintenanceMode.value = isPct ? 'pct' : 'dollar';
        if (isPct) {
          maintenanceModePct.className = 'flex-1 h-9 border-hairline-strong bg-primary text-on-primary rounded-md font-sans text-xs font-medium transition-all shadow-lvl1 cursor-pointer';
          maintenanceModeDollar.className = 'flex-1 h-9 border border-hairline bg-canvas hover:bg-canvas-soft-2 text-body rounded-md font-sans text-xs font-medium transition-all cursor-pointer';
          maintenancePctGroup.classList.remove('hidden');
          maintenanceDollarGroup.classList.add('hidden');
        } else {
          maintenanceModeDollar.className = 'flex-1 h-9 border-hairline-strong bg-primary text-on-primary rounded-md font-sans text-xs font-medium transition-all shadow-lvl1 cursor-pointer';
          maintenanceModePct.className = 'flex-1 h-9 border border-hairline bg-canvas hover:bg-canvas-soft-2 text-body rounded-md font-sans text-xs font-medium transition-all cursor-pointer';
          maintenancePctGroup.classList.add('hidden');
          maintenanceDollarGroup.classList.remove('hidden');
        }
      };

      maintenanceModePct.addEventListener('click', () => setMaintenanceMode(true));
      maintenanceModeDollar.addEventListener('click', () => setMaintenanceMode(false));

      // Format Helpers
      const fmt = (val) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0,
        }).format(val);
      };

      const fmtCents = (val) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        }).format(val);
      };

      const fmtPct = (val) => {
        return val.toFixed(1) + '%';
      };

      const fmtRatio = (val) => {
        return val.toFixed(2);
      };

      // Inline Amortization Formula
      const getMonthlyPayment = (principal, annualRate, termMonths) => {
        if (principal <= 0 || termMonths <= 0) return 0;
        const r = annualRate / 100 / 12;
        if (r === 0) return principal / termMonths;
        const factor = Math.pow(1 + r, termMonths);
        return principal * (r * factor) / (factor - 1);
      };

      // Core Calculation
      const calculate = () => {
        // Parse inputs
        const purchasePrice = Math.max(0, parseFloat(purchasePriceEl.value) || 0);
        const downPaymentPct = Math.max(0, Math.min(100, parseFloat(downPaymentEl.value) || 0));
        const interestRate = Math.max(0, parseFloat(interestRateEl.value) || 0);
        const loanTermYears = Math.max(1, parseInt(loanTermEl.value, 10) || 30);
        const closingCosts = Math.max(0, parseFloat(closingCostsEl.value) || 0);
        const monthlyRent = Math.max(0, parseFloat(monthlyRentEl.value) || 0);
        const vacancyRate = Math.max(0, Math.min(100, parseFloat(vacancyRateEl.value) || 0));
        const annualTax = Math.max(0, parseFloat(propertyTaxEl.value) || 0);
        const annualIns = Math.max(0, parseFloat(insuranceEl.value) || 0);
        const maintPctVal = Math.max(0, Math.min(100, parseFloat(maintenancePctEl.value) || 0));
        const maintDollarVal = Math.max(0, parseFloat(maintenanceDollarEl.value) || 0);
        const managementFee = Math.max(0, Math.min(100, parseFloat(managementFeeEl.value) || 0));
        const hoaMonthly = Math.max(0, parseFloat(hoaEl.value) || 0);
        const otherMonthly = Math.max(0, parseFloat(otherExpensesEl.value) || 0);

        // Mortgage
        const downPaymentAmount = (downPaymentPct / 100) * purchasePrice;
        const loanAmount = Math.max(0, purchasePrice - downPaymentAmount);
        const totalCashInvested = downPaymentAmount + closingCosts;
        const termMonths = loanTermYears * 12;
        const monthlyPI = getMonthlyPayment(loanAmount, interestRate, termMonths);
        const annualMortgagePayment = monthlyPI * 12;

        // Income
        const effectiveRent = monthlyRent * (1 - vacancyRate / 100);
        const annualEffectiveRent = effectiveRent * 12;

        // Expenses (annual)
        const annualMaintenance = maintIsPct
          ? (effectiveRent * 12 * maintPctVal / 100)
          : maintDollarVal * 12;
        const annualManagement = effectiveRent * 12 * (managementFee / 100);
        const annualHOA = hoaMonthly * 12;
        const annualOther = otherMonthly * 12;
        const annualOperatingExpenses = annualTax + annualIns + annualMaintenance + annualManagement + annualHOA + annualOther;

        // Key Metrics - NOI EXCLUDES mortgage payment
        const NOI = annualEffectiveRent - annualOperatingExpenses;
        const annualCashFlowVal = NOI - annualMortgagePayment;
        const monthlyCashFlowVal = annualCashFlowVal / 12;

        const capRate = purchasePrice > 0 ? (NOI / purchasePrice) * 100 : 0;
        const cashOnCash = totalCashInvested > 0 ? (annualCashFlowVal / totalCashInvested) * 100 : 0;
        const DSCR = annualMortgagePayment > 0 ? NOI / annualMortgagePayment : Infinity;

        // Monthly expense values for display
        const monthlyTax = annualTax / 12;
        const monthlyIns = annualIns / 12;
        const monthlyMaint = annualMaintenance / 12;
        const monthlyMgmt = annualManagement / 12;
        const monthlyHOA = annualHOA / 12;
        const monthlyOther = annualOther / 12;
        const totalMonthlyExpenses = monthlyPI + monthlyTax + monthlyIns + monthlyMaint + monthlyMgmt + monthlyHOA + monthlyOther;

        // ---- Update 4 Metric Showcase Cards ----
        // Monthly Cash Flow
        const cfColor = monthlyCashFlowVal >= 0 ? 'text-emerald-500' : 'text-red-500';
        metricMonthlyCf.textContent = fmtCents(monthlyCashFlowVal);
        metricMonthlyCf.className = `text-2xl md:text-3xl font-bold tracking-tight mt-1 tabular-nums ${cfColor}`;

        metricCapRate.textContent = fmtPct(capRate);
        metricCapRate.className = 'text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-1 tabular-nums';

        metricCashOnCash.textContent = fmtPct(cashOnCash);
        metricCashOnCash.className = 'text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-1 tabular-nums';

        metricDscr.textContent = DSCR === Infinity ? '∞' : fmtRatio(DSCR);
        const dscrColor = DSCR === Infinity ? 'text-ink' : DSCR >= 1.25 ? 'text-emerald-500' : DSCR >= 1.0 ? 'text-amber-500' : 'text-red-500';
        metricDscr.className = `text-2xl md:text-3xl font-bold tracking-tight mt-1 tabular-nums ${dscrColor}`;

        // ---- Income vs Expenses Visual Bars ----
        const totalMonthlyIncome = effectiveRent;
        const totalMonthlyExp = monthlyTax + monthlyIns + monthlyMaint + monthlyMgmt + monthlyHOA + monthlyOther;
        const maxBar = Math.max(totalMonthlyIncome, totalMonthlyExp + monthlyPI, 1);

        barIncomeLabel.textContent = fmtCents(totalMonthlyIncome);
        barIncomeFill.style.width = `${(totalMonthlyIncome / maxBar) * 100}%`;

        barExpensesLabel.textContent = fmtCents(totalMonthlyExp);
        barExpensesFill.style.width = `${(totalMonthlyExp / maxBar) * 100}%`;

        barNetLabel.textContent = fmtCents(monthlyCashFlowVal);
        barNetLabel.className = `text-xs font-bold font-sans tabular-nums ${cfColor}`;

        // ---- Detailed Calculation ----
        detailGrossRent.textContent = fmt(monthlyRent);
        detailVacancyLoss.textContent = '−' + fmt(monthlyRent * vacancyRate / 100);
        detailEffectiveRent.textContent = fmtCents(effectiveRent);
        detailMortgage.textContent = fmtCents(monthlyPI);
        detailTax.textContent = fmtCents(monthlyTax);
        detailInsurance.textContent = fmtCents(monthlyIns);
        detailMaintenance.textContent = fmtCents(monthlyMaint);
        detailManagement.textContent = fmtCents(monthlyMgmt);
        detailHoa.textContent = fmtCents(monthlyHOA);
        detailOther.textContent = fmtCents(monthlyOther);
        detailTotalExpenses.textContent = fmtCents(totalMonthlyExpenses);
        detailCashFlow.textContent = fmtCents(monthlyCashFlowVal);
        detailCashFlow.className = `text-sm font-bold font-sans tabular-nums ${cfColor}`;

        // ---- Annual Metrics ----
        annualNoi.textContent = fmt(NOI);
        annualMortgage.textContent = fmt(annualMortgagePayment);
        annualCashFlow.textContent = fmt(annualCashFlowVal);
        annualCashFlow.className = `text-ink font-bold ${cfColor.replace('text-', 'text-')}`;
        annualCashInvested.textContent = fmt(totalCashInvested);
        annualCapRate.textContent = fmtPct(capRate);
        annualCocReturn.textContent = fmtPct(cashOnCash);
        annualDscr.textContent = DSCR === Infinity ? '∞' : fmtRatio(DSCR);
        annualDscr.className = `text-body font-medium ${dscrColor}`;
      };

      // Event Listeners
      calculateBtn.addEventListener('click', calculate);

      // Auto-calculate on Enter key for text inputs
      const inputFields = [
        purchasePriceEl, downPaymentEl, interestRateEl, loanTermEl, closingCostsEl,
        monthlyRentEl, vacancyRateEl, propertyTaxEl, insuranceEl,
        maintenancePctEl, maintenanceDollarEl, managementFeeEl, hoaEl, otherExpensesEl
      ];

      inputFields.forEach(input => {
        if (input) {
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') calculate();
          });
        }
      });

      // Auto-calculate on change for select
      loanTermEl.addEventListener('change', calculate);

      // Calculate on initial load
      setMaintenanceMode(true);
      calculate();
    })();
  </script>
</Layout>
