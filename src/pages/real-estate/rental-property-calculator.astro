---
import Layout from '../../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is cap rate and what's considered good?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cap rate (capitalization rate) measures a property's return based on its Net Operating Income (NOI) relative to its purchase price, excluding any mortgage financing. It is calculated as NOI divided by the property's purchase price. A good cap rate depends on the market, property type, and risk profile. In general, 4% to 6% is considered low-risk in strong markets, 6% to 8% is average, and 8% to 12% or higher is considered good but may come with higher risk, older properties, or less desirable locations. Cap rate is best used to compare similar properties in the same market."
      }
    },
    {
      "@type": "Question",
      "name": "What's cash-on-cash return?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cash-on-cash return measures the annual return on the actual cash you invested in the property — your down payment plus closing costs. It is calculated by dividing the annual pre-tax cash flow (NOI minus annual mortgage payments) by the total cash invested. For example, if you invest $50,000 as a down payment and closing costs and generate $6,000 in annual cash flow, your cash-on-cash return is 12%. This metric is particularly useful for investors who finance their properties because it shows how efficiently their cash is working relative to the leverage provided by the mortgage."
      }
    },
    {
      "@type": "Question",
      "name": "What is DSCR and why do lenders care about it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "DSCR stands for Debt Service Coverage Ratio. It measures a property's ability to cover its annual mortgage payments using its Net Operating Income (NOI). It is calculated as NOI divided by the total annual mortgage payment (principal and interest). A DSCR of 1.0 means the property generates just enough income to cover the mortgage. Most lenders require a DSCR of at least 1.2 to 1.25, meaning the property generates 20% to 25% more income than the debt payment. A DSCR below 1.0 indicates negative cash flow, which most lenders will not approve for investment property loans."
      }
    },
    {
      "@type": "Question",
      "name": "What's a reasonable vacancy rate to assume?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A reasonable vacancy rate assumption for rental property analysis typically ranges from 5% to 10% of gross rental income. The appropriate rate depends on the property type, location, and market conditions. For single-family homes in desirable suburban areas with strong rental demand, 5% to 7% is common. For multi-family properties in urban areas or markets with higher turnover, 8% to 10% may be more realistic. Markets with seasonal fluctuations or economic volatility may require 10% or higher. Using a conservative vacancy rate (8% or higher) is advisable when underwriting a potential investment to avoid overestimating income."
      }
    },
    {
      "@type": "Question",
      "name": "What expenses do new landlords often forget?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "New landlords commonly overlook several expenses when evaluating a rental property. These include vacancy costs (lost rent between tenants), property management fees (typically 8% to 12% of monthly rent), capital expenditures or CapEx (roof replacement, HVAC, appliances, flooring — long-term repairs that are more expensive than routine maintenance), landscaping and snow removal, HOA fees, professional cleaning between tenants, pest control, eviction costs and legal fees, landlord insurance (which costs more than standard homeowners insurance), and property tax increases over time. Budgeting 10% to 15% of rental income for maintenance and another 5% to 10% for vacancy helps create a realistic cash flow projection."
      }
    },
    {
      "@type": "Question",
      "name": "What is the 1% rule in rental property investing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 1% Rule states that a rental property should generate monthly gross rent equal to at least 1% of the total purchase price (including repairs) to be a viable investment."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate Cap Rate (Capitalization Rate)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cap Rate is calculated by dividing Net Operating Income (NOI) by the property purchase price. It estimates the return on investment before financing costs are considered."
      }
    },
    {
      "@type": "Question",
      "name": "What is Cash-on-Cash (CoC) Return?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cash-on-Cash return is calculated by dividing annual pre-tax cash flow by the total actual cash invested (down payment, closing costs, and repairs), measuring the performance of down payment capital."
      }
    },
    {
      "@type": "Question",
      "name": "What expenses should be included in rental property cash flow projections?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Project should include mortgage principal and interest, property taxes, landlord insurance, property management fees, vacancy reserves (5-10%), maintenance reserves (5-10%), and capital expenditure (CapEx) reserves."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between cash flow and equity appreciation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cash flow is the monthly net profit generated from rental income after expenses are paid. Appreciation is the increase in the property's market value over time, which represents a long-term capital gain."
      }
    }
  ]
};

const ogMeta = {
  title: "Rental Property Calculator - Free Real Estate Investment Analysis | ToolzTotal",
  description: "Analyze any rental property in seconds. Calculate cash flow, cap rate, cash-on-cash return, and DSCR with this free rental property calculator — no signup required.",
  image: "https://toolztotal.com/og-image.png",
};

const canonicalUrl = "https://toolztotal.com/real-estate/rental-property-calculator";

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout
  title={ogMeta.title}
  description={ogMeta.description}
  faqJsonLd={faqJsonLd}
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/real-estate" class="hover:text-ink transition-colors">Real Estate & Mortgage</a>
      <span>/</span>
      <span class="text-ink">Rental Property Cash Flow Calculator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Rental Property Cash Flow Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Evaluate any rental property investment with detailed cash flow analysis, cap rate, cash-on-cash return, and DSCR. Enter your property details below to see a complete financial breakdown.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">

      <!-- Left Column: Input Form (5 cols) -->
      <div class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Property & Loan Details</h2>

        <!-- Purchase Price -->
        <div>
          <label for="purchase-price" class="block text-xs font-mono uppercase text-mute mb-2">Purchase Price</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input
              type="number"
              id="purchase-price"
              value="200000"
              step="5000"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Down Payment -->
        <div>
          <label for="down-payment" class="block text-xs font-mono uppercase text-mute mb-2">Down Payment</label>
          <div class="relative">
            <input
              type="number"
              id="down-payment"
              value="20"
              step="1"
              min="0"
              max="100"
              class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
          </div>
        </div>

        <!-- Interest Rate -->
        <div>
          <label for="interest-rate" class="block text-xs font-mono uppercase text-mute mb-2">Interest Rate</label>
          <div class="relative">
            <input
              type="number"
              id="interest-rate"
              value="6.5"
              step="0.125"
              min="0"
              max="100"
              class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
          </div>
        </div>

        <!-- Loan Term -->
        <div>
          <label for="loan-term" class="block text-xs font-mono uppercase text-mute mb-2">Loan Term (Years)</label>
          <select
            id="loan-term"
            class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
          >
            <option value="15">15 Years</option>
            <option value="20">20 Years</option>
            <option value="25">25 Years</option>
            <option value="30" selected>30 Years</option>
          </select>
        </div>

        <!-- Closing Costs -->
        <div>
          <label for="closing-costs" class="block text-xs font-mono uppercase text-mute mb-2">Estimated Closing Costs</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input
              type="number"
              id="closing-costs"
              value="3000"
              step="500"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
          </div>
        </div>

        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3 pt-2">Income & Expenses</h2>

        <!-- Monthly Rent -->
        <div>
          <label for="monthly-rent" class="block text-xs font-mono uppercase text-mute mb-2">Expected Monthly Rent</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input
              type="number"
              id="monthly-rent"
              value="1800"
              step="100"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Vacancy Rate -->
        <div>
          <label for="vacancy-rate" class="block text-xs font-mono uppercase text-mute mb-2">Vacancy Rate</label>
          <div class="relative">
            <input
              type="number"
              id="vacancy-rate"
              value="5"
              step="0.5"
              min="0"
              max="100"
              class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
          </div>
        </div>

        <!-- Annual Property Tax -->
        <div>
          <label for="property-tax" class="block text-xs font-mono uppercase text-mute mb-2">Annual Property Tax</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input
              type="number"
              id="property-tax"
              value="2400"
              step="200"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Annual Insurance -->
        <div>
          <label for="insurance" class="block text-xs font-mono uppercase text-mute mb-2">Annual Insurance</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input
              type="number"
              id="insurance"
              value="1200"
              step="100"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Maintenance / Repairs -->
        <div>
          <label class="block text-xs font-mono uppercase text-mute mb-2">Maintenance / Repairs</label>
          <div class="flex items-center gap-3 mb-2">
            <button type="button" id="maintenance-mode-pct" class="flex-1 h-9 border-hairline-strong bg-primary text-on-primary rounded-md font-sans text-xs font-medium transition-all shadow-lvl1 cursor-pointer">% of Rent</button>
            <button type="button" id="maintenance-mode-dollar" class="flex-1 h-9 border border-hairline bg-canvas hover:bg-canvas-soft-2 text-body rounded-md font-sans text-xs font-medium transition-all cursor-pointer">$/mo</button>
          </div>
          <input type="hidden" id="maintenance-mode" value="pct" />
          <div id="maintenance-pct-group">
            <div class="relative">
              <input
                type="number"
                id="maintenance-pct"
                value="10"
                step="1"
                min="0"
                max="100"
                class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
            </div>
          </div>
          <div id="maintenance-dollar-group" class="hidden">
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
              <input
                type="number"
                id="maintenance-dollar"
                value="150"
                step="25"
                min="0"
                class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
            </div>
          </div>
        </div>

        <!-- Property Management Fee -->
        <div>
          <label for="management-fee" class="block text-xs font-mono uppercase text-mute mb-2">Property Management Fee</label>
          <div class="relative">
            <input
              type="number"
              id="management-fee"
              value="0"
              step="1"
              min="0"
              max="100"
              class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
          </div>
        </div>

        <!-- HOA Monthly -->
        <div>
          <label for="hoa" class="block text-xs font-mono uppercase text-mute mb-2">HOA (Monthly)</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input
              type="number"
              id="hoa"
              value="0"
              step="25"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Other Monthly Expenses -->
        <div>
          <label for="other-expenses" class="block text-xs font-mono uppercase text-mute mb-2">Other Monthly Expenses</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input
              type="number"
              id="other-expenses"
              value="0"
              step="25"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Calculate Button -->
        <button
          type="button"
          id="calculate-btn"
          class="w-full h-11 bg-primary text-on-primary font-sans font-medium text-sm rounded-lg hover:opacity-90 transition-all shadow-lvl2 cursor-pointer active:scale-[0.98]"
        >
          Calculate Cash Flow
        </button>
      </div>

      <!-- Right Column: Results (7 cols) -->
      <div class="lg:col-span-7 space-y-6">

        <!-- 4 Metric Showcase Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2">
            <span class="text-[10px] font-mono uppercase tracking-wider text-mute">Monthly Cash Flow</span>
            <div id="metric-monthly-cf" class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-1 tabular-nums">$0</div>
            <p class="text-[11px] text-mute font-sans mt-1">Money left after all expenses</p>
          </div>
          <div class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2">
            <span class="text-[10px] font-mono uppercase tracking-wider text-mute">Cap Rate</span>
            <div id="metric-cap-rate" class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-1 tabular-nums">0%</div>
            <p class="text-[11px] text-mute font-sans mt-1">Property-level return (excludes mortgage)</p>
          </div>
          <div class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2">
            <span class="text-[10px] font-mono uppercase tracking-wider text-mute">Cash-on-Cash Return</span>
            <div id="metric-cash-on-cash" class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-1 tabular-nums">0%</div>
            <p class="text-[11px] text-mute font-sans mt-1">Return on your actual cash invested</p>
          </div>
          <div class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2">
            <span class="text-[10px] font-mono uppercase tracking-wider text-mute">DSCR</span>
            <div id="metric-dscr" class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-1 tabular-nums">0.00</div>
            <p class="text-[11px] text-mute font-sans mt-1">Debt Service Coverage Ratio (lenders use this)</p>
          </div>
        </div>

        <!-- Income vs Expenses Breakdown (Visual Bars) -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2">
          <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-5">Income vs Expenses Breakdown</h3>
          <div class="space-y-4">
            <!-- Income Side -->
            <div>
              <div class="flex justify-between items-center mb-1">
                <span class="text-xs font-sans text-body">Total Monthly Income</span>
                <span id="bar-income-label" class="text-xs font-bold text-ink font-sans tabular-nums">$0</span>
              </div>
              <div class="w-full h-4 bg-emerald-100 dark:bg-emerald-900/30 border border-emerald-300 dark:border-emerald-700 rounded-full overflow-hidden">
                <div id="bar-income-fill" class="h-full bg-emerald-500 transition-all duration-500" style="width: 100%;"></div>
              </div>
            </div>
            <!-- Expenses Side -->
            <div>
              <div class="flex justify-between items-center mb-1">
                <span class="text-xs font-sans text-body">Monthly Expenses</span>
                <span id="bar-expenses-label" class="text-xs font-bold text-ink font-sans tabular-nums">$0</span>
              </div>
              <div class="w-full h-4 bg-red-100 dark:bg-red-900/30 border border-red-300 dark:border-red-700 rounded-full overflow-hidden">
                <div id="bar-expenses-fill" class="h-full bg-red-500 transition-all duration-500" style="width: 0%;"></div>
              </div>
            </div>
            <!-- Net Line -->
            <div class="flex justify-between items-center pt-2 border-t border-hairline">
              <span class="text-xs font-bold font-sans text-ink">Net Cash Flow</span>
              <span id="bar-net-label" class="text-xs font-bold font-sans tabular-nums text-ink">$0</span>
            </div>
          </div>
        </div>

        <!-- Detailed Calculation Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2">
          <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-4">Detailed Calculation</h3>
          <div class="space-y-2 text-sm font-sans tabular-nums">
            <div class="flex justify-between">
              <span class="text-body">Gross Rent</span>
              <span id="detail-gross-rent" class="text-ink font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body">Vacancy Loss</span>
              <span id="detail-vacancy-loss" class="text-red-500 font-medium">−$0</span>
            </div>
            <div class="flex justify-between border-b border-hairline pb-2">
              <span class="text-body font-medium">Effective Rent</span>
              <span id="detail-effective-rent" class="text-ink font-bold">$0</span>
            </div>
            <div class="flex justify-between pt-1">
              <span class="text-body">Monthly Mortgage (P&amp;I)</span>
              <span id="detail-mortgage" class="text-body font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body">Property Tax</span>
              <span id="detail-tax" class="text-body font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body">Insurance</span>
              <span id="detail-insurance" class="text-body font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body">Maintenance</span>
              <span id="detail-maintenance" class="text-body font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body">Management</span>
              <span id="detail-management" class="text-body font-medium">$0</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body">HOA</span>
              <span id="detail-hoa" class="text-body font-medium">$0</span>
            </div>
            <div class="flex justify-between border-b border-hairline pb-2">
              <span class="text-body">Other</span>
              <span id="detail-other" class="text-body font-medium">$0</span>
            </div>
            <div class="flex justify-between pt-1">
              <span class="text-body font-medium">Total Expenses</span>
              <span id="detail-total-expenses" class="text-ink font-bold">$0</span>
            </div>
            <div class="flex justify-between border-t-2 border-hairline-strong pt-2">
              <span class="text-sm font-bold text-ink font-sans">Monthly Cash Flow</span>
              <span id="detail-cash-flow" class="text-sm font-bold font-sans tabular-nums text-ink">$0</span>
            </div>
          </div>
        </div>

