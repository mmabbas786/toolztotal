        let dpVal = Math.max(0, parseFloat(dpValInput.value) || 0);

        // We need to solve for max home price. Start by computing max PITI from DTI.
        const maxFrontPITI = monthlyIncome * frontendLimit;
        const maxBackTotal = monthlyIncome * backendLimit;
        const maxBackPITI = maxBackTotal - monthlyDebt;
        let maxPITI = Math.min(maxFrontPITI, maxBackPITI);
        if (maxPITI < 0) maxPITI = 0;

        // Subtract tax & insurance to get max P&I
        const taxAnnual = Math.max(0, parseFloat(propertyTaxInput.value) || 0);
        const insuranceAnnual = Math.max(0, parseFloat(homeInsuranceInput.value) || 0);
        const monthlyTax = taxAnnual / 12;
        const monthlyInsurance = insuranceAnnual / 12;
        let maxPI = maxPITI - monthlyTax - monthlyInsurance;
        if (maxPI < 0) maxPI = 0;

        // Solve for principal using amortization formula inverted
        // M = P * (r*(1+r)^n) / ((1+r)^n - 1)
        // P = M * ((1+r)^n - 1) / (r * (1+r)^n)
        let principal = 0;
        if (monthlyRate > 0 && n > 0) {
          const factor = Math.pow(1 + monthlyRate, n);
          principal = maxPI * (factor - 1) / (monthlyRate * factor);
        } else if (n > 0) {
          principal = maxPI * n;
        }

        // Now compute max home price from principal and down payment %
        // principal = homePrice - downPayment
        // If mode is %, dpPct is given: downPayment = homePrice * dpPct / 100
        // principal = homePrice * (1 - dpPct/100)
        // homePrice = principal / (1 - dpPct/100)
        let maxHomePrice = 0;
        let downPaymentAmount = 0;
        let downPaymentPercent = dpPct;

        if (downPaymentMode === 'pct') {
          downPaymentPercent = Math.min(100, Math.max(0, dpPct));
          if (downPaymentPercent >= 100) {
            maxHomePrice = 0;
            downPaymentAmount = 0;
          } else {
            maxHomePrice = principal / (1 - downPaymentPercent / 100);
            downPaymentAmount = maxHomePrice * (downPaymentPercent / 100);
          }
          dpVal = downPaymentAmount;
          dpValInput.value = Math.round(dpVal).toString();
        } else {
          downPaymentAmount = Math.max(0, dpVal);
          maxHomePrice = principal + downPaymentAmount;
          downPaymentPercent = maxHomePrice > 0 ? (downPaymentAmount / maxHomePrice) * 100 : 0;
          dpPctInput.value = downPaymentPercent.toFixed(2);
        }

        const actualPrincipal = Math.max(0, maxHomePrice - downPaymentAmount);

        // Recalculate actual monthly payment
        let actualMonthlyPI = 0;
        if (monthlyRate > 0 && n > 0) {
          const factor = Math.pow(1 + monthlyRate, n);
          actualMonthlyPI = actualPrincipal > 0 ? actualPrincipal * (monthlyRate * factor) / (factor - 1) : 0;
        } else if (n > 0) {
          actualMonthlyPI = actualPrincipal / n;
        }

        const actualPITI = actualMonthlyPI + monthlyTax + monthlyInsurance;
        const computedFrontendDTI = monthlyIncome > 0 ? (actualPITI / monthlyIncome) * 100 : 0;
        const computedBackendDTI = monthlyIncome > 0 ? ((actualPITI + monthlyDebt) / monthlyIncome) * 100 : 0;

        // 6. Update Results DOM
        maxHomePriceEl.textContent = maxHomePrice > 0 ? fmt(maxHomePrice) : '$0';
        resultMonthlyPITI.textContent = fmtCents(actualPITI);
        resultFrontendDTI.textContent = fmtPct(computedFrontendDTI);
        resultBackendDTI.textContent = fmtPct(computedBackendDTI);
        resultMonthlyPI.textContent = fmt(actualMonthlyPI);
        resultLoanPrincipal.textContent = fmt(actualPrincipal);
        resultDownPayment.textContent = fmt(downPaymentAmount);
        resultDpPct.textContent = downPaymentPercent.toFixed(1) + '%';
        resultLoanTypeLabel.textContent = loanType;
        breakdownPi.textContent = fmtCents(actualMonthlyPI);
        breakdownTax.textContent = fmtCents(monthlyTax);
        breakdownInsurance.textContent = fmtCents(monthlyInsurance);
        breakdownTotal.textContent = fmtCents(actualPITI);

        // Color-code DTI stats
        const frontColor = dtiColor(computedFrontendDTI / 100, frontendLimit);
        const backColor = dtiColor(computedBackendDTI / 100, backendLimit);
        resultFrontendDTI.style.color = frontColor;
        resultBackendDTI.style.color = backColor;

        // 7. Update DTI Gauge
        const maxGaugePct = Math.max(backendLimit * 1.25, 0.5) * 100;
        const frontPctOfMax = Math.min((computedFrontendDTI / maxGaugePct) * 100, 100);
        const backPctOfMax = Math.min((computedBackendDTI / maxGaugePct) * 100, 100);
        const thresholdPctOfMax = Math.min((backendLimit * 100 / maxGaugePct) * 100, 100);

        gaugeFrontend.style.width = frontPctOfMax + '%';
        gaugeBackend.style.width = Math.max(0, backPctOfMax - frontPctOfMax) + '%';
        gaugeBackend.style.left = frontPctOfMax + '%';
        gaugeThreshold.style.left = thresholdPctOfMax + '%';

        // Color the gauge sections
        const gaugeFrontColor = dtiColor(computedFrontendDTI / 100, frontendLimit);
        const gaugeBackColor = dtiColor(computedBackendDTI / 100, backendLimit);
        gaugeFrontend.style.background = gaugeFrontColor;
        gaugeBackend.style.background = gaugeBackColor;

        gaugeThresholdLabel.textContent = 'Limit: ' + (backendLimit * 100).toFixed(0) + '%';
        gaugeMaxLabel.textContent = maxGaugePct.toFixed(0) + '%';
        gaugeLegendLimit.textContent = loanType + ' Limit';
      };

      // 8. Event Listeners

      // Down payment toggle
      dpTogglePct.addEventListener('click', () => {
        if (downPaymentMode === 'pct') return;
        downPaymentMode = 'pct';
        dpTogglePct.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl2');
        dpTogglePct.classList.remove('text-mute');
        dpToggleVal.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl2');
        dpToggleVal.classList.add('text-mute');
        dpPctContainer.classList.remove('hidden');
        dpValContainer.classList.add('hidden');
      });

      dpToggleVal.addEventListener('click', () => {
        if (downPaymentMode === 'val') return;
        downPaymentMode = 'val';
        dpToggleVal.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl2');
        dpToggleVal.classList.remove('text-mute');
        dpTogglePct.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl2');
        dpTogglePct.classList.add('text-mute');
        dpValContainer.classList.remove('hidden');
        dpPctContainer.classList.add('hidden');
      });

      // Term buttons
      termBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const years = parseInt(btn.dataset.years, 10);
          currentTermYears = years;
          loanTermInput.value = years.toString();

          termBtns.forEach(b => {
            b.classList.remove('border-hairline-strong', 'bg-primary', 'text-on-primary', 'shadow-lvl2');
            b.classList.add('border-hairline', 'bg-canvas', 'text-body');
          });
          btn.classList.remove('border-hairline', 'bg-canvas', 'text-body');
          btn.classList.add('border-hairline-strong', 'bg-primary', 'text-on-primary', 'shadow-lvl2');
        });
      });

      // Optional costs toggle
      optionalCostsToggle.addEventListener('click', () => {
        const isExpanded = optionalCostsToggle.getAttribute('aria-expanded') === 'true';
        optionalCostsToggle.setAttribute('aria-expanded', (!isExpanded).toString());
        costsChevron.classList.toggle('rotate-180', !isExpanded);
        optionalCostsContainer.classList.toggle('hidden', isExpanded);
      });

      // Calculate button & input listeners
      const triggerCalculate = () => calculate();

      calculateBtn.addEventListener('click', triggerCalculate);

      const autoInputs = [
        annualIncomeInput, monthlyDebtInput, dpPctInput, dpValInput,
        interestRateInput, propertyTaxInput, homeInsuranceInput, loanTypeSelect
      ];

      autoInputs.forEach(input => {
        input.addEventListener('input', triggerCalculate);
        if (input.tagName === 'SELECT') {
          input.addEventListener('change', triggerCalculate);
        }
      });

      // 9. Initial run
      calculate();
    })();
  </script>

</Layout>
