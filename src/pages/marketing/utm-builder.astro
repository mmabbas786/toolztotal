<script>
// @ts-nocheck
  // ============================================================
  // DOM Elements
  // ============================================================
  const btnNewsletter = document.getElementById('preset-newsletter') as HTMLButtonElement;
  const btnFacebook = document.getElementById('preset-facebook') as HTMLButtonElement;
  const btnGoogle = document.getElementById('preset-google') as HTMLButtonElement;

  const urlInput = document.getElementById('url') as HTMLInputElement;
  const sourceInput = document.getElementById('source') as HTMLInputElement;
  const mediumInput = document.getElementById('medium') as HTMLInputElement;
  const campaignInput = document.getElementById('campaign') as HTMLInputElement;
  const termInput = document.getElementById('term') as HTMLInputElement;
  const contentInput = document.getElementById('content') as HTMLInputElement;

  const generatedUrl = document.getElementById('generated-url') as HTMLSpanElement;
  const btnCopy = document.getElementById('btn-copy') as HTMLButtonElement;
  
  const qrCanvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
  const btnDownloadQr = document.getElementById('btn-download-qr') as HTMLButtonElement;

  // ============================================================
  // Functions
  // ============================================================
  const applyPreset = (source: string, medium: string, campaign: string) => {
    sourceInput.value = source;
    mediumInput.value = medium;
    campaignInput.value = campaign;
    buildUrl();
  };

  const buildUrl = async () => {
    const rawUrl = urlInput.value.trim();
    const source = sourceInput.value.trim();
    const medium = mediumInput.value.trim();
    const campaign = campaignInput.value.trim();
    const term = termInput.value.trim();
    const content = contentInput.value.trim();

    if (!rawUrl) {
      generatedUrl.textContent = "Please enter a valid website URL.";
      return;
    }

    try {
      // Validate and construct base URL
      let urlStr = rawUrl;
      if (!/^https?:\/\//i.test(urlStr)) {
        urlStr = 'https://' + urlStr;
      }
      const parsedUrl = new URL(urlStr);

      // Append parameters if set
      if (source) parsedUrl.searchParams.set('utm_source', source);
      if (medium) parsedUrl.searchParams.set('utm_medium', medium);
      if (campaign) parsedUrl.searchParams.set('utm_campaign', campaign);
      if (term) parsedUrl.searchParams.set('utm_term', term);
      if (content) parsedUrl.searchParams.set('utm_content', content);

      const finalUrl = parsedUrl.toString();
      generatedUrl.textContent = finalUrl;

      // Render QR Code using the module library
      const QRCode = (await import('qrcode')).default;
      QRCode.toCanvas(qrCanvas, finalUrl, {
        width: 128,
        margin: 1,
        color: {
          dark: '#000000',
          light: '#ffffff'
        }
      }, (error) => {
        if (error) console.error("QR Code Error:", error);
      });

    } catch (e) {
      generatedUrl.textContent = "Invalid URL format.";
    }
  };

  const copyToClipboard = () => {
    const text = generatedUrl.textContent || "";
    if (text && !text.startsWith("Please") && !text.startsWith("Invalid") && !text.startsWith("Generating")) {
      navigator.clipboard.writeText(text).then(() => {
        // Simple success visual state change
        const oldHtml = btnCopy.innerHTML;
        btnCopy.innerHTML = `
          <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        `;
        setTimeout(() => {
          btnCopy.innerHTML = oldHtml;
        }, 1500);
      });
    }
  };

  const downloadQr = () => {
    const dataUrl = qrCanvas.toDataURL("image/png");
    const link = document.createElement("a");
    link.download = `utm_qrcode_${Date.now()}.png`;
    link.href = dataUrl;
    link.click();
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  btnNewsletter.addEventListener('click', () => applyPreset('newsletter', 'email', 'summer_promo'));
  btnFacebook.addEventListener('click', () => applyPreset('facebook', 'social', 'cpc_audience_1'));
  btnGoogle.addEventListener('click', () => applyPreset('google', 'cpc', 'search_brand'));

  [urlInput, sourceInput, mediumInput, campaignInput, termInput, contentInput].forEach(inp => {
    inp.addEventListener('input', buildUrl);
  });

  btnCopy.addEventListener('click', copyToClipboard);
  btnDownloadQr.addEventListener('click', downloadQr);

  // Initial render
  buildUrl();
</script>
