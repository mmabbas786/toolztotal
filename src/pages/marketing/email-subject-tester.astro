---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';
---

<Layout 
  title="Email Subject Line Tester - Free Spam Scanner & Suggestions | ToolzTotal"
  description="Test your email subject lines. Scans for spam trigger phrases, evaluates character length thresholds for major ESPs, and suggests A/B variants."
  canonicalUrl="https://toolztotal.com/marketing/email-subject-tester"
>
  <ToolSchema
    toolName="Email Subject Line Tester"
    toolSlug="email-subject-tester"
    categoryName="Marketing & SEO"
    categorySlug="marketing"
    description="Test your email subject lines. Scans for spam trigger phrases, evaluates character length thresholds for major ESPs, and suggests A/B variants."
  faqs={[
    { question: "What is the ideal length for an email subject line?", answer: "For general email campaigns, the ideal subject line length is between 30 and 50 characters. Subject lines in this range prevent layout clipping on mobile screens while providing enough context to encourage the recipient to open the email." },
    { question: "How do spam trigger words affect email deliverability?", answer: "Spam filters run automated scoring algorithms on email subject lines and body content. Using aggressive sales jargon or spam trigger phrases (like '100% free', 'make money', or 'guaranteed winner') increases your spam score, making it likely your email lands in the spam or promotions folder instead of the primary inbox." },
    { question: "Where do major email clients cut off subject lines?", answer: "Clipping limits vary by platform: Gmail desktop displays up to 70 characters; Outlook desktop displays up to 54 characters; and mobile devices (like iPhone Mail or Gmail App) typically cut off subject lines between 35 and 41 characters." },
    { question: "Why is A/B testing email subject lines recommended?", answer: "A/B testing involves sending two different subject line variants to small segments of your subscriber list to compare performance. The variant that achieves the higher open rate is then sent to the remainder of the list, helping you maximize overall campaign engagement." },
    { question: "Are my campaign subject lines private?", answer: "Yes. This email subject line testing tool runs entirely client-side. None of your campaigns, headings, or subjects are uploaded, logged, or sent to a server." },
    { question: "What is the ideal character length for an email subject line?", answer: "The recommended length is between 40 and 60 characters. This ensures the subject line is long enough to explain the email's value while remaining short enough to display fully on most mobile and desktop email clients." },
    { question: "How do spam filters analyze subject lines for trigger words?", answer: "Spam filters scan subject lines for aggressive sales language, excessive capitalization (e.g., 'FREE NOW'), and trigger words like 'guaranteed', 'risk-free', or 'earn money'. Using these terms excessively can direct your email to the spam folder." },
    { question: "Should I use personalization tokens in my subject lines?", answer: "Yes, using personalization tokens like a recipient's first name can increase open rates. However, ensure you have a clean fallback option (like 'there') in case the database field is blank, to avoid displaying broken code like 'Hi [First_Name]'." },
    { question: "How do emojis in subject lines affect email open rates?", answer: "Emojis can increase open rates by adding visual interest in a crowded inbox. However, they should be used sparingly (limit to 1 or 2) and make sense for the topic to prevent the email from looking like spam or rendering incorrectly on older devices." },
    { question: "What is preheader text and how does it relate to the subject line?", answer: "Preheader text is the brief summary text that displays next to or below the subject line in an inbox. It acts as secondary preview copy, allowing you to build on the hook in your subject line and encourage users to open the email." }
  ]}
  />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categoryName="Marketing & SEO"
      categorySlug="marketing"
      toolName="Email Subject Line Tester"
      toolSlug="email-subject-tester"
    />


    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Free Email Subject Line Tester
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Analyze subject line length limits for mobile and desktop screens. Scan for potential spam filters trigger words, and receive instant A/B testing suggestions.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Inputs (5 cols) -->
      <div class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Campaign Subject</h2>
        
        <!-- Subject Line Input -->
        <div>
          <label for="subject-input" class="block text-xs font-mono uppercase text-mute mb-2 flex justify-between">
            <span>Subject Line</span>
            <span id="char-count" class="text-[10px] text-mute">0 chars</span>
          </label>
          <textarea 
            id="subject-input" 
            rows="3"
            placeholder="Type your email subject line here..."
            class="w-full p-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 resize-none"
          >Get 100% FREE Access To Our Premium Marketing Calculator Tools Now!</textarea>
        </div>
      </div>

      <!-- Right Column: Results (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Analysis Results Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Subject Line Analysis</h2>
          
          <!-- Clipping indicators -->
          <div class="space-y-4">
            <h3 class="text-xs font-mono uppercase text-mute">Inbox Clipping Previews</h3>
            
            <div class="space-y-3">
              <!-- Mobile -->
              <div class="flex justify-between items-center py-2 border-b border-hairline">
                <div class="text-xs font-mono text-mute uppercase">Mobile (Max 41 chars)</div>
                <div id="badge-mobile" class="px-2 py-0.5 text-[10px] font-mono font-semibold rounded bg-emerald-500/10 text-emerald-500 border border-emerald-500/20">Fits</div>
              </div>
              
              <!-- Outlook -->
              <div class="flex justify-between items-center py-2 border-b border-hairline">
                <div class="text-xs font-mono text-mute uppercase">Outlook Desktop (Max 54 chars)</div>
                <div id="badge-outlook" class="px-2 py-0.5 text-[10px] font-mono font-semibold rounded bg-emerald-500/10 text-emerald-500 border border-emerald-500/20">Fits</div>
              </div>

              <!-- Gmail -->
              <div class="flex justify-between items-center py-2">
                <div class="text-xs font-mono text-mute uppercase">Gmail Desktop (Max 70 chars)</div>
                <div id="badge-gmail" class="px-2 py-0.5 text-[10px] font-mono font-semibold rounded bg-emerald-500/10 text-emerald-500 border border-emerald-500/20">Fits</div>
              </div>
            </div>
          </div>

          <!-- Spam Trigger Words scanner -->
          <div class="space-y-4 pt-4 border-t border-hairline">
            <h3 class="text-xs font-mono uppercase text-mute">Spam Trigger Scanner</h3>
            
            <div id="spam-result-box" class="p-4 rounded-lg bg-emerald-500/5 border border-emerald-500/10 text-emerald-500 flex gap-3 text-xs md:text-sm font-sans leading-relaxed">
              <svg id="spam-icon-ok" class="w-5 h-5 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <svg id="spam-icon-warn" class="w-5 h-5 shrink-0 text-red-500 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <div>
                <strong id="spam-title" class="font-sans block mb-0.5">Clear of spam words</strong>
                <p id="spam-desc" class="text-body text-xs mt-1">No major spam trigger phrases detected. Your subject line is safe from simple filters.</p>
              </div>
            </div>
          </div>

          <!-- A/B testing suggestions -->
          <div class="space-y-4 pt-4 border-t border-hairline">
            <h3 class="text-xs font-mono uppercase text-mute">A/B Testing Variants</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="variants-grid">
              <!-- Dynamically populated card suggestions -->
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Article Content -->
    <article class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6">Optimizing Email Subject Lines: ESP Clipping Limits and Spam Trigger Words</h2>
      <div class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6">
        <p>
          Email marketing effectiveness hinges on one primary metric: <strong>Open Rate</strong>. If your recipients do not open your email, your inner messages, graphics, and CTR assets are completely lost. To maximize opens, you must optimize subject lines to grab attention, fit within inbox viewing boundaries, and bypass spam filtering scripts.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Understanding Inbox Viewing Boundaries (ESPs)</h3>
        <p>
          Each email service provider (ESP) allocates a set amount of horizontal space to display subject lines in the user inbox. If your subject line is too long, the inbox layout truncates it.
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li><strong>Gmail (Desktop):</strong> Displays approximately 70 characters before clipping.</li>
          <li><strong>Outlook (Desktop):</strong> Displays approximately 54 characters.</li>
          <li><strong>Mobile Devices (Gmail App / iOS Mail):</strong> Typically display between 35 and 41 characters. Because over 50% of emails are opened on mobile devices, keeping your primary value hooks within the first 35 characters is essential.</li>
        </ul>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Avoiding Spam Filters and Trigger Words</h3>
        <p>
          Modern email spam filters analyze both subject line structures and email body content using automated algorithms. They scan for aggressive sales language, excessive capitalization, and specific spam trigger words.
        </p>
        <p>
          Spam triggers are vocabulary terms statistically associated with email fraud, phishing, or pushy marketing. Examples include:
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li><strong>Urgency triggers:</strong> `act now`, `urgent`, `limited time`, `buy now`.</li>
          <li><strong>Financial triggers:</strong> `make money`, `earn cash`, `extra income`, `lowest price`.</li>
          <li><strong>Exaggerated claims:</strong> `100% free`, `guaranteed winner`, `risk-free`, `miracle`.</li>
        </ul>
        <p>
          Our analyzer scans your text against these dictionaries, warning you to refine terms that might flags spam filters.
        </p>

        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Drafting A/B Test Variants</h3>
        <p>
          A/B testing is a reliable strategy for finding what resonates with your subscribers. Our tool suggests four different variant structures based on your input parameters to give you alternative angles for your campaigns:
        </p>
        <ul class="list-disc pl-5 space-y-2 font-sans text-sm">
          <li><strong>Curiosity Angle:</strong> Intriguing statements or questions that prompt the reader to open the email to find the answer.</li>
          <li><strong>Urgency Angle:</strong> Implies time-sensitivity without using spam-flagged terms.</li>
          <li><strong>Benefit Angle:</strong> Directly highlights the value, coupon, or guide inside.</li>
          <li><strong>Numeric Angle:</strong> Uses numbers or lists, which have a high open rate in inboxes.</li>
        </ul>
      
<h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">The Mechanics of Mobile Email Clients</h3>
        <p>
          When drafting email marketing campaigns, it is essential to consider the limitations of mobile email clients. Over 50% of emails are opened on mobile devices, where screen space is highly restricted. While a desktop client like Outlook might display up to 80 characters of a subject line, mobile applications like Gmail or Apple Mail often truncate subject lines after just 30 to 40 characters. This means the first three to four words of your subject line must convey the value of your email to capture the user's attention. If your main message is placed at the end of a long subject line, it will not be visible on mobile screens.
        </p>
        <p>
          Additionally, you must coordinate your subject line with your preheader text. Preheader text is the preview snippet displayed directly next to or below the subject line in the inbox. Using this space to build on the subject line provides a cohesive preview that encourages users to open the email.
        </p>
        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Walkthrough: Refining a Subject Line for Open Rates</h3>
        <p>
          Let's walk through how to improve a weak subject line using standard copywriting techniques. Suppose your original draft is: <code>Check out our newsletter for July because we have some cool product updates and a special discount code.</code> This subject line has 104 characters, which is too long and lacks urgency.
        </p>
        <p>
          To optimize this, first move the primary hook to the front of the line: <code>July Updates & Discount Inside</code>. Next, add a power word or numbers to make it stand out: <code>July Updates: Save 20% Inside</code>. Finally, run it through this tester to verify the character length (27 characters) and review the scoring dashboard, which helps you craft punchy, mobile-optimized subject lines.
        </p>        <h3 class="text-lg font-bold text-ink font-sans mt-8 mb-3">Conducting Systematic Subject Line Split Tests</h3>
        <p>
          To continuously improve your email campaign metrics, implement a structured A/B testing workflow for every broadcast. Send version A to 10% of your email list and version B to another 10%. Allow the test to run for two to four hours, then analyze the results. The system should automatically send the winning variant—defined by the highest unique open rate—to the remaining 80% of your subscribers. Consistent testing helps you identify which copywriting angles (such as curiosity, scarcity, or direct utility) yield the highest engagement for your specific audience.
        </p>
      </div>
    </article>

  <Sources sources={[
    { label: 'Google Search Central — SEO Starter Guide', url: 'https://developers.google.com/search/docs/fundamentals/seo-starter-guide' },
    { label: 'Google Analytics Help', url: 'https://support.google.com/analytics/' }
  ]} />

    <!-- FAQ Section -->
    
    <!-- FAQ Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Frequently Asked Questions">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is the ideal length for an email subject line?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            For general email campaigns, the ideal subject line length is between 30 and 50 characters. Subject lines in this range prevent layout clipping on mobile screens while providing enough context to encourage the recipient to open the email.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How do spam trigger words affect email deliverability?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Spam filters run automated scoring algorithms on email subject lines and body content. Using aggressive sales jargon or spam trigger phrases (like '100% free', 'make money', or 'guaranteed winner') increases your spam score, making it likely your email lands in the spam or promotions folder instead of the primary inbox.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Where do major email clients cut off subject lines?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Clipping limits vary by platform: Gmail desktop displays up to 70 characters; Outlook desktop displays up to 54 characters; and mobile devices (like iPhone Mail or Gmail App) typically cut off subject lines between 35 and 41 characters.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Why is A/B testing email subject lines recommended?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            A/B testing involves sending two different subject line variants to small segments of your subscriber list to compare performance. The variant that achieves the higher open rate is then sent to the remainder of the list, helping you maximize overall campaign engagement.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Are my campaign subject lines private?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes. This email subject line testing tool runs entirely client-side. None of your campaigns, headings, or subjects are uploaded, logged, or sent to a server.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is the ideal character length for an email subject line?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            The recommended length is between 40 and 60 characters. This ensures the subject line is long enough to explain the email's value while remaining short enough to display fully on most mobile and desktop email clients.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How do spam filters analyze subject lines for trigger words?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Spam filters scan subject lines for aggressive sales language, excessive capitalization (e.g., 'FREE NOW'), and trigger words like 'guaranteed', 'risk-free', or 'earn money'. Using these terms excessively can direct your email to the spam folder.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            Should I use personalization tokens in my subject lines?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Yes, using personalization tokens like a recipient's first name can increase open rates. However, ensure you have a clean fallback option (like 'there') in case the database field is blank, to avoid displaying broken code like 'Hi [First_Name]'.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            How do emojis in subject lines affect email open rates?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Emojis can increase open rates by adding visual interest in a crowded inbox. However, they should be used sparingly (limit to 1 or 2) and make sense for the topic to prevent the email from looking like spam or rendering incorrectly on older devices.
          </div>
        </details>
      
        <details class="bg-canvas ring-1 ring-inset ring-hairline rounded-xl overflow-hidden shadow-lvl2 group">
          <summary class="px-6 py-4 cursor-pointer flex items-center justify-between font-sans font-semibold text-sm text-ink list-none hover:bg-canvas-soft transition-colors select-none">
            What is preheader text and how does it relate to the subject line?
            <svg class="w-4 h-4 text-mute shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-body font-sans leading-relaxed border-t border-hairline pt-4">
            Preheader text is the brief summary text that displays next to or below the subject line in an inbox. It acts as secondary preview copy, allowing you to build on the hook in your subject line and encourage users to open the email.
          </div>
        </details>
      </div>
    </section>

    <!-- Related Tools Section -->
    <section class="max-w-4xl pt-16 mt-20 border-t border-hairline" aria-label="Related Tools">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Marketing Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/marketing/headline-analyzer" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Headline Analyzer
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Analyze titles for Emotional Value (EMV) and power words.</p>
        </a>
        <a href="/marketing/serp-preview" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            SERP Snippet Preview Tool
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Preview page SERPs on desktop and mobile with pixel limits.</p>
        </a>
        <a href="/marketing/meta-tag-generator" class="group bg-canvas ring-1 ring-inset ring-hairline hover:border-hairline-strong rounded-xl p-5 shadow-lvl1 hover:shadow-lvl2 transition-all">
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center gap-2">
            Meta Tag Generator
            <svg class="w-3.5 h-3.5 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-1.5">Generate meta tags with Google and social sharing snippet previews.</p>
        </a>
