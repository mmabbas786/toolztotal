---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why is pixel width more accurate than character count for search results?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Google renders search snippets using a proportional Arial font. Because letters differ in pixel width (e.g. a capital 'W' is much wider than a lowercase 'i'), character counts only estimate size. Pixel width measures the actual physical size Google allocates, providing a precise preview of truncation."
      }
    },
    {
      "@type": "Question",
      "name": "What are Google's title and description pixel limits?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "On Google desktop search results, titles clip after 600 pixels (about 50–60 characters) and descriptions clip after 960 pixels (about 150–160 characters). On mobile devices, titles have similar limits but descriptions clip after roughly 680 pixels (about 110–120 characters)."
      }
    },
    {
      "@type": "Question",
      "name": "What are rich snippets and how do they look in previews?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rich snippets display additional structured data in search listings, such as review stars, price ranges, or collapsible FAQ drop-downs. Adding these elements can significantly improve a search snippet's visual size, visibility, and Click-Through Rate (CTR)."
      }
    },
    {
      "@type": "Question",
      "name": "How does Google handle title tags that are too long?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If a title tag exceeds the 600-pixel width limit, Google cuts it off with an ellipsis (...) to fit. In some cases, Google may rewrite long titles entirely using the page's H1 tag or anchor texts to improve readability for users."
      }
    },
    {
      "@type": "Question",
      "name": "Is my SERP data sent to a server?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Like all tools on ToolzTotal, this SERP preview tool processes all input values, pixel width measurements, and simulations locally in your browser sandbox using client-side JavaScript."
      }
    },
    {
      "@type": "Question",
      "name": "Why does Google rewrite meta descriptions on search result pages?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Google will rewrite your meta description if it determines the text doesn't accurately describe your page, contains keyword stuffing, or if another snippet of text from your content is a better match for the user's search query."
      }
    },
    {
      "@type": "Question",
      "name": "How do mobile search previews differ from desktop search previews?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mobile search results have smaller screen widths, meaning titles and descriptions are truncated sooner than on desktop (often cutting off descriptions at 120 characters instead of 160). Emojis and site favicons are also displayed more prominently in mobile search feeds."
      }
    },
    {
      "@type": "Question",
      "name": "What are rich snippets and how do they affect SERP previews?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rich snippets are search results that display extra visual details alongside the title and description, such as review stars, recipe cook times, or product prices. They are generated by search engines parsing structured schema data in your HTML."
      }
    },
    {
      "@type": "Question",
      "name": "How does search click-through rate (CTR) impact organic rankings?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A high Click-Through Rate (CTR) indicates to search engines that your page is a relevant, appealing answer to a query. Over time, search engines may adjust rankings to promote pages that receive higher-than-average click rates."
      }
    },
    {
      "@type": "Question",
      "name": "Can emojis be used in meta descriptions and titles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, you can use emojis, but search engines do not guarantee they will display. Emojis can increase visual prominence on a search page, but they should be used sparingly and make sense for the topic to avoid looking spammy."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

