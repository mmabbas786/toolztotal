---
import Layout from "../../layouts/Layout.astro";
import ContentFooter from "../../components/ContentFooter.astro";
import Sources from "../../components/Sources.astro";
import DisclaimerBanner from "../../components/DisclaimerBanner.astro";
import ToolSchema from "../../components/ToolSchema.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RelatedTools from "../../components/RelatedTools.astro";

const paycheckFaqs = [
  {
    question: "How is overtime pay calculated?",
    answer:
      "Overtime is typically 1.5x your regular hourly rate for hours over 40 in a week under the federal FLSA. Some states have daily overtime rules — for example, in California, hours over 8 per day are paid at 1.5x and hours over 12 per day at 2x.",
  },
  {
    question: "What's the difference between gross pay and net pay?",
    answer:
      "Gross pay is your total earnings before deductions. Net pay (take-home) is what you actually receive after federal income tax, state income tax, FICA, and other deductions such as insurance or retirement contributions are withheld.",
  },
  {
    question: "Are bonuses and commissions taxed differently?",
    answer:
      "Supplemental wages like bonuses are often withheld at a flat 22% federal rate. Your actual tax liability depends on your marginal bracket when you file, so you may receive a refund or owe more at tax time.",
  },
  {
    question: "How do pre-tax deductions affect my paycheck?",
    answer:
      "Pre-tax deductions such as 401(k) contributions, HSA, and health insurance lower your taxable income. This reduces the amount of federal, state, and FICA taxes withheld from each paycheck.",
  },
  {
    question: "What is FICA and how much is it?",
    answer:
      "FICA funds Social Security (6.2% up to the annual wage base limit) and Medicare (1.45% on all wages). High earners pay an additional 0.9% Medicare surtax. Your employer matches these amounts dollar for dollar.",
  },
  {
    question: "How are state income taxes applied to my paycheck?",
    answer:
      "State income tax depends on where you live. States like Texas and Florida have no income tax, while others use flat or graduated rates. This calculator applies a simplified state rate to your annual gross to estimate per-period withholding.",
  },
];
---

<Layout
  title="Paycheck Calculator - Hourly & Overtime Take-Home Estimator | ToolzTotal"
  description="Estimate your hourly and overtime paycheck after federal, state, and FICA taxes. See gross pay, net pay, and effective tax rate per pay period."
  canonicalUrl="https://toolztotal.com/finance/paycheck-calculator"
>
  <ToolSchema
    toolName="Paycheck Calculator"
    toolSlug="paycheck-calculator"
    categoryName="Finance & Loans"
    categorySlug="finance"
    description="Estimate your hourly and overtime paycheck after federal, state, and FICA taxes. See gross pay, net pay, and effective tax rate per pay period."
    faqs={paycheckFaqs}
  />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categorySlug="finance"
      categoryName="Finance & Loans"
      toolName="Paycheck Calculator"
      toolSlug="paycheck-calculator"
    />

    <DisclaimerBanner category="finance" />

    <div class="max-w-4xl mb-12">
      <div
        class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider"
          >Free Tool</span
        >
      </div>
      <h1
        class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty"
      >
        Paycheck Calculator
      </h1>
      <p
        class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl"
      >
        Estimate your hourly and overtime take-home pay after federal, state,
        and FICA taxes. Adjust your filing status, state, and deductions to see
        your net pay per period — all calculations run privately in your
        browser.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      <form
        id="paycheck-form"
        class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6"
        onsubmit="return false;"
      >
        <div>
          <h2
            class="text-sm font-mono uppercase tracking-wider text-mute border-b border-hairline pb-2 mb-4"
          >
            Earnings
          </h2>
          <div class="space-y-4">
            <div>
              <label
                for="hourly-rate"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Hourly Rate ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="hourly-rate"
                  value="25"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 25"
                  inputmode="decimal"
                  required
                />
              </div>
            </div>

            <div>
              <label
                for="regular-hours"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Regular Hours / Week</label
              >
              <input
                type="number"
                id="regular-hours"
                value="40"
                min="0"
                max="168"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                inputmode="numeric"
              />
            </div>

            <div>
              <label
                for="overtime-hours"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Overtime Hours / Week</label
              >
              <input
                type="number"
                id="overtime-hours"
                value="0"
                min="0"
                max="168"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                inputmode="numeric"
              />
            </div>

            <div>
              <label
                for="ot-multiplier"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Overtime Multiplier</label
              >
              <select
                id="ot-multiplier"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <option value="1.5" selected>1.5x (Time and a half)</option>
                <option value="2">2x (Double time)</option>
                <option value="2.5">2.5x</option>
                <option value="3">3x</option>
              </select>
            </div>

            <div>
              <label
                for="pay-period"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Pay Period</label
              >
              <select
                id="pay-period"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <option value="weekly" selected>Weekly (52/yr)</option>
                <option value="bi-weekly">Bi-Weekly (26/yr)</option>
                <option value="semi-monthly">Semi-Monthly (24/yr)</option>
                <option value="monthly">Monthly (12/yr)</option>
              </select>
            </div>
          </div>
        </div>
        <div class="border-t border-hairline pt-5">
          <h2
            class="text-sm font-mono uppercase tracking-wider text-mute border-b border-hairline pb-2 mb-4"
          >
            Taxes & Deductions
          </h2>
          <div class="space-y-4">
            <div>
              <label
                for="filing-status"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Federal Filing Status</label
              >
              <select
                id="filing-status"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <option value="single" selected>Single</option>
                <option value="married-joint">Married Filing Jointly</option>
                <option value="married-separate">Married Filing Separately</option>
                <option value="head-of-household">Head of Household</option>
              </select>
            </div>

            <div>
              <label
                for="state-sel"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >State</label
              >
              <select
                id="state-sel"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <option value="CA" selected>California</option>
                <option value="TX">Texas</option>
                <option value="FL">Florida</option>
                <option value="NY">New York</option>
                <option value="IL">Illinois</option>
              </select>
            </div>

            <div>
              <label
                for="pre-tax-year"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Pre-Tax Deductions / Year ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="pre-tax-year"
                  value="0"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 6,000"
                  inputmode="decimal"
                />
              </div>
              <p class="text-[10px] text-mute font-sans mt-1">
                401(k), HSA, health insurance — lowers taxable income.
              </p>
            </div>

            <div>
              <label
                for="other-deduct"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Other Deductions / Period ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="other-deduct"
                  value="0"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 50"
                  inputmode="decimal"
                />
              </div>
              <p class="text-[10px] text-mute font-sans mt-1">
                After-tax deductions like garnishments or Roth contributions.
              </p>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-2 pt-4">
          <button
            type="submit"
            id="calculate-btn"
            class="w-full h-10 bg-primary hover:bg-primary-strong text-on-primary font-sans font-bold text-sm rounded-lg transition-colors cursor-pointer shadow-lvl2 text-center"
          >
            Calculate Paycheck
          </button>
          <button
            type="button"
            id="reset-btn"
            class="w-full py-2 text-mute hover:text-ink font-sans text-xs transition-colors cursor-pointer text-center"
          >
            Reset Form
          </button>
        </div>
      </form>

      <div class="lg:col-span-7 space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 flex flex-col justify-between"
          >
            <div>
              <h3
                class="text-xs font-mono uppercase tracking-wider text-mute mb-1"
              >
                Regular Gross / Period
              </h3>
              <p
                class="text-3xl font-bold font-sans text-ink tracking-tight tabular-nums"
                id="regular-gross-val"
              >
                $0.00
              </p>
            </div>
            <div class="mt-4 pt-3 border-t border-hairline">
              <p class="text-[11px] font-sans text-body leading-normal">
                Base pay before tax
              </p>
              <p class="text-[10px] font-mono text-mute mt-0.5">
                Excludes overtime
              </p>
            </div>
          </div>

          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 flex flex-col justify-between"
          >
            <div>
              <h3
                class="text-xs font-mono uppercase tracking-wider text-mute mb-1"
              >
                Overtime Pay / Period
              </h3>
              <p
                class="text-3xl font-bold font-sans text-ink tracking-tight tabular-nums"
                id="ot-pay-val"
              >
                $0.00
              </p>
            </div>
            <div class="mt-4 pt-3 border-t border-hairline">
              <p class="text-[11px] font-sans text-body leading-normal">
                Premium hours
              </p>
              <p class="text-[10px] font-mono text-mute mt-0.5">
                At selected multiplier
              </p>
            </div>
          </div>

          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 flex flex-col justify-between"
          >
            <div>
              <h3
                class="text-xs font-mono uppercase tracking-wider text-mute mb-1"
              >
                Total Gross / Period
              </h3>
              <p
                class="text-3xl font-bold font-sans text-ink tracking-tight tabular-nums"
                id="gross-val"
              >
                $0.00
              </p>
            </div>
            <div class="mt-4 pt-3 border-t border-hairline">
              <p class="text-[11px] font-sans text-body leading-normal">
                Regular + overtime
              </p>
              <p class="text-[10px] font-mono text-mute mt-0.5">
                Before deductions
              </p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Federal Tax / Period
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight tabular-nums"
              id="fed-val"
            >
              $0.00
            </p>
          </div>
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              State Tax / Period
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight tabular-nums"
              id="state-val"
            >
              $0.00
            </p>
          </div>
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              FICA / Period
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight tabular-nums"
              id="fica-val"
            >
              $0.00
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Pre-Tax / Period
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight tabular-nums"
              id="pretax-val"
            >
              $0.00
            </p>
          </div>
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Other Deductions / Period
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight tabular-nums"
              id="other-val"
            >
              $0.00
            </p>
          </div>
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Net Pay / Period
            </h3>
            <p
              class="text-2xl font-bold font-sans text-emerald-600 tracking-tight tabular-nums"
              id="net-val"
            >
              $0.00
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Effective Tax Rate
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight tabular-nums"
              id="eff-rate-val"
            >
              0.0%
            </p>
          </div>
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Annual Net Pay
            </h3>
            <p
              class="text-2xl font-bold font-sans text-emerald-600 tracking-tight tabular-nums"
              id="annual-net-val"
            >
              $0.00
            </p>
          </div>
        </div>

        <div
          class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-4"
        >
          <h3
            class="text-sm font-mono uppercase tracking-wider text-mute border-b border-hairline pb-2"
          >
            Full Breakdown (Per Period)
          </h3>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs font-sans">
              <thead>
                <tr
                  class="border-b border-hairline font-mono text-mute uppercase text-[10px] tracking-wider"
                >
                  <th class="py-2.5 px-3">Component</th>
                  <th class="py-2.5 px-3 text-right">Per Period</th>
                  <th class="py-2.5 px-3 text-right">Annual</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-hairline text-body tabular-nums">
                <tr>
                  <td class="py-3 px-3 font-semibold text-ink">Total Gross</td>
                  <td class="py-3 px-3 text-right font-semibold" id="row-gross"
                    >$0.00</td
                  >
                  <td class="py-3 px-3 text-right font-semibold" id="row-gross-yr"
                    >$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body">Federal income tax</td>
                  <td class="py-3 px-3 text-right text-rose-500" id="row-fed"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-fed-yr">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body">State income tax</td>
                  <td class="py-3 px-3 text-right text-rose-500" id="row-state"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-state-yr">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body">FICA (SS + Medicare)</td>
                  <td class="py-3 px-3 text-right text-rose-500" id="row-fica"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-fica-yr">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body">Pre-tax deductions</td>
                  <td class="py-3 px-3 text-right text-rose-500" id="row-pretax"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-pretax-yr">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body">Other deductions</td>
                  <td class="py-3 px-3 text-right text-rose-500" id="row-other"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-other-yr">-$0.00</td
                  >
                </tr>
                <tr class="bg-emerald-500/10">
                  <td
                    class="py-3 px-3 font-semibold text-emerald-800 dark:text-emerald-400"
                    >Net Pay</td
                  >
                  <td
                    class="py-3 px-3 text-right font-semibold text-emerald-800 dark:text-emerald-400"
                    id="row-net">$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right font-semibold text-emerald-800 dark:text-emerald-400"
                    id="row-net-yr">$0.00</td
                  >
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div
          id="error-panel"
          class="hidden bg-rose-50 dark:bg-rose-950/20 border border-rose-200 dark:border-rose-900 rounded-xl p-4 text-rose-700 dark:text-rose-400 text-xs leading-relaxed font-sans"
        >
        </div>

        <div
          class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl1 space-y-2 text-[11px] font-sans text-mute leading-relaxed"
        >
          <p>
            * <strong>Estimate Only</strong>: This calculator uses simplified
            2026 federal brackets and flat state rates. It does not account for
            local taxes, detailed withholding allowances, or credits. Consult a
            tax professional for exact figures.
          </p>
        </div>
      </div>
    </div>

    <section
      class="mt-16 bg-canvas border border-hairline rounded-2xl p-6 md:p-8 shadow-lvl1"
    >
      <h2
        class="text-lg font-bold text-ink font-sans mb-4 border-b border-hairline pb-2"
      >
        Paycheck Terms Explained
      </h2>
      <div
        class="grid grid-cols-1 md:grid-cols-2 gap-8 text-xs md:text-sm font-sans leading-relaxed text-body"
      >
        <div class="space-y-4">
          <div>
            <h3 class="font-bold text-ink mb-1 text-sm">Overtime (FLSA)</h3>
            <p>
              The Fair Labor Standards Act requires 1.5x the regular rate for
              hours beyond 40 in a workweek. Some states add daily overtime
              rules on top of the federal standard.
            </p>
          </div>
          <div>
            <h3 class="font-bold text-ink mb-1 text-sm">FICA</h3>
            <p>
              Social Security (6.2% up to the wage base) plus Medicare (1.45% on
              all wages). High earners pay an extra 0.9% Medicare surtax. Your
              employer matches the employee portion.
            </p>
          </div>
        </div>
        <div class="space-y-4">
          <div>
            <h3 class="font-bold text-ink mb-1 text-sm">Pre-Tax vs After-Tax</h3>
            <p>
              Pre-tax deductions reduce taxable income, lowering your tax
              withholding. After-tax deductions (like Roth contributions) come
              out of already-taxed pay and don't reduce your tax bill.
            </p>
          </div>
          <div>
            <h3 class="font-bold text-ink mb-1 text-sm">Pay Periods</h3>
            <p>
              Weekly (52), bi-weekly (26), semi-monthly (24), and monthly (12)
              periods change how your annual salary is divided across the year,
              which affects each paycheck's size.
            </p>
          </div>
        </div>
      </div>
    </section>
    <article
      class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16"
    >
      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6"
      >
        How to Calculate Overtime Pay
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          Overtime pay rewards hours worked beyond a standard threshold. Under
          the federal Fair Labor Standards Act (FLSA), non-exempt employees must
          receive at least 1.5 times their regular rate of pay for hours over 40
          in a workweek.
        </p>
        <div
          class="bg-canvas-soft-2/30 border border-hairline rounded-xl p-4 font-mono text-xs md:text-sm text-ink space-y-1"
        >
          <p>Overtime Pay = Overtime Hours × Hourly Rate × Multiplier</p>
          <p class="text-mute text-[10px]">
            Example: 10 OT hours at $25/hr × 1.5 = $375
          </p>
        </div>
        <p>
          Some states go further. California requires daily overtime: time
          worked beyond 8 hours in a day is paid at 1.5x, and beyond 12 hours at
          2x. Alaska, Nevada, and Colorado also have daily overtime rules. This
          calculator uses the federal 40-hour weekly rule by default, but you can
          adjust the multiplier to model state-specific premiums.
        </p>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-12 mb-6"
      >
        Gross Pay vs Net Pay: What's the Difference?
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          <strong>Gross pay</strong> is everything you earn before anything is
          taken out — your hourly rate times hours worked, plus overtime and any
          bonuses. <strong>Net pay</strong> (take-home) is what actually lands
          in your bank account after mandatory and voluntary deductions.
        </p>
        <ul class="list-disc pl-5 space-y-2">
          <li>
            <strong>Federal income tax</strong> — withheld based on your W-4 and
            progressive brackets.
          </li>
          <li>
            <strong>State income tax</strong> — varies by state; some states
            have none.
          </li>
          <li>
            <strong>FICA</strong> — Social Security and Medicare.
          </li>
          <li>
            <strong>Pre-tax deductions</strong> — 401(k), HSA, health insurance.
          </li>
          <li>
            <strong>After-tax deductions</strong> — Roth contributions,
            garnishments, union dues.
          </li>
        </ul>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-12 mb-6"
      >
        How Payroll Taxes Work
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          Three main taxes reduce your gross paycheck:
        </p>
        <ul class="list-disc pl-5 space-y-2">
          <li>
            <strong>Federal income tax</strong> — progressive; only the portion
            of income in each bracket is taxed at that rate.
          </li>
          <li>
            <strong>State income tax</strong> — ranges from 0% (TX, FL) to
            graduated brackets (CA, NY).
          </li>
          <li>
            <strong>FICA</strong> — a flat 6.2% Social Security (up to the wage
            base) plus 1.45% Medicare on all wages, with an extra 0.9% Medicare
            surtax for high earners.
          </li>
        </ul>
        <p>
          Unlike income tax, FICA is calculated on your gross wages and is not
          reduced by pre-tax deductions. Your employer pays a matching FICA
          amount, so the total cost to employ you is roughly 7.65% higher than
          your gross.
        </p>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-12 mb-6"
      >
        Pre-Tax vs After-Tax Deductions
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          Pre-tax deductions lower your taxable income, which reduces federal,
          state, and FICA withholding. Common examples include traditional 401(k)
          contributions, health savings accounts (HSAs), and employer health
          insurance premiums.
        </p>
        <p>
          After-tax deductions are taken from pay that has already been taxed.
          Roth 401(k) contributions are the most common example: they don't
          lower your current tax bill, but qualified withdrawals in retirement
          are tax-free. Use the "Pre-Tax Deductions" field for tax-reducing
          items and "Other Deductions" for after-tax items.
        </p>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-12 mb-6"
      >
        Overtime Laws by State
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          While the FLSA sets the federal baseline (1.5x after 40 hours/week),
          several states provide additional protection:
        </p>
        <div
          class="overflow-x-auto my-6 border border-hairline rounded-lg bg-canvas shadow-lvl1"
        >
          <table
            class="w-full text-left border-collapse text-xs md:text-sm font-sans"
          >
            <thead>
              <tr
                class="bg-canvas-soft-2 font-mono text-mute uppercase text-[11px] tracking-wider border-b border-hairline"
              >
                <th class="py-3 px-4">State</th>
                <th class="py-3 px-4 text-right">Weekly OT</th>
                <th class="py-3 px-4 text-right">Daily OT</th>
                <th class="py-3 px-4 text-right">State Income Tax</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-hairline text-body tabular-nums">
              <tr>
                <td class="py-3 px-4 font-bold text-ink">California</td>
                <td class="py-3.5 px-4 text-right">1.5x &gt; 40 hrs</td>
                <td class="py-3.5 px-4 text-right">1.5x &gt; 8h, 2x &gt; 12h</td>
                <td class="py-3.5 px-4 text-right">1%–13.3%</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-bold text-ink">Texas</td>
                <td class="py-3.5 px-4 text-right">1.5x &gt; 40 hrs</td>
                <td class="py-3.5 px-4 text-right">None</td>
                <td class="py-3.5 px-4 text-right">0%</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-bold text-ink">Florida</td>
                <td class="py-3.5 px-4 text-right">1.5x &gt; 40 hrs</td>
                <td class="py-3.5 px-4 text-right">None</td>
                <td class="py-3.5 px-4 text-right">0%</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-bold text-ink">New York</td>
                <td class="py-3.5 px-4 text-right">1.5x &gt; 40 hrs</td>
                <td class="py-3.5 px-4 text-right">None (Hospitality: 1.5x &gt; 10h/day)</td>
                <td class="py-3.5 px-4 text-right">4%–10.9%</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-bold text-ink">Illinois</td>
                <td class="py-3.5 px-4 text-right">1.5x &gt; 40 hrs</td>
                <td class="py-3.5 px-4 text-right">None</td>
                <td class="py-3.5 px-4 text-right">3.75%–4.95%</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </article>

    <Sources
      sources={[
        {
          label: "IRS Publication 15-T (2026 Federal Income Tax Withholding Methods)",
          url: "https://www.irs.gov/publications/p15t",
        },
        {
          label: "U.S. Department of Labor — FLSA Overtime Standards",
          url: "https://www.dol.gov/agencies/whd/fact-sheets/23",
        },
        {
          label: "Social Security Administration — 2026 FICA Tax Rates",
          url: "https://www.ssa.gov/oact/cola/cws.html",
        },
        {
          label: "California DIR — Overtime & Daily Overtime Rules",
          url: "https://www.dir.ca.gov/dlse/FAQ_Overtime.htm",
        },
      ]}
    />

    <section class="mt-20 pt-16 border-t border-hairline max-w-4xl">
      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty"
      >
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {
          paycheckFaqs.map((faq, index) => (
            <div class="border border-hairline rounded-lg bg-canvas overflow-hidden shadow-lvl1">
              <button
                type="button"
                class="faq-toggle w-full px-6 py-4 flex items-center justify-between text-left font-sans text-sm font-bold text-ink hover:bg-canvas-soft-2 transition-colors cursor-pointer"
                aria-expanded="false"
                id={`faq-btn-${index}`}
              >
                <span>{faq.question}</span>
                <svg
                  class="w-4 h-4 text-mute transition-transform duration-200"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-content hidden border-t border-hairline px-6 py-4 bg-canvas-soft">
                <p class="text-body text-sm font-sans leading-relaxed">
                  {faq.answer}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <RelatedTools categorySlug="finance" toolSlug="paycheck-calculator" />
  </div>

  <ContentFooter category="finance" />
</Layout>

<script>
  const hourlyRate = document.getElementById("hourly-rate") as HTMLInputElement;
  const regularHours = document.getElementById("regular-hours") as HTMLInputElement;
  const overtimeHours = document.getElementById("overtime-hours") as HTMLInputElement;
  const otMultiplier = document.getElementById("ot-multiplier") as HTMLSelectElement;
  const payPeriod = document.getElementById("pay-period") as HTMLSelectElement;
  const filingStatus = document.getElementById("filing-status") as HTMLSelectElement;
  const stateSel = document.getElementById("state-sel") as HTMLSelectElement;
  const preTaxYear = document.getElementById("pre-tax-year") as HTMLInputElement;
  const otherDeduct = document.getElementById("other-deduct") as HTMLInputElement;

  const calculateBtn = document.getElementById("calculate-btn");
  const resetBtn = document.getElementById("reset-btn");

  const regularGrossVal = document.getElementById("regular-gross-val");
  const otPayVal = document.getElementById("ot-pay-val");
  const grossVal = document.getElementById("gross-val");
  const fedVal = document.getElementById("fed-val");
  const stateVal = document.getElementById("state-val");
  const ficaVal = document.getElementById("fica-val");
  const pretaxVal = document.getElementById("pretax-val");
  const otherVal = document.getElementById("other-val");
  const netVal = document.getElementById("net-val");
  const effRateVal = document.getElementById("eff-rate-val");
  const annualNetVal = document.getElementById("annual-net-val");

  const rowGross = document.getElementById("row-gross");
  const rowGrossYr = document.getElementById("row-gross-yr");
  const rowFed = document.getElementById("row-fed");
  const rowFedYr = document.getElementById("row-fed-yr");
  const rowState = document.getElementById("row-state");
  const rowStateYr = document.getElementById("row-state-yr");
  const rowFica = document.getElementById("row-fica");
  const rowFicaYr = document.getElementById("row-fica-yr");
  const rowPretax = document.getElementById("row-pretax");
  const rowPretaxYr = document.getElementById("row-pretax-yr");
  const rowOther = document.getElementById("row-other");
  const rowOtherYr = document.getElementById("row-other-yr");
  const rowNet = document.getElementById("row-net");
  const rowNetYr = document.getElementById("row-net-yr");

  const errorPanel = document.getElementById("error-panel");

  function parseVal(el) {
    const rawVal = el.value.replace(/,/g, "").trim();
    if (rawVal === "") return 0;
    const parsed = parseFloat(rawVal);
    return isNaN(parsed) || parsed < 0 ? 0 : parsed;
  }

  function formatMoney(num) {
    return new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
    }).format(num);
  }

  function round(num, decimals) {
    return Math.round(num * Math.pow(10, decimals)) / Math.pow(10, decimals);
  }

  const PERIODS = { weekly: 52, "bi-weekly": 26, "semi-monthly": 24, monthly: 12 };

  function fedBrackets(status) {
    if (status === "married-joint") {
      return [
        { max: 23850, rate: 0.10 },
        { max: 96950, rate: 0.12 },
        { max: 206700, rate: 0.22 },
        { max: 394600, rate: 0.24 },
        { max: 501050, rate: 0.32 },
        { max: 1252700, rate: 0.35 },
        { max: Infinity, rate: 0.37 },
      ];
    }
    if (status === "head-of-household") {
      return [
        { max: 16000, rate: 0.10 },
        { max: 64850, rate: 0.12 },
        { max: 115300, rate: 0.22 },
        { max: 219700, rate: 0.24 },
        { max: 279050, rate: 0.32 },
        { max: 693750, rate: 0.35 },
        { max: Infinity, rate: 0.37 },
      ];
    }
    // single and married-separate
    return [
      { max: 11925, rate: 0.10 },
      { max: 48475, rate: 0.12 },
      { max: 103350, rate: 0.22 },
      { max: 197300, rate: 0.24 },
      { max: 250525, rate: 0.32 },
      { max: 626350, rate: 0.35 },
      { max: Infinity, rate: 0.37 },
    ];
  }

  function calcFedTax(annual, status) {
    const brackets = fedBrackets(status);
    let tax = 0;
    let prev = 0;
    for (const b of brackets) {
      if (annual <= prev) break;
      const taxable = Math.min(annual, b.max) - prev;
      tax += taxable * b.rate;
      prev = b.max;
    }
    return tax;
  }

  function runCalculations() {
    errorPanel.classList.add("hidden");
    errorPanel.textContent = "";

    const rate = parseVal(hourlyRate);
    const regH = parseVal(regularHours);
    const otH = parseVal(overtimeHours);
    const mult = parseFloat(otMultiplier.value) || 1.5;
    const period = payPeriod.value;
    const status = filingStatus.value;
    const state = stateSel.value;
    const preTax = parseVal(preTaxYear);
    const other = parseVal(otherDeduct);

    const periods = PERIODS[period] || 52;

    const annualRegular = rate * regH * 52;
    const annualOT = rate * otH * 52 * mult;
    const annualGross = annualRegular + annualOT;

    if (annualGross <= 0) {
      errorPanel.classList.remove("hidden");
      errorPanel.textContent =
        "Please enter a positive hourly rate and at least some hours.";
      return;
    }

    const fedAnnual = calcFedTax(annualGross, status);
    const stateRates = { CA: 0.06, TX: 0, FL: 0, NY: 0.05, IL: 0.045 };
    const stateAnnual = annualGross * (stateRates[state] || 0);

    const wageBase = 168600;
    const ss = Math.min(annualGross, wageBase) * 0.062;
    const medicare = annualGross * 0.0145;
    let addMed = 0;
    if (status === "single") {
      if (annualGross > 200000) addMed = (annualGross - 200000) * 0.009;
    } else if (status === "married-joint" || status === "married-separate") {
      if (annualGross > 250000) addMed = (annualGross - 250000) * 0.009;
    }
    const ficaAnnual = ss + medicare + addMed;

    const regularPer = annualRegular / periods;
    const otPer = annualOT / periods;
    const grossPer = annualGross / periods;

    const fedPer = fedAnnual / periods;
    const statePer = stateAnnual / periods;
    const ficaPer = ficaAnnual / periods;
    const preTaxPer = preTax / periods;

    const netPer =
      grossPer - fedPer - statePer - ficaPer - preTaxPer - other;
    const effRate = ((fedAnnual + stateAnnual + ficaAnnual) / annualGross) * 100;
    const annualNet = netPer * periods;

    regularGrossVal.textContent = formatMoney(regularPer);
    otPayVal.textContent = formatMoney(otPer);
    grossVal.textContent = formatMoney(grossPer);
    fedVal.textContent = formatMoney(fedPer);
    stateVal.textContent = formatMoney(statePer);
    ficaVal.textContent = formatMoney(ficaPer);
    pretaxVal.textContent = formatMoney(preTaxPer);
    otherVal.textContent = formatMoney(other);
    netVal.textContent = formatMoney(netPer);
    effRateVal.textContent = round(effRate, 1) + "%";
    annualNetVal.textContent = formatMoney(annualNet);

    rowGross.textContent = formatMoney(grossPer);
    rowGrossYr.textContent = formatMoney(annualGross);
    rowFed.textContent = "-" + formatMoney(fedPer);
    rowFedYr.textContent = "-" + formatMoney(fedAnnual);
    rowState.textContent = "-" + formatMoney(statePer);
    rowStateYr.textContent = "-" + formatMoney(stateAnnual);
    rowFica.textContent = "-" + formatMoney(ficaPer);
    rowFicaYr.textContent = "-" + formatMoney(ficaAnnual);
    rowPretax.textContent = "-" + formatMoney(preTaxPer);
    rowPretaxYr.textContent = "-" + formatMoney(preTax);
    rowOther.textContent = "-" + formatMoney(other);
    rowOtherYr.textContent = "-" + formatMoney(other * periods);
    rowNet.textContent = formatMoney(netPer);
    rowNetYr.textContent = formatMoney(annualNet);
  }

  function formatInputOnBlur(e) {
    const target = e.target;
    const rawVal = target.value.replace(/,/g, "").trim();
    if (rawVal === "") return;
    const parsed = parseFloat(rawVal);
    if (!isNaN(parsed) && parsed >= 0) {
      target.value = new Intl.NumberFormat("en-US").format(parsed);
    }
  }

  [hourlyRate, preTaxYear, otherDeduct].forEach((input) => {
    input.addEventListener("input", runCalculations);
    input.addEventListener("blur", formatInputOnBlur);
  });
  [regularHours, overtimeHours, otMultiplier, payPeriod, filingStatus, stateSel].forEach(
    (el) => el.addEventListener("input", runCalculations),
  );

  calculateBtn.addEventListener("click", runCalculations);

  resetBtn.addEventListener("click", () => {
    hourlyRate.value = "25";
    regularHours.value = "40";
    overtimeHours.value = "0";
    otMultiplier.value = "1.5";
    payPeriod.value = "weekly";
    filingStatus.value = "single";
    stateSel.value = "CA";
    preTaxYear.value = "0";
    otherDeduct.value = "0";
    runCalculations();
  });

  document.querySelectorAll(".faq-toggle").forEach((button) => {
    button.addEventListener("click", () => {
      const content = button.nextElementSibling;
      const chevron = button.querySelector("svg");
      const isHidden = content.classList.toggle("hidden");
      chevron.classList.toggle("rotate-180", !isHidden);
      button.setAttribute("aria-expanded", (!isHidden).toString());
    });
  });

  runCalculations();
</script>
