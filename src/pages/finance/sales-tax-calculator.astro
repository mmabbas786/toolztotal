<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const stateSelect = document.getElementById('state-select') as HTMLSelectElement;
  const taxRateIn = document.getElementById('tax-rate-input') as HTMLInputElement;
  
  const modeForward = document.getElementById('mode-forward') as HTMLButtonElement;
  const modeReverse = document.getElementById('mode-reverse') as HTMLButtonElement;

  const priceLabel = document.getElementById('price-label') as HTMLLabelElement;
  const priceIn = document.getElementById('price-input') as HTMLInputElement;

  const resTotalLabel = document.getElementById('res-total-label') as HTMLSpanElement;
  const resTotal = document.getElementById('res-total') as HTMLSpanElement;
  const lblBreakdownPrice = document.getElementById('lbl-breakdown-price') as HTMLSpanElement;
  const resPretax = document.getElementById('res-pretax') as HTMLSpanElement;
  const resTaxAmount = document.getElementById('res-tax-amount') as HTMLSpanElement;

  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;

  // ============================================================
  // State variables
  // ============================================================
  let activeMode: 'forward' | 'reverse' = 'forward';

  // Read stateTaxRates safely from defined vars on window
  const ratesTable = (window as any).stateTaxRates || {};

  // ============================================================
  // Functions
  // ============================================================
  const handleStateChange = () => {
    const stateVal = stateSelect.value;
    if (stateVal === 'custom') {
      taxRateIn.disabled = false;
    } else {
      const match = ratesTable[stateVal];
      if (match) {
        taxRateIn.value = match.salesTaxRate.toString();
        taxRateIn.disabled = true;
      }
    }
    calculateTax();
  };

  const calculateTax = () => {
    const rate = parseFloat(taxRateIn.value) || 0;
    const priceVal = parseFloat(priceIn.value) || 0;

    let base = 0;
    let tax = 0;
    let total = 0;

    if (activeMode === 'forward') {
      // Forward: Input is pre-tax price
      base = priceVal;
      tax = priceVal * (rate / 100);
      total = base + tax;

      resTotalLabel.textContent = "Total Price (Inc. Tax)";
      lblBreakdownPrice.textContent = "PRE-TAX PRICE:";
      resPretax.textContent = "$" + base.toFixed(2);
      resTaxAmount.textContent = "$" + tax.toFixed(2);
      resTotal.textContent = "$" + total.toFixed(2);
    } else {
      // Reverse: Input is total price (tax-inclusive)
      total = priceVal;
      base = total / (1 + (rate / 100));
      tax = total - base;

      resTotalLabel.textContent = "Original Pre-Tax Price";
      lblBreakdownPrice.textContent = "TOTAL PRICE (INC. TAX):";
      resPretax.textContent = "$" + total.toFixed(2);
      resTaxAmount.textContent = "$" + tax.toFixed(2);
      resTotal.textContent = "$" + base.toFixed(2);
    }
  };

  const toggleMode = (mode: 'forward' | 'reverse') => {
    activeMode = mode;
    if (mode === 'forward') {
      modeForward.className = "flex-1 py-1.5 text-xs font-mono font-semibold rounded bg-canvas border border-hairline text-ink cursor-pointer transition-all shadow-lvl1";
      modeReverse.className = "flex-1 py-1.5 text-xs font-mono text-mute cursor-pointer transition-all";
      priceLabel.textContent = "Base Price ($)";
    } else {
      modeReverse.className = "flex-1 py-1.5 text-xs font-mono font-semibold rounded bg-canvas border border-hairline text-ink cursor-pointer transition-all shadow-lvl1";
      modeForward.className = "flex-1 py-1.5 text-xs font-mono text-mute cursor-pointer transition-all";
      priceLabel.textContent = "Total Price ($) (Inc. Tax)";
    }
    calculateTax();
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  stateSelect.addEventListener('change', handleStateChange);
  taxRateIn.addEventListener('input', calculateTax);
  priceIn.addEventListener('input', calculateTax);

  modeForward.addEventListener('click', () => toggleMode('forward'));
  modeReverse.addEventListener('click', () => toggleMode('reverse'));

  btnReset.addEventListener('click', () => {
    stateSelect.value = 'custom';
    taxRateIn.value = '8.25';
    taxRateIn.disabled = false;
    priceIn.value = '100.00';
    toggleMode('forward');
    calculateTax();
  });

  // Initial render
  handleStateChange();
</script>
