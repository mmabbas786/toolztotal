---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you calculate a basic percentage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To find a percentage of a number, convert the percentage to a decimal (divide by 100) and multiply: Value = Total * (Percentage / 100)."
      }
    },
    {
      "@type": "Question",
      "name": "How do you calculate percentage change?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To find the percentage increase or decrease between two values: Percentage Change = ((New Value - Old Value) / Old Value) * 100."
      }
    },
    {
      "@type": "Question",
      "name": "What is percentage points vs. percent?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Percent measures the rate of change relative to an original value. Percentage points measure the simple arithmetic difference between two percentages (e.g., an increase from 10% to 15% is a 5 percentage point increase, but a 50% relative increase)."
      }
    },
    {
      "@type": "Question",
      "name": "How do you find the whole if you have the part and percent?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To find the total value from a partial value and its percentage: Total = Part / (Percentage / 100)."
      }
    },
    {
      "@type": "Question",
      "name": "How is percentage increase calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To increase a number by a percentage: New Value = Original * (1 + (Percentage / 100))."
      }
    },
    {
      "@type": "Question",
      "name": "How is percentage decrease calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To decrease a number by a percentage: New Value = Original * (1 - (Percentage / 100))."
      }
    },
    {
      "@type": "Question",
      "name": "What is a percentage multiplier?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A percentage multiplier is the factor used to adjust a value directly. An 8% tax has a multiplier of 1.08, while a 20% discount has a multiplier of 0.80."
      }
    },
    {
      "@type": "Question",
      "name": "How do you calculate fraction to percentage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide the numerator by the denominator, then multiply by 100: Percentage = (Numerator / Denominator) * 100."
      }
    },
    {
      "@type": "Question",
      "name": "Why are percentages important in business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Percentages are used to compare financial performance across different company sizes, showing profit margins, tax rates, growth rates, and market share."
      }
    },
    {
      "@type": "Question",
      "name": "Does this calculator support decimals?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can input fractional percentages and decimal values, and the engine will compute exact figures rounded to standard decimal places."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
