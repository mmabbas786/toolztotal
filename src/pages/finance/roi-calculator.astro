    const tdRoiB = document.getElementById('td-roi-b') as HTMLTableCellElement;
    const tdRoiDelta = document.getElementById('td-roi-delta') as HTMLTableCellElement;
    const tdCagrA = document.getElementById('td-cagr-a') as HTMLTableCellElement;
    const tdCagrB = document.getElementById('td-cagr-b') as HTMLTableCellElement;
    const tdCagrDelta = document.getElementById('td-cagr-delta') as HTMLTableCellElement;
    const tdBeA = document.getElementById('td-be-a') as HTMLTableCellElement;
    const tdBeB = document.getElementById('td-be-b') as HTMLTableCellElement;
    const tdBeDelta = document.getElementById('td-be-delta') as HTMLTableCellElement;

    // SVG Chart Elements
    const chartYMax = document.getElementById('chart-y-max') as SVGTextElement;
    const chartYMid = document.getElementById('chart-y-mid') as SVGTextElement;
    const chartLineA = document.getElementById('chart-line-a') as SVGPathElement;
    const chartLineAFill = document.getElementById('chart-line-a-fill') as SVGPathElement;
    const chartInvestedA = document.getElementById('chart-invested-a') as SVGPathElement;
    const chartLineB = document.getElementById('chart-line-b') as SVGPathElement;
    const chartLineBFill = document.getElementById('chart-line-b-fill') as SVGPathElement;
    const chartInvestedB = document.getElementById('chart-invested-b') as SVGPathElement;
    const chartXLabels = document.getElementById('chart-x-labels') as SVGGraphicsElement;

    // Compare-mode chart SVG elements (second chart inside results-compare-panel)
    const chart2YMax = document.getElementById('chart2-y-max') as SVGTextElement;
    const chart2YMid = document.getElementById('chart2-y-mid') as SVGTextElement;
    const chart2LineA = document.getElementById('chart2-line-a') as SVGPathElement;
    const chart2LineAFill = document.getElementById('chart2-line-a-fill') as SVGPathElement;
    const chart2InvestedA = document.getElementById('chart2-invested-a') as SVGPathElement;
    const chart2LineB = document.getElementById('chart2-line-b') as SVGPathElement;
    const chart2LineBFill = document.getElementById('chart2-line-b-fill') as SVGPathElement;
    const chart2InvestedB = document.getElementById('chart2-invested-b') as SVGPathElement;
    const chart2XLabels = document.getElementById('chart2-x-labels') as SVGGraphicsElement;

    // Legends toggling
    const lgndInvestedA = document.getElementById('lgnd-invested-a') as HTMLDivElement;
    const lgndValueB = document.getElementById('lgnd-value-b') as HTMLDivElement;
    const lgndInvestedB = document.getElementById('lgnd-invested-b') as HTMLDivElement;

    const copyLinkBtn = document.getElementById('copy-link-btn') as HTMLButtonElement;
    const copyLinkBtnCompare = document.getElementById('copy-link-btn-compare') as HTMLButtonElement;
    const downloadCsvBtn = document.getElementById('download-csv') as HTMLButtonElement;

    // State Globals
    let csvDataContent = '';
    let globalValueTimelineA: any[] = [];
    let globalValueTimelineB: any[] = [];

    // Helper functions
    const formatCurrency = (val: number) => {
      const isNegative = val < 0;
      const formatted = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(Math.abs(val));
      return isNegative ? `-${formatted}` : formatted;
    };

    const formatPercent = (val: number) => {
      return (val * 100).toFixed(2) + '%';
    };

    // NPV/IRR bisection solver
    // Finds rate 'r' such that NPV = 0. We discount monthly.
    const solveIRR = (
      init: number,
      finalValue: number,
      termMonths: number,
      contribType: string,
      contribAmt: number,
      contribTimeMonths: number
    ): number => {
      if (finalValue <= 0) return -1.0; // Math constraint -100%

      let low = -0.999;
      let high = 100.0;
      let rate = 0;

      // NPV Function
      const calcNPV = (r: number) => {
        let npv = -init;
        for (let m = 1; m <= termMonths; m++) {
          let cf = 0;
          if (contribType === 'monthly') cf += contribAmt;
          if (contribType === 'onetime' && m === contribTimeMonths) cf += contribAmt;
          npv -= cf / Math.pow(1 + r, m / 12);
        }
        npv += finalValue / Math.pow(1 + r, termMonths / 12);
        return npv;
      };

      const fLow = calcNPV(low);
      const fHigh = calcNPV(high);
      if (fLow * fHigh > 0) {
        // Root not enclosed, fallback to simple CAGR on total invested
        const totalInvested = init + (contribType === 'monthly' ? contribAmt * termMonths : (contribType === 'onetime' ? contribAmt : 0));
        if (totalInvested <= 0) return 0;
        return Math.pow(finalValue / totalInvested, 12 / termMonths) - 1;
      }

      for (let i = 0; i < 80; i++) {
        rate = (low + high) / 2;
        const npv = calcNPV(rate);
        if (Math.abs(npv) < 0.0001) break;
        if (calcNPV(low) * npv < 0) {
          high = rate;
        } else {
          low = rate;
        }
      }
      return rate;
    };

    // Calculate Investment Scenario
    const runScenario = (
      init: number,
      isProjected: boolean,
      finalOrRate: number,
      termVal: number,
      termUnit: string,
      contribType: string,
      contribAmt: number,
      contribTimeVal: number
    ) => {
      const termMonths = termUnit === 'years' ? Math.round(termVal * 12) : Math.round(termVal);
      const termYears = termMonths / 12;

      let contribTimeMonths = 0;
      if (contribType === 'onetime') {
        contribTimeMonths = termUnit === 'years' ? Math.round(contribTimeVal * 12) : Math.round(contribTimeVal);
        contribTimeMonths = Math.min(termMonths, Math.max(1, contribTimeMonths));
      }

      let finalValue = 0;
      let cagr = 0;
      let totalContributions = 0;

      // Calculate total cash flows
      if (contribType === 'monthly') {
        totalContributions = contribAmt * termMonths;
      } else if (contribType === 'onetime') {
        totalContributions = contribAmt;
      }

      const totalInvested = init + totalContributions;

      if (isProjected) {
        // Compounding forwards
        cagr = finalOrRate / 100;
        const monthlyRate = Math.pow(1 + cagr, 1 / 12) - 1;

        let currentVal = init;
        const timeline: any[] = [{ month: 0, val: init, invested: init }];

        for (let m = 1; m <= termMonths; m++) {
          currentVal = currentVal * (1 + monthlyRate);
          let cf = 0;
          if (contribType === 'monthly') cf = contribAmt;
          if (contribType === 'onetime' && m === contribTimeMonths) cf = contribAmt;
          
          currentVal += cf;
          
          let cumInvested = init;
          if (contribType === 'monthly') {
            cumInvested += contribAmt * m;
          } else if (contribType === 'onetime' && m >= contribTimeMonths) {
            cumInvested += contribAmt;
          }

          timeline.push({ month: m, val: currentVal, invested: cumInvested });
        }

        finalValue = currentVal;
        globalValueTimelineA = timeline; // cached
      } else {
        // Knowing Final Value
        finalValue = finalOrRate;
        
        // Solve CAGR (MWRR) rate
        cagr = solveIRR(init, finalValue, termMonths, contribType, contribAmt, contribTimeMonths);

        // Build simulated growth curve matching CAGR
        const monthlyRate = Math.pow(1 + cagr, 1 / 12) - 1;
        let currentVal = init;
        const timeline: any[] = [{ month: 0, val: init, invested: init }];

        for (let m = 1; m <= termMonths; m++) {
          currentVal = currentVal * (1 + monthlyRate);
          let cf = 0;
          if (contribType === 'monthly') cf = contribAmt;
          if (contribType === 'onetime' && m === contribTimeMonths) cf = contribAmt;
          
          currentVal += cf;

          let cumInvested = init;
          if (contribType === 'monthly') {
            cumInvested += contribAmt * m;
          } else if (contribType === 'onetime' && m >= contribTimeMonths) {
            cumInvested += contribAmt;
          }

          timeline.push({ month: m, val: currentVal, invested: cumInvested });
        }

        // Adjust final rounding slightly to lock final coordinate value
        if (timeline.length > 0) {
          timeline[timeline.length - 1].val = finalValue;
        }
        globalValueTimelineA = timeline;
      }

      const netProfit = finalValue - totalInvested;
      const totalRoi = totalInvested > 0 ? (netProfit / totalInvested) : 0;

      // Solve Break-Even month
      let breakEvenMonthIndex = -1;
      let timeline = globalValueTimelineA;
      for (let m = 0; m < timeline.length; m++) {
        // Has the value overtaken or equaled the cumulative cash invested?
        if (timeline[m].val >= timeline[m].invested) {
          // It must stay positive/above or just cross. We find the first month
          if (breakEvenMonthIndex === -1 && m > 0) {
            breakEvenMonthIndex = m;
          }
        } else {
          // If it falls below (due to additions), reset
          breakEvenMonthIndex = -1;
        }
      }

      // If it starts broken even at Month 0
      if (init > 0 && timeline[0].val >= timeline[0].invested) {
        breakEvenMonthIndex = 0;
      }

      let breakEvenStr = 'Not achieved';
      if (breakEvenMonthIndex === 0) {
        breakEvenStr = 'Instant';
      } else if (breakEvenMonthIndex > 0) {
        const y = Math.floor(breakEvenMonthIndex / 12);
        const remMonths = breakEvenMonthIndex % 12;
        let str = '';
        if (y > 0) str += `${y} yr${y > 1 ? 's' : ''}`;
        if (remMonths > 0) str += ` ${remMonths} mo${remMonths > 1 ? 's' : ''}`;
        breakEvenStr = str.trim();
      }

      return {
        totalRoi,
        cagr,
        netProfit,
        finalValue,
        totalContributions,
        totalInvested,
        breakEvenStr,
        timeline
      };
    };

    // Core execution loop
    const recalculate = () => {
      const mode = activeModeInput.value;

      // 1. Gather A inputs
      const initA = Math.max(0, parseFloat(initAInput.value) || 0);
      const isProjectedA = valModeAInput.value === 'project';
      const finalOrRateA = Math.max(-100, parseFloat(isProjectedA ? rateAInput.value : finalAInput.value) || 0);
      const termA = Math.max(1, parseFloat(termAInput.value) || 1);
      const termUnitA = termUnitAInput.value;
      const contribTypeA = contribTypeAInput.value;
      const contribAmtA = Math.max(0, parseFloat(contribAmtAInput.value) || 0);
      const contribTimeA = Math.max(0, parseFloat(contribTimeAInput.value) || 0);

      // Solve A
      const resA = runScenario(initA, isProjectedA, finalOrRateA, termA, termUnitA, contribTypeA, contribAmtA, contribTimeA);
      globalValueTimelineA = resA.timeline;

      // 2. Gather B inputs if compare
      let resB: any = null;
      if (mode === 'compare') {
        const initB = Math.max(0, parseFloat(initBInput.value) || 0);
        const isProjectedB = valModeBInput.value === 'project';
        const finalOrRateB = Math.max(-100, parseFloat(isProjectedB ? rateBInput.value : finalBInput.value) || 0);
        const termB = Math.max(1, parseFloat(termBInput.value) || 1);
        const termUnitB = termUnitBInput.value;
        const contribTypeB = contribTypeBInput.value;
        const contribAmtB = Math.max(0, parseFloat(contribAmtBInput.value) || 0);
        const contribTimeB = Math.max(0, parseFloat(contribTimeBInput.value) || 0);

        // Solve B
        resB = runScenario(initB, isProjectedB, finalOrRateB, termB, termUnitB, contribTypeB, contribAmtB, contribTimeB);
        globalValueTimelineB = resB.timeline;
      }

      // Update URL search parameters silently
      updateUrlParams(initA, isProjectedA, finalOrRateA, termA, termUnitA, contribTypeA, contribAmtA, contribTimeA, resB);

      // Render Results Dashboards
      if (mode === 'single') {
        roiMainDisplay.textContent = (resA.totalRoi * 100).toFixed(2) + '%';
        statAnnualized.textContent = (resA.cagr * 100).toFixed(2) + '%';
        statNetProfit.textContent = formatCurrency(resA.netProfit);
        statBreakEven.textContent = resA.breakEvenStr;
        
        // Colors
        if (resA.netProfit < 0) {
          roiMainDisplay.className = "text-4xl md:text-5xl font-bold tracking-tight text-red-500 dark:text-red-400 font-sans tabular-nums";
        } else {
          roiMainDisplay.className = "text-4xl md:text-5xl font-bold tracking-tight text-violet-600 dark:text-violet-400 font-sans tabular-nums";
        }
      } else {
        // Compare values
        tdInitA.textContent = formatCurrency(initA);
        tdInitB.textContent = formatCurrency(resB.init || parseFloat(initBInput.value) || 0);
        tdInitDelta.textContent = formatCurrency(initA - (parseFloat(initBInput.value) || 0));

        tdAddA.textContent = formatCurrency(resA.totalContributions);
        tdAddB.textContent = formatCurrency(resB.totalContributions);
        tdAddDelta.textContent = formatCurrency(resA.totalContributions - resB.totalContributions);

        tdFinalA.textContent = formatCurrency(resA.finalValue);
        tdFinalB.textContent = formatCurrency(resB.finalValue);
        tdFinalDelta.textContent = formatCurrency(resA.finalValue - resB.finalValue);

        tdProfitA.textContent = formatCurrency(resA.netProfit);
        tdProfitB.textContent = formatCurrency(resB.netProfit);
        tdProfitDelta.textContent = formatCurrency(resA.netProfit - resB.netProfit);

        tdRoiA.textContent = (resA.totalRoi * 100).toFixed(2) + '%';
        tdRoiB.textContent = (resB.totalRoi * 100).toFixed(2) + '%';
        tdRoiDelta.textContent = ((resA.totalRoi - resB.totalRoi) * 100).toFixed(2) + '%';

        tdCagrA.textContent = (resA.cagr * 100).toFixed(2) + '%';
        tdCagrB.textContent = (resB.cagr * 100).toFixed(2) + '%';
        tdCagrDelta.textContent = ((resA.cagr - resB.cagr) * 100).toFixed(2) + '%';

        tdBeA.textContent = resA.breakEvenStr;
        tdBeB.textContent = resB.breakEvenStr;
      }

      // Render Visual Chart
      drawChart(resA, resB, mode);

      // Build CSV Data structure
      buildCsvContent(resA, resB, mode);
    };

    // Draw SVG Chart
    const drawChart = (resA: any, resB: any, mode: string) => {
      const paddingLeft = 50;
      const paddingRight = 10;
      const chartWidth = 600 - paddingLeft - paddingRight;
      const paddingTop = 15;
      const paddingBottom = 25;
      const chartHeight = 220 - paddingTop - paddingBottom;

      // Find global viewport bounds
      let maxVal = Math.max(resA.finalValue, resA.totalInvested);
      let minVal = 0; // standard floor

      resA.timeline.forEach((pt: any) => {
        if (pt.val > maxVal) maxVal = pt.val;
      });

      if (mode === 'compare' && resB) {
        resB.timeline.forEach((pt: any) => {
          if (pt.val > maxVal) maxVal = pt.val;
        });
        maxVal = Math.max(maxVal, resB.finalValue, resB.totalInvested);
      }

      // Scale Y label references - update both charts
      const yMaxStr = formatCurrency(maxVal);
      const yMidStr = formatCurrency(maxVal / 2);
      chartYMax.textContent = yMaxStr;
      chartYMid.textContent = yMidStr;
      if (chart2YMax) { chart2YMax.textContent = yMaxStr; }
      if (chart2YMid) { chart2YMid.textContent = yMidStr; }

      const getPoints = (timeline: any[]) => {
        const totalPeriods = timeline.length - 1;
        return timeline.map(pt => {
          const x = paddingLeft + (pt.month / totalPeriods) * chartWidth;
          const y = paddingTop + (1 - (pt.val - minVal) / (maxVal - minVal)) * chartHeight;
          const yInvested = paddingTop + (1 - (pt.invested - minVal) / (maxVal - minVal)) * chartHeight;
          return { x, y, yInvested };
        });
      };

      const ptsA = getPoints(resA.timeline);

      // Curve Path A
      let baseLineD = `M ${ptsA[0].x},${ptsA[0].y}`;
      let baseFillD = `M ${ptsA[0].x},195 L ${ptsA[0].x},${ptsA[0].y}`;
      let investedLineD = `M ${ptsA[0].x},${ptsA[0].yInvested}`;

      for (let i = 1; i < ptsA.length; i++) {
        baseLineD += ` L ${ptsA[i].x},${ptsA[i].y}`;
        baseFillD += ` L ${ptsA[i].x},${ptsA[i].y}`;
        investedLineD += ` L ${ptsA[i].x},${ptsA[i].yInvested}`;
      }
      baseFillD += ` L ${ptsA[ptsA.length - 1].x},195 Z`;

      // Write to single-mode chart
      chartLineA.setAttribute('d', baseLineD);
      chartLineAFill.setAttribute('d', baseFillD);
      chartInvestedA.setAttribute('d', investedLineD);
      // Write to compare-mode chart
      if (chart2LineA) { chart2LineA.setAttribute('d', baseLineD); }
      if (chart2LineAFill) { chart2LineAFill.setAttribute('d', baseFillD); }
      if (chart2InvestedA) { chart2InvestedA.setAttribute('d', investedLineD); }

      // Handles B comparison lines
      if (mode === 'compare' && resB) {
        const ptsB = getPoints(resB.timeline);

        let compareLineD = `M ${ptsB[0].x},${ptsB[0].y}`;
        let compareFillD = `M ${ptsB[0].x},195 L ${ptsB[0].x},${ptsB[0].y}`;
        let compareInvestedLineD = `M ${ptsB[0].x},${ptsB[0].yInvested}`;

        for (let i = 1; i < ptsB.length; i++) {
          compareLineD += ` L ${ptsB[i].x},${ptsB[i].y}`;
          compareFillD += ` L ${ptsB[i].x},${ptsB[i].y}`;
          compareInvestedLineD += ` L ${ptsB[i].x},${ptsB[i].yInvested}`;
        }
        compareFillD += ` L ${ptsB[ptsB.length - 1].x},195 Z`;

        chartLineB.setAttribute('d', compareLineD);
        chartLineBFill.setAttribute('d', compareFillD);
        chartInvestedB.setAttribute('d', compareInvestedLineD);

        chartLineB.classList.remove('hidden');
        chartLineBFill.classList.remove('hidden');
        chartInvestedB.classList.remove('hidden');

        // Write B to compare chart too
        if (chart2LineB) { chart2LineB.setAttribute('d', compareLineD); }
        if (chart2LineBFill) { chart2LineBFill.setAttribute('d', compareFillD); }
        if (chart2InvestedB) { chart2InvestedB.setAttribute('d', compareInvestedLineD); }

        // Toggle legend overlay identifiers
        lgndValueB.classList.remove('hidden');
        lgndInvestedB.classList.remove('hidden');
      } else {
        chartLineB.classList.add('hidden');
        chartLineBFill.classList.add('hidden');
        chartInvestedB.classList.add('hidden');

        lgndValueB.classList.add('hidden');
        lgndInvestedB.classList.add('hidden');
      }

      // X-Axis labels
      const totalBaselinePeriods = resA.timeline.length - 1;
      let xLabelsHtml = '';
      const step = Math.ceil(totalBaselinePeriods / 2);
      
      for (let i = 0; i <= 2; i++) {
        const monthNum = Math.min(totalBaselinePeriods, i * step);
        const xPos = paddingLeft + (monthNum / totalBaselinePeriods) * chartWidth;
        const yearVal = (monthNum / 12).toFixed(1).replace('.0', '');
        xLabelsHtml += `<text x="${xPos}" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Yr ${yearVal}</text>`;
      }
      chartXLabels.innerHTML = xLabelsHtml;
      if (chart2XLabels) { chart2XLabels.innerHTML = xLabelsHtml; }
    };

    // Serialize timeline logs to CSV string format
    const buildCsvContent = (resA: any, resB: any, mode: string) => {
      let csv = 'Month,Value A,Invested A';
      if (mode === 'compare' && resB) {
        csv += ',Value B,Invested B';
      }
      csv += '\r\n';

      const maxMonths = Math.max(resA.timeline.length, mode === 'compare' ? resB.timeline.length : 0);

      for (let m = 0; m < maxMonths; m++) {
        const ptA = resA.timeline[m] || { val: '', invested: '' };
        let line = `${m},${ptA.val},${ptA.invested}`;

        if (mode === 'compare' && resB) {
          const ptB = resB.timeline[m] || { val: '', invested: '' };
          line += `,${ptB.val},${ptB.invested}`;
        }
        csv += line + '\r\n';
      }

      csvDataContent = csv;
    };

    // Sync query parameters
    const updateUrlParams = (
      initA: number,
      isProjectedA: boolean,
      finalOrRateA: number,
      termA: number,
      termUnitA: string,
      contribTypeA: string,
      contribAmtA: number,
      contribTimeA: number,
      resB: any
    ) => {
      const params = new URLSearchParams();
      params.set('mode', activeModeInput.value);

      // Scenario A
      params.set('initA', initA.toString());
      params.set('isProjA', isProjectedA.toString());
      params.set('finalA', finalOrRateA.toString());
      params.set('termA', termA.toString());
      params.set('unitA', termUnitA);
      params.set('contTypeA', contribTypeA);
      params.set('contAmtA', contribAmtA.toString());
      params.set('contTimeA', contribTimeA.toString());

      // Scenario B (If compare active)
      if (activeModeInput.value === 'compare') {
        params.set('initB', initBInput.value);
        params.set('isProjB', (valModeBInput.value === 'project').toString());
        params.set('finalB', valModeBInput.value === 'project' ? rateBInput.value : finalBInput.value);
        params.set('termB', termBInput.value);
        params.set('unitB', termUnitBInput.value);
        params.set('contTypeB', contribTypeBInput.value);
        params.set('contAmtB', contribAmtBInput.value);
        params.set('contTimeB', contribTimeBInput.value);
      }

      const newUrl = `${window.location.pathname}?${params.toString()}`;
      window.history.replaceState({ path: newUrl }, '', newUrl);
    };

    // Hydrate form inputs from URL parameters
    const hydrateFromUrl = () => {
      const params = new URLSearchParams(window.location.search);
      if (!params.has('mode')) return;

      const mode = params.get('mode') || 'single';
      activeModeInput.value = mode;

      if (mode === 'single') {
        setSingleModeLayout();
      } else {
        setCompareModeLayout();
      }

      // Scenario A values
      if (params.has('initA')) initAInput.value = params.get('initA')!;
      if (params.has('isProjA')) {
        const isProj = params.get('isProjA') === 'true';
        updateValuationMode('a', isProj ? 'project' : 'simple');
      }
      if (params.has('finalA')) {
        const isProj = params.get('isProjA') === 'true';
        if (isProj) {
          rateAInput.value = params.get('finalA')!;
        } else {
          finalAInput.value = params.get('finalA')!;
        }
      }
      if (params.has('termA')) termAInput.value = params.get('termA')!;
      if (params.has('unitA')) updateTermUnit('a', params.get('unitA')!);
      if (params.has('contTypeA')) {
        contribTypeAInput.value = params.get('contTypeA')!;
        updateContribLayout('a');
      }
      if (params.has('contAmtA')) contribAmtAInput.value = params.get('contAmtA')!;
      if (params.has('contTimeA')) contribTimeAInput.value = params.get('contTimeA')!;

      // Scenario B values
      if (mode === 'compare') {
        if (params.has('initB')) initBInput.value = params.get('initB')!;
        if (params.has('isProjB')) {
          const isProj = params.get('isProjB') === 'true';
          updateValuationMode('b', isProj ? 'project' : 'simple');
        }
        if (params.has('finalB')) {
          const isProj = params.get('isProjB') === 'true';
          if (isProj) {
            rateBInput.value = params.get('finalB')!;
          } else {
            finalBInput.value = params.get('finalB')!;
          }
        }
        if (params.has('termB')) termBInput.value = params.get('termB')!;
        if (params.has('unitB')) updateTermUnit('b', params.get('unitB')!);
        if (params.has('contTypeB')) {
          contribTypeBInput.value = params.get('contTypeB')!;
          updateContribLayout('b');
        }
        if (params.has('contAmtB')) contribAmtBInput.value = params.get('contAmtB')!;
        if (params.has('contTimeB')) contribTimeBInput.value = params.get('contTimeB')!;
      }
    };

    // Mode Toggle — use data-mode attribute instead of dynamic className swaps
    // All layout CSS is in the <style> block above, keyed off data-mode.
    const mainWorkspace = document.getElementById('main-workspace') as HTMLDivElement;

    const setSingleModeLayout = () => {
      activeModeInput.value = 'single';
      mainWorkspace.setAttribute('data-mode', 'single');
      modeSingleBtn.className = "px-5 py-3 text-sm font-sans font-medium border-b-2 border-primary text-ink transition-all cursor-pointer";
      modeCompareBtn.className = "px-5 py-3 text-sm font-sans font-medium border-b-2 border-transparent text-mute hover:text-ink transition-all cursor-pointer";

      inputsBCard.classList.add('hidden');
      resultsSinglePanel.classList.remove('hidden');
      resultsComparePanel.classList.add('hidden');
    };

    const setCompareModeLayout = () => {
      activeModeInput.value = 'compare';
      mainWorkspace.setAttribute('data-mode', 'compare');
      modeCompareBtn.className = "px-5 py-3 text-sm font-sans font-medium border-b-2 border-primary text-ink transition-all cursor-pointer";
      modeSingleBtn.className = "px-5 py-3 text-sm font-sans font-medium border-b-2 border-transparent text-mute hover:text-ink transition-all cursor-pointer";

      inputsBCard.classList.remove('hidden');
      resultsSinglePanel.classList.add('hidden');
      resultsComparePanel.classList.remove('hidden');
    };

    modeSingleBtn.addEventListener('click', () => {
      setSingleModeLayout();
      recalculate();
    });

    modeCompareBtn.addEventListener('click', () => {
      setCompareModeLayout();
      recalculate();
    });

    // Valuation mode switchers A
    const updateValuationMode = (card: string, valMode: string) => {
      const isCardA = card === 'a';
      const valModeInput = isCardA ? valModeAInput : valModeBInput;
      const simpleBtn = isCardA ? valToggleSimpleABtn : valToggleSimpleBBtn;
      const projectBtn = isCardA ? valToggleProjectABtn : valToggleProjectBBtn;
      const finalContainer = isCardA ? containerFinalA : containerFinalB;
      const rateContainer = isCardA ? containerRateA : containerRateB;

      valModeInput.value = valMode;

      const activeClass = "flex-1 text-center py-2 px-3 text-xs font-sans font-semibold whitespace-nowrap rounded-md bg-primary text-on-primary shadow-lvl1 cursor-pointer transition-all";
      const inactiveClass = "flex-1 text-center py-2 px-3 text-xs font-sans font-semibold whitespace-nowrap rounded-md text-mute hover:text-ink cursor-pointer transition-all";

      if (valMode === 'simple') {
        simpleBtn.className = activeClass;
        projectBtn.className = inactiveClass;
        finalContainer.classList.remove('hidden');
        rateContainer.classList.add('hidden');
      } else {
        projectBtn.className = activeClass;
        simpleBtn.className = inactiveClass;
        finalContainer.classList.add('hidden');
        rateContainer.classList.remove('hidden');
      }
    };

    valToggleSimpleABtn.addEventListener('click', () => { updateValuationMode('a', 'simple'); recalculate(); });
    valToggleProjectABtn.addEventListener('click', () => { updateValuationMode('a', 'project'); recalculate(); });
    valToggleSimpleBBtn.addEventListener('click', () => { updateValuationMode('b', 'simple'); recalculate(); });
    valToggleProjectBBtn.addEventListener('click', () => { updateValuationMode('b', 'project'); recalculate(); });

    // Term toggle switcher A & B
    const updateTermUnit = (card: string, unit: string) => {
      const isCardA = card === 'a';
      const termUnitInput = isCardA ? termUnitAInput : termUnitBInput;
      const yearsBtn = isCardA ? termToggleYearsABtn : termToggleYearsBBtn;
      const monthsBtn = isCardA ? termToggleMonthsABtn : termToggleMonthsBBtn;
      const suffix = isCardA ? termSuffixA : termSuffixB;
      const termInput = isCardA ? termAInput : termBInput;
      const contribTimeSuffix = isCardA ? contribTimeSuffixA : contribTimeSuffixB;

      if (termUnitInput.value === unit) return;
      termUnitInput.value = unit;

      const rawVal = parseFloat(termInput.value) || 0;

      if (unit === 'years') {
        yearsBtn.className = "px-2.5 py-1 text-[10px] font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer";
        monthsBtn.className = "px-2.5 py-1 text-[10px] font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer";
        suffix.textContent = 'years';
        contribTimeSuffix.textContent = 'year';
        termInput.value = (rawVal / 12).toFixed(1).replace('.0', '');
      } else {
        monthsBtn.className = "px-2.5 py-1 text-[10px] font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer";
        yearsBtn.className = "px-2.5 py-1 text-[10px] font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer";
        suffix.textContent = 'months';
        contribTimeSuffix.textContent = 'month';
        termInput.value = Math.round(rawVal * 12).toString();
      }
    };

    termToggleYearsABtn.addEventListener('click', () => { updateTermUnit('a', 'years'); recalculate(); });
    termToggleMonthsABtn.addEventListener('click', () => { updateTermUnit('a', 'months'); recalculate(); });
    termToggleYearsBBtn.addEventListener('click', () => { updateTermUnit('b', 'years'); recalculate(); });
    termToggleMonthsBBtn.addEventListener('click', () => { updateTermUnit('b', 'months'); recalculate(); });

    // Contributions Type switches
    const updateContribLayout = (card: string) => {
      const isCardA = card === 'a';
      const typeInput = isCardA ? contribTypeAInput : contribTypeBInput;
      const amtContainer = isCardA ? containerContribAmtA : containerContribAmtB;
      const timeContainer = isCardA ? containerContribTimeA : containerContribTimeB;
      const periodSuffix = isCardA ? contribPeriodSuffixA : contribPeriodSuffixB;

      const val = typeInput.value;

      if (val === 'none') {
        amtContainer.classList.add('hidden');
        timeContainer.classList.add('hidden');
      } else if (val === 'monthly') {
        amtContainer.classList.remove('hidden');
        timeContainer.classList.add('hidden');
        periodSuffix.textContent = '/mo';
      } else {
        amtContainer.classList.remove('hidden');
        timeContainer.classList.remove('hidden');
        periodSuffix.textContent = 'one-time';
      }
    };

    contribTypeAInput.addEventListener('change', () => { updateContribLayout('a'); recalculate(); });
    contribTypeBInput.addEventListener('change', () => { updateContribLayout('b'); recalculate(); });

    // Copy clipboard results link
    const copyLinkAction = async (btn: HTMLButtonElement) => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const originalText = btn.innerHTML;
        btn.innerHTML = `
          <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-emerald-500">Copied!</span>
        `;
        setTimeout(() => {
          btn.innerHTML = originalText;
        }, 1500);
      } catch (err) {
        console.error('Failed to copy text: ', err);
      }
    };

    copyLinkBtn.addEventListener('click', () => copyLinkAction(copyLinkBtn));
    copyLinkBtnCompare.addEventListener('click', () => copyLinkAction(copyLinkBtnCompare));

    // CSV Downloader
    downloadCsvBtn.addEventListener('click', () => {
      if (!csvDataContent) return;
      const blob = new Blob([csvDataContent], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.setAttribute("href", url);
      link.setAttribute("download", `roi_growth_timeline_${activeModeInput.value}.csv`);
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    });

    // FAQs Accordion bindings
    document.querySelectorAll('.faq-toggle').forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling as HTMLDivElement;
        const chevron = button.querySelector('svg') as unknown as SVGElement;
        const isHidden = content.classList.toggle('hidden');
        chevron.classList.toggle('rotate-180', !isHidden);
        button.setAttribute('aria-expanded', (!isHidden).toString());
      });
    });

    // Live event triggers
    const triggerInputsList = [
      initAInput, finalAInput, rateAInput, termAInput, contribAmtAInput, contribTimeAInput,
      initBInput, finalBInput, rateBInput, termBInput, contribAmtBInput, contribTimeBInput
    ];

    triggerInputsList.forEach(input => {
      input.addEventListener('input', recalculate);
    });

    // Run first initialization
    hydrateFromUrl();
    recalculate();

  </script>
</Layout>
