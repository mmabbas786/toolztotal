---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a good ROI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard equity portfolios average an 8% to 10% annual return before inflation adjustments. What constitutes a \"good\" return depends on risk levels and liquidity requirements. Higher risk projects demand higher premium targets (e.g., venture investments or individual startups seeking 25%+), whereas lower risk savings rates typically yield 3% to 5%."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between ROI and annualized ROI (CAGR)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Simple ROI yields the raw ratio of gains relative to cumulative invested capital over the total time period. Annualized ROI (CAGR) normalizes that gain to a yearly rate, compounding it geometrically. This enables direct comparison of a 5-year investment with a 1-year investment."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate ROI with additional contributions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If you add funds over time, calculating annualized returns requires finding the Internal Rate of Return (IRR). Because a contribution added in Month 30 has less compounding time than the initial balance, IRR discounts each flow according to the exact month it was invested. Our calculator resolves this using a numerical bisection root-finder."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use this for real estate or stock investments?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, it is highly applicable for both. For stocks, enter the initial buy, monthly recurring additions, and current portfolio value. For real estate, input your down payment, monthly cash flows or mortgage amortization, and expected sale price to determine real returns."
      }
    },
    {
      "@type": "Question",
      "name": "Is this ROI calculator financial advice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Standard compounding calculations do not include asset liquidation fees, taxes, or inflation. Use the calculator for initial planning and scenario testing, and seek guidance from a qualified financial planner or tax advisor for professional advisory quotes."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good return on investment (ROI)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A good ROI varies by asset class. Historically, the S&P 500 yields an average annual ROI of 8% to 10% (nominal). Real estate typically averages 6% to 8%, while riskier assets expect higher returns to offset the volatility."
      }
    },
    {
      "@type": "Question",
      "name": "How does ROI compare to Return on Equity (ROE)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ROI measures the overall efficiency of an investment using total assets. ROE measures profitability relative to shareholder equity, showing how effectively a company utilizes owner capital."
      }
    },
    {
      "@type": "Question",
      "name": "Does ROI account for time value of money?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Simple ROI calculates the total return over the entire investment holding period, regardless of whether it took 1 year or 10 years. To account for time, use annualized ROI or CAGR (Compound Annual Growth Rate)."
      }
    },
    {
      "@type": "Question",
      "name": "Can ROI be negative?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. If the final value of your investment is less than your initial investment cost, the ROI will be negative, representing a capital loss."
      }
    },
    {
      "@type": "Question",
      "name": "How do taxes impact my net ROI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Capital gains taxes, income taxes, and transaction fees reduce your final investment return. Net ROI calculates returns after subtracting all taxes, transaction costs, and management fees."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="ROI Calculator - Free Return on Investment Calculator | ToolzTotal"
  description="Calculate your Return on Investment (ROI), annualized ROI (CAGR), and net profits. Side-by-side comparison mode and shareable links included."
  faqJsonLd={faqJsonLd}
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/finance" class="hover:text-ink transition-colors">Finance & Loans</a>
      <span>/</span>
      <span class="text-ink">ROI Calculator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Return on Investment (ROI) Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Estimate raw ROI percentages, annualized returns (CAGR), and cash accumulation timelines. Analyze a single portfolio or compare two different scenarios side-by-side.
      </p>
    </div>

    <!-- Mode Selector Tabs -->
    <div class="mb-8 border-b border-hairline flex flex-wrap gap-1">
      <button 
        type="button" 
        id="mode-single" 
        class="px-5 py-3 text-sm font-sans font-medium border-b-2 border-primary text-ink transition-all cursor-pointer"
      >
        📊 Single Investment
      </button>
      <button 
        type="button" 
        id="mode-compare" 
        class="px-5 py-3 text-sm font-sans font-medium border-b-2 border-transparent text-mute hover:text-ink transition-all cursor-pointer"
      >
        ⚔️ Compare Investments
      </button>
      <input type="hidden" id="active-mode" value="single" />
    </div>

    <!-- Layout styles driven by data-mode attribute so ALL classes are statically present for Tailwind -->
    <style is:global>
      /* Single mode: inputs left (5/12), results right (7/12) */
      #main-workspace[data-mode="single"] #inputs-wrapper {
        grid-column: span 5 / span 5;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      #main-workspace[data-mode="single"] #results-wrapper {
        grid-column: span 7 / span 7;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      /* Compare mode: both full-width and stacked */
      #main-workspace[data-mode="compare"] #inputs-wrapper {
        grid-column: span 12 / span 12;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.5rem;
      }
      #main-workspace[data-mode="compare"] #results-wrapper {
        grid-column: span 12 / span 12;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      /* Mobile: always full width single column */
      @media (max-width: 1023px) {
        #main-workspace[data-mode="single"] #inputs-wrapper,
        #main-workspace[data-mode="single"] #results-wrapper,
        #main-workspace[data-mode="compare"] #inputs-wrapper,
        #main-workspace[data-mode="compare"] #results-wrapper {
          grid-column: span 1 / span 1;
        }
        #main-workspace[data-mode="compare"] #inputs-wrapper {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <!-- Main Workspace Grid -->
    <div id="main-workspace" class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start" data-mode="single">
      
      <!-- Input Section Column -->
      <div id="inputs-wrapper" class="">
        
        <!-- Scenario A Input Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-5">
          <div class="flex items-center justify-between border-b border-hairline pb-3">
            <h2 class="text-lg font-bold text-ink font-sans flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-violet-600 inline-block"></span>
              Investment A
            </h2>
            <span class="text-[10px] font-mono text-mute uppercase" id="card-label-a">Primary Option</span>
          </div>

          <!-- Initial Capital -->
          <div>
            <label for="init-a" class="block text-xs font-mono uppercase text-mute mb-2">Initial Investment</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
              <input 
                type="number" 
                id="init-a" 
                value="10000" 
                step="1000"
                min="1"
                class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Valuation Mode Switcher -->
          <div>
            <label class="block text-xs font-mono uppercase text-mute mb-2">Valuation Mode</label>
            <div class="flex rounded-lg bg-canvas-soft-2 p-1 border border-hairline shadow-lvl1 w-full gap-1">
              <button 
                type="button" 
                id="val-toggle-simple-a" 
                class="flex-1 text-center py-2 px-3 text-xs font-sans font-semibold whitespace-nowrap rounded-md bg-primary text-on-primary shadow-lvl1 cursor-pointer transition-all"
              >
                Final Value
              </button>
              <button 
                type="button" 
                id="val-toggle-project-a" 
                class="flex-1 text-center py-2 px-3 text-xs font-sans font-semibold whitespace-nowrap rounded-md text-mute hover:text-ink cursor-pointer transition-all"
              >
                Project Rate
              </button>
            </div>
            <input type="hidden" id="val-mode-a" value="simple" />
          </div>

          <!-- Final Value Input (Simple Mode) -->
          <div id="container-final-a">
            <label for="final-a" class="block text-xs font-mono uppercase text-mute mb-2">Final Value / Current Value</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
              <input 
                type="number" 
                id="final-a" 
                value="13000" 
                step="1000"
                min="0"
                class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Projected Rate Input (Projected Mode) -->
          <div id="container-rate-a" class="hidden">
            <label for="rate-a" class="block text-xs font-mono uppercase text-mute mb-2">Expected Annual Return</label>
            <div class="relative">
              <input 
                type="number" 
                id="rate-a" 
                value="8.0" 
                step="0.1"
                min="-100"
                max="1000"
                class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
            </div>
          </div>

          <!-- Duration Period -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label for="term-a" class="block text-xs font-mono uppercase text-mute">Holding Period</label>
              <div class="inline-flex rounded-md bg-canvas-soft-2 p-0.5 border border-hairline shadow-lvl1">
                <button 
                  type="button" 
                  id="term-toggle-years-a" 
                  class="px-2.5 py-1 text-[10px] font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer"
                >
                  Years
                </button>
                <button 
                  type="button" 
                  id="term-toggle-months-a" 
                  class="px-2.5 py-1 text-[10px] font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer"
                >
                  Months
                </button>
              </div>
              <input type="hidden" id="term-unit-a" value="years" />
            </div>
            
            <div class="relative">
              <input 
                type="number" 
                id="term-a" 
                value="3" 
                step="1"
                min="1"
                class="w-full h-10 pl-3 pr-16 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
              <span id="term-suffix-a" class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-xs font-mono">years</span>
            </div>
          </div>

          <!-- Cash flows add-ons -->
          <div class="border-t border-hairline pt-5 space-y-4">
            <div>
              <label for="contrib-type-a" class="block text-xs font-mono uppercase text-mute mb-2">Additional Contributions</label>
              <select 
                id="contrib-type-a" 
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <option value="none">None</option>
                <option value="monthly">Monthly Recurring</option>
                <option value="onetime">One-Time Contribution</option>
              </select>
            </div>

            <!-- Contribution size -->
            <div id="container-contrib-amt-a" class="hidden">
              <label for="contrib-amt-a" id="label-contrib-amt-a" class="block text-xs font-mono uppercase text-mute mb-2">Contribution Amount</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
                <input 
                  type="number" 
                  id="contrib-amt-a" 
                  value="0" 
                  step="50"
                  min="0"
                  class="w-full h-10 pl-7 pr-10 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  autocomplete="off"
                />
                <span id="contrib-period-suffix-a" class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-[10px] font-mono">/mo</span>
              </div>
            </div>

            <!-- One-time timing -->
            <div id="container-contrib-time-a" class="hidden">
              <label for="contrib-time-a" class="block text-xs font-mono uppercase text-mute mb-2">Contribution Date (Occurrence)</label>
              <div class="relative">
                <input 
                  type="number" 
                  id="contrib-time-a" 
                  value="1" 
                  step="0.5"
                  min="0"
                  class="w-full h-10 pl-3 pr-16 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  autocomplete="off"
                />
                <span id="contrib-time-suffix-a" class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-xs font-mono">year</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Scenario B Input Card (Hidden unless in comparison mode) -->
        <div id="inputs-b-card" class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-5 hidden">
          <div class="flex items-center justify-between border-b border-hairline pb-3">
            <h2 class="text-lg font-bold text-ink font-sans flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 inline-block"></span>
              Investment B
            </h2>
            <span class="text-[10px] font-mono text-mute uppercase">Secondary Option</span>
          </div>

          <!-- Initial Capital B -->
          <div>
            <label for="init-b" class="block text-xs font-mono uppercase text-mute mb-2">Initial Investment</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
              <input 
                type="number" 
                id="init-b" 
                value="10000" 
                step="1000"
                min="1"
                class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Valuation Mode Switcher B -->
          <div>
            <label class="block text-xs font-mono uppercase text-mute mb-2">Valuation Mode</label>
            <div class="flex rounded-lg bg-canvas-soft-2 p-1 border border-hairline shadow-lvl1 w-full gap-1">
              <button 
                type="button" 
                id="val-toggle-simple-b" 
                class="flex-1 text-center py-2 px-3 text-xs font-sans font-semibold whitespace-nowrap rounded-md bg-primary text-on-primary shadow-lvl1 cursor-pointer transition-all"
              >
                Final Value
              </button>
              <button 
                type="button" 
                id="val-toggle-project-b" 
                class="flex-1 text-center py-2 px-3 text-xs font-sans font-semibold whitespace-nowrap rounded-md text-mute hover:text-ink cursor-pointer transition-all"
              >
                Project Rate
              </button>
            </div>
            <input type="hidden" id="val-mode-b" value="simple" />
          </div>

          <!-- Final Value Input B (Simple Mode) -->
          <div id="container-final-b">
            <label for="final-b" class="block text-xs font-mono uppercase text-mute mb-2">Final Value / Current Value</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
              <input 
                type="number" 
                id="final-b" 
                value="15000" 
                step="1000"
                min="0"
                class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Projected Rate Input B (Projected Mode) -->
          <div id="container-rate-b" class="hidden">
            <label for="rate-b" class="block text-xs font-mono uppercase text-mute mb-2">Expected Annual Return</label>
            <div class="relative">
              <input 
                type="number" 
                id="rate-b" 
                value="10.0" 
                step="0.1"
                min="-100"
                max="1000"
                class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
            </div>
          </div>

          <!-- Duration Period B -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label for="term-b" class="block text-xs font-mono uppercase text-mute">Holding Period</label>
              <div class="inline-flex rounded-md bg-canvas-soft-2 p-0.5 border border-hairline shadow-lvl1">
                <button 
                  type="button" 
                  id="term-toggle-years-b" 
                  class="px-2.5 py-1 text-[10px] font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer"
                >
                  Years
                </button>
                <button 
                  type="button" 
                  id="term-toggle-months-b" 
                  class="px-2.5 py-1 text-[10px] font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer"
                >
                  Months
                </button>
              </div>
              <input type="hidden" id="term-unit-b" value="years" />
            </div>
            
            <div class="relative">
              <input 
                type="number" 
                id="term-b" 
                value="3" 
                step="1"
                min="1"
                class="w-full h-10 pl-3 pr-16 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
              <span id="term-suffix-b" class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-xs font-mono">years</span>
            </div>
          </div>

          <!-- Cash flows add-ons B -->
          <div class="border-t border-hairline pt-5 space-y-4">
            <div>
              <label for="contrib-type-b" class="block text-xs font-mono uppercase text-mute mb-2">Additional Contributions</label>
              <select 
                id="contrib-type-b" 
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <option value="none">None</option>
                <option value="monthly">Monthly Recurring</option>
                <option value="onetime">One-Time Contribution</option>
              </select>
            </div>

            <!-- Contribution size B -->
            <div id="container-contrib-amt-b" class="hidden">
              <label for="contrib-amt-b" id="label-contrib-amt-b" class="block text-xs font-mono uppercase text-mute mb-2">Contribution Amount</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
                <input 
                  type="number" 
                  id="contrib-amt-b" 
                  value="0" 
                  step="50"
                  min="0"
                  class="w-full h-10 pl-7 pr-10 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  autocomplete="off"
                />
                <span id="contrib-period-suffix-b" class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-[10px] font-mono">/mo</span>
              </div>
            </div>

            <!-- One-time timing B -->
            <div id="container-contrib-time-b" class="hidden">
              <label for="contrib-time-b" class="block text-xs font-mono uppercase text-mute mb-2">Contribution Date (Occurrence)</label>
              <div class="relative">
                <input 
                  type="number" 
                  id="contrib-time-b" 
                  value="1" 
                  step="0.5"
                  min="0"
                  class="w-full h-10 pl-3 pr-16 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  autocomplete="off"
                />
                <span id="contrib-time-suffix-b" class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-xs font-mono">year</span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Results & Chart Column -->
      <div id="results-wrapper" class="">
        
        <!-- Single Mode Results Display -->
        <div id="results-single-panel" class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 relative">
          
          <div class="flex items-center justify-between mb-8">
            <div>
              <h2 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">Total ROI</h2>
              <div id="roi-main-display" class="text-4xl md:text-5xl font-bold tracking-tight text-ink font-sans tabular-nums">
                0.00%
              </div>
            </div>
            <button 
              type="button" 
              id="copy-link-btn" 
              class="h-9 px-4 border border-hairline bg-canvas hover:bg-canvas-soft text-body hover:text-ink font-sans text-xs rounded-md shadow-lvl1 transition-colors flex items-center gap-1.5 cursor-pointer"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742a3 3 0 000 4.516l5.904 4.428a3 3 0 004.532-2.258V6.572a3 3 0 00-4.532-2.258l-5.904 4.428zm0 0L5 12" />
              </svg>
              Copy Shareable Link
            </button>
          </div>

          <!-- Single Mode Stats Row -->
