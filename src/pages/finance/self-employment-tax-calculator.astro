---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

// NOTE: All SE tax rate constants are isolated in seTaxConfig.ts
// Update that file annually — do NOT change rates here.

const ogMeta = {
  title: "Self-Employment Tax Calculator - Free SE Tax & Quarterly Payment Estimator | ToolzTotal",
  description: "Free self employment tax calculator — estimate SE tax, Social Security & Medicare portions, and quarterly estimated payments. No signup required.",
  url: "https://toolztotal.com/finance/self-employment-tax-calculator",
  image: "https://toolztotal.com/og-default.png",
};
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';
import DisclaimerBanner from '../../components/DisclaimerBanner.astro';
---

<Layout
  title="Self-Employment Tax Calculator - Free SE Tax & Quarterly Payment Estimator | ToolzTotal"
  description="Free self employment tax calculator — estimate SE tax, Social Security & Medicare portions, and quarterly estimated payments. No signup required."
>
  <ToolSchema
    toolName="Self-Employment Tax Calculator"
    toolSlug="self-employment-tax-calculator"
    categoryName="Finance & Loans"
    categorySlug="finance"
    description="Free self employment tax calculator — estimate SE tax, Social Security & Medicare portions, and quarterly estimated payments. No signup required."
    faqs={[
      { question: "What is self-employment tax?", answer: "Self-employment tax is the Social Security and Medicare tax paid by self-employed individuals. Employees split this cost with their employer — self-employed people pay both sides, totaling 15.3% (12.4% Social Security + 2.9% Medicare) on 92.35% of net SE earnings." },
      { question: "Who has to pay self-employment tax?", answer: "Anyone with net self-employment earnings of $400 or more must file Schedule SE. This covers freelancers, 1099 contractors, sole proprietors, gig workers, and partners. Even if SE income is a side hustle alongside a W-2 job, the SE income is still taxed separately." },
      { question: "How is self-employment tax different from income tax?", answer: "SE tax covers Social Security and Medicare. Income tax is a separate federal tax on your taxable income after deductions. You owe both. You can deduct half of your SE tax from gross income when calculating federal income tax, which reduces your income tax burden slightly." },
      { question: "What happens if I don't pay quarterly estimated taxes?", answer: "If you owe $1,000+ and underpay by each quarterly deadline, the IRS can charge an underpayment penalty — calculated using the current federal short-term interest rate plus 3 percentage points. Paying quarterly keeps you current and avoids this penalty." },
      { question: "Is this calculator a substitute for a tax professional?", answer: "No. This tool provides general estimates for informational use only — it is not tax advice. Tax law is complex, changes annually, and depends on your complete financial picture, state taxes, credits, and deductions. Always consult a licensed CPA or tax attorney and verify figures at irs.gov before filing." },
      { question: "Who is considered self-employed for tax purposes?", answer: "The IRS considers you self-employed if you carry on a trade or business as a sole proprietor, an independent contractor, a member of a partnership, or otherwise work for yourself (including gig workers)." },
      { question: "What is the self-employment tax rate?", answer: "The self-employment tax rate is 15.3% of net earnings. This consists of 12.4% for Social Security and 2.9% for Medicare." },
      { question: "Can I deduct a portion of my self-employment tax?", answer: "Yes. You can deduct half of your self-employment tax (the employer-equivalent portion) as an adjustment to income on Form 1040, which lowers your Adjusted Gross Income (AGI)." },
      { question: "What business expenses can I deduct to lower my tax liability?", answer: "You can deduct ordinary and necessary business expenses, such as home office expenses, vehicle mileage, equipment, advertising, business insurance, and professional services." },
      { question: "Do I still pay self-employment tax if I have a W-2 day job?", answer: "Yes. Self-employment tax applies to all net freelance earnings of $400 or more, regardless of whether you also pay FICA taxes through a W-2 employer." }
    ]}
  />

  <!-- OG / Twitter Card -->
  <meta slot="head" property="og:title" content={ogMeta.title} />
  <meta slot="head" property="og:description" content={ogMeta.description} />
  <meta slot="head" property="og:url" content={ogMeta.url} />
  <meta slot="head" property="og:image" content={ogMeta.image} />
  <meta slot="head" name="twitter:card" content="summary_large_image" />
  <meta slot="head" name="twitter:title" content={ogMeta.title} />
  <meta slot="head" name="twitter:description" content={ogMeta.description} />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categoryName="Finance & Loans"
      categorySlug="finance"
      toolName="Self-Employment Tax Calculator"
      toolSlug="self-employment-tax-calculator"
    />
  <DisclaimerBanner category="finance" />


    <!-- Header -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Self-Employment Tax Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Estimate your SE tax (Social Security + Medicare), rough income tax, and quarterly estimated payments. Built for freelancers, 1099 contractors, and sole proprietors.
      </p>
    </div>

    <!-- Compliance alert bar -->
    <div class="max-w-5xl mb-10 flex items-start gap-3 bg-amber-500/10 border border-amber-500/30 rounded-xl px-5 py-4">
      <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <p class="text-xs font-sans text-amber-700 dark:text-amber-300 leading-relaxed">
        <strong>Not tax advice.</strong> This calculator provides general estimates for informational purposes only. Tax rates, wage bases, and thresholds change annually and depend on your full financial situation. Verify current figures at <a href="https://www.irs.gov/businesses/small-businesses-self-employed/self-employment-tax-social-security-and-medicare-taxes" target="_blank" rel="noopener noreferrer" class="underline font-semibold hover:text-amber-900 dark:hover:text-amber-100 transition-colors">IRS.gov ↗</a> and consult a licensed tax professional before filing.
      </p>
    </div>

    <!-- Main Calculator Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start max-w-7xl">

      <!-- LEFT: Inputs -->
      <div class="lg:col-span-5 space-y-6">

        <!-- Input Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <div class="border-b border-hairline pb-4">
            <h2 class="text-base font-bold text-ink font-sans">Your Income Details</h2>
            <p class="text-xs text-mute font-sans mt-1">Enter your self-employment figures below.</p>
          </div>

          <!-- Net SE Income -->
          <div>
            <div class="flex items-center gap-2 mb-2">
              <label for="se-income" class="text-xs font-mono uppercase text-mute">Net Self-Employment Income</label>
              <div class="relative group">
                <button type="button" class="w-4 h-4 rounded-full bg-canvas-soft-2 border border-hairline text-mute text-[9px] font-bold flex items-center justify-center cursor-default" aria-label="What is net income?">?</button>
                <div class="absolute left-6 top-0 z-10 w-64 hidden group-hover:block bg-canvas border border-hairline rounded-lg p-3 text-xs font-sans text-body shadow-lvl2">
                  Net income = business revenue minus deductible business expenses. Do <strong>not</strong> subtract SE tax here — the calculator handles that.
                </div>
              </div>
            </div>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
              <input
                type="number"
                id="se-income"
                value="60000"
                min="0"
                step="1000"
                class="w-full h-11 pl-7 pr-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
            </div>
            <p class="text-[10px] font-mono text-mute mt-1.5">Revenue minus deductible business expenses.</p>
          </div>

          <!-- Filing Status -->
          <div>
            <label for="filing-status" class="block text-xs font-mono uppercase text-mute mb-2">Filing Status</label>
            <select
              id="filing-status"
              class="w-full h-11 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
            >
              <option value="single">Single</option>
              <option value="mfj">Married Filing Jointly</option>
            </select>
            <p class="text-[10px] font-mono text-mute mt-1.5">Affects the Additional Medicare Tax threshold only.</p>
          </div>

          <!-- Income Tax Estimate Toggle -->
          <div class="border-t border-hairline pt-5 space-y-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-xs font-mono uppercase text-mute">Income Tax Estimate</p>
                <p class="text-[10px] font-mono text-mute mt-0.5 leading-tight">Rough estimate — not a substitute for real tax software</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="income-tax-toggle" class="sr-only peer" checked />
                <div class="w-9 h-5 bg-canvas-soft-2 border border-hairline peer-focus:outline-none rounded-full peer peer-checked:bg-primary peer-checked:border-primary transition-all"></div>
                <div class="absolute left-0.5 top-0.5 bg-white w-4 h-4 rounded-full transition-all peer-checked:translate-x-4"></div>
              </label>
            </div>

            <div id="income-tax-bracket-container" class="space-y-3">
              <div>
                <label for="tax-bracket" class="block text-xs font-mono uppercase text-mute mb-2">Your Estimated Federal Bracket</label>
                <select
                  id="tax-bracket"
                  class="w-full h-11 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
                >
                  <option value="auto">Auto-estimate (use standard brackets)</option>
                  <option value="10">10% bracket</option>
                  <option value="12">12% bracket</option>
                  <option value="22">22% bracket</option>
                  <option value="24">24% bracket</option>
                  <option value="32">32% bracket</option>
                  <option value="35">35% bracket</option>
                  <option value="37">37% bracket</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Calculate Button -->
          <button
            type="button"
            id="calculate-btn"
            class="w-full h-11 bg-primary text-on-primary font-sans font-semibold text-sm rounded-lg hover:bg-primary/90 active:scale-[0.98] transition-all shadow-lvl2 cursor-pointer"
          >
            Calculate SE Tax →
          </button>
        </div>

        <!-- Rate info card -->
        <div class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl1 space-y-3">
          <h3 class="text-xs font-mono uppercase text-mute tracking-wider">Rates Used (2024)</h3>
          <div class="space-y-2 text-xs font-sans">
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">Net Earnings Multiplier</span>
              <span class="font-mono font-semibold text-ink">92.35%</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">Social Security Rate</span>
              <span class="font-mono font-semibold text-ink">12.4% (up to wage base)</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">Medicare Rate</span>
              <span class="font-mono font-semibold text-ink">2.9% (no cap)</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">Additional Medicare</span>
              <span class="font-mono font-semibold text-ink">0.9% above threshold</span>
            </div>
            <div class="flex justify-between items-center py-1.5">
              <span class="text-body">SS Wage Base</span>
              <span class="font-mono font-semibold text-ink">$168,600</span>
            </div>
          </div>
          <p class="text-[9px] font-mono text-mute leading-relaxed pt-1 border-t border-hairline">
            Tax rates and thresholds shown are illustrative; verify current figures at <a href="https://www.irs.gov" target="_blank" rel="noopener noreferrer" class="underline">irs.gov</a> before filing.
          </p>
        </div>

      </div>

      <!-- RIGHT: Results -->
      <div class="lg:col-span-7 space-y-6" id="results-section">

        <!-- Results Panel -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-0">

          <!-- Header row -->
          <div class="flex items-start justify-between border-b border-hairline pb-5 mb-6">
            <div>
              <p class="text-xs font-mono uppercase text-mute mb-1.5">Total SE Tax Owed</p>
              <div id="result-se-tax-total" class="text-4xl md:text-5xl font-bold tracking-tight text-violet-600 dark:text-violet-400 font-sans tabular-nums">
                $8,477
              </div>
            </div>
            <button
              type="button"
              id="download-csv-btn"
              class="h-9 px-4 border border-hairline bg-canvas hover:border-hairline-strong text-body hover:text-ink font-sans text-xs rounded-lg shadow-lvl1 transition-colors flex items-center gap-1.5 cursor-pointer"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Export CSV
            </button>
          </div>

          <!-- Step-by-step breakdown -->
          <div class="space-y-0">

            <!-- Step 1 -->
            <div class="flex items-start gap-4 pb-5 border-b border-hairline">
              <div class="w-7 h-7 rounded-full bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300 text-xs font-bold font-mono flex items-center justify-center shrink-0 mt-0.5">1</div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-mono uppercase text-mute mb-1">Net Earnings Subject to SE Tax</p>
                <p class="text-xl font-bold font-sans text-ink tabular-nums" id="result-net-earnings">$55,410</p>
                <p class="text-[11px] text-mute font-sans mt-1">Net income × 92.35% = taxable SE base</p>
              </div>
            </div>

            <!-- Step 2 -->
            <div class="flex items-start gap-4 py-5 border-b border-hairline">
              <div class="w-7 h-7 rounded-full bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300 text-xs font-bold font-mono flex items-center justify-center shrink-0 mt-0.5">2</div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-mono uppercase text-mute mb-3">SE Tax Breakdown</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
                  <div class="bg-canvas-soft border border-hairline rounded-lg p-3">
                    <p class="text-[10px] font-mono text-mute uppercase mb-1">Social Security</p>
                    <p class="text-base font-bold text-ink font-sans tabular-nums" id="result-ss-tax">$6,871</p>
                    <p class="text-[10px] text-mute font-mono mt-0.5">12.4%</p>
                  </div>
                  <div class="bg-canvas-soft border border-hairline rounded-lg p-3">
                    <p class="text-[10px] font-mono text-mute uppercase mb-1">Medicare</p>
                    <p class="text-base font-bold text-ink font-sans tabular-nums" id="result-medicare-tax">$1,607</p>
                    <p class="text-[10px] text-mute font-mono mt-0.5">2.9%</p>
                  </div>
                  <div class="bg-canvas-soft border border-hairline rounded-lg p-3" id="result-addl-medicare-card">
                    <p class="text-[10px] font-mono text-mute uppercase mb-1">Addl. Medicare</p>
                    <p class="text-base font-bold text-ink font-sans tabular-nums" id="result-addl-medicare-tax">$0</p>
                    <p class="text-[10px] text-mute font-mono mt-0.5">0.9% (if applicable)</p>
                  </div>
                </div>

                <!-- Donut chart -->
                <div class="relative w-full" aria-hidden="true">
                  <svg id="se-donut-chart" viewBox="0 0 200 110" class="w-full max-w-[280px] mx-auto h-auto">
                    <!-- Background track -->
                    <path id="donut-bg" d="M 20,100 A 80,80 0 0,1 180,100" fill="none" stroke-width="18" class="stroke-canvas-soft-2"/>
                    <!-- SS segment -->
                    <path id="donut-ss" d="M 20,100 A 80,80 0 0,1 180,100" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-violet-500 transition-all duration-500"/>
                    <!-- Medicare segment -->
                    <path id="donut-medicare" d="M 20,100 A 80,80 0 0,1 180,100" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-emerald-500 transition-all duration-500"/>
                    <!-- Addl Medicare -->
                    <path id="donut-addl" d="M 20,100 A 80,80 0 0,1 180,100" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-amber-500 transition-all duration-500 hidden"/>
                    <!-- Center label -->
                    <text x="100" y="88" text-anchor="middle" class="fill-ink font-sans text-[10px] font-bold" id="donut-label">15.3%</text>
                    <text x="100" y="100" text-anchor="middle" class="fill-mute font-mono text-[8px]">SE Tax Rate</text>
                  </svg>
                  <!-- Legend -->
                  <div class="flex flex-wrap gap-4 justify-center mt-2 text-[10px] font-mono text-mute">
                    <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-violet-500 inline-block"></span>Social Security</div>
                    <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-emerald-500 inline-block"></span>Medicare</div>
                    <div id="donut-addl-legend" class="flex items-center gap-1.5 hidden"><span class="w-3 h-3 rounded-sm bg-amber-500 inline-block"></span>Addl. Medicare</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Step 3 -->
            <div class="flex items-start gap-4 py-5 border-b border-hairline" id="income-tax-step">
              <div class="w-7 h-7 rounded-full bg-canvas-soft-2 text-mute text-xs font-bold font-mono flex items-center justify-center shrink-0 mt-0.5">3</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <p class="text-xs font-mono uppercase text-mute">Estimated Income Tax</p>
                  <span class="text-[9px] font-mono bg-amber-500/15 text-amber-700 dark:text-amber-400 border border-amber-500/30 px-1.5 py-0.5 rounded-full uppercase tracking-wider">Rough Estimate</span>
                </div>
                <p class="text-xl font-bold font-sans text-ink tabular-nums" id="result-income-tax">$6,617</p>
                <p class="text-[11px] text-mute font-sans mt-1">Based on standard deduction + bracket. Not a substitute for real tax software.</p>
                <p class="text-[10px] text-mute font-mono mt-1" id="result-deduction-note">Half of SE tax ($4,239) deducted from income before bracket calculation.</p>
              </div>
            </div>

            <!-- Step 4 -->
            <div class="flex items-start gap-4 py-5 border-b border-hairline">
              <div class="w-7 h-7 rounded-full bg-canvas-soft-2 text-mute text-xs font-bold font-mono flex items-center justify-center shrink-0 mt-0.5">4</div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-mono uppercase text-mute mb-1">Total Estimated Tax Liability</p>
                <p class="text-2xl font-bold font-sans text-ink tabular-nums" id="result-total-liability">$15,094</p>
                <p class="text-[11px] text-mute font-sans mt-1">SE Tax + Estimated Income Tax</p>
              </div>
            </div>

            <!-- Step 5 -->
            <div class="flex items-start gap-4 pt-5">
              <div class="w-7 h-7 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 text-xs font-bold font-mono flex items-center justify-center shrink-0 mt-0.5">5</div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-mono uppercase text-mute mb-1">Quarterly Estimated Payment</p>
                <p class="text-2xl font-bold font-sans text-emerald-600 dark:text-emerald-400 tabular-nums" id="result-quarterly">$3,774</p>
                <p class="text-[11px] text-mute font-sans mt-1 mb-4">Total liability ÷ 4 payments per year</p>

                <!-- Quarterly due dates -->
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                  <div class="bg-canvas-soft border border-hairline rounded-lg p-3 text-center">
                    <p class="text-[9px] font-mono text-mute uppercase mb-1">Q1</p>
                    <p class="text-[11px] font-semibold font-sans text-ink">Mid-April</p>
                    <p class="text-[9px] font-mono text-mute mt-0.5">Jan 1–Mar 31</p>
                  </div>
                  <div class="bg-canvas-soft border border-hairline rounded-lg p-3 text-center">
                    <p class="text-[9px] font-mono text-mute uppercase mb-1">Q2</p>
                    <p class="text-[11px] font-semibold font-sans text-ink">Mid-June</p>
                    <p class="text-[9px] font-mono text-mute mt-0.5">Apr 1–May 31</p>
                  </div>
                  <div class="bg-canvas-soft border border-hairline rounded-lg p-3 text-center">
                    <p class="text-[9px] font-mono text-mute uppercase mb-1">Q3</p>
                    <p class="text-[11px] font-semibold font-sans text-ink">Mid-September</p>
                    <p class="text-[9px] font-mono text-mute mt-0.5">Jun 1–Aug 31</p>
                  </div>
                  <div class="bg-canvas-soft border border-hairline rounded-lg p-3 text-center">
                    <p class="text-[9px] font-mono text-mute uppercase mb-1">Q4</p>
                    <p class="text-[11px] font-semibold font-sans text-ink">Mid-January</p>
                    <p class="text-[9px] font-mono text-mute mt-0.5">Sep 1–Dec 31</p>
                  </div>
                </div>
                <p class="text-[10px] font-mono text-mute mt-2">Exact due dates shift slightly by year. Use IRS Form 1040-ES to confirm. <a href="https://www.irs.gov/businesses/small-businesses-self-employed/estimated-taxes" target="_blank" rel="noopener noreferrer" class="underline">IRS Estimated Tax guide ↗</a></p>
              </div>
            </div>

          </div>
        </div>

        <!-- Full disclaimer -->
        <div class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl1">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-mute shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-[11px] font-sans text-mute leading-relaxed">
              <strong class="text-body">Important Disclaimer:</strong> This calculator provides a general estimate for informational purposes only and is <strong>NOT tax advice</strong>. Self-employment tax rules, rates, and thresholds change and depend on your full financial situation. For accurate figures and filing guidance, consult a licensed tax professional or visit the official IRS website:
              <a href="https://www.irs.gov/businesses/small-businesses-self-employed/self-employment-tax-social-security-and-medicare-taxes" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:text-primary/80 break-all">
                irs.gov/self-employment-tax ↗
              </a>
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- Related Tools -->
