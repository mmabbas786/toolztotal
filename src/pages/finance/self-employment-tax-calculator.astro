<script>
// @ts-nocheck
  // ============================================================
  // SE Tax Config (mirrored from seTaxConfig.ts — keep in sync)
  // NOTE: Update these constants annually. Do NOT change UI code.
  // ============================================================
  const CFG = {
    NET_EARNINGS_MULTIPLIER: 0.9235,
    SS_RATE: 0.124,
    SS_WAGE_BASE: 168_600,
    MEDICARE_RATE: 0.029,
    ADDITIONAL_MEDICARE_RATE: 0.009,
    ADDITIONAL_MEDICARE_THRESHOLD_SINGLE: 200_000,
    ADDITIONAL_MEDICARE_THRESHOLD_MFJ: 250_000,
    STANDARD_DEDUCTION_SINGLE: 14_600,
    STANDARD_DEDUCTION_MFJ: 29_200,
    BRACKETS_SINGLE: [
      { rate: 0.10, upTo: 11_600 },
      { rate: 0.12, upTo: 47_150 },
      { rate: 0.22, upTo: 100_525 },
      { rate: 0.24, upTo: 191_950 },
      { rate: 0.32, upTo: 243_725 },
      { rate: 0.35, upTo: 609_350 },
      { rate: 0.37, upTo: Infinity },
    ],
    BRACKETS_MFJ: [
      { rate: 0.10, upTo: 23_200 },
      { rate: 0.12, upTo: 94_300 },
      { rate: 0.22, upTo: 201_050 },
      { rate: 0.24, upTo: 383_900 },
      { rate: 0.32, upTo: 487_450 },
      { rate: 0.35, upTo: 731_200 },
      { rate: 0.37, upTo: Infinity },
    ],
  };

  // ============================================================
  // DOM References
  // ============================================================
  const seIncomeInput = document.getElementById('se-income') as HTMLInputElement;
  const filingStatusSelect = document.getElementById('filing-status') as HTMLSelectElement;
  const incomeTaxToggle = document.getElementById('income-tax-toggle') as HTMLInputElement;
  const taxBracketSelect = document.getElementById('tax-bracket') as HTMLSelectElement;
  const incomeTaxBracketContainer = document.getElementById('income-tax-bracket-container') as HTMLDivElement;
  const incomeTaxStep = document.getElementById('income-tax-step') as HTMLDivElement;
  const calculateBtn = document.getElementById('calculate-btn') as HTMLButtonElement;
  const downloadCsvBtn = document.getElementById('download-csv-btn') as HTMLButtonElement;

  // Result display elements
  const resultSeTaxTotal = document.getElementById('result-se-tax-total') as HTMLElement;
  const resultNetEarnings = document.getElementById('result-net-earnings') as HTMLElement;
  const resultSsTax = document.getElementById('result-ss-tax') as HTMLElement;
  const resultMedicareTax = document.getElementById('result-medicare-tax') as HTMLElement;
  const resultAddlMedicareTax = document.getElementById('result-addl-medicare-tax') as HTMLElement;
  const resultAddlMedicareCard = document.getElementById('result-addl-medicare-card') as HTMLElement;
  const resultIncomeTax = document.getElementById('result-income-tax') as HTMLElement;
  const resultDeductionNote = document.getElementById('result-deduction-note') as HTMLElement;
  const resultTotalLiability = document.getElementById('result-total-liability') as HTMLElement;
  const resultQuarterly = document.getElementById('result-quarterly') as HTMLElement;

  // Donut chart paths
  const donutBg = document.getElementById('donut-bg') as SVGPathElement;
  const donutSs = document.getElementById('donut-ss') as SVGPathElement;
  const donutMedicare = document.getElementById('donut-medicare') as SVGPathElement;
  const donutAddl = document.getElementById('donut-addl') as SVGPathElement;
  const donutLabel = document.getElementById('donut-label') as SVGTextElement;
  const donutAddlLegend = document.getElementById('donut-addl-legend') as HTMLElement;

  // ============================================================
  // Helpers
  // ============================================================
  const fmt = (n: number) => '$' + Math.round(n).toLocaleString('en-US');
  const fmt2 = (n: number) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  const calcBracketTax = (taxableIncome: number, brackets: typeof CFG.BRACKETS_SINGLE) => {
    let tax = 0;
    let prev = 0;
    for (const b of brackets) {
      if (taxableIncome <= prev) break;
      const slice = Math.min(taxableIncome, b.upTo) - prev;
      tax += slice * b.rate;
      prev = b.upTo;
    }
    return tax;
  };

  let lastResults: any = null;

  // ============================================================
  // Core Calculation Engine
  // ============================================================
  const calculate = () => {
    const netIncome = Math.max(0, parseFloat(seIncomeInput.value) || 0);
    const filingStatus = filingStatusSelect.value; // 'single' | 'mfj'
    const showIncomeTax = incomeTaxToggle.checked;
    const bracketMode = taxBracketSelect.value; // 'auto' | number string

    // Step 1: Net earnings subject to SE tax
    const netEarnings = netIncome * CFG.NET_EARNINGS_MULTIPLIER;

    // Step 2: SE Tax breakdown
    // Social Security — capped at SS_WAGE_BASE
    const ssBase = Math.min(netEarnings, CFG.SS_WAGE_BASE);
    const ssTax = ssBase * CFG.SS_RATE;

    // Medicare — no cap
    const medicareTax = netEarnings * CFG.MEDICARE_RATE;

    // Additional Medicare Tax
    const addlMedicareThreshold = filingStatus === 'mfj'
      ? CFG.ADDITIONAL_MEDICARE_THRESHOLD_MFJ
      : CFG.ADDITIONAL_MEDICARE_THRESHOLD_SINGLE;
    const addlMedicareBase = Math.max(0, netEarnings - addlMedicareThreshold);
    const addlMedicareTax = addlMedicareBase * CFG.ADDITIONAL_MEDICARE_RATE;

    const seTaxTotal = ssTax + medicareTax + addlMedicareTax;

    // Step 3: Rough income tax estimate
    // IRS allows deducting half of SE tax from gross income
    const halfSeTax = seTaxTotal / 2;
    const standardDeduction = filingStatus === 'mfj'
      ? CFG.STANDARD_DEDUCTION_MFJ
      : CFG.STANDARD_DEDUCTION_SINGLE;
    const taxableIncome = Math.max(0, netIncome - halfSeTax - standardDeduction);

    let incomeTaxEstimate = 0;
    if (showIncomeTax) {
      if (bracketMode === 'auto') {
        const brackets = filingStatus === 'mfj' ? CFG.BRACKETS_MFJ : CFG.BRACKETS_SINGLE;
        incomeTaxEstimate = calcBracketTax(taxableIncome, brackets);
      } else {
        incomeTaxEstimate = taxableIncome * (parseFloat(bracketMode) / 100);
      }
    }

    // Step 4: Total liability
    const totalLiability = seTaxTotal + incomeTaxEstimate;

    // Step 5: Quarterly payment
    const quarterlyPayment = totalLiability / 4;

    // Effective rate for donut label
    const effectiveRate = netIncome > 0 ? ((seTaxTotal / netIncome) * 100).toFixed(1) : '0.0';

    // Cache for CSV
    lastResults = {
      netIncome, netEarnings, ssTax, medicareTax, addlMedicareTax,
      seTaxTotal, incomeTaxEstimate, totalLiability, quarterlyPayment,
      halfSeTax, standardDeduction, taxableIncome, filingStatus,
    };

    // ============================================================
    // Update DOM
    // ============================================================
    resultSeTaxTotal.textContent = fmt(seTaxTotal);
    resultNetEarnings.textContent = fmt(netEarnings);
    resultSsTax.textContent = fmt(ssTax);
    resultMedicareTax.textContent = fmt(medicareTax);
    resultAddlMedicareTax.textContent = fmt(addlMedicareTax);

    // Color the SE tax total
    resultSeTaxTotal.className = seTaxTotal > 0
      ? 'text-4xl md:text-5xl font-bold tracking-tight text-violet-600 dark:text-violet-400 font-sans tabular-nums'
      : 'text-4xl md:text-5xl font-bold tracking-tight text-ink font-sans tabular-nums';

    // Show/hide Addl Medicare card highlight
    if (addlMedicareTax > 0) {
      resultAddlMedicareCard.className = resultAddlMedicareCard.className.replace('bg-canvas-soft', 'bg-amber-500/10 border-amber-500/40');
      donutAddl.classList.remove('hidden');
      donutAddlLegend.classList.remove('hidden');
    } else {
      donutAddl.classList.add('hidden');
      donutAddlLegend.classList.add('hidden');
    }

    // Income tax step visibility
    if (showIncomeTax) {
      incomeTaxStep.classList.remove('opacity-40');
      resultIncomeTax.textContent = fmt(incomeTaxEstimate);
      resultDeductionNote.textContent = `Half of SE tax (${fmt(halfSeTax)}) + standard deduction (${fmt(standardDeduction)}) deducted from income before tax calculation.`;
      resultTotalLiability.textContent = fmt(totalLiability);
      resultQuarterly.textContent = fmt(quarterlyPayment);
    } else {
      incomeTaxStep.classList.add('opacity-40');
      resultIncomeTax.textContent = '—';
      resultDeductionNote.textContent = 'Enable income tax estimate to see this figure.';
      resultTotalLiability.textContent = fmt(seTaxTotal) + ' (SE tax only)';
      resultQuarterly.textContent = fmt(seTaxTotal / 4) + ' (SE tax only)';
    }

    // ============================================================
    // Draw Donut Chart (semicircle)
    // ============================================================
    drawDonut(ssTax, medicareTax, addlMedicareTax, effectiveRate);
  };

  // ============================================================
  // Donut Chart — semicircle SVG from (20,100) to (180,100)
  // Arc radius 80, total arc length ≈ 251.3px (half of full circle)
  // ============================================================
  const drawDonut = (ssTax: number, medicareTax: number, addlMedicareTax: number, effectiveRate: string) => {
    const total = ssTax + medicareTax + addlMedicareTax;
    if (total <= 0) return;

    // SVG half-circle arc: center (100,100), radius 80
    const cx = 100, cy = 100, r = 80;
    const arcLen = Math.PI * r; // half-circle arc length ≈ 251.3

    const ssLen = (ssTax / total) * arcLen;
    const medLen = (medicareTax / total) * arcLen;
    const addlLen = (addlMedicareTax / total) * arcLen;

    // Stroke dash: segment length, then gap = rest of arc
    // We use stroke-dashoffset to position segments
    // Arc drawn left-to-right starting at M20,100

    // SS: starts at offset 0
    donutSs.style.strokeDasharray = `${ssLen} ${arcLen}`;
    donutSs.style.strokeDashoffset = '0';

    // Medicare: starts after SS
    donutMedicare.style.strokeDasharray = `${medLen} ${arcLen}`;
    donutMedicare.style.strokeDashoffset = `${-ssLen}`;

    // Additional Medicare: starts after SS + Medicare
    donutAddl.style.strokeDasharray = `${addlLen} ${arcLen}`;
    donutAddl.style.strokeDashoffset = `${-(ssLen + medLen)}`;

    // Background: full arc
    donutBg.style.strokeDasharray = `${arcLen} ${arcLen}`;
    donutBg.style.strokeDashoffset = '0';

    donutLabel.textContent = effectiveRate + '%';
  };

  // ============================================================
  // CSV Export
  // ============================================================
  const exportCsv = () => {
    if (!lastResults) return;
    const r = lastResults;
    const rows = [
      ['Self-Employment Tax Calculator — ToolzTotal.com', ''],
      ['', ''],
      ['Input', 'Value'],
      ['Net Self-Employment Income', r.netIncome.toFixed(2)],
      ['Filing Status', r.filingStatus === 'mfj' ? 'Married Filing Jointly' : 'Single'],
      ['', ''],
      ['Results', 'Amount ($)'],
      ['Net Earnings (×92.35%)', r.netEarnings.toFixed(2)],
      ['Social Security Tax (12.4%)', r.ssTax.toFixed(2)],
      ['Medicare Tax (2.9%)', r.medicareTax.toFixed(2)],
      ['Additional Medicare Tax (0.9%)', r.addlMedicareTax.toFixed(2)],
      ['Total SE Tax', r.seTaxTotal.toFixed(2)],
      ['Half SE Tax Deduction', r.halfSeTax.toFixed(2)],
      ['Standard Deduction Applied', r.standardDeduction.toFixed(2)],
      ['Taxable Income (for income tax)', r.taxableIncome.toFixed(2)],
      ['Estimated Income Tax (rough)', r.incomeTaxEstimate.toFixed(2)],
      ['Total Estimated Tax Liability', r.totalLiability.toFixed(2)],
      ['Quarterly Estimated Payment', (r.totalLiability / 4).toFixed(2)],
      ['', ''],
      ['DISCLAIMER', 'Estimates only. Not tax advice. Verify at irs.gov.'],
    ];
    const csv = rows.map(r => r.map(c => `"${c}"`).join(',')).join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'se-tax-estimate-toolztotal.csv';
    a.click();
    URL.revokeObjectURL(a.href);
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  calculateBtn.addEventListener('click', calculate);
  downloadCsvBtn.addEventListener('click', exportCsv);

  incomeTaxToggle.addEventListener('change', () => {
    if (incomeTaxToggle.checked) {
      incomeTaxBracketContainer.classList.remove('hidden');
    } else {
      incomeTaxBracketContainer.classList.add('hidden');
    }
    calculate();
  });

  // Live recalc on input change
  [seIncomeInput, filingStatusSelect, taxBracketSelect].forEach(el => {
    el.addEventListener('change', calculate);
    if (el.tagName === 'INPUT') el.addEventListener('input', calculate);
  });

  // ============================================================
  // Initial calculation on page load
  // ============================================================
  calculate();
</script>
