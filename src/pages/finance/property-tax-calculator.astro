<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const homeValueIn = document.getElementById('home-value') as HTMLInputElement;
  const stateSelect = document.getElementById('state-select') as HTMLSelectElement;
  const taxRateIn = document.getElementById('tax-rate-input') as HTMLInputElement;

  const homesteadCheck = document.getElementById('homestead-check') as HTMLInputElement;
  const homesteadContainer = document.getElementById('homestead-input-container') as HTMLDivElement;
  const homesteadValueIn = document.getElementById('homestead-value') as HTMLInputElement;

  const resAnnualTax = document.getElementById('res-annual-tax') as HTMLSpanElement;
  const resTaxableValue = document.getElementById('res-taxable-value') as HTMLSpanElement;
  const resMonthlyTax = document.getElementById('res-monthly-tax') as HTMLSpanElement;

  // Read stateTaxRates safely from defined vars on window
  const ratesTable = (window as any).stateTaxRates || {};

  // ============================================================
  // Functions
  // ============================================================
  const handleStateChange = () => {
    const stateVal = stateSelect.value;
    if (stateVal === 'custom') {
      taxRateIn.disabled = false;
    } else {
      const match = ratesTable[stateVal];
      if (match) {
        taxRateIn.value = match.propertyTaxRate.toString();
        taxRateIn.disabled = true;
      }
    }
    calculatePropertyTax();
  };

  const calculatePropertyTax = () => {
    const value = parseFloat(homeValueIn.value) || 0;
    const rate = parseFloat(taxRateIn.value) || 0;
    const applyHomestead = homesteadCheck.checked;
    const homesteadAmt = applyHomestead ? (parseFloat(homesteadValueIn.value) || 0) : 0;

    // Toggle homestead inputs
    if (applyHomestead) {
      homesteadContainer.classList.remove('hidden');
    } else {
      homesteadContainer.classList.add('hidden');
    }

    const taxableValue = Math.max(0, value - homesteadAmt);
    const annualTax = taxableValue * (rate / 100);
    const monthlyTax = annualTax / 12;

    resTaxableValue.textContent = "$" + taxableValue.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    resAnnualTax.textContent = "$" + annualTax.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    resMonthlyTax.textContent = "$" + monthlyTax.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + " / mo";
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  stateSelect.addEventListener('change', handleStateChange);
  taxRateIn.addEventListener('input', calculatePropertyTax);
  homeValueIn.addEventListener('input', calculatePropertyTax);
  homesteadCheck.addEventListener('change', calculatePropertyTax);
  homesteadValueIn.addEventListener('input', calculatePropertyTax);

  // Initial render
  handleStateChange();
</script>
