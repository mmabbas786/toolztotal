---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How is my loan payment calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your monthly loan payment is calculated using standard amortization formulas: M = P * [r(1+r)^n] / [(1+r)^n - 1]. Here, P represents the principal amount you borrow, r is the monthly interest rate (annual rate divided by 12), and n is the total number of payments (duration in months)."
      }
    },
    {
      "@type": "Question",
      "name": "What's a typical interest rate for an auto/personal/student loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Average rates fluctuate but generally, auto loans range between 5% and 9% depending on prime conditions and credit scores. Personal loans are unsecured and range higher, usually between 8% and 25%. Federal student loan rates are set by Congress and generally range between 5% and 8% depending on the loan disbursement date and degree status."
      }
    },
    {
      "@type": "Question",
      "name": "Does my credit score affect my rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, credit scores are the primary risk metric lenders use. Higher credit scores indicate a solid track record of repayment, qualifying you for lowest rate bands. Lower scores increase your default risk profile, meaning lenders charge higher interest rates to compensate, increasing your monthly and overall debt expense."
      }
    },
    {
      "@type": "Question",
      "name": "How much can extra payments save me?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Extra payments lower the principal amount immediately. Since interest is calculated monthly as a percentage of your outstanding balance, reducing the base amount reduces future interest accruals. This speeds up your schedule, shaves months off your term, and saves hundreds or thousands of dollars in cumulative financing charges."
      }
    },
    {
      "@type": "Question",
      "name": "Is this loan calculator accurate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, our calculations use standard mathematical amortization algorithms. However, lenders may use slightly different day count conventions, add loan origination or administration fees, or compound interest differently. Always crosscheck these calculations against a official Truth in Lending disclosure statement before signing contract details."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between secured and unsecured loans?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Secured loans are backed by physical collateral (like a home or car) that the lender can repossess if you default. Unsecured loans (like personal loans or credit cards) have no collateral, carrying higher interest rates due to increased risk."
      }
    },
    {
      "@type": "Question",
      "name": "How does loan duration affect my total interest paid?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shorter loan durations have higher monthly payments but lower interest rates, saving you money on interest. Longer loan durations offer lower payments but increase total interest over time."
      }
    },
    {
      "@type": "Question",
      "name": "What is a prepayment penalty on a loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A prepayment penalty is a fee charged by some lenders if you pay off your loan early, protecting the lender's expected interest profit. Always ask for fee terms before signing."
      }
    },
    {
      "@type": "Question",
      "name": "How does my credit history affect my loan interest rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lenders use your credit report and credit score to assess risk. Borrowers with high credit scores qualify for the lowest rates, while lower scores result in premium interest rates."
      }
    },
    {
      "@type": "Question",
      "name": "Can a personal loan be used to consolidate credit card debt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Consolidating credit card debt with a personal loan can lower your average interest rate and simplify multiple monthly payments into a single fixed installment."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Loan Calculator - Free Auto, Personal & Student Loan Payment Estimator | ToolzTotal"
  description="Calculate monthly payments for auto, personal, or student loans with our free, ad-free loan calculator. Compare presets and extra payment savings."
  faqJsonLd={faqJsonLd}
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/finance" class="hover:text-ink transition-colors">Finance & Loans</a>
      <span>/</span>
      <span class="text-ink">Loan Calculator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Loan Payment Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Estimate monthly loan repayments, interest totals, and payoff timelines. Select from preset loan profiles or configure a custom term with optional monthly extra payments.
      </p>
    </div>

    <!-- Loan Type Presets Tabs -->
    <div class="mb-8 border-b border-hairline flex flex-wrap gap-1">
      <button 
        type="button" 
        id="preset-auto" 
        data-preset="auto"
        class="px-5 py-3 text-sm font-sans font-medium border-b-2 border-primary text-ink transition-all cursor-pointer"
      >
        🚗 Auto Loan
      </button>
      <button 
        type="button" 
        id="preset-personal" 
        data-preset="personal"
        class="px-5 py-3 text-sm font-sans font-medium border-b-2 border-transparent text-mute hover:text-ink transition-all cursor-pointer"
      >
        💼 Personal Loan
      </button>
      <button 
        type="button" 
        id="preset-student" 
        data-preset="student"
        class="px-5 py-3 text-sm font-sans font-medium border-b-2 border-transparent text-mute hover:text-ink transition-all cursor-pointer"
      >
        🎓 Student Loan
      </button>
      <button 
        type="button" 
        id="preset-custom" 
        data-preset="custom"
        class="px-5 py-3 text-sm font-sans font-medium border-b-2 border-transparent text-mute hover:text-ink transition-all cursor-pointer"
      >
        ⚙️ Custom
      </button>
      <input type="hidden" id="active-preset" value="auto" />
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Input Form (5 cols) -->
      <div class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Loan Details</h2>
        
        <!-- Loan Amount -->
        <div>
          <label for="loan-amount" class="block text-xs font-mono uppercase text-mute mb-2">Loan Amount</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input 
              type="number" 
              id="loan-amount" 
              value="25000" 
              step="1000"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 25,000…"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Interest Rate -->
        <div>
          <label for="interest-rate" class="block text-xs font-mono uppercase text-mute mb-2">Interest Rate</label>
          <div class="relative">
            <input 
              type="number" 
              id="interest-rate" 
              value="7.0" 
              step="0.05"
              min="0"
              max="100"
              class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 7.0…"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
          </div>
          <p class="text-[11px] text-mute font-sans mt-1.5 leading-normal" id="rate-tip">Interest rates default to auto loan standard. Adjust as needed.</p>
        </div>

        <!-- Loan Term -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label for="loan-term" class="block text-xs font-mono uppercase text-mute">Loan Term</label>
            <div class="inline-flex rounded-md bg-canvas-soft-2 p-0.5 border border-hairline shadow-lvl1">
              <button 
                type="button" 
                id="term-toggle-months" 
                class="px-2.5 py-1 text-[10px] font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer"
                aria-label="Toggle loan term to months"
              >
                Months
              </button>
              <button 
                type="button" 
                id="term-toggle-years" 
                class="px-2.5 py-1 text-[10px] font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer"
                aria-label="Toggle loan term to years"
              >
                Years
              </button>
            </div>
            <input type="hidden" id="term-mode" value="months" />
          </div>
          
          <div class="relative">
            <input 
              type="number" 
              id="loan-term" 
              value="60" 
              step="1"
              min="1"
              class="w-full h-10 pl-3 pr-16 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 60…"
              autocomplete="off"
            />
            <span id="term-suffix" class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-xs font-mono">months</span>
          </div>
        </div>

        <!-- Extra Monthly Payment -->
        <div class="border-t border-hairline pt-5">
          <label for="extra-payment" class="block text-xs font-mono uppercase text-mute mb-2 flex items-center justify-between">
            <span>Extra Monthly Payment</span>
            <span class="text-[10px] text-emerald-500 font-mono">payoff faster</span>
          </label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input 
              type="number" 
              id="extra-payment" 
              value="0" 
              step="25"
              min="0"
              class="w-full h-10 pl-7 pr-10 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 100…"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-[10px] font-mono">/mo</span>
          </div>
          <p class="text-[11px] text-mute font-sans mt-1.5 leading-normal">Reduce interest costs and accelerate your payoff timeline.</p>
        </div>

      </div>

      <!-- Right Column: Results Dashboard & Charts (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Estimated Monthly Payment Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 relative">
          <h2 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">Monthly Payment</h2>
          <div id="monthly-payment-total" class="text-4xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-6 tabular-nums">
            $0.00
          </div>
          
          <!-- Donut Breakdown Grid (Principal vs Interest proportion over total loan cost) -->
          <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center border-t border-hairline pt-6">
            
            <!-- SVG Donut Chart (4 cols) -->
            <div class="md:col-span-4 flex justify-center">
              <div class="relative w-36 h-36">
                <svg viewBox="0 0 100 100" class="w-full h-full transform -rotate-90">
                  <circle cx="50" cy="50" r="38" stroke-width="10" class="stroke-canvas-soft-2 fill-none" />
                  <!-- Principal segment -->
                  <circle 
                    id="donut-principal" 
                    cx="50" 
                    cy="50" 
                    r="38" 
                    stroke-width="10" 
                    stroke-dasharray="0 238.76" 
                    stroke-dashoffset="0"
                    class="stroke-neutral-900 dark:stroke-neutral-100 fill-none transition-all duration-300" 
                  />
                  <!-- Interest segment -->
                  <circle 
                    id="donut-interest" 
                    cx="50" 
                    cy="50" 
                    r="38" 
                    stroke-width="10" 
                    stroke-dasharray="0 238.76" 
                    stroke-dashoffset="0"
                    class="stroke-purple-500 dark:stroke-purple-400 fill-none transition-all duration-300" 
                  />
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
                  <span id="donut-center-total" class="text-xs font-bold text-ink tabular-nums">$0</span>
                  <span class="text-[8px] font-mono text-mute uppercase">Total Cost</span>
                </div>
              </div>
            </div>
            
            <!-- Breakdown Numbers list (8 cols) -->
            <div class="md:col-span-8 space-y-2.5">
              <div class="text-xs font-mono uppercase text-mute border-b border-hairline pb-1 mb-2">Total Repayment Breakdown</div>
              <!-- Principal -->
              <div class="flex items-center justify-between text-xs font-sans">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-neutral-950 dark:bg-neutral-100 inline-block"></span>
                  <span class="text-body font-medium">Principal Amount</span>
                </div>
                <span id="breakdown-principal-val" class="font-bold text-ink tabular-nums">$0.00</span>
              </div>
              <!-- Interest -->
              <div class="flex items-center justify-between text-xs font-sans">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-purple-500 dark:bg-purple-400 inline-block"></span>
                  <span class="text-body font-medium">Total Interest</span>
                </div>
                <span id="breakdown-interest-val" class="font-bold text-ink tabular-nums">$0.00</span>
              </div>
            </div>
            
          </div>

          <!-- Disclaimer inline -->
          <div class="mt-6 pt-4 border-t border-hairline text-[10px] text-mute leading-normal font-sans">
            <strong>Disclaimer:</strong> This calculator provides estimates for informational purposes only and is not a loan offer or financial advice. Actual rates depend on your credit profile and lender terms.
          </div>
        </div>

        <!-- Payoff Summary Grid -->
        <div class="grid grid-cols-3 gap-4">
          <div class="bg-canvas border border-hairline rounded-lg p-4 shadow-lvl1">
            <span class="block text-[10px] font-mono uppercase text-mute mb-1">Repayment Total</span>
            <span id="summary-repayment-total" class="text-base font-bold text-ink font-sans tabular-nums">$0</span>
          </div>
          <div class="bg-canvas border border-hairline rounded-lg p-4 shadow-lvl1">
            <span class="block text-[10px] font-mono uppercase text-mute mb-1">Interest Cost</span>
            <span id="summary-interest" class="text-base font-bold text-ink font-sans tabular-nums">$0</span>
          </div>
          <div class="bg-canvas border border-hairline rounded-lg p-4 shadow-lvl1">
            <span class="block text-[10px] font-mono uppercase text-mute mb-1">Payoff Date</span>
            <span id="summary-payoff" class="text-base font-bold text-ink font-sans tabular-nums">--</span>
          </div>
        </div>

        <!-- Extra Payment Accelerator Impact showcase (Hidden by default unless extra payment is added) -->
        <div id="accel-impact-card" class="bg-canvas border border-emerald-500/20 dark:border-emerald-500/30 rounded-xl p-6 shadow-lvl3 relative hidden overflow-hidden">
          <div class="absolute right-0 top-0 bg-emerald-500/10 dark:bg-emerald-500/20 text-emerald-500 font-mono text-[9px] uppercase px-3 py-1 rounded-bl">
            Acceleration Benefit
          </div>
          
          <h3 class="text-sm font-bold text-ink font-sans mb-4 flex items-center gap-1.5">
            <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Extra Payment Impact
          </h3>

          <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="bg-emerald-500/5 dark:bg-emerald-500/10 p-3 rounded-lg border border-emerald-500/10">
              <span class="block text-[9px] font-mono uppercase text-mute mb-0.5">Interest Saved</span>
              <span id="accel-saved-interest" class="text-base font-bold text-emerald-600 dark:text-emerald-400 font-sans tabular-nums">$0</span>
            </div>
            <div class="bg-emerald-500/5 dark:bg-emerald-500/10 p-3 rounded-lg border border-emerald-500/10">
              <span class="block text-[9px] font-mono uppercase text-mute mb-0.5">Time Saved</span>
              <span id="accel-saved-time" class="text-base font-bold text-emerald-600 dark:text-emerald-400 font-sans">0 months</span>
            </div>
            <div class="bg-emerald-500/5 dark:bg-emerald-500/10 p-3 rounded-lg border border-emerald-500/10">
              <span class="block text-[9px] font-mono uppercase text-mute mb-0.5">New Payoff Date</span>
              <span id="accel-new-date" class="text-base font-bold text-emerald-600 dark:text-emerald-400 font-sans whitespace-nowrap">--</span>
            </div>
          </div>

          <!-- Payoff Timeline Bars -->
          <div class="space-y-4">
            <!-- Timeline 1: Original Payoff -->
            <div>
              <div class="flex items-center justify-between text-[10px] font-mono text-mute mb-1">
                <span>Baseline Payoff Timeline</span>
                <span id="timeline-orig-term" class="font-bold text-ink">60 Months</span>
              </div>
              <div class="w-full h-3 bg-canvas-soft-2 border border-hairline rounded-full overflow-hidden">
                <div class="h-full bg-neutral-300 dark:bg-neutral-700 w-full"></div>
              </div>
            </div>
            <!-- Timeline 2: Accelerated Payoff -->
            <div>
              <div class="flex items-center justify-between text-[10px] font-mono text-mute mb-1">
                <span>Accelerated Payoff Timeline</span>
                <span id="timeline-accel-term" class="font-bold text-emerald-500">48 Months</span>
              </div>
              <div class="w-full h-3 bg-canvas-soft-2 border border-hairline rounded-full flex overflow-hidden">
                <div id="timeline-accel-bar" class="h-full bg-emerald-500 dark:bg-emerald-600" style="width: 80%;"></div>
                <div id="timeline-saved-bar" class="h-full bg-emerald-500/25 border-l border-dashed border-emerald-500/50" style="width: 20%;"></div>
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>

    <!-- Amortization Visualization Section -->
    <div class="mt-16 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-hairline pb-4 mb-6">
        <div>
          <h2 class="text-xl font-bold text-ink font-sans">Amortization Schedule</h2>
          <p class="text-xs text-mute font-sans mt-0.5">Visualize remaining balance over the duration of the loan.</p>
        </div>
        <div class="flex items-center gap-3">
          <!-- Granularity Toggle -->
          <div class="inline-flex rounded-md bg-canvas-soft-2 p-0.5 border border-hairline shadow-lvl1">
            <button 
              type="button" 
              id="chart-toggle-yearly" 
              class="px-3 py-1 text-xs font-mono rounded-md bg-primary text-on-primary shadow-lvl1 cursor-pointer"
            >
              Yearly
            </button>
            <button 
              type="button" 
              id="chart-toggle-monthly" 
              class="px-3 py-1 text-xs font-mono rounded-md text-mute hover:text-ink cursor-pointer"
            >
              Monthly
            </button>
          </div>
          <!-- Download CSV -->
          <button 
            type="button" 
            id="download-csv" 
            class="h-8 border border-hairline bg-canvas hover:border-hairline-strong text-body hover:text-ink font-sans text-xs px-3 rounded-md transition-colors flex items-center gap-1.5 cursor-pointer shadow-lvl1"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download CSV
          </button>
        </div>
      </div>

      <!-- Interactive SVG Chart -->
      <div class="w-full relative">
        <svg id="amortization-chart" viewBox="0 0 600 220" class="w-full h-auto max-h-[300px]">
          <!-- Grid lines -->
          <line x1="50" y1="15" x2="590" y2="15" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
          <line x1="50" y1="60" x2="590" y2="60" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
          <line x1="50" y1="105" x2="590" y2="105" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" stroke-dasharray="2 2" />
          <line x1="50" y1="150" x2="590" y2="150" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
          <line x1="50" y1="195" x2="590" y2="195" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />

          <!-- Y-axis labels -->
          <text x="42" y="20" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px] text-right" text-anchor="end" id="chart-y-max">$25k</text>
          <text x="42" y="110" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="end" id="chart-y-mid">$12.5k</text>
          <text x="42" y="198" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="end">0</text>

          <!-- SVG Paths for Baseline Area -->
          <path id="chart-baseline-fill" class="fill-neutral-200/50 dark:fill-neutral-800/40" d="M 50,195 L 590,195 Z" />
          <path id="chart-baseline-line" class="stroke-neutral-400 dark:stroke-neutral-600 fill-none" stroke-width="2" d="M 50,195 L 590,195 Z" />

          <!-- SVG Paths for Accelerated Area -->
          <path id="chart-accel-fill" class="fill-emerald-500/10 dark:fill-emerald-500/5 hidden" d="M 50,195 L 590,195 Z" />
          <path id="chart-accel-line" class="stroke-emerald-500 dark:stroke-emerald-400 fill-none hidden" stroke-width="2" d="M 50,195 L 590,195 Z" />

          <!-- X-axis Labels (Dynamic based on term) -->
          <g id="chart-x-labels">
            <text x="50" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Mo 0</text>
            <text x="230" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Mo 20</text>
            <text x="410" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Mo 40</text>
            <text x="590" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Mo 60</text>
          </g>
        </svg>
        
        <!-- Legend overlays -->
        <div class="flex gap-4 justify-center items-center text-[10px] font-mono text-mute mt-3">
          <div class="flex items-center gap-1.5">
            <span class="w-3.5 h-1.5 bg-neutral-400 dark:bg-neutral-600 inline-block rounded-xs"></span>
            <span>Standard Payoff Balance</span>
          </div>
