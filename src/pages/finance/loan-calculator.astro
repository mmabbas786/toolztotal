      }).format(val);
    };

    const getPayoffDate = (monthsToAdd: number) => {
      const date = new Date();
      date.setMonth(date.getMonth() + monthsToAdd);
      return date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
    };

    // Primary Calculation
    const runCalculations = () => {
      const principal = Math.max(0, parseFloat(loanAmountInput.value) || 0);
      const annualRate = Math.max(0, parseFloat(interestRateInput.value) || 0);
      const rawTerm = Math.max(1, parseFloat(termInput.value) || 1);
      const extraPayment = Math.max(0, parseFloat(extraPaymentInput.value) || 0);

      // Determine term in months
      const termMonths = currentTermMode === 'months' ? Math.round(rawTerm) : Math.round(rawTerm * 12);

      // Call Amortization Utility
      const result = calculateAmortization(principal, annualRate, termMonths, extraPayment);
      const monthlyPI = result.monthlyPI;
      activeBaselineSchedule = result.baseline.schedule;
      activeAcceleratedSchedule = result.accelerated.schedule;

      const baselineInterest = result.baseline.totalInterest;
      const totalCostOfLoan = principal + baselineInterest;
      const baselinePayoffMonths = result.baseline.payoffMonths;

      // Update Results DOM
      monthlyPaymentTotal.textContent = formatCurrencyWithCents(monthlyPI + (extraPayment > 0 ? extraPayment : 0));
      summaryRepaymentTotal.textContent = formatCurrency(totalCostOfLoan);
      summaryInterest.textContent = formatCurrency(baselineInterest);
      summaryPayoff.textContent = getPayoffDate(baselinePayoffMonths);

      // Update Donut Chart
      breakdownPrincipalVal.textContent = formatCurrencyWithCents(principal);
      breakdownInterestVal.textContent = formatCurrencyWithCents(baselineInterest);
      donutCenterTotal.textContent = formatCurrency(totalCostOfLoan);

      const circumference = 2 * Math.PI * 38; // 238.761
      const totalAmount = principal + baselineInterest;
      
      const segments = [
        { el: donutPrincipal, val: principal },
        { el: donutInterest, val: baselineInterest }
      ];

      let cumulativePct = 0;
      segments.forEach(item => {
        const percent = totalAmount > 0 ? item.val / totalAmount : 0;
        const strokeLength = percent * circumference;
        const strokeSpace = circumference - strokeLength;
        item.el.setAttribute('stroke-dasharray', `${strokeLength} ${strokeSpace}`);
        item.el.setAttribute('stroke-dashoffset', (-cumulativePct * circumference).toString());
        cumulativePct += percent;
      });

      // Update timelines orig term
      timelineOrigTerm.textContent = `${termMonths} Months`;

      // Update Accelerated Statistics
      if (extraPayment > 0 && principal > 0 && activeAcceleratedSchedule.length > 0) {
        accelImpactCard.classList.remove('hidden');
        chartLegendAccel.classList.remove('hidden');

        const accelInterest = result.accelerated.totalInterest;
        const interestSavedVal = Math.max(0, baselineInterest - accelInterest);
        accelSavedInterest.textContent = formatCurrency(interestSavedVal);

        const accelMonths = result.accelerated.payoffMonths;
        const monthsSaved = baselinePayoffMonths - accelMonths;
        const yearsSaved = Math.floor(monthsSaved / 12);
        const remMonths = monthsSaved % 12;

        let timeSavedStr = '';
        if (yearsSaved > 0) timeSavedStr += `${yearsSaved} yr${yearsSaved > 1 ? 's' : ''}`;
        if (remMonths > 0) timeSavedStr += ` ${remMonths} mo${remMonths > 1 ? 's' : ''}`;
        if (monthsSaved <= 0) timeSavedStr = '0 months';
        accelSavedTime.textContent = timeSavedStr;

        accelNewDate.textContent = getPayoffDate(accelMonths);
        timelineAccelTerm.textContent = `${accelMonths} Months`;

        const percentOfTerm = (accelMonths / termMonths) * 100;
        const percentSaved = (monthsSaved / termMonths) * 100;
        timelineAccelBar.style.width = `${percentOfTerm}%`;
        timelineSavedBar.style.width = `${percentSaved}%`;
      } else {
        accelImpactCard.classList.add('hidden');
        chartLegendAccel.classList.add('hidden');
      }

      // Update Chart & Table representation
      updateAmortizationView();
    };

    // Render Amortization chart and table
    const updateAmortizationView = () => {
      const principal = Math.max(0, parseFloat(loanAmountInput.value) || 0);
      if (principal <= 0 || activeBaselineSchedule.length === 0) {
        chartBaselineLine.classList.add('hidden');
        chartBaselineFill.classList.add('hidden');
        chartAccelLine.classList.add('hidden');
        chartAccelFill.classList.add('hidden');
        scheduleTableBody.innerHTML = '<tr><td colspan="5" class="py-6 text-center text-mute font-mono">Enter a valid Loan Amount to view the schedule.</td></tr>';
        return;
      }

      chartYMax.textContent = formatCurrency(principal);
      chartYMid.textContent = formatCurrency(principal / 2);

      const isYearly = chartGranularity === 'yearly';

      // Draw SVG Curve paths
      const paths = getSvgChartPaths(activeBaselineSchedule, activeAcceleratedSchedule, principal, isYearly);
      chartBaselineLine.setAttribute('d', paths.baseLineD);
      chartBaselineFill.setAttribute('d', paths.baseFillD);
      chartBaselineLine.classList.remove('hidden');
      chartBaselineFill.classList.remove('hidden');

      if (paths.hasAccel) {
        chartAccelLine.setAttribute('d', paths.accelLineD);
        chartAccelFill.setAttribute('d', paths.accelFillD);
        chartAccelLine.classList.remove('hidden');
        chartAccelFill.classList.remove('hidden');
      } else {
        chartAccelLine.classList.add('hidden');
        chartAccelFill.classList.add('hidden');
      }

      // Draw dynamic X axis labels
      const totalBaselinePeriods = activeBaselineSchedule.length;
      let xLabelsHtml = '';

      const paddingLeft = 50;
      const paddingRight = 10;
      const chartWidth = 600 - paddingLeft - paddingRight;

      if (isYearly) {
        const totalTermYears = Math.ceil(totalBaselinePeriods / 12);
        const step = Math.ceil(totalTermYears / 3);
        for (let i = 0; i <= 3; i++) {
          const yearNum = Math.min(totalTermYears, i * step);
          const xPos = paddingLeft + (yearNum / totalTermYears) * chartWidth;
          xLabelsHtml += `<text x="${xPos}" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Yr ${yearNum}</text>`;
        }
      } else {
        const step = Math.ceil(totalBaselinePeriods / 3);
        for (let i = 0; i <= 3; i++) {
          const monthNum = Math.min(totalBaselinePeriods, i * step);
          const xPos = paddingLeft + (monthNum / totalBaselinePeriods) * chartWidth;
          xLabelsHtml += `<text x="${xPos}" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Mo ${monthNum}</text>`;
        }
      }
      chartXLabels.innerHTML = xLabelsHtml;

      // Group table rows
      let tableRowsData: any[] = [];
      if (isYearly) {
        tableRowsData = getYearlySchedule(activeBaselineSchedule, principal);
        tableHdrPeriod.textContent = 'Year';
      } else {
        activeBaselineSchedule.forEach(m => {
          tableRowsData.push({
            period: `Month ${m.period}`,
            beginningBalance: m.beginningBalance,
            principalPaid: m.principalPaid,
            interestPaid: m.interestPaid,
            endingBalance: m.endingBalance
          });
        });
        tableHdrPeriod.textContent = 'Month';
      }

      let rowsHtml = '';
      tableRowsData.forEach(row => {
        rowsHtml += `
          <tr class="hover:bg-canvas-soft-2 transition-colors border-b border-hairline">
            <td class="py-2.5 px-4 font-mono font-medium text-ink">${row.period}</td>
            <td class="py-2.5 px-4 text-right">${formatCurrency(row.beginningBalance)}</td>
            <td class="py-2.5 px-4 text-right text-emerald-600 dark:text-emerald-400 font-semibold">${formatCurrency(row.principalPaid)}</td>
            <td class="py-2.5 px-4 text-right text-red-500 dark:text-red-400">${formatCurrency(row.interestPaid)}</td>
            <td class="py-2.5 px-4 text-right font-medium">${formatCurrency(row.endingBalance)}</td>
          </tr>
        `;
      });
      scheduleTableBody.innerHTML = rowsHtml;

      csvContent = generateCsv(tableRowsData, isYearly ? 'Year' : 'Month');
    };

    // 5. Presets Handling
    const presets: Record<string, { term: number; rate: number; mode: string; label: string }> = {
      auto: { term: 60, rate: 7.0, mode: 'months', label: 'Interest rates default to auto loan standard. Adjust as needed.' },
      personal: { term: 36, rate: 11.0, mode: 'months', label: 'Interest rates default to personal loan standard. Adjust as needed.' },
      student: { term: 120, rate: 6.0, mode: 'months', label: 'Interest rates default to student loan standard. Adjust as needed.' },
      custom: { term: 60, rate: 7.0, mode: 'months', label: 'Custom configuration mode. Enter parameters manually.' }
    };

    const selectPreset = (presetName: string) => {
      const config = presets[presetName];
      if (!config) return;

      activePresetInput.value = presetName;

      // Update button styles
      const btns = [
        { el: presetAuto, name: 'auto' },
        { el: presetPersonal, name: 'personal' },
        { el: presetStudent, name: 'student' },
        { el: presetCustom, name: 'custom' }
      ];

      btns.forEach(item => {
        if (item.name === presetName) {
          item.el.classList.add('border-primary', 'text-ink');
          item.el.classList.remove('border-transparent', 'text-mute');
        } else {
          item.el.classList.remove('border-primary', 'text-ink');
          item.el.classList.add('border-transparent', 'text-mute');
        }
      });

      if (presetName !== 'custom') {
        interestRateInput.value = config.rate.toFixed(2);
        termInput.value = config.term.toString();
        rateTip.textContent = config.label;
        updateTermMode(config.mode);
      } else {
        rateTip.textContent = config.label;
      }

      runCalculations();
    };

    presetAuto.addEventListener('click', () => selectPreset('auto'));
    presetPersonal.addEventListener('click', () => selectPreset('personal'));
    presetStudent.addEventListener('click', () => selectPreset('student'));
    presetCustom.addEventListener('click', () => selectPreset('custom'));

    // Handle shift to custom if values edited
    const triggerCustomMode = () => {
      if (activePresetInput.value !== 'custom') {
        selectPreset('custom');
      }
    };

    interestRateInput.addEventListener('input', triggerCustomMode);
    termInput.addEventListener('input', triggerCustomMode);

    // 6. Term Toggle handler
    const updateTermMode = (mode: string) => {
      if (currentTermMode === mode) return;
      currentTermMode = mode;
      termModeInput.value = mode;

      const rawVal = parseFloat(termInput.value) || 0;

      if (mode === 'months') {
        termToggleMonths.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl2');
        termToggleMonths.classList.remove('text-mute');
        termToggleYears.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl2');
        termToggleYears.classList.add('text-mute');
        termSuffix.textContent = 'months';
        
        // Convert years to months
        termInput.value = Math.round(rawVal * 12).toString();
      } else {
        termToggleYears.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl2');
        termToggleYears.classList.remove('text-mute');
        termToggleMonths.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl2');
        termToggleMonths.classList.add('text-mute');
        termSuffix.textContent = 'years';

        // Convert months to years
        termInput.value = (Math.round((rawVal / 12) * 100) / 100).toFixed(2).replace('.00', '');
      }

      runCalculations();
    };

    termToggleMonths.addEventListener('click', () => {
      triggerCustomMode();
      updateTermMode('months');
    });

    termToggleYears.addEventListener('click', () => {
      triggerCustomMode();
      updateTermMode('years');
    });

    // Amortization Granularity Switches
    chartToggleYearly.addEventListener('click', () => {
      if (chartGranularity === 'yearly') return;
      chartGranularity = 'yearly';
      chartToggleYearly.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl1');
      chartToggleYearly.classList.remove('text-mute');
      chartToggleMonthly.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl1');
      chartToggleMonthly.classList.add('text-mute');
      updateAmortizationView();
    });

    chartToggleMonthly.addEventListener('click', () => {
      if (chartGranularity === 'monthly') return;
      chartGranularity = 'monthly';
      chartToggleMonthly.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl1');
      chartToggleMonthly.classList.remove('text-mute');
      chartToggleYearly.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl1');
      chartToggleYearly.classList.add('text-mute');
      updateAmortizationView();
    });

    // Amortization Table toggle drawer
    toggleScheduleTable.addEventListener('click', () => {
      const isExpanded = toggleScheduleTable.getAttribute('aria-expanded') === 'true';
      toggleScheduleTable.setAttribute('aria-expanded', (!isExpanded).toString());
      tableChevron.classList.toggle('rotate-180', !isExpanded);
      scheduleTableContainer.classList.toggle('hidden', isExpanded);
    });

    // CSV Trigger download
    downloadCsvBtn.addEventListener('click', () => {
      if (!csvContent) return;
      const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
      const link = document.createElement("a");
      const url = URL.createObjectURL(blob);
      link.setAttribute("href", url);
      link.setAttribute("download", `loan_amortization_schedule_${chartGranularity}.csv`);
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    });

    // FAQs Accordion bindings
    document.querySelectorAll('.faq-toggle').forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling as HTMLDivElement;
        const chevron = button.querySelector('svg') as unknown as SVGElement;
        const isHidden = content.classList.toggle('hidden');
        chevron.classList.toggle('rotate-180', !isHidden);
        button.setAttribute('aria-expanded', (!isHidden).toString());
      });
    });

    // Dynamic Recalculation on form inputs
    const inputsList = [loanAmountInput, interestRateInput, termInput, extraPaymentInput];
    inputsList.forEach(input => {
      input.addEventListener('input', runCalculations);
    });

    // Initial Trigger
    runCalculations();

  </script>
</Layout>
