    </section>

  </div>

    <RelatedTools
      categorySlug="finance"
      toolSlug="inflation-calculator"
    />

  <ContentFooter category="finance" />
</Layout>

<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const startAmountIn = document.getElementById('start-amount') as HTMLInputElement;
  const startYearSelect = document.getElementById('start-year') as HTMLSelectElement;
  const endYearSelect = document.getElementById('end-year') as HTMLSelectElement;

  const resAdjustedAmount = document.getElementById('res-adjusted-amount') as HTMLSpanElement;
  const resStatement = document.getElementById('res-statement') as HTMLDivElement;
  const resCumInflation = document.getElementById('res-cum-inflation') as HTMLSpanElement;
  const resStartCpi = document.getElementById('res-start-cpi') as HTMLSpanElement;
  const resEndCpi = document.getElementById('res-end-cpi') as HTMLSpanElement;

  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;

  // Retrieve CPI data defined via vars on window
  const cpiDataset: Array<{ year: number, cpi: number }> = (window as any).cpiHistory || [];

  // ============================================================
  // Functions
  // ============================================================
  const calculateInflation = () => {
    const amount = parseFloat(startAmountIn.value) || 0;
    const startYear = parseInt(startYearSelect.value);
    const endYear = parseInt(endYearSelect.value);

    const startData = cpiDataset.find(d => d.year === startYear);
    const endData = cpiDataset.find(d => d.year === endYear);

    if (!startData || !endData) return;

    const startCpi = startData.cpi;
    const endCpi = endData.cpi;

    // Formula: Adjusted Amount = Amount * (End CPI / Start CPI)
    const adjustedAmount = amount * (endCpi / startCpi);
    const cumulativeRate = ((endCpi - startCpi) / startCpi) * 100;

    resStartCpi.textContent = startCpi.toFixed(3);
    resEndCpi.textContent = endCpi.toFixed(3);
    resAdjustedAmount.textContent = "$" + adjustedAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    resCumInflation.textContent = cumulativeRate.toFixed(1) + "%";

    resStatement.textContent = `A basket of goods costing $${amount.toLocaleString()} in ${startYear} would cost $${adjustedAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })} in ${endYear} due to a cumulative inflation rate of ${cumulativeRate.toFixed(1)}%.`;
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  startAmountIn.addEventListener('input', calculateInflation);
  startYearSelect.addEventListener('change', calculateInflation);
  endYearSelect.addEventListener('change', calculateInflation);

  btnReset.addEventListener('click', () => {
    startAmountIn.value = '100';
    startYearSelect.value = '1980';
    endYearSelect.value = '2026';
    calculateInflation();
  });

  // Initial Calculation
  calculateInflation();
</script>
