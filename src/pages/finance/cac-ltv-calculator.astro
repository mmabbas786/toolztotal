<script>
  // ============================================================
  // DOM Elements
  // ============================================================
  const marketingSpendIn = document.getElementById('marketing-spend') as HTMLInputElement;
  const salesSpendIn = document.getElementById('sales-spend') as HTMLInputElement;
  const newCustomersIn = document.getElementById('new-customers') as HTMLInputElement;

  const arpuIn = document.getElementById('arpu') as HTMLInputElement;
  const grossMarginIn = document.getElementById('gross-margin') as HTMLInputElement;
  const churnIn = document.getElementById('churn-rate') as HTMLInputElement;

  const resCac = document.getElementById('res-cac') as HTMLSpanElement;
  const resLtv = document.getElementById('res-ltv') as HTMLSpanElement;
  const resRatio = document.getElementById('res-ratio') as HTMLSpanElement;
  const resRatioDesc = document.getElementById('res-ratio-desc') as HTMLParagraphElement;
  const ratioBox = document.getElementById('ratio-box') as HTMLDivElement;

  const resPayback = document.getElementById('res-payback') as HTMLSpanElement;
  const resLifetime = document.getElementById('res-lifetime') as HTMLSpanElement;

  const btnReset = document.getElementById('btn-reset') as HTMLButtonElement;

  // ============================================================
  // Functions
  // ============================================================
  const calculateSaaSMetrics = () => {
    const marketing = parseFloat(marketingSpendIn.value) || 0;
    const sales = parseFloat(salesSpendIn.value) || 0;
    const customers = parseFloat(newCustomersIn.value) || 0;

    const arpu = parseFloat(arpuIn.value) || 0;
    const margin = (parseFloat(grossMarginIn.value) || 0) / 100;
    const churn = (parseFloat(churnIn.value) || 0) / 100;

    // 1. CAC calculation
    const cac = customers > 0 ? (marketing + sales) / customers : 0;
    resCac.textContent = "$" + cac.toFixed(2);

    // 2. LTV calculation
    const monthlyGrossProfit = arpu * margin;
    const ltv = churn > 0 ? monthlyGrossProfit / churn : 0;
    resLtv.textContent = "$" + ltv.toFixed(2);

    // 3. Ratio calculation
    const ratio = cac > 0 ? ltv / cac : 0;
    resRatio.textContent = ratio.toFixed(1) + "x";

    // 4. Payback period
    const payback = monthlyGrossProfit > 0 ? cac / monthlyGrossProfit : 0;
    resPayback.textContent = payback.toFixed(1) + " months";

    // 5. Estimated customer lifetime
    const lifetime = churn > 0 ? 1 / churn : 0;
    resLifetime.textContent = lifetime.toFixed(1) + " months";

    // Style Ratio Box and set descriptions based on SaaS benchmarks
    if (ratio >= 3.0) {
      ratioBox.className = "p-6 bg-emerald-500/5 border border-emerald-500/20 rounded-lg text-center space-y-1 shadow-lvl1";
      resRatio.className = "text-4xl md:text-5xl font-black text-emerald-500 font-sans block";
      resRatioDesc.textContent = "🏆 Excellent! Your LTV:CAC ratio exceeds the healthy SaaS benchmark of 3.0x.";
    } else if (ratio >= 1.5) {
      ratioBox.className = "p-6 bg-yellow-500/5 border border-yellow-500/20 rounded-lg text-center space-y-1 shadow-lvl1";
      resRatio.className = "text-4xl md:text-5xl font-black text-yellow-600 dark:text-yellow-500 font-sans block";
      resRatioDesc.textContent = "⚠️ Fair. A ratio between 1.5x and 3.0x is average, but optimizing churn or margins is recommended.";
    } else {
      ratioBox.className = "p-6 bg-red-500/5 border border-red-500/20 rounded-lg text-center space-y-1 shadow-lvl1";
      resRatio.className = "text-4xl md:text-5xl font-black text-red-500 font-sans block";
      resRatioDesc.textContent = "🚨 Warning. Your ratio is under 1.5x, suggesting unsustainable acquisition costs relative to retention.";
    }
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  [marketingSpendIn, salesSpendIn, newCustomersIn, arpuIn, grossMarginIn, churnIn].forEach(inp => {
    inp.addEventListener('input', calculateSaaSMetrics);
  });

  btnReset.addEventListener('click', () => {
    marketingSpendIn.value = '10000';
    salesSpendIn.value = '5000';
    newCustomersIn.value = '150';
    arpuIn.value = '100';
    grossMarginIn.value = '80';
    churnIn.value = '3.5';
    calculateSaaSMetrics();
  });

  // Initial Calculation
  calculateSaaSMetrics();
</script>
