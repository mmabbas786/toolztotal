---
import Layout from "../../layouts/Layout.astro";
import ContentFooter from "../../components/ContentFooter.astro";
import Sources from "../../components/Sources.astro";
import DisclaimerBanner from "../../components/DisclaimerBanner.astro";
import ToolSchema from "../../components/ToolSchema.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RelatedTools from "../../components/RelatedTools.astro";

const autoLoanFaqs = [
  {
    question: "What is a good APR for an auto loan?",
    answer:
      "New car loans typically run 5–7% for excellent credit and 10–15% for fair credit. Used car loans run 7–10% for excellent credit and 15–25% for fair credit. Credit union loans often run 1–2% lower than banks.",
  },
  {
    question: "Should I put money down on a car?",
    answer:
      "A 20% down payment is ideal. It reduces the amount you finance, lowers monthly payments, reduces total interest paid, and protects against depreciation. If you can't reach 20%, put down enough to avoid being upside-down on the loan.",
  },
  {
    question: "What is the average auto loan term?",
    answer:
      "New cars: 60–72 months is most common. Used cars: 48–60 months. Longer terms such as 84 months lower monthly payments but cost significantly more in interest and increase the risk of being upside-down.",
  },
  {
    question: "How much will my auto loan cost in total?",
    answer:
      "Total cost equals the sum of all payments minus the loan amount — that is your total interest paid. A $30,000 loan at 7% for 60 months costs roughly $6,000 in interest.",
  },
  {
    question: "Can I pay off my auto loan early?",
    answer:
      "Yes. Check for prepayment penalties first. Most auto loans allow early payoff without penalty, which saves the remaining interest. Call your lender for a current payoff quote.",
  },
];
---

<Layout
  title="Auto Loan Calculator - Monthly Payment & Amortization | ToolzTotal"
  description="Calculate your auto loan monthly payment, total interest, and full amortization schedule. Factor in down payment, trade-in, sales tax, and fees."
  canonicalUrl="https://toolztotal.com/finance/auto-loan-calculator"
>
  <ToolSchema
    toolName="Auto Loan Calculator"
    toolSlug="auto-loan-calculator"
    categoryName="Finance & Loans"
    categorySlug="finance"
    description="Calculate your auto loan monthly payment, total interest, and full amortization schedule. Factor in down payment, trade-in, sales tax, and fees."
    faqs={autoLoanFaqs}
  />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categorySlug="finance"
      categoryName="Finance & Loans"
      toolName="Auto Loan Calculator"
      toolSlug="auto-loan-calculator"
    />

    <DisclaimerBanner category="finance" />

    <div class="max-w-4xl mb-12">
      <div
        class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider"
          >Free Tool</span
        >
      </div>
      <h1
        class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty"
      >
        Auto Loan Calculator
      </h1>
      <p
        class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl"
      >
        Estimate your monthly car payment, total interest, and full amortization
        schedule. Include your down payment, trade-in, sales tax, and fees to
        see the real cost of financing.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      <form
        id="auto-form"
        class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6"
        onsubmit="return false;"
      >
        <div>
          <h2
            class="text-sm font-mono uppercase tracking-wider text-mute border-b border-hairline pb-2 mb-4"
          >
            Vehicle & Loan
          </h2>
          <div class="space-y-4">
            <div>
              <label
                for="vehicle-price"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Vehicle Price ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="vehicle-price"
                  value="30,000"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 30,000"
                  inputmode="decimal"
                  required
                />
              </div>
            </div>

            <div>
              <label
                for="down-payment"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Down Payment ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="down-payment"
                  value="6,000"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 6,000"
                  inputmode="decimal"
                />
              </div>
            </div>

            <div>
              <label
                for="trade-in"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Trade-In Value ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="trade-in"
                  value="0"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 4,000"
                  inputmode="decimal"
                />
              </div>
            </div>

            <div>
              <label
                for="loan-amount"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Loan Amount ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="loan-amount"
                  value="24,000"
                  disabled
                  class="w-full h-10 pl-7 pr-3 bg-canvas-soft-2 border border-hairline rounded-md text-sm font-sans text-ink tabular-nums opacity-70"
                />
              </div>
              <p class="text-[10px] text-mute font-sans mt-1">
                Auto-calculated: price − down − trade-in + tax + fees.
              </p>
            </div>

            <div>
              <label
                for="interest-rate"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Interest Rate (APR %)</label
              >
              <div class="relative">
                <input
                  type="text"
                  id="interest-rate"
                  value="7.0"
                  class="w-full h-10 pl-3 pr-8 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 7.0"
                  inputmode="decimal"
                  required
                />
                <span
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >%</span
                >
              </div>
            </div>

            <div>
              <label
                for="loan-term"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Loan Term (Months)</label
              >
              <select
                id="loan-term"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <option value="36">36 months</option>
                <option value="48">48 months</option>
                <option value="60" selected>60 months</option>
                <option value="72">72 months</option>
                <option value="84">84 months</option>
              </select>
            </div>

            <div>
              <label
                for="sales-tax"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Sales Tax (%)</label
              >
              <div class="relative">
                <input
                  type="text"
                  id="sales-tax"
                  value="0"
                  class="w-full h-10 pl-3 pr-8 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 7"
                  inputmode="decimal"
                />
                <span
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >%</span
                >
              </div>
            </div>

            <div>
              <label
                for="fees"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Fees ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="fees"
                  value="0"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 500"
                  inputmode="decimal"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-2 pt-4">
          <button
            type="submit"
            id="calculate-btn"
            class="w-full h-10 bg-primary hover:bg-primary-strong text-on-primary font-sans font-bold text-sm rounded-lg transition-colors cursor-pointer shadow-lvl2 text-center"
          >
            Calculate Auto Loan
          </button>
          <button
            type="button"
            id="reset-btn"
            class="w-full py-2 text-mute hover:text-ink font-sans text-xs transition-colors cursor-pointer text-center"
          >
            Reset Form
          </button>
        </div>
      </form>
      <div class="lg:col-span-7 space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 flex flex-col justify-between"
          >
            <div>
              <h3
                class="text-xs font-mono uppercase tracking-wider text-mute mb-1"
              >
                Monthly Payment
              </h3>
              <p
                class="text-3xl font-bold font-sans text-ink tracking-tight tabular-nums"
                id="monthly-payment-val"
              >
                $0.00
              </p>
            </div>
            <div class="mt-4 pt-3 border-t border-hairline">
              <p class="text-[11px] font-sans text-body leading-normal">
                Principal + interest
              </p>
              <p class="text-[10px] font-mono text-mute mt-0.5">
                Excludes insurance & tax
              </p>
            </div>
          </div>

          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 flex flex-col justify-between"
          >
            <div>
              <h3
                class="text-xs font-mono uppercase tracking-wider text-mute mb-1"
              >
                Total Loan Amount
              </h3>
              <p
                class="text-3xl font-bold font-sans text-ink tracking-tight tabular-nums"
                id="loan-amount-val"
              >
                $0.00
              </p>
            </div>
            <div class="mt-4 pt-3 border-t border-hairline">
              <p class="text-[11px] font-sans text-body leading-normal">
                After tax & fees
              </p>
              <p class="text-[10px] font-mono text-mute mt-0.5">
                Amount financed
              </p>
            </div>
          </div>

          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Total Interest Paid
            </h3>
            <p
              class="text-2xl font-bold font-sans text-rose-600 tracking-tight tabular-nums"
              id="total-interest-val"
            >
              $0.00
            </p>
          </div>

          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Total Cost
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight tabular-nums"
              id="total-cost-val"
            >
              $0.00
            </p>
          </div>

          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 sm:col-span-2"
          >
            <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">
              Loan-to-Value (LTV) Ratio
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight tabular-nums"
              id="ltv-val"
            >
              0.0%
            </p>
            <p class="text-[10px] font-mono text-mute mt-1">
              Loan amount ÷ vehicle price (incl. tax)
            </p>
          </div>
        </div>

        <div
          class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-4"
        >
          <h3
            class="text-sm font-mono uppercase tracking-wider text-mute border-b border-hairline pb-2"
          >
            Amortization Schedule
          </h3>
          <div class="overflow-x-auto max-h-96 overflow-y-auto">
            <table class="w-full text-left border-collapse text-xs font-sans">
              <thead class="sticky top-0 bg-canvas">
                <tr
                  class="border-b border-hairline font-mono text-mute uppercase text-[10px] tracking-wider"
                >
                  <th class="py-2.5 px-3">Month</th>
                  <th class="py-2.5 px-3 text-right">Payment</th>
                  <th class="py-2.5 px-3 text-right">Principal</th>
                  <th class="py-2.5 px-3 text-right">Interest</th>
                  <th class="py-2.5 px-3 text-right">Balance</th>
                </tr>
              </thead>
              <tbody
                id="amortization-body"
                class="divide-y divide-hairline text-body tabular-nums"
              >
              </tbody>
            </table>
          </div>
        </div>

        <div
          id="error-panel"
          class="hidden bg-rose-50 dark:bg-rose-950/20 border border-rose-200 dark:border-rose-900 rounded-xl p-4 text-rose-700 dark:text-rose-400 text-xs leading-relaxed font-sans"
        >
        </div>

        <div
          class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl1 space-y-2 text-[11px] font-sans text-mute leading-relaxed"
        >
          <p>
            * <strong>Estimate Only</strong>: This calculator assumes a fixed
            APR and standard amortization. Actual offers depend on credit score,
            lender fees, and whether the rate is simple or precomputed.
          </p>
        </div>
      </div>
    </div>
    <article
      class="mt-20 prose dark:prose-invert max-w-4xl border-t border-hairline pt-16"
    >
      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-6"
      >
        How Auto Loan APR Affects Your Monthly Payment
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          Your annual percentage rate (APR) is the single biggest driver of what
          you pay each month. A small change in rate can mean thousands of
          dollars over the life of the loan.
        </p>
        <div
          class="bg-canvas-soft-2/30 border border-hairline rounded-xl p-4 font-mono text-xs md:text-sm text-ink space-y-1"
        >
          <p>Monthly = P × r(1+r)^n ÷ ((1+r)^n − 1)</p>
          <p class="text-mute text-[10px]">
            P = loan amount, r = monthly rate (APR ÷ 12 ÷ 100), n = months
          </p>
        </div>
        <p>
          On a $30,000 loan for 60 months, dropping the APR from 9% to 5% cuts
          the monthly payment by about $60 and saves over $3,500 in total
          interest.
        </p>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-12 mb-6"
      >
        How Much Should You Put Down on a Car?
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          A 20% down payment is the standard recommendation. It does four
          things at once:
        </p>
        <ul class="list-disc pl-5 space-y-2">
          <li>Reduces the amount you finance, lowering your monthly payment.</li>
          <li>Cuts total interest paid over the loan term.</li>
          <li>Protects against depreciation so you aren't upside-down.</li>
          <li>Often qualifies you for a better interest rate.</li>
        </ul>
        <p>
          New cars lose roughly 20% of their value in the first year. Without a
          solid down payment, you can owe more than the car is worth almost
          immediately.
        </p>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-12 mb-6"
      >
        Auto Loan Amortization: How It Works
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          Each payment is split between interest (what the lender earns) and
          principal (what reduces your balance). Early payments are mostly
          interest; later payments are mostly principal. The amortization
          schedule above shows this shift month by month.
        </p>
        <p>
          Because interest is calculated on the remaining balance, paying extra
          toward principal early shortens the loan and saves substantial
          interest.
        </p>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-12 mb-6"
      >
        New Car vs Used Car Loan Rates
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <p>
          Lenders view used cars as riskier collateral, so rates are higher. For
          excellent credit, new-car loans average 5–7% while used-car loans
          average 7–10%. For fair credit, new loans run 10–15% and used loans
          15–25%. Credit unions frequently beat banks by 1–2%.
        </p>
      </div>

      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mt-12 mb-6"
      >
        How to Get the Best Auto Loan Rate
      </h2>
      <div
        class="text-body text-sm md:text-base font-sans leading-relaxed space-y-6"
      >
        <ul class="list-disc pl-5 space-y-2">
          <li>
            <strong>Check your credit score</strong> before shopping and fix
            errors on your report.
          </li>
          <li>
            <strong>Get pre-approved</strong> at a bank or credit union so you
            can negotiate at the dealership.
          </li>
          <li>
            <strong>Shorten the term</strong> — 48–60 months typically carry
            lower rates than 72–84.
          </li>
          <li>
            <strong>Make a larger down payment</strong> to reduce the
            loan-to-value ratio.
          </li>
        </ul>
      </div>
    </article>

    <Sources
      sources={[
        {
          label: "Federal Reserve — G.20 Finance Companies Auto Loan Rates",
          url: "https://www.federalreserve.gov/releases/g20/",
        },
        {
          label: "Experian — State of the Automotive Finance Market",
          url: "https://www.experian.com/consumer-automotive/automotive-financial-services",
        },
        {
          label: "Consumer Financial Protection Bureau — Auto Loan Guide",
          url: "https://www.consumerfinance.gov/consumer-tools/auto-loans/",
        },
        {
          label: "NADA — National Automobile Dealers Association",
          url: "https://www.nada.org/",
        },
      ]}
    />

    <section class="mt-20 pt-16 border-t border-hairline max-w-4xl">
      <h2
        class="text-2xl md:text-3xl font-bold tracking-tight text-ink font-sans mb-8 text-pretty"
      >
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {
          autoLoanFaqs.map((faq, index) => (
            <div class="border border-hairline rounded-lg bg-canvas overflow-hidden shadow-lvl1">
              <button
                type="button"
                class="faq-toggle w-full px-6 py-4 flex items-center justify-between text-left font-sans text-sm font-bold text-ink hover:bg-canvas-soft-2 transition-colors cursor-pointer"
                aria-expanded="false"
                id={`faq-btn-${index}`}
              >
                <span>{faq.question}</span>
                <svg
                  class="w-4 h-4 text-mute transition-transform duration-200"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="faq-content hidden border-t border-hairline px-6 py-4 bg-canvas-soft">
                <p class="text-body text-sm font-sans leading-relaxed">
                  {faq.answer}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <RelatedTools categorySlug="finance" toolSlug="auto-loan-calculator" />
  </div>

  <ContentFooter category="finance" />
</Layout>

<script>
  const vehiclePrice = document.getElementById("vehicle-price") as HTMLInputElement;
  const downPayment = document.getElementById("down-payment") as HTMLInputElement;
  const tradeIn = document.getElementById("trade-in") as HTMLInputElement;
  const loanAmount = document.getElementById("loan-amount") as HTMLInputElement;
  const interestRate = document.getElementById("interest-rate") as HTMLInputElement;
  const loanTerm = document.getElementById("loan-term") as HTMLSelectElement;
  const salesTax = document.getElementById("sales-tax") as HTMLInputElement;
  const fees = document.getElementById("fees") as HTMLInputElement;

  const calculateBtn = document.getElementById("calculate-btn");
  const resetBtn = document.getElementById("reset-btn");

  const monthlyPaymentVal = document.getElementById("monthly-payment-val");
  const loanAmountVal = document.getElementById("loan-amount-val");
  const totalInterestVal = document.getElementById("total-interest-val");
  const totalCostVal = document.getElementById("total-cost-val");
  const ltvVal = document.getElementById("ltv-val");
  const amortizationBody = document.getElementById("amortization-body");
  const errorPanel = document.getElementById("error-panel");

  function parseVal(el) {
    const rawVal = el.value.replace(/,/g, "").trim();
    if (rawVal === "") return 0;
    const parsed = parseFloat(rawVal);
    return isNaN(parsed) || parsed < 0 ? 0 : parsed;
  }

  function formatMoney(num) {
    return new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
    }).format(num);
  }

  function round(num, decimals) {
    return Math.round(num * Math.pow(10, decimals)) / Math.pow(10, decimals);
  }

  function monthlyPayment(principal, annualRatePct, months) {
    const r = annualRatePct / 100 / 12;
    if (r === 0) return principal / months;
    const pow = Math.pow(1 + r, months);
    return (principal * r * pow) / (pow - 1);
  }

  function runCalculations() {
    errorPanel.classList.add("hidden");
    errorPanel.textContent = "";

    const price = parseVal(vehiclePrice);
    const down = parseVal(downPayment);
    const trade = parseVal(tradeIn);
    const apr = parseVal(interestRate);
    const term = parseInt(loanTerm.value, 10);
    const taxPct = parseVal(salesTax);
    const feeAmt = parseVal(fees);

    const taxAmount = price * (taxPct / 100);
    let loan = price - down - trade + taxAmount + feeAmt;
    if (loan < 0) loan = 0;

    loanAmount.value = new Intl.NumberFormat("en-US").format(round(loan, 2));

    if (loan <= 0 || term <= 0) {
      errorPanel.classList.remove("hidden");
      errorPanel.textContent =
        "Please enter a valid vehicle price, down payment, and term.";
      return;
    }

    const pmt = monthlyPayment(loan, apr, term);
    let balance = loan;
    let totalInterest = 0;
    const schedule = [];
    const r = apr / 100 / 12;

    for (let m = 1; m <= term; m++) {
      const interest = balance * r;
      let principalPart = pmt - interest;
      let payment = pmt;
      if (principalPart >= balance) {
        principalPart = balance;
        payment = balance + interest;
        balance = 0;
      } else {
        balance -= principalPart;
      }
      totalInterest += interest;
      schedule.push({
        month: m,
        payment: round(payment, 2),
        principal: round(principalPart, 2),
        interest: round(interest, 2),
        balance: round(balance, 2),
      });
      if (balance <= 0) break;
    }

    const totalCost = price + totalInterest + taxAmount + feeAmt;
    const ltv = (loan / (price + taxAmount)) * 100;

    monthlyPaymentVal.textContent = formatMoney(pmt);
    loanAmountVal.textContent = formatMoney(loan);
    totalInterestVal.textContent = formatMoney(totalInterest);
    totalCostVal.textContent = formatMoney(totalCost);
    ltvVal.textContent = round(ltv, 1) + "%";

    amortizationBody.innerHTML = "";
    const display = schedule.slice(0, 60);
    display.forEach((row) => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="py-2.5 px-3">${row.month}</td>
        <td class="py-2.5 px-3 text-right">${formatMoney(row.payment)}</td>
        <td class="py-2.5 px-3 text-right">${formatMoney(row.principal)}</td>
        <td class="py-2.5 px-3 text-right">${formatMoney(row.interest)}</td>
        <td class="py-2.5 px-3 text-right">${formatMoney(row.balance)}</td>
      `;
      amortizationBody.appendChild(tr);
    });
    if (schedule.length > 60) {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td colspan="5" class="py-3 px-3 text-center text-mute text-[10px] font-mono uppercase tracking-wider">
          ... ${schedule.length - 60} more months ...
        </td>
      `;
      amortizationBody.appendChild(tr);
    }
  }

  function formatInputOnBlur(e) {
    const target = e.target;
    const rawVal = target.value.replace(/,/g, "").trim();
    if (rawVal === "") return;
    const parsed = parseFloat(rawVal);
    if (!isNaN(parsed) && parsed >= 0) {
      target.value = new Intl.NumberFormat("en-US").format(parsed);
    }
  }

  [vehiclePrice, downPayment, tradeIn, fees].forEach((input) => {
    input.addEventListener("input", runCalculations);
    input.addEventListener("blur", formatInputOnBlur);
  });
  [interestRate, salesTax, loanTerm].forEach((el) =>
    el.addEventListener("input", runCalculations),
  );

  calculateBtn.addEventListener("click", runCalculations);

  resetBtn.addEventListener("click", () => {
    vehiclePrice.value = "30,000";
    downPayment.value = "6,000";
    tradeIn.value = "0";
    interestRate.value = "7.0";
    loanTerm.value = "60";
    salesTax.value = "0";
    fees.value = "0";
    runCalculations();
  });

  document.querySelectorAll(".faq-toggle").forEach((button) => {
    button.addEventListener("click", () => {
      const content = button.nextElementSibling;
      const chevron = button.querySelector("svg");
      const isHidden = content.classList.toggle("hidden");
      chevron.classList.toggle("rotate-180", !isHidden);
      button.setAttribute("aria-expanded", (!isHidden).toString());
    });
  });

  runCalculations();
</script>