    />

  <ContentFooter category="finance" />
</Layout>

<script>
// @ts-nocheck
  // ============================================================
  // Payroll Tax Calculator — Client-Side Engine
  // Uses 2024 tax year constants (update annually)
  // ============================================================

  // ── Constants ─────────────────────────────────────────────────
  const FICA_SS_RATE = 0.062;
  const FICA_SS_WAGE_BASE = 168_600;
  const FICA_MEDICARE_RATE = 0.0145;

  const STD_DEDUCTION_SINGLE = 14_600;
  const STD_DEDUCTION_MFJ = 29_200;
  const STD_DEDUCTION_HOH = 21_900;

  const ALLOWANCE_VALUE = 4_300;

  const BRACKETS_SINGLE = [
    { rate: 0.10, upTo: 11_600 },
    { rate: 0.12, upTo: 47_150 },
    { rate: 0.22, upTo: 100_525 },
    { rate: 0.24, upTo: 191_950 },
    { rate: 0.32, upTo: 243_725 },
    { rate: 0.35, upTo: 609_350 },
    { rate: 0.37, upTo: Infinity },
  ];

  const BRACKETS_MFJ = [
    { rate: 0.10, upTo: 23_200 },
    { rate: 0.12, upTo: 94_300 },
    { rate: 0.22, upTo: 201_050 },
    { rate: 0.24, upTo: 383_900 },
    { rate: 0.32, upTo: 487_450 },
    { rate: 0.35, upTo: 731_200 },
    { rate: 0.37, upTo: Infinity },
  ];

  const BRACKETS_HOH = [
    { rate: 0.10, upTo: 16_550 },
    { rate: 0.12, upTo: 63_100 },
    { rate: 0.22, upTo: 100_500 },
    { rate: 0.24, upTo: 191_950 },
    { rate: 0.32, upTo: 243_700 },
    { rate: 0.35, upTo: 609_350 },
    { rate: 0.37, upTo: Infinity },
  ];

  // ── DOM References ───────────────────────────────────────────
  const grossSalaryInput = document.getElementById('gross-salary');
  const payFreqSelect = document.getElementById('pay-frequency');
  const filingStatusSelect = document.getElementById('filing-status');
  const w4AllowancesInput = document.getElementById('w4-allowances');
  const k401PctInput = document.getElementById('k401-pct');
  const insurancePpInput = document.getElementById('insurance-pp');
  const fsaPpInput = document.getElementById('fsa-pp');
  const stateSelect = document.getElementById('state-select');
  const calculateBtn = document.getElementById('calculate-btn');

  const resultNetAnnual = document.getElementById('result-net-annual');
  const resultPerPeriod = document.getElementById('result-per-period');
  const resultGrossPp = document.getElementById('result-gross-pp');
  const resultNetPp = document.getElementById('result-net-pp');
  const resultAnnualGross = document.getElementById('result-annual-gross');

  // Breakdown elements
  const brkFedTax = document.getElementById('brk-fed-tax');
  const brkSsTax = document.getElementById('brk-ss-tax');
  const brkMedicareTax = document.getElementById('brk-medicare-tax');
  const brk401k = document.getElementById('brk-401k');
  const brkInsurance = document.getElementById('brk-insurance');
  const brkFsa = document.getElementById('brk-fsa');
  const brkTotalDeductions = document.getElementById('brk-total-deductions');
  const brkNetPay = document.getElementById('brk-net-pay');

  // Donut chart paths (7 segments + bg)
  const donutBg = document.getElementById('donut-bg');
  const donutFedTax = document.getElementById('donut-fed-tax');
  const donutSs = document.getElementById('donut-ss');
  const donutMedicare = document.getElementById('donut-medicare');
  const donut401k = document.getElementById('donut-401k');
  const donutInsurance = document.getElementById('donut-insurance');
  const donutFsa = document.getElementById('donut-fsa');
  const donutNetPay = document.getElementById('donut-net-pay');
  const donutLabel = document.getElementById('donut-label');

  // Legend visibility
  const legend401k = document.getElementById('legend-401k');
  const legendInsurance = document.getElementById('legend-insurance');
  const legendFsa = document.getElementById('legend-fsa');

  // ── Helpers ──────────────────────────────────────────────────
  const fmt = (n) => '$' + Math.round(n).toLocaleString('en-US');

  const calcBracketTax = (taxableIncome, brackets) => {
    let tax = 0;
    let prev = 0;
    for (const b of brackets) {
      if (taxableIncome <= prev) break;
      const slice = Math.min(taxableIncome, b.upTo) - prev;
      tax += slice * b.rate;
      prev = b.upTo;
    }
    return tax;
  };

  const getBrackets = (status) => {
    if (status === 'mfj') return BRACKETS_MFJ;
    if (status === 'hoh') return BRACKETS_HOH;
    return BRACKETS_SINGLE;
  };

  const getStdDeduction = (status) => {
    if (status === 'mfj') return STD_DEDUCTION_MFJ;
    if (status === 'hoh') return STD_DEDUCTION_HOH;
    return STD_DEDUCTION_SINGLE;
  };

  const getPayFreqLabel = (val) => {
    const map = { '52': 'Weekly', '26': 'Bi-Weekly', '24': 'Semi-Monthly', '12': 'Monthly' };
    return map[val] || 'Bi-Weekly';
  };

  // ── Core Calculation ─────────────────────────────────────────
  const calculate = () => {
    const salary = Math.max(0, parseFloat(grossSalaryInput.value) || 0);
    const periods = parseInt(payFreqSelect.value) || 26;
    const filingStatus = filingStatusSelect.value;
    const allowances = Math.max(0, Math.min(10, parseInt(w4AllowancesInput.value) || 0));
    const k401Pct = Math.max(0, Math.min(100, parseFloat(k401PctInput.value) || 0));
    const insurancePP = Math.max(0, parseFloat(insurancePpInput.value) || 0);
    const fsaPP = Math.max(0, parseFloat(fsaPpInput.value) || 0);

    // Pre-tax deductions
    const k401Annual = salary * (k401Pct / 100);
    const insuranceAnnual = insurancePP * periods;
    const fsaAnnual = fsaPP * periods;
    const preTaxTotal = k401Annual + insuranceAnnual + fsaAnnual;

    // Adjusted gross income (used for FICA and fed tax calculation)
    // In this model, all pre-tax deductions reduce AGI for both FICA and income tax
    const adjustedGross = Math.max(0, salary - preTaxTotal);

    // ── Federal Income Tax ─────────────────────────────────────
    const standardDeduction = getStdDeduction(filingStatus);
    const allowanceReduction = allowances * ALLOWANCE_VALUE;
    const taxableIncome = Math.max(0, adjustedGross - standardDeduction - allowanceReduction);
    const brackets = getBrackets(filingStatus);
    const federalTax = calcBracketTax(taxableIncome, brackets);

    // ── FICA Taxes ─────────────────────────────────────────────
    const ssTax = Math.min(adjustedGross, FICA_SS_WAGE_BASE) * FICA_SS_RATE;
    const medicareTax = adjustedGross * FICA_MEDICARE_RATE;

    // ── Totals ──────────────────────────────────────────────────
    const ficaTotal = ssTax + medicareTax;
    const totalDeductions = federalTax + ficaTotal + preTaxTotal;
    const netAnnual = Math.max(0, salary - totalDeductions);

    // Per-period amounts
    const grossPP = salary / periods;
    const netPP = netAnnual / periods;

    // ── Update DOM ─────────────────────────────────────────────
    resultNetAnnual.textContent = fmt(netAnnual);
    resultPerPeriod.innerHTML = 'Per Pay Period (' + getPayFreqLabel(payFreqSelect.value) + '): <span class="font-semibold text-ink tabular-nums">' + fmt(netPP) + '</span>';
    resultGrossPp.textContent = fmt(grossPP);
    resultNetPp.textContent = fmt(netPP);
    resultAnnualGross.textContent = fmt(salary);

    // Breakdown
    brkFedTax.textContent = fmt(federalTax);
    brkSsTax.textContent = fmt(ssTax);
    brkMedicareTax.textContent = fmt(medicareTax);
    brk401k.textContent = fmt(k401Annual);
    brkInsurance.textContent = fmt(insuranceAnnual);
    brkFsa.textContent = fmt(fsaAnnual);
    brkTotalDeductions.textContent = fmt(totalDeductions);
    brkNetPay.textContent = fmt(netAnnual);

    // Show/hide zero deduction rows
    const hideRow = (id, val) => {
      const el = document.getElementById(id);
      if (el) el.style.display = val > 0 ? 'flex' : 'none';
    };
    hideRow('brk-401k-row', k401Annual);
    hideRow('brk-insurance-row', insuranceAnnual);
    hideRow('brk-fsa-row', fsaAnnual);

    // Legend visibility
    const hideLegend = (id, val) => {
      const el = document.getElementById(id);
      if (el) el.style.display = val > 0 ? 'flex' : 'none';
    };
    hideLegend('legend-401k', k401Annual);
    hideLegend('legend-insurance', insuranceAnnual);
    hideLegend('legend-fsa', fsaAnnual);

    // ── Draw Donut Chart ──────────────────────────────────────
    drawDonut(federalTax, ssTax, medicareTax, k401Annual, insuranceAnnual, fsaAnnual, netAnnual, salary);
  };

  // ── Donut Chart (semicircle, 7 segments) ────────────────────
  const drawDonut = (fedTax, ssTax, medicareTax, k401, insurance, fsa, netPay, salary) => {
    const total = fedTax + ssTax + medicareTax + k401 + insurance + fsa + netPay;
    if (total <= 0) return;

    const takeHomePct = ((netPay / salary) * 100).toFixed(1);
    donutLabel.textContent = takeHomePct + '%';

    // SVG semicircle: center (100,110), radius 80
    // Arc from (20,110) to (180,110)
    // Half-circumference = PI * 80 = 251.3
    const arcLen = Math.PI * 80;

    // Build segments array (value, element)
    const segments = [
      { val: fedTax, el: donutFedTax },
      { val: ssTax, el: donutSs },
      { val: medicareTax, el: donutMedicare },
      { val: k401, el: donut401k },
      { val: insurance, el: donutInsurance },
      { val: fsa, el: donutFsa },
      { val: netPay, el: donutNetPay },
    ];

    let offset = 0;
    for (const seg of segments) {
      const len = (seg.val / total) * arcLen;
      if (seg.val > 0) {
        seg.el.style.strokeDasharray = Math.max(len, 1) + ' ' + arcLen;
        seg.el.style.strokeDashoffset = '' + (-offset);
        seg.el.classList.remove('hidden');
      } else {
        seg.el.classList.add('hidden');
      }
      offset += len;
    }

    // Background: full arc
    donutBg.style.strokeDasharray = arcLen + ' ' + arcLen;
    donutBg.style.strokeDashoffset = '0';
  };

  // ── Attach Event Listeners ──────────────────────────────────
  calculateBtn.addEventListener('click', calculate);

  // Live recalc on change/input for all inputs
  const inputElements = [
    grossSalaryInput, payFreqSelect, filingStatusSelect,
    w4AllowancesInput, k401PctInput, insurancePpInput,
    fsaPpInput, stateSelect,
  ];

  inputElements.forEach((el) => {
    if (!el) return;
    el.addEventListener('change', calculate);
    if (el.tagName === 'INPUT') el.addEventListener('input', calculate);
  });

  // ── Keyboard Support: Enter triggers calculate ──────────────
  const keyHandler = (e) => {
    if (e.key === 'Enter') {
      calculate();
      e.preventDefault();
    }
  };
  inputElements.forEach((el) => {
    if (el && el.tagName === 'INPUT') {
      el.addEventListener('keydown', keyHandler);
    }
  });

  // ── Accessibility: announce results on update ───────────────
  const resultsSection = document.getElementById('results-section');
  if (resultsSection) {
    resultsSection.setAttribute('aria-live', 'polite');
    resultsSection.setAttribute('aria-atomic', 'true');
  }

  // ── Input validation helpers ────────────────────────────────
  const enforceRange = (input, min, max) => {
    input.addEventListener('blur', () => {
      let val = parseFloat(input.value);
      if (isNaN(val)) val = min;
      input.value = Math.max(min, Math.min(max, val));
      calculate();
    });
  };
  enforceRange(grossSalaryInput, 0, 9_999_999);
  enforceRange(w4AllowancesInput, 0, 10);
  enforceRange(k401PctInput, 0, 100);
  enforceRange(insurancePpInput, 0, 50_000);
  enforceRange(fsaPpInput, 0, 10_000);

  // ── Initial Calculation ─────────────────────────────────────
  calculate();
</script>
