---
import Layout from '../../layouts/Layout.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const ogMeta = {
  title: "Payroll Tax Calculator - Free Take-Home Pay Estimator | ToolzTotal",
  description: "Free payroll tax calculator — estimate your take-home pay after federal taxes, FICA, and pre-tax deductions. No signup required.",
  url: "https://toolztotal.com/finance/payroll-tax-calculator",
  image: "https://toolztotal.com/og-default.png",
};
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';
import DisclaimerBanner from '../../components/DisclaimerBanner.astro';
---

<Layout
  title="Payroll Tax Calculator - Free Take-Home Pay Estimator | ToolzTotal"
  description="Free payroll tax calculator — estimate your take-home pay after federal taxes, FICA, and pre-tax deductions. No signup required."
>
  <ToolSchema
    toolName="Payroll Tax Calculator"
    toolSlug="payroll-tax-calculator"
    categoryName="Finance & Loans"
    categorySlug="finance"
    description="Free payroll tax calculator — estimate your take-home pay after federal taxes, FICA, and pre-tax deductions. No signup required."
  faqs={[
    { question: "What is FICA?", answer: "FICA (Federal Insurance Contributions Act) is the U.S. payroll tax that funds Social Security and Medicare. Employees pay 6.2% for Social Security (up to the $168,600 wage base) and 1.45% for Medicare (no cap). Employers match these amounts, making the total contribution 15.3% on the first $168,600 of wages. FICA is separate from federal income tax and is required by law for all W-2 employees." },
    { question: "How is federal income tax withheld from my paycheck?", answer: "Employers use your Form W-4 selections — filing status, dependents, and additional withholding — to determine your withholding amount. They apply the IRS progressive tax brackets to your estimated annual income and divide by your number of pay periods. The goal is to withhold approximately the right amount so that your total withholding equals your actual tax liability, avoiding a large refund or balance due at tax time." },
    { question: "What is the difference between gross and net pay?", answer: "Gross pay is your total earnings before any deductions — your salary or hourly wages for the pay period. Net pay (take-home pay) is the amount you actually receive after subtracting all deductions, including federal income tax, Social Security, Medicare, health insurance, retirement contributions, and other withholdings. The difference between the two can be substantial — typically 20-35% of gross pay depending on your income and benefits. For example, a $75,000 salary with 5% 401(k) contributions, health insurance, and standard withholding may yield around $55,000 in net annual pay — roughly 73% of gross. This calculator shows you exactly how each deduction impacts your bottom line." },
    { question: "How does filing status affect my withholding?", answer: "Your filing status determines your standard deduction amount and which tax brackets apply to your income. Married Filing Jointly offers the largest standard deduction ($29,200 for 2024) and widest tax brackets, resulting in the lowest withholding for a given income. Head of Household falls between Single and MFJ. Using the correct status on your W-4 is essential for accurate withholding — using the wrong status can lead to significant over- or under-withholding. For example, a single filer earning $75,000 falls into the 22% marginal bracket, while a married filer with the same income stays in the 12% bracket — a meaningful difference in tax burden." },
    { question: "Is this payroll calculator a substitute for a CPA?", answer: "No. This tool provides general estimates for educational and informational purposes only — it is not tax, legal, or accounting advice. Actual payroll and tax calculations depend on your complete financial picture, including state and local taxes, credits, deductions, investment income, and other factors this calculator cannot account for. Always consult a licensed CPA or tax attorney for personalized advice. Verify all current tax figures at irs.gov ." },
    { question: "What is the difference between FICA taxes and Federal Income Tax?", answer: "FICA taxes are flat-rate payroll taxes that fund Social Security (6.2%) and Medicare (1.45%), split between employers and employees. Federal Income Tax is a progressive tax based on your tax bracket and W-4 filings." },
    { question: "What is the FICA tax cap for Social Security contributions?", answer: "Social Security taxes are subject to a wage base limit ($168,600 for the tax year 2024). Any earnings above this limit are not subject to the 6.2% Social Security tax, though Medicare tax has no wage limit." },
    { question: "Who is responsible for paying Federal Unemployment (FUTA) taxes?", answer: "FUTA (and state-level SUTA) taxes are paid solely by the employer to fund unemployment compensation programs. These taxes are not deducted from the employee's gross paycheck." },
    { question: "What are pre-tax deductions and how do they affect payroll calculations?", answer: "Pre-tax deductions are allocations (like 401(k) contributions, HSA savings, or health insurance premiums) subtracted from your gross wages before taxes are calculated, lowering your overall tax liability." },
    { question: "How does the W-4 form influence tax withholding?", answer: "The Form W-4 tells your employer how much federal income tax to withhold from your pay based on factors like filing status, dependents, and multiple jobs. Filing a new W-4 adjustments helps prevent tax refund surprises." }
  ]}
  />

  <meta slot="head" property="og:title" content={ogMeta.title} />
  <meta slot="head" property="og:description" content={ogMeta.description} />
  <meta slot="head" property="og:url" content={ogMeta.url} />
  <meta slot="head" property="og:image" content={ogMeta.image} />
  <meta slot="head" name="twitter:card" content="summary_large_image" />
  <meta slot="head" name="twitter:title" content={ogMeta.title} />
  <meta slot="head" name="twitter:description" content={ogMeta.description} />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categoryName="Finance & Loans"
      categorySlug="finance"
      toolName="Payroll Tax Calculator"
      toolSlug="payroll-tax-calculator"
    />
  <DisclaimerBanner category="finance" />


    <!-- Header -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Payroll Tax Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Estimate your take-home pay after federal income tax, FICA (Social Security & Medicare), and pre-tax deductions. Built for employees who want to understand their net paycheck.
      </p>
    </div>

    <!-- Disclaimer alert bar -->
    <div class="max-w-5xl mb-10 flex items-start gap-3 bg-amber-500/10 border border-amber-500/30 rounded-xl px-5 py-4">
      <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <p class="text-xs font-sans text-amber-700 leading-relaxed">
        <strong>Not tax advice.</strong> This calculator provides general estimates for informational purposes only. Tax rates, wage bases, and thresholds change annually and depend on your full financial situation. This calculator does not account for state or local taxes, tax credits, or itemized deductions. Verify current figures at <a href="https://www.irs.gov" target="_blank" rel="noopener noreferrer" class="underline font-semibold hover:text-amber-900 transition-colors">IRS.gov ↗</a> and consult a licensed tax professional before filing.
      </p>
    </div>

    <!-- Main Calculator Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start max-w-7xl">

      <!-- LEFT: Inputs -->
      <div class="lg:col-span-5 space-y-6">

        <!-- Input Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
          <div class="border-b border-hairline pb-4">
            <h2 class="text-base font-bold text-ink font-sans">Employment Details</h2>
            <p class="text-xs text-mute font-sans mt-1">Enter your salary and deduction information below.</p>
          </div>

          <!-- Gross Annual Salary -->
          <div>
            <label for="gross-salary" class="block text-xs font-mono uppercase text-mute mb-2">Gross Annual Salary</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
              <input
                type="number"
                id="gross-salary"
                value="75000"
                min="0"
                step="1000"
                class="w-full h-11 pl-7 pr-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Pay Frequency -->
          <div>
            <label for="pay-frequency" class="block text-xs font-mono uppercase text-mute mb-2">Pay Frequency</label>
            <select
              id="pay-frequency"
              class="w-full h-11 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
            >
              <option value="52">Weekly (52)</option>
              <option value="26" selected>Bi-Weekly (26)</option>
              <option value="24">Semi-Monthly (24)</option>
              <option value="12">Monthly (12)</option>
            </select>
          </div>

          <!-- Filing Status -->
          <div>
            <label for="filing-status" class="block text-xs font-mono uppercase text-mute mb-2">Filing Status</label>
            <select
              id="filing-status"
              class="w-full h-11 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
            >
              <option value="single" selected>Single</option>
              <option value="mfj">Married Filing Jointly</option>
              <option value="hoh">Head of Household</option>
            </select>
          </div>

          <!-- W-4 Allowances -->
          <div>
            <label for="w4-allowances" class="block text-xs font-mono uppercase text-mute mb-2">W-4 Allowances</label>
            <input
              type="number"
              id="w4-allowances"
              value="2"
              min="0"
              max="10"
              class="w-full h-11 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              autocomplete="off"
            />
            <p class="text-[10px] font-mono text-mute mt-1.5">Each allowance reduces taxable income by ~$4,300 for withholding purposes.</p>
          </div>

          <!-- Pre-tax Deductions -->
          <div class="border-t border-hairline pt-5 space-y-4">
            <div>
              <p class="text-xs font-mono uppercase text-mute">Pre-tax Deductions</p>
              <p class="text-[10px] font-mono text-mute mt-0.5">These reduce your taxable income for federal income tax.</p>
            </div>

            <!-- 401(k) Contribution -->
            <div>
              <label for="k401-pct" class="block text-xs font-mono uppercase text-mute mb-2">401(k) Contribution (%)</label>
              <div class="relative">
                <input
                  type="number"
                  id="k401-pct"
                  value="0"
                  min="0"
                  max="100"
                  step="1"
                  class="w-full h-11 pr-8 pl-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  autocomplete="off"
                />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
              </div>
            </div>

            <!-- Health Insurance Premium -->
            <div>
              <label for="insurance-pp" class="block text-xs font-mono uppercase text-mute mb-2">Health Insurance Premium ($/pay period)</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
                <input
                  type="number"
                  id="insurance-pp"
                  value="0"
                  min="0"
                  step="10"
                  class="w-full h-11 pl-7 pr-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  autocomplete="off"
                />
              </div>
            </div>

            <!-- FSA Contribution -->
            <div>
              <label for="fsa-pp" class="block text-xs font-mono uppercase text-mute mb-2">FSA Contribution ($/pay period)</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
                <input
                  type="number"
                  id="fsa-pp"
                  value="0"
                  min="0"
                  step="5"
                  class="w-full h-11 pl-7 pr-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  autocomplete="off"
                />
              </div>
            </div>
          </div>

          <!-- State Dropdown -->
          <div class="border-t border-hairline pt-5">
            <label for="state-select" class="block text-xs font-mono uppercase text-mute mb-2">State</label>
            <select
              id="state-select"
              class="w-full h-11 px-3 bg-canvas border border-hairline rounded-lg text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
            >
              <option value="">Select State</option>
              <option value="CA">California</option>
              <option value="TX">Texas</option>
              <option value="NY">New York</option>
              <option value="FL">Florida</option>
              <option value="IL">Illinois</option>
              <option value="PA">Pennsylvania</option>
              <option value="OH">Ohio</option>
            </select>
            <p class="text-[10px] font-mono text-amber-600 mt-1.5">State tax not included in calculation. This calculator estimates federal taxes only.</p>
          </div>

          <!-- Calculate Button -->
          <button
            type="button"
            id="calculate-btn"
            class="w-full h-11 bg-primary text-on-primary font-sans font-semibold text-sm rounded-lg hover:bg-primary/90 active:scale-[0.98] transition-all shadow-lvl2 cursor-pointer"
          >
            Calculate Take-Home Pay &rarr;
          </button>
        </div>

        <!-- Rate info card -->
        <div class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl1 space-y-3">
          <h3 class="text-xs font-mono uppercase text-mute tracking-wider">Rates Used (2024)</h3>
          <div class="space-y-2 text-xs font-sans">
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">Social Security (Employee)</span>
              <span class="font-mono font-semibold text-ink">6.2% (up to wage base)</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">Medicare (Employee)</span>
              <span class="font-mono font-semibold text-ink">1.45% (no cap)</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">SS Wage Base</span>
              <span class="font-mono font-semibold text-ink">$168,600</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">Standard Deduction (Single)</span>
              <span class="font-mono font-semibold text-ink">$14,600</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-hairline">
              <span class="text-body">Standard Deduction (MFJ)</span>
              <span class="font-mono font-semibold text-ink">$29,200</span>
            </div>
            <div class="flex justify-between items-center py-1.5">
              <span class="text-body">Standard Deduction (HOH)</span>
              <span class="font-mono font-semibold text-ink">$21,900</span>
            </div>
          </div>
          <p class="text-[9px] font-mono text-mute leading-relaxed pt-1 border-t border-hairline">
            Tax rates and thresholds shown are for 2024; verify current figures at <a href="https://www.irs.gov" target="_blank" rel="noopener noreferrer" class="underline">irs.gov</a>.
          </p>
        </div>

      </div>

      <!-- RIGHT: Results -->
      <div class="lg:col-span-7 space-y-6" id="results-section">

        <!-- Results Panel -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2">

          <!-- Net Annual Pay Display -->
          <div class="text-center pb-6 border-b border-hairline mb-6">
            <p class="text-xs font-mono uppercase text-mute mb-2">Net Annual Take-Home Pay</p>
            <div id="result-net-annual" class="text-4xl md:text-5xl font-bold tracking-tight text-ink font-sans tabular-nums">
              $55,234
            </div>
            <p class="text-sm text-mute font-sans mt-2" id="result-per-period">
              Per Pay Period: <span class="font-semibold text-ink tabular-nums">$2,124</span>
            </p>
          </div>

          <!-- Stats Row -->
          <div class="grid grid-cols-3 gap-4 mb-2">
            <div class="bg-canvas-soft border border-hairline rounded-lg p-4 text-center">
              <p class="text-[10px] font-mono text-mute uppercase mb-1">Gross / Pay Period</p>
              <p class="text-lg font-bold text-ink font-sans tabular-nums" id="result-gross-pp">$2,885</p>
            </div>
            <div class="bg-canvas-soft border border-hairline rounded-lg p-4 text-center">
              <p class="text-[10px] font-mono text-mute uppercase mb-1">Net / Pay Period</p>
              <p class="text-lg font-bold text-emerald-600 font-sans tabular-nums" id="result-net-pp">$2,124</p>
            </div>
            <div class="bg-canvas-soft border border-hairline rounded-lg p-4 text-center">
              <p class="text-[10px] font-mono text-mute uppercase mb-1">Annual Gross</p>
              <p class="text-lg font-bold text-ink font-sans tabular-nums" id="result-annual-gross">$75,000</p>
            </div>
          </div>
        </div>

        <!-- Payroll Breakdown Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2">
          <h3 class="text-xs font-mono uppercase text-mute mb-5">Payroll Breakdown</h3>
          <div class="space-y-0" id="breakdown-list">

            <!-- Federal Income Tax -->
            <div class="flex items-center justify-between py-3 border-b border-hairline">
              <div class="flex items-center gap-3">
                <span class="w-3 h-3 rounded-sm bg-blue-500 shrink-0"></span>
                <span class="text-sm font-sans text-body">Federal Income Tax</span>
              </div>
              <span class="text-sm font-semibold font-sans text-ink tabular-nums" id="brk-fed-tax">$6,617</span>
            </div>

            <!-- Social Security -->
            <div class="flex items-center justify-between py-3 border-b border-hairline">
              <div class="flex items-center gap-3">
                <span class="w-3 h-3 rounded-sm bg-violet-500 shrink-0"></span>
                <span class="text-sm font-sans text-body">Social Security Tax (6.2%)</span>
              </div>
              <span class="text-sm font-semibold font-sans text-ink tabular-nums" id="brk-ss-tax">$4,650</span>
            </div>

            <!-- Medicare -->
            <div class="flex items-center justify-between py-3 border-b border-hairline">
              <div class="flex items-center gap-3">
                <span class="w-3 h-3 rounded-sm bg-emerald-500 shrink-0"></span>
                <span class="text-sm font-sans text-body">Medicare Tax (1.45%)</span>
              </div>
              <span class="text-sm font-semibold font-sans text-ink tabular-nums" id="brk-medicare-tax">$1,088</span>
            </div>

            <!-- 401(k) -->
            <div class="flex items-center justify-between py-3 border-b border-hairline" id="brk-401k-row">
              <div class="flex items-center gap-3">
                <span class="w-3 h-3 rounded-sm bg-amber-500 shrink-0"></span>
                <span class="text-sm font-sans text-body">401(k) Contribution</span>
              </div>
              <span class="text-sm font-semibold font-sans text-ink tabular-nums" id="brk-401k">$0</span>
            </div>

            <!-- Health Insurance -->
            <div class="flex items-center justify-between py-3 border-b border-hairline" id="brk-insurance-row">
              <div class="flex items-center gap-3">
                <span class="w-3 h-3 rounded-sm bg-rose-500 shrink-0"></span>
                <span class="text-sm font-sans text-body">Health Insurance</span>
              </div>
              <span class="text-sm font-semibold font-sans text-ink tabular-nums" id="brk-insurance">$0</span>
            </div>

            <!-- FSA -->
            <div class="flex items-center justify-between py-3 border-b border-hairline" id="brk-fsa-row">
              <div class="flex items-center gap-3">
                <span class="w-3 h-3 rounded-sm bg-cyan-500 shrink-0"></span>
                <span class="text-sm font-sans text-body">FSA Contribution</span>
              </div>
              <span class="text-sm font-semibold font-sans text-ink tabular-nums" id="brk-fsa">$0</span>
            </div>

            <!-- Total Deductions -->
            <div class="flex items-center justify-between py-3 border-b border-hairline">
              <span class="text-sm font-semibold font-sans text-body">Total Deductions</span>
              <span class="text-sm font-bold font-sans text-ink tabular-nums" id="brk-total-deductions">$12,355</span>
            </div>

            <!-- Net Pay (highlighted) -->
            <div class="flex items-center justify-between py-4">
              <span class="text-base font-bold font-sans text-ink">Net Pay</span>
              <span class="text-lg font-bold font-sans text-emerald-600 tabular-nums" id="brk-net-pay">$62,645</span>
            </div>

          </div>
        </div>

        <!-- Donut Chart Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2">
          <h3 class="text-xs font-mono uppercase text-mute mb-4">Where Your Paycheck Goes</h3>
          <div class="relative w-full" aria-hidden="true">
            <svg id="payroll-donut-chart" viewBox="0 0 200 120" class="w-full max-w-[320px] mx-auto h-auto">
              <!-- Background track -->
              <path id="donut-bg" d="M 20,110 A 80,80 0 0,1 180,110" fill="none" stroke-width="18" class="stroke-canvas-soft-2"/>
              <!-- Fed Tax segment -->
              <path id="donut-fed-tax" d="M 20,110 A 80,80 0 0,1 180,110" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-blue-500 transition-all duration-500"/>
              <!-- SS segment -->
              <path id="donut-ss" d="M 20,110 A 80,80 0 0,1 180,110" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-violet-500 transition-all duration-500"/>
              <!-- Medicare segment -->
              <path id="donut-medicare" d="M 20,110 A 80,80 0 0,1 180,110" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-emerald-500 transition-all duration-500"/>
              <!-- 401k segment -->
              <path id="donut-401k" d="M 20,110 A 80,80 0 0,1 180,110" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-amber-500 transition-all duration-500"/>
              <!-- Insurance segment -->
              <path id="donut-insurance" d="M 20,110 A 80,80 0 0,1 180,110" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-rose-500 transition-all duration-500"/>
              <!-- FSA segment -->
              <path id="donut-fsa" d="M 20,110 A 80,80 0 0,1 180,110" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-cyan-500 transition-all duration-500"/>
              <!-- Net Pay segment -->
              <path id="donut-net-pay" d="M 20,110 A 80,80 0 0,1 180,110" fill="none" stroke-width="18" stroke-linecap="round" class="stroke-gray-300 transition-all duration-500"/>
              <!-- Center label -->
              <text x="100" y="98" text-anchor="middle" class="fill-ink font-sans text-[11px] font-bold" id="donut-label">73.7%</text>
              <text x="100" y="112" text-anchor="middle" class="fill-mute font-mono text-[8px]">Take-Home</text>
            </svg>
            <!-- Legend -->
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 justify-center mt-3 text-[10px] font-mono text-mute" id="donut-legend">
              <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-blue-500 inline-block"></span>Fed Tax</div>
              <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-violet-500 inline-block"></span>SS</div>
