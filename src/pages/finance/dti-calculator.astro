---
import Layout from '../../layouts/Layout.astro';
import ContentFooter from '../../components/ContentFooter.astro';
import Sources from '../../components/Sources.astro';
import DisclaimerBanner from '../../components/DisclaimerBanner.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedTools from '../../components/RelatedTools.astro';

const dtiFaqs = [
  {
    question: "What's a good DTI ratio for a mortgage?",
    answer: "For conventional loans, lenders prefer a back-end DTI of 36% or less. FHA loans allow up to 50% with compensating factors like strong credit or significant reserves."
  },
  {
    question: "Does FHA really allow 50% DTI?",
    answer: "Yes, FHA permits back-end DTIs up to 50% in some cases, but most lenders apply stricter limits (typically 43%) unless the borrower has strong compensating factors."
  },
  {
    question: "How do lenders treat deferred student loans?",
    answer: "For FHA loans, lenders may exclude deferred student loans from DTI if there's documented evidence the loans will remain deferred for at least 12 months. Conventional loans typically count 1% of the balance as the monthly payment."
  },
  {
    question: "Can I include my partner's income?",
    answer: "Yes, if your partner is a co-borrower on the loan. Their income, debts, and credit history are all considered together. Non-borrowing partner income is generally not counted."
  },
  {
    question: "Does DTI affect my interest rate?",
    answer: "Indirectly, yes. A higher DTI typically signals higher risk to lenders, which may result in a higher interest rate or require mortgage insurance. Better DTI ratios usually unlock the best rates."
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": dtiFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
});
---

<Layout 
  title="DTI Calculator - Calculate Debt-to-Income Ratio | ToolzTotal"
  description="Calculate your Debt-to-Income (DTI) ratio for mortgage qualification. See front-end and back-end DTI and lender classification instantly."
  canonicalUrl="https://toolztotal.com/finance/dti-calculator"
  faqJsonLd={faqJsonLd}
>
  <ToolSchema
    toolName="DTI Calculator"
    toolSlug="dti-calculator"
    categoryName="Finance & Loans"
    categorySlug="finance"
    description="Calculate your Debt-to-Income (DTI) ratio for mortgage qualification. See front-end and back-end DTI and lender classification."
    faqs={dtiFaqs}
  />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categorySlug="finance"
      categoryName="Finance & Loans"
      toolName="DTI Calculator"
      toolSlug="dti-calculator"
    />

    <DisclaimerBanner category="finance" />

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
