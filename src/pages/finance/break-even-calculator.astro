<script>
// @ts-nocheck
  // ============================================================
  // DOM References
  // ============================================================
  const productNameInput = document.getElementById('product-name') as HTMLInputElement;
  const fixedCostsInput = document.getElementById('fixed-costs') as HTMLInputElement;
  const varCostInput = document.getElementById('var-cost') as HTMLInputElement;
  const priceUnitInput = document.getElementById('price-unit') as HTMLInputElement;
  const salesVolumeInput = document.getElementById('sales-volume') as HTMLInputElement;
  const calculateBtn = document.getElementById('calculate-btn') as HTMLButtonElement;
  const downloadCsvBtn = document.getElementById('download-csv-btn') as HTMLButtonElement;

  const resultBeUnits = document.getElementById('result-be-units') as HTMLElement;
  const resultBeRevenue = document.getElementById('result-be-revenue') as HTMLElement;
  const resultContMargin = document.getElementById('result-cont-margin') as HTMLElement;
  const resultContRatio = document.getElementById('result-cont-ratio') as HTMLElement;
  const resultTotalRevenue = document.getElementById('result-total-revenue') as HTMLElement;
  const resultTotalCosts = document.getElementById('result-total-costs') as HTMLElement;
  const resultProfit = document.getElementById('result-profit') as HTMLElement;
  const volumeBar = document.getElementById('volume-bar') as HTMLDivElement;
  const volumeIndicatorLabel = document.getElementById('volume-indicator-label') as HTMLElement;
  const bepMarkerLabel = document.getElementById('bep-marker-label') as HTMLElement;
  const volMaxLabel = document.getElementById('vol-max-label') as HTMLElement;

  // Chart elements
  const chartGridLines = document.getElementById('chart-grid-lines') as SVGGElement;
  const chartYLabels = document.getElementById('chart-y-labels') as SVGGElement;
  const chartXLabels = document.getElementById('chart-x-labels') as SVGGElement;
  const chartRevenueLine = document.getElementById('chart-revenue-line') as SVGPathElement;
  const chartCostLine = document.getElementById('chart-cost-line') as SVGPathElement;
  const chartFillProfit = document.getElementById('chart-fill-profit') as SVGPathElement;
  const chartFillLoss = document.getElementById('chart-fill-loss') as SVGPathElement;
  const chartBepLine = document.getElementById('chart-bep-line') as SVGLineElement;
  const chartBepLabel = document.getElementById('chart-bep-label') as SVGTextElement;

  // ============================================================
  // Helpers
  // ============================================================
  const fmtCurrency = (n: number) => '$' + Math.round(n).toLocaleString('en-US');
  const fmtUnits = (n: number) => Math.round(n).toLocaleString('en-US') + ' units';
  const fmtUnitCount = (n: number) => Math.round(n).toLocaleString('en-US');

  let lastResults: any = null;

  // ============================================================
  // Core Calculation Engine
  // ============================================================
  const calculate = () => {
    const fixedCosts = Math.max(0, parseFloat(fixedCostsInput.value) || 0);
    const varCost = Math.max(0, parseFloat(varCostInput.value) || 0);
    const price = Math.max(0.01, parseFloat(priceUnitInput.value) || 0.01);
    const volume = Math.max(0, parseFloat(salesVolumeInput.value) || 0);

    const contributionMargin = price - varCost;
    const contributionMarginRatio = contributionMargin / price;
    const breakEvenUnits = contributionMargin > 0 ? fixedCosts / contributionMargin : Infinity;
    const breakEvenRevenue = breakEvenUnits * price;

    const totalRevenue = volume * price;
    const totalCosts = fixedCosts + (volume * varCost);
    const profit = totalRevenue - totalCosts;

    const isProfitable = profit >= 0;
    const volumePct = breakEvenUnits > 0 && breakEvenUnits !== Infinity ? Math.min(100, (volume / breakEvenUnits) * 100) : 0;

    // Cache for CSV
    lastResults = {
      productName: productNameInput.value || 'Product A',
      fixedCosts, varCost, price, volume,
      contributionMargin, contributionMarginRatio,
      breakEvenUnits, breakEvenRevenue,
      totalRevenue, totalCosts, profit,
    };

    // ============================================================
    // Update DOM
    // ============================================================
    resultBeUnits.textContent = breakEvenUnits === Infinity ? 'N/A' : fmtUnits(breakEvenUnits);
    resultBeUnits.className = breakEvenUnits === Infinity
      ? 'text-4xl md:text-5xl font-bold tracking-tight text-rose-600 dark:text-rose-400 font-sans tabular-nums'
      : 'text-4xl md:text-5xl font-bold tracking-tight text-emerald-600 dark:text-emerald-400 font-sans tabular-nums';

    resultBeRevenue.textContent = breakEvenRevenue === Infinity ? 'N/A' : fmtCurrency(breakEvenRevenue);
    resultContMargin.textContent = '$' + contributionMargin.toFixed(2);
    resultContRatio.textContent = (contributionMarginRatio * 100).toFixed(2) + '%';
    resultTotalRevenue.textContent = fmtCurrency(totalRevenue);
    resultTotalCosts.textContent = fmtCurrency(totalCosts);

    resultProfit.textContent = isProfitable ? fmtCurrency(profit) : '-' + fmtCurrency(Math.abs(profit));
    resultProfit.className = isProfitable
      ? 'text-base font-bold text-emerald-600 dark:text-emerald-400 font-sans tabular-nums'
      : 'text-base font-bold text-rose-600 dark:text-rose-400 font-sans tabular-nums';

    // Volume indicator bar
    const barWidth = Math.min(100, volumePct);
    volumeBar.style.width = barWidth + '%';
    volumeBar.className = isProfitable
      ? 'h-full rounded-full bg-emerald-500 transition-all duration-300'
      : 'h-full rounded-full bg-rose-500 transition-all duration-300';

    volumeIndicatorLabel.textContent = breakEvenUnits === Infinity
      ? 'Cannot break even'
      : fmtUnitCount(volume) + ' units (' + Math.round(volumePct) + '% of BEP)';

    bepMarkerLabel.textContent = 'BEP: ' + fmtUnitCount(breakEvenUnits);
    volMaxLabel.textContent = fmtUnitCount(volume);

    // Draw chart
    drawChart(fixedCosts, varCost, price, volume, breakEvenUnits, breakEvenRevenue, contributionMargin);
  };

  // ============================================================
  // Draw SVG Break-Even Chart
  // ============================================================
  const drawChart = (
    fixedCosts: number,
    varCost: number,
    price: number,
    volume: number,
    breakEvenUnits: number,
    breakEvenRevenue: number,
    contributionMargin: number
  ) => {
    const paddingLeft = 50;
    const paddingRight = 25;
    const paddingTop = 15;
    const paddingBottom = 25;
    const chartW = 600 - paddingLeft - paddingRight;
    const chartH = 220 - paddingTop - paddingBottom;

    // Determine max value for Y-axis
    const maxUnits = Math.max(volume, breakEvenUnits * 1.3, 10);
    const maxRevenue = maxUnits * price;
    const maxCost = fixedCosts + (maxUnits * varCost);
    const maxVal = Math.max(maxRevenue, maxCost, 1);

    // Y-axis ticks (5 grid lines)
    const numYTicks = 5;
    let yTicksHtml = '';
    let yLabelsHtml = '';
    for (let i = 0; i <= numYTicks; i++) {
      const val = (maxVal / numYTicks) * i;
      const y = paddingTop + chartH - (val / maxVal) * chartH;
      const isDashed = i > 0 && i < numYTicks;
      yTicksHtml += `<line x1="${paddingLeft}" y1="${y}" x2="${600 - paddingRight}" y2="${y}" class="stroke-hairline dark:stroke-neutral-800" stroke-width="1"${isDashed ? ' stroke-dasharray="3 3"' : ''} />`;
      yLabelsHtml += `<text x="${paddingLeft - 6}" y="${y + 3}" class="fill-mute font-mono text-[8px]" text-anchor="end">${fmtCurrency(val)}</text>`;
    }
    chartGridLines.innerHTML = yTicksHtml;
    chartYLabels.innerHTML = yLabelsHtml;

    // X-axis: 5 ticks
    const numXTicks = 4;
    let xLabelsHtml = '';
    for (let i = 0; i <= numXTicks; i++) {
      const unitVal = (maxUnits / numXTicks) * i;
      const x = paddingLeft + (unitVal / maxUnits) * chartW;
      const label = i === 0 ? '0' : fmtUnitCount(unitVal);
      xLabelsHtml += `<text x="${x}" y="${220 - paddingBottom + 16}" class="fill-mute font-mono text-[8px]" text-anchor="middle">${label}</text>`;
    }
    chartXLabels.innerHTML = xLabelsHtml;

    // Revenue line: from (paddingLeft, costAtZeroRevenue) to (paddingLeft + chartW, costAtMaxRevenue)
    // Revenue at 0 units = 0
    const revY0 = paddingTop + chartH; // bottom (y=0)
    const revYMax = paddingTop + chartH - ((maxUnits * price) / maxVal) * chartH;
    const revLineD = `M ${paddingLeft},${revY0} L ${paddingLeft + chartW},${revYMax}`;
    chartRevenueLine.setAttribute('d', revLineD);

    // Cost line: from (paddingLeft, costAtZero) to (paddingLeft + chartW, costAtMax)
    const costAtZero = fixedCosts;
    const costY0 = paddingTop + chartH - (costAtZero / maxVal) * chartH;
    const costAtMax = fixedCosts + (maxUnits * varCost);
    const costYMax = paddingTop + chartH - (costAtMax / maxVal) * chartH;
    const costLineD = `M ${paddingLeft},${costY0} L ${paddingLeft + chartW},${costYMax}`;
    chartCostLine.setAttribute('d', costLineD);

    // Break-even point
    if (breakEvenUnits > 0 && breakEvenUnits <= maxUnits && contributionMargin > 0) {
      const beX = paddingLeft + (breakEvenUnits / maxUnits) * chartW;
      const beY = paddingTop + chartH - (breakEvenRevenue / maxVal) * chartH;

      chartBepLine.setAttribute('x1', String(beX));
      chartBepLine.setAttribute('y1', String(beY));
      chartBepLine.setAttribute('x2', String(beX));
      chartBepLine.setAttribute('y2', String(paddingTop + chartH));
      chartBepLine.classList.remove('hidden');

      chartBepLabel.setAttribute('x', String(beX));
      chartBepLabel.setAttribute('y', String(beY - 6));
      chartBepLabel.textContent = 'BEP';
      chartBepLabel.classList.remove('hidden');
    } else {
      chartBepLine.classList.add('hidden');
      chartBepLabel.classList.add('hidden');
    }

    // Fill regions: profit (revenue > cost) and loss (cost > revenue)
    // We need to compute the fill polygon for profit and loss regions
    // Profit region: from BEP to max volume, between revenue and cost lines
    // Loss region: from 0 to BEP, between cost and revenue lines

    if (contributionMargin > 0 && breakEvenUnits > 0 && breakEvenUnits <= maxUnits) {
      const beX = paddingLeft + (breakEvenUnits / maxUnits) * chartW;
      const beY = paddingTop + chartH - (breakEvenRevenue / maxVal) * chartH;

      // Profit fill (right of BEP): revenue above cost
      // Starting from BEP going right to max, revenue line, then back along cost line
      let profitFillD = `M ${beX},${beY}`;
      // Revenue points from BEP to max
      const revEndX = paddingLeft + chartW;
      const revEndY = paddingTop + chartH - ((maxUnits * price) / maxVal) * chartH;
      profitFillD += ` L ${revEndX},${revEndY}`;
      // Cost points from max back to BEP
      const costEndY = paddingTop + chartH - ((fixedCosts + (maxUnits * varCost)) / maxVal) * chartH;
      profitFillD += ` L ${revEndX},${costEndY}`;
      profitFillD += ` Z`;
      chartFillProfit.setAttribute('d', profitFillD);
      chartFillProfit.classList.remove('hidden');

      // Loss fill (left of BEP): cost above revenue
      const revY0 = paddingTop + chartH;
      const costY0 = paddingTop + chartH - (fixedCosts / maxVal) * chartH;
      let lossFillD = `M ${paddingLeft},${costY0}`;
      // Cost line from 0 to BEP
      lossFillD += ` L ${beX},${beY}`;
      // Revenue line from BEP back to 0
      lossFillD += ` L ${beX},${beY}`;
      lossFillD += ` L ${paddingLeft},${revY0}`;
      lossFillD += ` Z`;
      chartFillLoss.setAttribute('d', lossFillD);
      chartFillLoss.classList.remove('hidden');
    } else {
      chartFillProfit.classList.add('hidden');
      chartFillLoss.classList.add('hidden');
    }
  };

  // ============================================================
  // CSV Export
  // ============================================================
  const exportCsv = () => {
    if (!lastResults) return;
    const r = lastResults;

    const rows = [
      ['Break-Even Analysis — ToolzTotal.com', ''],
      ['', ''],
      ['Input', 'Value'],
      ['Product / Service Name', r.productName],
      ['Fixed Costs ($)', r.fixedCosts.toFixed(2)],
      ['Variable Cost Per Unit ($)', r.varCost.toFixed(2)],
      ['Price Per Unit ($)', r.price.toFixed(2)],
      ['Sales Volume Projection', r.volume.toString()],
      ['', ''],
      ['Key Metrics', 'Value'],
      ['Contribution Margin Per Unit ($)', r.contributionMargin.toFixed(2)],
      ['Contribution Margin Ratio (%)', (r.contributionMarginRatio * 100).toFixed(2)],
      ['Break-Even Units', Math.ceil(r.breakEvenUnits).toLocaleString('en-US')],
      ['Break-Even Revenue ($)', r.breakEvenRevenue.toFixed(2)],
      ['', ''],
      ['Profit Analysis at Projected Volume', ''],
      ['Total Revenue ($)', r.totalRevenue.toFixed(2)],
      ['Total Costs ($)', r.totalCosts.toFixed(2)],
      ['Profit / Loss ($)', r.profit.toFixed(2)],
      ['', ''],
      ['Volume Scenarios', 'Units', 'Revenue ($)', 'Cost ($)', 'Profit ($)'],
    ];

    // Add scenarios at various volumes
    const scenarios = [0.25, 0.5, 0.75, 1, 1.25, 1.5, 2];
    for (const mult of scenarios) {
      const u = Math.round(r.breakEvenUnits * mult);
      const rev = u * r.price;
      const cost = r.fixedCosts + (u * r.varCost);
      const p = rev - cost;
      rows.push([
        `${Math.round(mult * 100)}% of BEP`,
        u.toString(),
        rev.toFixed(2),
        cost.toFixed(2),
        p.toFixed(2),
      ]);
    }

    rows.push(['', '', '', '', '']);
    rows.push(['DISCLAIMER', 'Estimates only. Not financial advice. Consult a professional.']);

    const csv = rows.map(r => r.map(c => `"${c}"`).join(',')).join('\n');
    const blob = new Blob([csv], { type: 'text/csv' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'break-even-analysis-toolztotal.csv';
    a.click();
    URL.revokeObjectURL(a.href);
  };

  // ============================================================
  // Event Listeners
  // ============================================================
  calculateBtn.addEventListener('click', calculate);

  downloadCsvBtn.addEventListener('click', exportCsv);

  // Live recalc on input change
  const inputs = [fixedCostsInput, varCostInput, priceUnitInput, salesVolumeInput, productNameInput];
  inputs.forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // ============================================================
  // Initial calculation on page load
  // ============================================================
  calculate();
</script>
