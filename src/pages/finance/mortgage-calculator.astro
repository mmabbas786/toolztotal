            <svg class="w-4 h-4 text-mute transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="faq-content hidden border-t border-hairline px-6 py-4 bg-canvas-soft">
            <p class="text-body text-sm font-sans leading-relaxed">
              Discount points are prepaid interest buy-downs. Purchasing one point costs 1% of the loan amount and typically lowers your mortgage interest rate by 0.25%, reducing your monthly payment over the life of the loan.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Related Tools Section -->
    <section class="mt-20 pt-16 border-t border-hairline">
      <h3 class="text-xs font-mono uppercase tracking-wider text-mute mb-8">Related Real Estate & Loan Tools</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        
        <a 
          href="/finance/loan-calculator" 
          class="block bg-canvas border border-hairline hover:border-hairline-strong transition-all duration-200 rounded-lg p-5 hover:shadow-lvl2 shadow-lvl1 group"
        >
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center justify-between">
            Loan Payment Calculator
            <svg class="w-4 h-4 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-2">Calculate payments for personal, auto, or student loans with preset options.</p>
        </a>

        <a 
          href="/real-estate/mortgage-affordability-calculator" 
          class="block bg-canvas border border-hairline hover:border-hairline-strong transition-all duration-200 rounded-lg p-5 hover:shadow-lvl2 shadow-lvl1 group"
        >
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center justify-between">
            Mortgage Affordability Calculator
            <svg class="w-4 h-4 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-2">Determine the maximum home purchase price you can afford based on income and debts.</p>
        </a>

        <a 
          href="/real-estate/mortgage-refinance-calculator" 
          class="block bg-canvas border border-hairline hover:border-hairline-strong transition-all duration-200 rounded-lg p-5 hover:shadow-lvl2 shadow-lvl1 group"
        >
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center justify-between">
            Mortgage Refinance Calculator
            <svg class="w-4 h-4 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-2">See if refinancing your home mortgage will save you money on interest and payments.</p>
        </a>

        <a 
          href="/real-estate/rent-vs-buy-calculator" 
          class="block bg-canvas border border-hairline hover:border-hairline-strong transition-all duration-200 rounded-lg p-5 hover:shadow-lvl2 shadow-lvl1 group"
        >
          <h4 class="text-sm font-bold text-ink font-sans group-hover:text-primary transition-colors flex items-center justify-between">
            Rent vs Buy Calculator
            <svg class="w-4 h-4 text-mute group-hover:text-primary group-hover:translate-x-0.5 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </h4>
          <p class="text-mute text-xs font-sans mt-2">Compare the long-term financial costs of renting versus buying a home.</p>
        </a>

      </div>
    </section>

  </div>

  <!-- Client-Side Calculator Logic Script -->
  <script>
    import { calculateAmortization, getYearlySchedule, generateCsv, getSvgChartPaths } from '../../utils/amortization';

    // 1. DOM Element Cache
    const homePriceInput = document.getElementById('home-price') as HTMLInputElement;
    
    const dpTogglePct = document.getElementById('dp-toggle-pct') as HTMLButtonElement;
    const dpToggleVal = document.getElementById('dp-toggle-val') as HTMLButtonElement;
    const dpPctContainer = document.getElementById('dp-pct-container') as HTMLDivElement;
    const dpValContainer = document.getElementById('dp-val-container') as HTMLDivElement;
    const dpPctInput = document.getElementById('dp-pct') as HTMLInputElement;
    const dpValInput = document.getElementById('dp-val') as HTMLInputElement;

    const term15Btn = document.getElementById('term-15') as HTMLButtonElement;
    const term20Btn = document.getElementById('term-20') as HTMLButtonElement;
    const term30Btn = document.getElementById('term-30') as HTMLButtonElement;
    const termInput = document.getElementById('loan-term') as HTMLInputElement;

    const interestRateInput = document.getElementById('interest-rate') as HTMLInputElement;
    const optionalCostsToggle = document.getElementById('toggle-optional-costs') as HTMLButtonElement;
    const costsChevron = document.getElementById('costs-chevron') as unknown as SVGElement;
    const optionalCostsContainer = document.getElementById('optional-costs-container') as HTMLDivElement;

    const propertyTaxInput = document.getElementById('property-tax') as HTMLInputElement;
    const homeInsuranceInput = document.getElementById('home-insurance') as HTMLInputElement;
    const pmiContainer = document.getElementById('pmi-container') as HTMLDivElement;
    const pmiInput = document.getElementById('pmi') as HTMLInputElement;
    const hoaInput = document.getElementById('hoa') as HTMLInputElement;
    const extraPaymentInput = document.getElementById('extra-payment') as HTMLInputElement;

    // Results DOM Elements
    const monthlyPaymentTotal = document.getElementById('monthly-payment-total') as HTMLDivElement;
    const donutCenterTotal = document.getElementById('donut-center-total') as HTMLSpanElement;
    const breakdownPiVal = document.getElementById('breakdown-pi-val') as HTMLSpanElement;
    const breakdownTaxVal = document.getElementById('breakdown-tax-val') as HTMLSpanElement;
    const breakdownInsuranceVal = document.getElementById('breakdown-insurance-val') as HTMLSpanElement;
    const breakdownPmiRow = document.getElementById('breakdown-pmi-row') as HTMLDivElement;
    const breakdownPmiVal = document.getElementById('breakdown-pmi-val') as HTMLSpanElement;
    const breakdownHoaVal = document.getElementById('breakdown-hoa-val') as HTMLSpanElement;

    const summaryPrincipal = document.getElementById('summary-principal') as HTMLSpanElement;
    const summaryInterest = document.getElementById('summary-interest') as HTMLSpanElement;
    const summaryPayoff = document.getElementById('summary-payoff') as HTMLSpanElement;

    // Accel Benefit DOM Elements
    const accelImpactCard = document.getElementById('accel-impact-card') as HTMLDivElement;
    const accelSavedInterest = document.getElementById('accel-saved-interest') as HTMLSpanElement;
    const accelSavedTime = document.getElementById('accel-saved-time') as HTMLSpanElement;
    const accelNewDate = document.getElementById('accel-new-date') as HTMLSpanElement;
    const timelineOrigTerm = document.getElementById('timeline-orig-term') as HTMLSpanElement;
    const timelineAccelTerm = document.getElementById('timeline-accel-term') as HTMLSpanElement;
    const timelineAccelBar = document.getElementById('timeline-accel-bar') as HTMLDivElement;
    const timelineSavedBar = document.getElementById('timeline-saved-bar') as HTMLDivElement;

    // Chart Elements
    const chartToggleYearly = document.getElementById('chart-toggle-yearly') as HTMLButtonElement;
    const chartToggleMonthly = document.getElementById('chart-toggle-monthly') as HTMLButtonElement;
    const chartYMax = document.getElementById('chart-y-max') as SVGTextElement;
    const chartYMid = document.getElementById('chart-y-mid') as SVGTextElement;
    const chartBaselineFill = document.getElementById('chart-baseline-fill') as SVGPathElement;
    const chartBaselineLine = document.getElementById('chart-baseline-line') as SVGPathElement;
    const chartAccelFill = document.getElementById('chart-accel-fill') as SVGPathElement;
    const chartAccelLine = document.getElementById('chart-accel-line') as SVGPathElement;
    const chartXLabels = document.getElementById('chart-x-labels') as SVGGraphicsElement;
    const chartLegendAccel = document.getElementById('chart-legend-accel') as HTMLDivElement;

    // Donut Segments Elements
    const donutPi = document.getElementById('donut-pi') as SVGCircleElement;
    const donutTax = document.getElementById('donut-tax') as SVGCircleElement;
    const donutInsurance = document.getElementById('donut-insurance') as SVGCircleElement;
    const donutPmi = document.getElementById('donut-pmi') as SVGCircleElement;
    const donutHoa = document.getElementById('donut-hoa') as SVGCircleElement;

    // Table & CSV Elements
    const toggleScheduleTable = document.getElementById('toggle-schedule-table') as HTMLButtonElement;
    const tableChevron = document.getElementById('table-chevron') as unknown as SVGElement;
    const scheduleTableContainer = document.getElementById('schedule-table-container') as HTMLDivElement;
    const scheduleTableBody = document.getElementById('schedule-table-body') as HTMLTableSectionElement;
    const tableHdrPeriod = document.getElementById('table-hdr-period') as HTMLTableCellElement;
    const downloadCsvBtn = document.getElementById('download-csv') as HTMLButtonElement;

    // 2. Global State Variables
    let downPaymentMode = 'pct';
    let currentTermYears = 30;
    let chartGranularity = 'yearly';
    let csvContent = '';
    let activeBaselineSchedule: any[] = [];
    let activeAcceleratedSchedule: any[] = [];

    // 3. Helper Functions
    const formatCurrency = (val: number) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(val);
    };

    const formatCurrencyWithCents = (val: number) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(val);
    };

    const getPayoffDate = (monthsToAdd: number) => {
      const date = new Date();
      date.setMonth(date.getMonth() + monthsToAdd);
      return date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
    };

    // 4. Primary Calculation Function
    const runCalculations = () => {
      const homePrice = Math.max(0, parseFloat(homePriceInput.value) || 0);
      let downPaymentPercent = parseFloat(dpPctInput.value) || 0;
      let downPaymentValue = parseFloat(dpValInput.value) || 0;

      // Synchronize down payment fields
      if (downPaymentMode === 'pct') {
        downPaymentPercent = Math.min(100, Math.max(0, downPaymentPercent));
        downPaymentValue = homePrice * (downPaymentPercent / 100);
        dpValInput.value = Math.round(downPaymentValue).toString();
      } else {
        downPaymentValue = Math.min(homePrice, Math.max(0, downPaymentValue));
        downPaymentPercent = homePrice > 0 ? (downPaymentValue / homePrice) * 100 : 0;
        dpPctInput.value = (Math.round(downPaymentPercent * 100) / 100).toFixed(2);
      }

      const loanPrincipal = Math.max(0, homePrice - downPaymentValue);
      const annualRate = Math.max(0, parseFloat(interestRateInput.value) || 0);
      const termYears = currentTermYears;

      // Toggle PMI display
      const isPmiRequired = downPaymentPercent < 20;
      pmiContainer.classList.toggle('hidden', !isPmiRequired);
      breakdownPmiRow.classList.toggle('hidden', !isPmiRequired);

      // Retrieve costs
      const propertyTaxAnnual = Math.max(0, parseFloat(propertyTaxInput.value) || 0);
      const homeInsuranceAnnual = Math.max(0, parseFloat(homeInsuranceInput.value) || 0);
      const monthlyPmi = isPmiRequired ? Math.max(0, parseFloat(pmiInput.value) || 0) : 0;
      const monthlyHoa = Math.max(0, parseFloat(hoaInput.value) || 0);
      const monthlyExtra = Math.max(0, parseFloat(extraPaymentInput.value) || 0);

      const totalMonths = termYears * 12;

      // Call shared calculation utility
      const result = calculateAmortization(loanPrincipal, annualRate, totalMonths, monthlyExtra);
      const monthlyPI = result.monthlyPI;
      activeBaselineSchedule = result.baseline.schedule;
      activeAcceleratedSchedule = result.accelerated.schedule;

      const monthlyTax = propertyTaxAnnual / 12;
      const monthlyInsurance = homeInsuranceAnnual / 12;
      const estimatedMonthlyTotal = monthlyPI + monthlyTax + monthlyInsurance + monthlyPmi + monthlyHoa;

      // Update main dashboard values
      monthlyPaymentTotal.textContent = formatCurrencyWithCents(estimatedMonthlyTotal);
      donutCenterTotal.textContent = formatCurrency(estimatedMonthlyTotal);
      breakdownPiVal.textContent = formatCurrencyWithCents(monthlyPI);
      breakdownTaxVal.textContent = formatCurrencyWithCents(monthlyTax);
      breakdownInsuranceVal.textContent = formatCurrencyWithCents(monthlyInsurance);
      breakdownPmiVal.textContent = formatCurrencyWithCents(monthlyPmi);
      breakdownHoaVal.textContent = formatCurrencyWithCents(monthlyHoa);

      summaryPrincipal.textContent = formatCurrency(loanPrincipal);

      // Update baseline stats
      const totalInterestPaid = result.baseline.totalInterest;
      summaryInterest.textContent = formatCurrency(totalInterestPaid);
      const baselinePayoffMonths = result.baseline.payoffMonths;
      summaryPayoff.textContent = getPayoffDate(baselinePayoffMonths);
      timelineOrigTerm.textContent = `${(baselinePayoffMonths / 12).toFixed(1).replace('.0', '')} Years`;

      // Show/Hide Accelerator Card & update stats
      if (monthlyExtra > 0 && loanPrincipal > 0 && activeAcceleratedSchedule.length > 0) {
        accelImpactCard.classList.remove('hidden');
        chartLegendAccel.classList.remove('hidden');

        const accelTotalInterest = result.accelerated.totalInterest;
        const interestSavedVal = Math.max(0, totalInterestPaid - accelTotalInterest);
        accelSavedInterest.textContent = formatCurrency(interestSavedVal);

        const accelMonth = result.accelerated.payoffMonths;
        const monthsSaved = baselinePayoffMonths - accelMonth;
        const yearsSaved = Math.floor(monthsSaved / 12);
        const remMonths = monthsSaved % 12;

        let timeSavedStr = '';
        if (yearsSaved > 0) timeSavedStr += `${yearsSaved} yr${yearsSaved > 1 ? 's' : ''}`;
        if (remMonths > 0) timeSavedStr += ` ${remMonths} mo${remMonths > 1 ? 's' : ''}`;
        if (monthsSaved <= 0) timeSavedStr = '0 months';
        accelSavedTime.textContent = timeSavedStr;

        accelNewDate.textContent = getPayoffDate(accelMonth);
        timelineAccelTerm.textContent = `${(accelMonth / 12).toFixed(1).replace('.0', '')} Years`;

        // Adjust visual timelines
        const percentOfTerm = (accelMonth / totalMonths) * 100;
        const percentSaved = (monthsSaved / totalMonths) * 100;
        timelineAccelBar.style.width = `${percentOfTerm}%`;
        timelineSavedBar.style.width = `${percentSaved}%`;
      } else {
        accelImpactCard.classList.add('hidden');
        chartLegendAccel.classList.add('hidden');
      }

      // 6. Update Donut Chart Segment Stroke Attributes
      const circumference = 2 * Math.PI * 38;
      const donutBreakdowns = [
        { el: donutPi, val: monthlyPI },
        { el: donutTax, val: monthlyTax },
        { el: donutInsurance, val: monthlyInsurance },
        { el: donutPmi, val: monthlyPmi },
        { el: donutHoa, val: monthlyHoa }
      ];

      let cumulativePct = 0;
      donutBreakdowns.forEach(item => {
        const percent = estimatedMonthlyTotal > 0 ? item.val / estimatedMonthlyTotal : 0;
        const strokeLength = percent * circumference;
        const strokeSpace = circumference - strokeLength;
        item.el.setAttribute('stroke-dasharray', `${strokeLength} ${strokeSpace}`);
        item.el.setAttribute('stroke-dashoffset', (-cumulativePct * circumference).toString());
        cumulativePct += percent;
      });

      // 7. Render Amortization Chart & Table
      updateAmortizationView();
    };

    // Helper: Render Area Chart and Schedule Table Based on Selected Granularity
    const updateAmortizationView = () => {
      const homePrice = Math.max(0, parseFloat(homePriceInput.value) || 0);
      const downPaymentValue = parseFloat(dpValInput.value) || 0;
      const principal = Math.max(0, homePrice - downPaymentValue);

      if (principal <= 0 || activeBaselineSchedule.length === 0) {
        chartBaselineLine.classList.add('hidden');
        chartBaselineFill.classList.add('hidden');
        chartAccelLine.classList.add('hidden');
        chartAccelFill.classList.add('hidden');
        scheduleTableBody.innerHTML = '<tr><td colspan="5" class="py-6 text-center text-mute font-mono">Enter a valid Home Price and Down Payment to calculate a schedule.</td></tr>';
        return;
      }

      chartYMax.textContent = formatCurrency(principal);
      chartYMid.textContent = formatCurrency(principal / 2);

      const isYearly = chartGranularity === 'yearly';

      // 1. Get SVG Paths from utility
      const paths = getSvgChartPaths(activeBaselineSchedule, activeAcceleratedSchedule, principal, isYearly);
      chartBaselineLine.setAttribute('d', paths.baseLineD);
      chartBaselineFill.setAttribute('d', paths.baseFillD);
      chartBaselineLine.classList.remove('hidden');
      chartBaselineFill.classList.remove('hidden');

      if (paths.hasAccel) {
        chartAccelLine.setAttribute('d', paths.accelLineD);
        chartAccelFill.setAttribute('d', paths.accelFillD);
        chartAccelLine.classList.remove('hidden');
        chartAccelFill.classList.remove('hidden');
      } else {
        chartAccelLine.classList.add('hidden');
        chartAccelFill.classList.add('hidden');
      }

      // 2. Draw dynamic X-axis labels
      const totalBaselinePeriods = activeBaselineSchedule.length;
      const totalTermYears = currentTermYears;
      let xLabelsHtml = '';

      const paddingLeft = 50;
      const paddingRight = 10;
      const chartWidth = 600 - paddingLeft - paddingRight;

      if (isYearly) {
        const step = Math.ceil(totalTermYears / 3);
        for (let i = 0; i <= 3; i++) {
          const yearNum = Math.min(totalTermYears, i * step);
          const xPos = paddingLeft + (yearNum / totalTermYears) * chartWidth;
          xLabelsHtml += `<text x="${xPos}" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Yr ${yearNum}</text>`;
        }
      } else {
        const step = Math.ceil(totalBaselinePeriods / 3);
        for (let i = 0; i <= 3; i++) {
          const monthNum = Math.min(totalBaselinePeriods, i * step);
          const xPos = paddingLeft + (monthNum / totalBaselinePeriods) * chartWidth;
          xLabelsHtml += `<text x="${xPos}" y="212" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]" text-anchor="middle">Mo ${monthNum}</text>`;
        }
      }
      chartXLabels.innerHTML = xLabelsHtml;

      // 3. Render table rows
      let tableRowsData: any[] = [];
      if (isYearly) {
        tableRowsData = getYearlySchedule(activeBaselineSchedule, principal);
        tableHdrPeriod.textContent = 'Year';
      } else {
        activeBaselineSchedule.forEach(m => {
          tableRowsData.push({
            period: `Month ${m.period}`,
            beginningBalance: m.beginningBalance,
            principalPaid: m.principalPaid,
            interestPaid: m.interestPaid,
            endingBalance: m.endingBalance
          });
        });
        tableHdrPeriod.textContent = 'Month';
      }

      let rowsHtml = '';
      tableRowsData.forEach(row => {
        rowsHtml += `
          <tr class="hover:bg-canvas-soft-2 transition-colors border-b border-hairline">
            <td class="py-2.5 px-4 font-mono font-medium text-ink">${row.period}</td>
            <td class="py-2.5 px-4 text-right">${formatCurrency(row.beginningBalance)}</td>
            <td class="py-2.5 px-4 text-right text-emerald-600 dark:text-emerald-400 font-semibold">${formatCurrency(row.principalPaid)}</td>
            <td class="py-2.5 px-4 text-right text-red-500 dark:text-red-400">${formatCurrency(row.interestPaid)}</td>
            <td class="py-2.5 px-4 text-right font-medium">${formatCurrency(row.endingBalance)}</td>
          </tr>
        `;
      });
      scheduleTableBody.innerHTML = rowsHtml;

      // 4. Generate CSV
      csvContent = generateCsv(tableRowsData, isYearly ? 'Year' : 'Month');
    };

    // 8. Event Listeners & Setup
    // Down payment toggle
    dpTogglePct.addEventListener('click', () => {
      if (downPaymentMode === 'pct') return;
      downPaymentMode = 'pct';
      dpTogglePct.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl2');
      dpTogglePct.classList.remove('text-mute');
      dpToggleVal.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl2');
      dpToggleVal.classList.add('text-mute');

      dpPctContainer.classList.remove('hidden');
      dpValContainer.classList.add('hidden');
      runCalculations();
    });

    dpToggleVal.addEventListener('click', () => {
      if (downPaymentMode === 'val') return;
      downPaymentMode = 'val';
      dpToggleVal.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl2');
      dpToggleVal.classList.remove('text-mute');
      dpTogglePct.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl2');
      dpTogglePct.classList.add('text-mute');

      dpValContainer.classList.remove('hidden');
      dpPctContainer.classList.add('hidden');
      runCalculations();
    });

    // Term select buttons helper
    const updateTermState = (selectedYears: number) => {
      currentTermYears = selectedYears;
      termInput.value = selectedYears.toString();

      const termBtns = [
        { btn: term15Btn, yr: 15 },
        { btn: term20Btn, yr: 20 },
        { btn: term30Btn, yr: 30 }
      ];

      termBtns.forEach(item => {
        if (item.yr === selectedYears) {
          item.btn.classList.add('bg-primary', 'text-on-primary', 'border-hairline-strong', 'shadow-lvl2');
          item.btn.classList.remove('bg-canvas', 'text-body', 'border-hairline', 'hover:bg-canvas-soft-2');
        } else {
          item.btn.classList.remove('bg-primary', 'text-on-primary', 'border-hairline-strong', 'shadow-lvl2');
          item.btn.classList.add('bg-canvas', 'text-body', 'border-hairline', 'hover:bg-canvas-soft-2');
        }
      });

      runCalculations();
    };

    term15Btn.addEventListener('click', () => updateTermState(15));
    term20Btn.addEventListener('click', () => updateTermState(20));
    term30Btn.addEventListener('click', () => updateTermState(30));

    // Optional expenses disclosure toggler
    optionalCostsToggle.addEventListener('click', () => {
      const isExpanded = optionalCostsToggle.getAttribute('aria-expanded') === 'true';
      optionalCostsToggle.setAttribute('aria-expanded', (!isExpanded).toString());
      costsChevron.classList.toggle('rotate-180', !isExpanded);
      optionalCostsContainer.classList.toggle('hidden', isExpanded);
    });

    // Full table toggle drawer
    toggleScheduleTable.addEventListener('click', () => {
      const isExpanded = toggleScheduleTable.getAttribute('aria-expanded') === 'true';
      toggleScheduleTable.setAttribute('aria-expanded', (!isExpanded).toString());
      tableChevron.classList.toggle('rotate-180', !isExpanded);
      scheduleTableContainer.classList.toggle('hidden', isExpanded);
    });

    // Granularity switches
    chartToggleYearly.addEventListener('click', () => {
      if (chartGranularity === 'yearly') return;
      chartGranularity = 'yearly';
      chartToggleYearly.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl1');
      chartToggleYearly.classList.remove('text-mute');
      chartToggleMonthly.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl1');
      chartToggleMonthly.classList.add('text-mute');
      updateAmortizationView();
    });

    chartToggleMonthly.addEventListener('click', () => {
      if (chartGranularity === 'monthly') return;
      chartGranularity = 'monthly';
      chartToggleMonthly.classList.add('bg-primary', 'text-on-primary', 'shadow-lvl1');
      chartToggleMonthly.classList.remove('text-mute');
      chartToggleYearly.classList.remove('bg-primary', 'text-on-primary', 'shadow-lvl1');
      chartToggleYearly.classList.add('text-mute');
      updateAmortizationView();
    });

    // Dynamic recalculation on form inputs
    const formInputs = [
      homePriceInput, dpPctInput, dpValInput, interestRateInput,
      propertyTaxInput, homeInsuranceInput, pmiInput, hoaInput, extraPaymentInput
    ];

    formInputs.forEach(input => {
      input.addEventListener('input', runCalculations);
    });

    // Download schedule table trigger
    downloadCsvBtn.addEventListener('click', () => {
      if (!csvContent) return;
      const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
      const link = document.createElement("a");
      const url = URL.createObjectURL(blob);
      link.setAttribute("href", url);
      link.setAttribute("download", `mortgage_amortization_schedule_${chartGranularity}.csv`);
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    });

    // FAQs Accordion bindings
    document.querySelectorAll('.faq-toggle').forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling as HTMLDivElement;
        const chevron = button.querySelector('svg') as unknown as SVGElement;
        const isHidden = content.classList.toggle('hidden');
        chevron.classList.toggle('rotate-180', !isHidden);
        button.setAttribute('aria-expanded', (!isHidden).toString());
      });
    });

    // 9. Initial Load Trigger
    runCalculations();
  </script>
</Layout>
