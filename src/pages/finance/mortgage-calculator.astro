---
import Layout from '../../layouts/Layout.astro';

// FAQ Schema JSON-LD for head insertion
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How is my monthly mortgage payment calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your monthly principal and interest payment is calculated using the standard amortization formula: M = P * [r(1+r)^n] / [(1+r)^n - 1], where P is the loan principal (home price minus down payment), r is the monthly interest rate (annual rate divided by 12), and n is the total number of payments (loan term in years multiplied by 12). Property taxes, home insurance, homeowners association (HOA) fees, and private mortgage insurance (PMI) are then added to this baseline amount to determine your total monthly payment."
      }
    },
    {
      "@type": "Question",
      "name": "What's included in a mortgage payment besides principal and interest?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Beyond principal and interest, a full monthly housing payment can include: 1. Property Taxes (annual fees paid to local county or municipality, divided by 12); 2. Homeowners Insurance (annual home protection plan, divided by 12); 3. Private Mortgage Insurance or PMI (lender protection plan required if down payment is under 20%); and 4. HOA Fees (dues assessed by community association for communal maintenance)."
      }
    },
    {
      "@type": "Question",
      "name": "How much difference does my down payment make?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your down payment fundamentally reduces the principal loan amount you need to borrow, which lowers the base payment and saves you substantial cumulative interest over the term. Additionally, putting down 20% or more allows you to entirely avoid Private Mortgage Insurance (PMI), which can save you $100 to $300 per month on average."
      }
    },
    {
      "@type": "Question",
      "name": "Does paying extra each month really save money?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, making extra monthly payments goes directly toward paying down your loan's principal balance. Since interest is calculated as a percentage of your remaining balance, reducing the principal faster reduces the compound interest billed in future periods. This accelerates your timeline, shaving years off your mortgage and saving you thousands of dollars in financing costs."
      }
    },
    {
      "@type": "Question",
      "name": "Is this mortgage calculator accurate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This calculator uses precise, industry-standard amortization formulas to model loan balances and payments. However, actual taxes, insurance policies, PMI rates, and lender underwriting parameters depend on local rates, property specifications, credit ratings, and closing requirements. Use this tool as a high-fidelity guide and consult with a licensed broker for exact quotes."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between conforming and non-conforming (jumbo) loans?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Conforming loans meet standard funding limits set by Fannie Mae and Freddie Mac. Jumbo loans exceed these limits, requiring larger down payments and higher credit scores due to increased risk."
      }
    },
    {
      "@type": "Question",
      "name": "How does a 15-year fixed mortgage compare to a 30-year fixed mortgage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 15-year fixed mortgage has higher monthly payments but lower interest rates, allowing you to pay off the loan faster and save tens of thousands in lifetime interest compared to a 30-year term."
      }
    },
    {
      "@type": "Question",
      "name": "What is an escrow account and how does it affect monthly mortgage payments?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An escrow account is a holding account managed by your lender to pay property taxes and home insurance. The lender estimates these annual bills, divides them by 12, and adds that amount to your monthly mortgage payment."
      }
    },
    {
      "@type": "Question",
      "name": "What is Private Mortgage Insurance (PMI) and how can I remove it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PMI is insurance that protects the lender if you default on your loan, typically required if your down payment is under 20%. You can request to remove PMI once your loan-to-value (LTV) ratio drops to 80%."
      }
    },
    {
      "@type": "Question",
      "name": "How do discount points work in mortgage financing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Discount points are prepaid interest buy-downs. Purchasing one point costs 1% of the loan amount and typically lowers your mortgage interest rate by 0.25%, reducing your monthly payment over the life of the loan."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
---

<Layout 
  title="Mortgage Calculator - Free & Accurate Monthly Payment Estimator | ToolzTotal"
  description="Calculate your monthly mortgage payments with our free, ad-free mortgage calculator. View interactive amortization schedules and extra payment interest savings."
  faqJsonLd={faqJsonLd}
>
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 mb-8 text-xs font-mono text-mute" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink transition-colors">Home</a>
      <span>/</span>
      <a href="/finance" class="hover:text-ink transition-colors">Finance & Loans</a>
      <span>/</span>
      <span class="text-ink">Mortgage Calculator</span>
    </nav>

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider">Free Tool</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty">
        Mortgage Payment Calculator
      </h1>
      <p class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl">
        Calculate your total monthly mortgage payment including principal, interest, property taxes, insurance, PMI, and HOA fees. Estimate payoff timelines and see the impact of adding extra monthly payments instantly.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      
      <!-- Left Column: Input Form (5 cols) -->
      <div class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6">
        <h2 class="text-lg font-bold text-ink font-sans border-b border-hairline pb-3">Loan Details</h2>
        
        <!-- Home Price -->
        <div>
          <label for="home-price" class="block text-xs font-mono uppercase text-mute mb-2">Home Price</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input 
              type="number" 
              id="home-price" 
              value="400000" 
              step="5000"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 400,000…"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Down Payment -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="block text-xs font-mono uppercase text-mute">Down Payment</label>
            <div class="inline-flex rounded-md bg-canvas-soft-2 p-0.5 border border-hairline shadow-lvl1">
              <button 
                type="button" 
                id="dp-toggle-pct" 
                class="px-2.5 py-1 text-[10px] font-mono rounded-md bg-primary text-on-primary shadow-lvl2 transition-all cursor-pointer"
                aria-label="Toggle down payment to percentage"
              >
                %
              </button>
              <button 
                type="button" 
                id="dp-toggle-val" 
                class="px-2.5 py-1 text-[10px] font-mono rounded-md text-mute hover:text-ink transition-all cursor-pointer"
                aria-label="Toggle down payment to dollar value"
              >
                $
              </button>
            </div>
          </div>
          
          <!-- Percentage Input -->
          <div id="dp-pct-container" class="relative">
            <input 
              type="number" 
              id="dp-pct" 
              value="20" 
              step="0.5"
              min="0"
              max="100"
              class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 20…"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
          </div>
          
          <!-- Dollar Input (hidden initially) -->
          <div id="dp-val-container" class="relative hidden">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input 
              type="number" 
              id="dp-val" 
              value="80000" 
              step="1000"
              min="0"
              class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 80,000…"
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Loan Term Presets -->
        <div>
          <label class="block text-xs font-mono uppercase text-mute mb-2">Loan Term</label>
          <div class="grid grid-cols-3 gap-2">
            <button 
              type="button" 
              id="term-15" 
              data-years="15"
              class="h-10 border border-hairline bg-canvas hover:bg-canvas-soft-2 text-body rounded-md font-sans text-xs font-medium transition-all cursor-pointer"
            >
              15 Years
            </button>
            <button 
              type="button" 
              id="term-20" 
              data-years="20"
              class="h-10 border border-hairline bg-canvas hover:bg-canvas-soft-2 text-body rounded-md font-sans text-xs font-medium transition-all cursor-pointer"
            >
              20 Years
            </button>
            <button 
              type="button" 
              id="term-30" 
              data-years="30"
              class="h-10 border border-hairline-strong bg-primary text-on-primary rounded-md font-sans text-xs font-medium transition-all shadow-lvl2 cursor-pointer"
            >
              30 Years
            </button>
          </div>
          <input type="hidden" id="loan-term" value="30" />
        </div>

        <!-- Interest Rate -->
        <div>
          <label for="interest-rate" class="block text-xs font-mono uppercase text-mute mb-2">Interest Rate</label>
          <div class="relative">
            <input 
              type="number" 
              id="interest-rate" 
              value="6.5" 
              step="0.05"
              min="0"
              max="100"
              class="w-full h-10 pl-3 pr-7 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 6.5…"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">%</span>
          </div>
          <p class="text-[11px] text-mute font-sans mt-1.5 leading-normal">Enter your quoted rate for an accurate estimate.</p>
        </div>

        <!-- Additional Monthly Costs (Optional) Accordion -->
        <div class="border-t border-hairline pt-5">
          <button 
            type="button" 
            id="toggle-optional-costs" 
            class="flex items-center justify-between w-full text-xs font-mono uppercase text-mute hover:text-ink transition-colors group cursor-pointer"
            aria-expanded="false"
            aria-controls="optional-costs-container"
          >
            <span>Additional Costs (Optional)</span>
            <svg id="costs-chevron" class="w-4 h-4 text-mute transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div id="optional-costs-container" class="space-y-4 pt-4 hidden">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="property-tax" class="block text-xs font-mono uppercase text-mute mb-2">Property Tax</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-xs font-sans">$</span>
                  <input 
                    type="number" 
                    id="property-tax" 
                    value="0" 
                    step="100"
                    min="0"
                    class="w-full h-10 pl-7 pr-10 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                    placeholder="e.g., 2,400…"
                    autocomplete="off"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-[10px] font-mono">/yr</span>
                </div>
              </div>
              <div>
                <label for="home-insurance" class="block text-xs font-mono uppercase text-mute mb-2">Home Insurance</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-xs font-sans">$</span>
                  <input 
                    type="number" 
                    id="home-insurance" 
                    value="0" 
                    step="100"
                    min="0"
                    class="w-full h-10 pl-7 pr-10 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                    placeholder="e.g., 1,200…"
                    autocomplete="off"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-[10px] font-mono">/yr</span>
                </div>
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div id="pmi-container" class="hidden">
                <label for="pmi" class="block text-xs font-mono uppercase text-mute mb-2 flex items-center justify-between">
                  <span>PMI</span>
                  <span class="text-[9px] text-warning-deep bg-warning-soft px-1 py-0.5 rounded font-sans uppercase">Required</span>
                </label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-xs font-sans">$</span>
                  <input 
                    type="number" 
                    id="pmi" 
                    value="150" 
                    step="10"
                    min="0"
                    class="w-full h-10 pl-7 pr-10 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                    placeholder="e.g., 150…"
                    autocomplete="off"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-[10px] font-mono">/mo</span>
                </div>
              </div>
              <div>
                <label for="hoa" class="block text-xs font-mono uppercase text-mute mb-2">HOA Fees</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-xs font-sans">$</span>
                  <input 
                    type="number" 
                    id="hoa" 
                    value="0" 
                    step="10"
                    min="0"
                    class="w-full h-10 pl-7 pr-10 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                    placeholder="e.g., 100…"
                    autocomplete="off"
                  />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-[10px] font-mono">/mo</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Extra Monthly Payment -->
        <div class="border-t border-hairline pt-5">
          <label for="extra-payment" class="block text-xs font-mono uppercase text-mute mb-2 flex items-center justify-between">
            <span>Extra Monthly Payment</span>
            <span class="text-[10px] text-emerald-500 font-mono">accelerate payoff</span>
          </label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans">$</span>
            <input 
              type="number" 
              id="extra-payment" 
              value="0" 
              step="50"
              min="0"
              class="w-full h-10 pl-7 pr-10 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
              placeholder="e.g., 200…"
              autocomplete="off"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-[10px] font-mono">/mo</span>
          </div>
          <p class="text-[11px] text-mute font-sans mt-1.5 leading-normal">Shave years off your loan and save thousands of dollars on interest instantly.</p>
        </div>

      </div>

      <!-- Right Column: Results Dashboard & Charts (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Estimated Payment Card -->
        <div class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 relative">
          <h2 class="text-xs font-mono uppercase tracking-wider text-mute mb-2">Estimated Monthly Payment</h2>
          <div id="monthly-payment-total" class="text-4xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-6 tabular-nums">
            $0.00
          </div>
          
          <!-- Donut Breakdown Grid -->
          <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center border-t border-hairline pt-6">
            
            <!-- SVG Donut Chart (4 cols) -->
            <div class="md:col-span-4 flex justify-center">
              <div class="relative w-36 h-36">
                <!-- SVG base -->
                <svg viewBox="0 0 100 100" class="w-full h-full transform -rotate-90">
                  <!-- Background Track Circle -->
                  <circle 
                    cx="50" 
                    cy="50" 
                    r="38" 
                    stroke-width="10" 
                    class="stroke-canvas-soft-2 fill-none" 
                  />
                  <!-- Principal & Interest segment -->
                  <circle 
                    id="donut-pi" 
                    cx="50" 
                    cy="50" 
                    r="38" 
                    stroke-width="10" 
                    stroke-dasharray="0 238.76" 
                    stroke-dashoffset="0"
                    class="stroke-neutral-900 dark:stroke-neutral-100 fill-none transition-all duration-300" 
                  />
                  <!-- Tax segment -->
                  <circle 
                    id="donut-tax" 
                    cx="50" 
                    cy="50" 
                    r="38" 
                    stroke-width="10" 
                    stroke-dasharray="0 238.76" 
                    stroke-dashoffset="0"
                    class="stroke-blue-500 dark:stroke-blue-400 fill-none transition-all duration-300" 
                  />
                  <!-- Insurance segment -->
                  <circle 
                    id="donut-insurance" 
                    cx="50" 
                    cy="50" 
                    r="38" 
                    stroke-width="10" 
                    stroke-dasharray="0 238.76" 
                    stroke-dashoffset="0"
                    class="stroke-amber-500 dark:stroke-amber-400 fill-none transition-all duration-300" 
                  />
                  <!-- PMI segment -->
                  <circle 
                    id="donut-pmi" 
                    cx="50" 
                    cy="50" 
                    r="38" 
                    stroke-width="10" 
                    stroke-dasharray="0 238.76" 
                    stroke-dashoffset="0"
                    class="stroke-purple-500 dark:stroke-purple-400 fill-none transition-all duration-300" 
                  />
                  <!-- HOA segment -->
                  <circle 
                    id="donut-hoa" 
                    cx="50" 
                    cy="50" 
                    r="38" 
                    stroke-width="10" 
                    stroke-dasharray="0 238.76" 
                    stroke-dashoffset="0"
                    class="stroke-pink-500 dark:stroke-pink-400 fill-none transition-all duration-300" 
                  />
                </svg>
                
                <!-- Inner Total Text label -->
                <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
                  <span id="donut-center-total" class="text-sm font-bold text-ink tabular-nums">$0</span>
                  <span class="text-[9px] font-mono text-mute uppercase">Total</span>
                </div>
              </div>
            </div>
            
            <!-- Breakdown Numbers list (8 cols) -->
            <div class="md:col-span-8 space-y-2.5">
              <!-- P&I -->
              <div class="flex items-center justify-between text-xs font-sans">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-neutral-950 dark:bg-neutral-100 inline-block"></span>
                  <span class="text-body font-medium">Principal & Interest</span>
                </div>
                <span id="breakdown-pi-val" class="font-bold text-ink tabular-nums">$0.00</span>
              </div>
              <!-- Property Tax -->
              <div class="flex items-center justify-between text-xs font-sans">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-blue-500 dark:bg-blue-400 inline-block"></span>
                  <span class="text-body font-medium">Property Tax</span>
                </div>
                <span id="breakdown-tax-val" class="font-bold text-ink tabular-nums">$0.00</span>
              </div>
              <!-- Home Insurance -->
              <div class="flex items-center justify-between text-xs font-sans">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-amber-500 dark:bg-amber-400 inline-block"></span>
                  <span class="text-body font-medium">Home Insurance</span>
                </div>
                <span id="breakdown-insurance-val" class="font-bold text-ink tabular-nums">$0.00</span>
              </div>
              <!-- PMI -->
              <div id="breakdown-pmi-row" class="flex items-center justify-between text-xs font-sans hidden">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-purple-500 dark:bg-purple-400 inline-block"></span>
                  <span class="text-body font-medium">PMI</span>
                </div>
                <span id="breakdown-pmi-val" class="font-bold text-ink tabular-nums">$0.00</span>
              </div>
              <!-- HOA -->
              <div class="flex items-center justify-between text-xs font-sans">
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full bg-pink-500 dark:bg-pink-400 inline-block"></span>
                  <span class="text-body font-medium">HOA Fees</span>
                </div>
                <span id="breakdown-hoa-val" class="font-bold text-ink tabular-nums">$0.00</span>
              </div>
            </div>
            
          </div>

          <!-- Disclaimer inline -->
          <div class="mt-6 pt-4 border-t border-hairline text-[10px] text-mute leading-normal font-sans">
            <strong>Disclaimer:</strong> This calculator provides estimates for informational purposes only and is not a loan offer or financial advice. Actual rates and payments may vary. Consult a licensed lender for a formal quote.
          </div>
        </div>

        <!-- Payoff Summary Grid (Original vs. Extra details) -->
        <div class="grid grid-cols-3 gap-4">
          <div class="bg-canvas border border-hairline rounded-lg p-4 shadow-lvl1">
            <span class="block text-[10px] font-mono uppercase text-mute mb-1">Total Loan Principal</span>
            <span id="summary-principal" class="text-lg font-bold text-ink font-sans tabular-nums">$0</span>
          </div>
          <div class="bg-canvas border border-hairline rounded-lg p-4 shadow-lvl1">
            <span class="block text-[10px] font-mono uppercase text-mute mb-1">Total Interest Paid</span>
            <span id="summary-interest" class="text-lg font-bold text-ink font-sans tabular-nums">$0</span>
          </div>
          <div class="bg-canvas border border-hairline rounded-lg p-4 shadow-lvl1">
            <span class="block text-[10px] font-mono uppercase text-mute mb-1">Estimated Payoff Date</span>
            <span id="summary-payoff" class="text-lg font-bold text-ink font-sans tabular-nums">--</span>
          </div>
        </div>

        <!-- Extra Payment Accelerator Impact showcase (Hidden by default unless extra payment is added) -->
        <div id="accel-impact-card" class="bg-canvas border border-emerald-500/20 dark:border-emerald-500/30 rounded-xl p-6 shadow-lvl3 relative hidden overflow-hidden">
          <div class="absolute right-0 top-0 bg-emerald-500/10 dark:bg-emerald-500/20 text-emerald-500 font-mono text-[9px] uppercase px-3 py-1 rounded-bl">
            Acceleration Benefit
          </div>
          
          <h3 class="text-sm font-bold text-ink font-sans mb-4 flex items-center gap-1.5">
            <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
