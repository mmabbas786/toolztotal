<script>
  import {
    FEDERAL_BRACKETS_2026,
    STANDARD_DEDUCTION_2026,
    FICA_2026,
    STATE_TAX_2026,
    type FilingStatus,
    type TaxBracket,
  } from "../../data/taxBrackets";

  // DOM Elements
  const grossSalaryInput = document.getElementById(
    "gross-salary",
  ) as HTMLInputElement;
  const payFrequencySelect = document.getElementById(
    "pay-frequency",
  ) as HTMLSelectElement;
  const hoursPerWeekInput = document.getElementById(
    "hours-per-week",
  ) as HTMLInputElement;
  const hourlyInputs = document.getElementById(
    "hourly-inputs",
  ) as HTMLDivElement;

  const filingStatusInput = document.getElementById(
    "filing-status",
  ) as HTMLInputElement;
  const stateCodeSelect = document.getElementById(
    "state-code",
  ) as HTMLSelectElement;
  const contrib401kInput = document.getElementById(
    "contrib-401k",
  ) as HTMLInputElement;
  const contribIraInput = document.getElementById(
    "contrib-ira",
  ) as HTMLInputElement;

  const calculateBtn = document.getElementById(
    "calculate-btn",
  ) as HTMLButtonElement;
  const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;

  // Output Elements
  const annualTakehomeVal = document.getElementById(
    "annual-takehome-val",
  ) as HTMLParagraphElement;
  const monthlyTakehomeVal = document.getElementById(
    "monthly-takehome-val",
  ) as HTMLParagraphElement;
  const effectiveRateVal = document.getElementById(
    "effective-rate-val",
  ) as HTMLParagraphElement;
  const totalTaxesVal = document.getElementById(
    "total-taxes-val",
  ) as HTMLParagraphElement;
  const taxBreakdownSubtext = document.getElementById(
    "tax-breakdown-subtext",
  ) as HTMLDivElement;

  const netAnnualList = document.getElementById(
    "net-annual-list",
  ) as HTMLSpanElement;
  const netMonthlyList = document.getElementById(
    "net-monthly-list",
  ) as HTMLSpanElement;
  const netBiweeklyList = document.getElementById(
    "net-biweekly-list",
  ) as HTMLSpanElement;
  const netWeeklyList = document.getElementById(
    "net-weekly-list",
  ) as HTMLSpanElement;

  // Table rows
  const rowGross = document.getElementById("row-gross") as HTMLTableCellElement;
  const rowGrossMonthly = document.getElementById(
    "row-gross-monthly",
  ) as HTMLTableCellElement;
  const row401k = document.getElementById("row-401k") as HTMLTableCellElement;
  const row401kMonthly = document.getElementById(
    "row-401k-monthly",
  ) as HTMLTableCellElement;
  const rowIra = document.getElementById("row-ira") as HTMLTableCellElement;
  const rowIraMonthly = document.getElementById(
    "row-ira-monthly",
  ) as HTMLTableCellElement;

  const rowTaxable = document.getElementById(
    "row-taxable",
  ) as HTMLTableCellElement;
  const rowTaxableMonthly = document.getElementById(
    "row-taxable-monthly",
  ) as HTMLTableCellElement;
  const rowFedtax = document.getElementById(
    "row-fedtax",
  ) as HTMLTableCellElement;
  const rowFedtaxMonthly = document.getElementById(
    "row-fedtax-monthly",
  ) as HTMLTableCellElement;

  const rowStatetaxLabel = document.getElementById(
    "row-statetax-label",
  ) as HTMLTableCellElement;
  const rowStatetax = document.getElementById(
    "row-statetax",
  ) as HTMLTableCellElement;
  const rowStatetaxMonthly = document.getElementById(
    "row-statetax-monthly",
  ) as HTMLTableCellElement;

  const rowSocsec = document.getElementById(
    "row-socsec",
  ) as HTMLTableCellElement;
  const rowSocsecMonthly = document.getElementById(
    "row-socsec-monthly",
  ) as HTMLTableCellElement;
  const rowMedicare = document.getElementById(
    "row-medicare",
  ) as HTMLTableCellElement;
  const rowMedicareMonthly = document.getElementById(
    "row-medicare-monthly",
  ) as HTMLTableCellElement;
  const rowAddMedicare = document.getElementById(
    "row-add-medicare",
  ) as HTMLTableCellElement;
  const rowAddMedicareMonthly = document.getElementById(
    "row-add-medicare-monthly",
  ) as HTMLTableCellElement;

  const rowNet = document.getElementById("row-net") as HTMLTableCellElement;
  const rowNetMonthly = document.getElementById(
    "row-net-monthly",
  ) as HTMLTableCellElement;

  const errorPanel = document.getElementById("error-panel") as HTMLDivElement;

  // Clean value parser
  function parseVal(el: HTMLInputElement): number {
    const rawVal = el.value.replace(/,/g, "").trim();
    if (rawVal === "") return 0;
    const parsed = parseFloat(rawVal);
    return isNaN(parsed) || parsed < 0 ? 0 : parsed;
  }

  // Format currency
  function formatMoney(num: number): string {
    return new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
    }).format(num);
  }

  // Round utility
  function round(num: number, decimals: number): number {
    return Math.round(num * Math.pow(10, decimals)) / Math.pow(10, decimals);
  }

  // Bracket calculation
  function calculateBracketTax(
    taxable: number,
    brackets: TaxBracket[],
  ): number {
    let tax = 0;
    for (const bracket of brackets) {
      if (taxable <= bracket.min) break;
      const upper =
        bracket.max === null ? taxable : Math.min(taxable, bracket.max);
      tax += (upper - bracket.min) * bracket.rate;
      if (taxable <= upper) break;
    }
    return tax;
  }

  // Dynamic calculations
  function runCalculations() {
    errorPanel.classList.add("hidden");
    errorPanel.textContent = "";

    const rawSalary = parseVal(grossSalaryInput);
    if (rawSalary === 0) {
      errorPanel.classList.remove("hidden");
      errorPanel.textContent = "Please enter a valid salary amount.";
      return;
    }

    const payFreq = payFrequencySelect.value;
    let grossAnnualSalary = rawSalary;

    if (payFreq === "monthly") {
      grossAnnualSalary = rawSalary * 12;
    } else if (payFreq === "biweekly") {
      grossAnnualSalary = rawSalary * 26;
    } else if (payFreq === "weekly") {
      grossAnnualSalary = rawSalary * 52;
    } else if (payFreq === "hourly") {
      const hoursPerWeek = parseFloat(hoursPerWeekInput.value) || 40;
      grossAnnualSalary = rawSalary * hoursPerWeek * 52;
    }

    const filingStatus = filingStatusInput.value as FilingStatus;
    const stateCode = stateCodeSelect.value;
    const contrib401kPercent = parseVal(contrib401kInput);
    const contribIra = parseVal(contribIraInput);

    // Step 1: Pre-tax deductions
    const retirement401k = Math.min(
      grossAnnualSalary * (contrib401kPercent / 100),
      23500, // 2026 Limit
    );
    const iraCapped = Math.min(contribIra, 7500); // 2026 traditional IRA cap
    const preTaxDeductions = retirement401k + iraCapped;

    // Step 2: Federal Tax taxable basis
    const federalAGI = grossAnnualSalary - preTaxDeductions;
    const federalTaxable = Math.max(
      0,
      federalAGI - STANDARD_DEDUCTION_2026[filingStatus],
    );
    const federalTax = calculateBracketTax(
      federalTaxable,
      FEDERAL_BRACKETS_2026[filingStatus],
    );

    // Step 3: State Tax
    const stateInfo = STATE_TAX_2026[stateCode];
    let stateTax = 0;
    if (stateInfo.hasIncomeTax) {
      if (stateInfo.flatRate !== undefined) {
        stateTax = federalAGI * stateInfo.flatRate;
      } else if (stateInfo.brackets !== undefined) {
        stateTax = calculateBracketTax(federalAGI, stateInfo.brackets);
      }
    }

    // Step 4: FICA
    const socialSecurity = Math.min(
      grossAnnualSalary * FICA_2026.socialSecurityRate,
      FICA_2026.socialSecurityWageBase * FICA_2026.socialSecurityRate,
    );
    const medicare = grossAnnualSalary * FICA_2026.medicareRate;
    const additionalMedicareThreshold =
      FICA_2026.additionalMedicareThreshold[filingStatus];
    const additionalMedicare = Math.max(
      0,
      (grossAnnualSalary - additionalMedicareThreshold) *
        FICA_2026.additionalMedicareRate,
    );
    const fica = socialSecurity + medicare + additionalMedicare;

    // Step 5: Net take home
    const totalTaxes = federalTax + stateTax + fica;
    const takeHome = grossAnnualSalary - totalTaxes - preTaxDeductions;
    const effectiveRate = (totalTaxes / grossAnnualSalary) * 100;

    // Output Cards Updates
    annualTakehomeVal.textContent = formatMoney(takeHome);
    monthlyTakehomeVal.textContent = formatMoney(takeHome / 12);
    effectiveRateVal.textContent = round(effectiveRate, 1).toFixed(1) + "%";
    totalTaxesVal.textContent = formatMoney(totalTaxes);

    taxBreakdownSubtext.innerHTML = `
      <div>${formatMoney(federalTax)} federal</div>
      <div>${formatMoney(stateTax)} state (${stateCode})</div>
      <div>${formatMoney(fica)} FICA</div>
    `;

    // Pay periods net list
    netAnnualList.textContent = formatMoney(takeHome);
    netMonthlyList.textContent = formatMoney(takeHome / 12);
    netBiweeklyList.textContent = formatMoney(takeHome / 26);
    netWeeklyList.textContent = formatMoney(takeHome / 52);

    // Table elements
    rowGross.textContent = formatMoney(grossAnnualSalary);
    rowGrossMonthly.textContent = formatMoney(grossAnnualSalary / 12);

    row401k.textContent = `-${formatMoney(retirement401k)}`;
    row401kMonthly.textContent = `-${formatMoney(retirement401k / 12)}`;

    rowIra.textContent = `-${formatMoney(iraCapped)}`;
    rowIraMonthly.textContent = `-${formatMoney(iraCapped / 12)}`;

    rowTaxable.textContent = formatMoney(federalAGI);
    rowTaxableMonthly.textContent = formatMoney(federalAGI / 12);

    rowFedtax.textContent = `-${formatMoney(federalTax)}`;
    rowFedtaxMonthly.textContent = `-${formatMoney(federalTax / 12)}`;

    rowStatetaxLabel.textContent = `State income tax (${stateCode})`;
    rowStatetax.textContent = `-${formatMoney(stateTax)}`;
    rowStatetaxMonthly.textContent = `-${formatMoney(stateTax / 12)}`;

    rowSocsec.textContent = `-${formatMoney(socialSecurity)}`;
    rowSocsecMonthly.textContent = `-${formatMoney(socialSecurity / 12)}`;

    rowMedicare.textContent = `-${formatMoney(medicare)}`;
    rowMedicareMonthly.textContent = `-${formatMoney(medicare / 12)}`;

    rowAddMedicare.textContent = `-${formatMoney(additionalMedicare)}`;
    rowAddMedicareMonthly.textContent = `-${formatMoney(additionalMedicare / 12)}`;

    rowNet.textContent = formatMoney(takeHome);
    rowNetMonthly.textContent = formatMoney(takeHome / 12);
  }

  // Format Inputs on Blur
  function formatInputOnBlur(e: FocusEvent) {
    const target = e.target as HTMLInputElement;
    const rawVal = target.value.replace(/,/g, "").trim();
    if (rawVal === "") return;
    const parsed = parseFloat(rawVal);
    if (!isNaN(parsed) && parsed >= 0) {
      target.value = new Intl.NumberFormat("en-US").format(parsed);
    }
  }

  // payfrequency UI toggle
  payFrequencySelect.addEventListener("change", () => {
    if (payFrequencySelect.value === "hourly") {
      hourlyInputs.classList.remove("hidden");
    } else {
      hourlyInputs.classList.add("hidden");
    }
    runCalculations();
  });

  // Status Tab toggler
  document.querySelectorAll(".status-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      document.querySelectorAll(".status-btn").forEach((b) => {
        b.className =
          "status-btn py-2 text-xs font-sans font-bold border border-hairline rounded-lg text-mute hover:text-ink cursor-pointer transition-all";
      });
      target.className =
        "status-btn py-2 text-xs font-sans font-bold border border-hairline rounded-lg bg-primary text-on-primary shadow-lvl1 cursor-pointer transition-all";
      filingStatusInput.value = target.getAttribute("data-status") || "single";
      runCalculations();
    });
  });

  // Listeners
  const allInputFields = [
    grossSalaryInput,
    hoursPerWeekInput,
    contrib401kInput,
    contribIraInput,
  ];
  allInputFields.forEach((el) => {
    el.addEventListener("input", runCalculations);
  });
  grossSalaryInput.addEventListener("blur", formatInputOnBlur);
  contribIraInput.addEventListener("blur", formatInputOnBlur);

  stateCodeSelect.addEventListener("change", runCalculations);
  calculateBtn.addEventListener("click", runCalculations);

  // Reset Form
  resetBtn.addEventListener("click", () => {
    grossSalaryInput.value = "75,000";
    payFrequencySelect.value = "annual";
    hourlyInputs.classList.add("hidden");
    hoursPerWeekInput.value = "40";

    // Reset status tabs
    document.querySelectorAll(".status-btn").forEach((b) => {
      b.className =
        "status-btn py-2 text-xs font-sans font-bold border border-hairline rounded-lg text-mute hover:text-ink cursor-pointer transition-all";
    });
    document
      .getElementById("status-single")
      ?.setAttribute(
        "class",
        "status-btn py-2 text-xs font-sans font-bold border border-hairline rounded-lg bg-primary text-on-primary shadow-lvl1 cursor-pointer transition-all",
      );
    filingStatusInput.value = "single";

    stateCodeSelect.value = "CA";
    contrib401kInput.value = "0";
    contribIraInput.value = "0";

    runCalculations();
  });

  // Accordion faq toggles
  document.querySelectorAll(".faq-toggle").forEach((button) => {
    button.addEventListener("click", () => {
      const content = button.nextElementSibling as HTMLDivElement;
      const chevron = button.querySelector("svg") as unknown as SVGElement;
      const isHidden = content.classList.toggle("hidden");
      chevron.classList.toggle("rotate-180", !isHidden);
      button.setAttribute("aria-expanded", (!isHidden).toString());
    });
  });

  // Run on startup
  runCalculations();
</script>
