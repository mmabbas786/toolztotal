---
import Layout from "../../layouts/Layout.astro";
import ContentFooter from "../../components/ContentFooter.astro";
import Sources from "../../components/Sources.astro";
import DisclaimerBanner from "../../components/DisclaimerBanner.astro";
import ToolSchema from "../../components/ToolSchema.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RelatedTools from "../../components/RelatedTools.astro";

const salaryFaqs = [
  {
    question: "What's the difference between gross and net salary?",
    answer:
      "Gross salary is your total compensation before any deductions. Net (take-home) salary is what lands in your bank account after federal income tax, state income tax, Social Security, Medicare, and pre-tax deductions like 401(k) contributions are subtracted.",
  },
  {
    question: "Is bonus income taxed differently?",
    answer:
      "Yes. Bonuses are typically withheld at a flat 22% federal supplemental rate (or 37% for amounts over $1 million). However, your actual tax liability depends on your marginal bracket for the year. You may get a refund or owe more at filing time depending on your total income.",
  },
  {
    question: "How does my state of residence affect my taxes?",
    answer:
      "Eight states have no income tax: Alaska, Florida, Nevada, South Dakota, Tennessee, Texas, Washington, and Wyoming. New Hampshire taxes only dividends and interest, not wages. The remaining 42 states have either a flat rate or graduated brackets that significantly affect take-home pay.",
  },
  {
    question: "What's the FICA wage base for 2026?",
    answer:
      "The Social Security wage base for 2026 is estimated at $168,600. You pay 6.2% Social Security on wages up to that limit, and 1.45% Medicare on all wages. Wages over $200,000 (single) or $250,000 (married filing jointly) are subject to an additional 0.9% Medicare tax.",
  },
  {
    question: "Should I contribute to a 401(k) to lower my taxes?",
    answer:
      "Contributing to a traditional 401(k) reduces your current taxable income, which lowers your tax bill now. The 2026 contribution limit is $23,500 ($31,000 if 50+, $34,750 if 60-63 under SECURE 2.0). The trade-off is that withdrawals in retirement are taxed as ordinary income. Roth 401(k) contributions don't reduce current taxes but grow tax-free.",
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: salaryFaqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
});
---

<Layout
  title="Salary Calculator - Take-Home Pay Tax Estimator | ToolzTotal"
  description="Calculate your take-home pay after federal, state, and FICA taxes. See monthly, bi-weekly, and weekly amounts for any salary and state."
  canonicalUrl="https://toolztotal.com/finance/salary-calculator"
>
  <ToolSchema
    toolName="Salary Calculator"
    toolSlug="salary-calculator"
    categoryName="Finance & Loans"
    categorySlug="finance"
    description="Calculate your take-home pay after federal, state, and FICA taxes. See monthly, bi-weekly, and weekly amounts for any salary and state."
    faqs={salaryFaqs}
  />

  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-12 md:py-20">
    <Breadcrumbs
      categorySlug="finance"
      categoryName="Finance & Loans"
      toolName="Salary Calculator"
      toolSlug="salary-calculator"
    />

    <DisclaimerBanner category="finance" />

    <!-- Header Section -->
    <div class="max-w-4xl mb-12">
      <div
        class="inline-flex items-center gap-2 border border-hairline bg-canvas px-3 py-1 rounded-full mb-6 shadow-lvl1"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        <span class="text-xs font-mono text-body uppercase tracking-wider"
          >Free Tool</span
        >
      </div>
      <h1
        class="text-3xl md:text-5xl font-bold tracking-tight text-ink font-sans mb-4 text-pretty"
      >
        Take-Home Salary Calculator
      </h1>
      <p
        class="text-body text-base md:text-lg font-sans leading-relaxed max-w-3xl"
      >
        Estimate your actual net take-home salary after subtracting federal,
        state, and FICA taxes, alongside retirement contributions.
      </p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
      <!-- Left Column: Input Form (5 cols) -->
      <form
        id="salary-form"
        class="lg:col-span-5 bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-6"
        onsubmit="return false;"
      >
        <!-- SECTION: Income Details -->
        <div>
          <h2
            class="text-sm font-mono uppercase tracking-wider text-mute border-b border-hairline pb-2 mb-4"
          >
            Salary Details
          </h2>

          <div class="space-y-4">
            <!-- Gross Salary -->
            <div>
              <label
                for="gross-salary"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Gross Income ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="gross-salary"
                  value="75,000"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 75,000"
                  inputmode="decimal"
                  required
                />
              </div>
            </div>

            <!-- Pay Frequency -->
            <div>
              <label
                for="pay-frequency"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Pay Frequency</label
              >
              <select
                id="pay-frequency"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <option value="annual">Annual Salary</option>
                <option value="monthly">Monthly</option>
                <option value="biweekly">Bi-weekly (Every 2 weeks)</option>
                <option value="weekly">Weekly</option>
                <option value="hourly">Hourly Rate</option>
              </select>
            </div>

            <!-- If Hourly: Hours/Week -->
            <div id="hourly-inputs" class="hidden animate-fadeIn space-y-4">
              <div>
                <label
                  for="hours-per-week"
                  class="block text-xs font-mono uppercase text-mute mb-1.5"
                  >Hours Per Week</label
                >
                <input
                  type="number"
                  id="hours-per-week"
                  value="40"
                  min="1"
                  max="168"
                  class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 40"
                  inputmode="numeric"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- SECTION: Tax & Filing Settings -->
        <div class="border-t border-hairline pt-5">
          <h2
            class="text-sm font-mono uppercase tracking-wider text-mute border-b border-hairline pb-2 mb-4"
          >
            Tax & Filing Settings
          </h2>

          <div class="space-y-4">
            <!-- Filing Status -->
            <div>
              <label class="block text-xs font-mono uppercase text-mute mb-2"
                >Filing Status</label
              >
              <div class="grid grid-cols-3 gap-2">
                <button
                  type="button"
                  id="status-single"
                  data-status="single"
                  class="status-btn py-2 text-xs font-sans font-bold border border-hairline rounded-lg bg-primary text-on-primary shadow-lvl1 cursor-pointer transition-all"
                >
                  Single
                </button>
                <button
                  type="button"
                  id="status-married"
                  data-status="married_jointly"
                  class="status-btn py-2 text-xs font-sans font-bold border border-hairline rounded-lg text-mute hover:text-ink cursor-pointer transition-all"
                >
                  MFJ
                </button>
                <button
                  type="button"
                  id="status-hoh"
                  data-status="head_of_household"
                  class="status-btn py-2 text-xs font-sans font-bold border border-hairline rounded-lg text-mute hover:text-ink cursor-pointer transition-all"
                >
                  HoH
                </button>
              </div>
              <input type="hidden" id="filing-status" value="single" />
            </div>

            <!-- State Selector Grouped by Region -->
            <div>
              <label
                for="state-code"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >State of Residence</label
              >
              <select
                id="state-code"
                class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 cursor-pointer"
              >
                <optgroup label="West">
                  <option value="AK">Alaska</option>
                  <option value="CA" selected>California</option>
                  <option value="CO">Colorado</option>
                  <option value="HI">Hawaii</option>
                  <option value="ID">Idaho</option>
                  <option value="MT">Montana</option>
                  <option value="NV">Nevada</option>
                  <option value="OR">Oregon</option>
                  <option value="UT">Utah</option>
                  <option value="WA">Washington</option>
                  <option value="WY">Wyoming</option>
                </optgroup>
                <optgroup label="Northeast">
                  <option value="CT">Connecticut</option>
                  <option value="ME">Maine</option>
                  <option value="MA">Massachusetts</option>
                  <option value="NH">New Hampshire</option>
                  <option value="NJ">New Jersey</option>
                  <option value="NY">New York</option>
                  <option value="PA">Pennsylvania</option>
                  <option value="RI">Rhode Island</option>
                  <option value="VT">Vermont</option>
                </optgroup>
                <optgroup label="Midwest">
                  <option value="IL">Illinois</option>
                  <option value="IN">Indiana</option>
                  <option value="IA">Iowa</option>
                  <option value="KS">Kansas</option>
                  <option value="MI">Michigan</option>
                  <option value="MN">Minnesota</option>
                  <option value="MO">Missouri</option>
                  <option value="NE">Nebraska</option>
                  <option value="ND">North Dakota</option>
                  <option value="OH">Ohio</option>
                  <option value="SD">South Dakota</option>
                  <option value="WI">Wisconsin</option>
                </optgroup>
                <optgroup label="Southeast">
                  <option value="AL">Alabama</option>
                  <option value="AR">Arkansas</option>
                  <option value="DE">Delaware</option>
                  <option value="DC">District of Columbia</option>
                  <option value="FL">Florida</option>
                  <option value="GA">Georgia</option>
                  <option value="KY">Kentucky</option>
                  <option value="LA">Louisiana</option>
                  <option value="MD">Maryland</option>
                  <option value="MS">Mississippi</option>
                  <option value="NC">North Carolina</option>
                  <option value="SC">South Carolina</option>
                  <option value="TN">Tennessee</option>
                  <option value="VA">Virginia</option>
                  <option value="WV">West Virginia</option>
                </optgroup>
                <optgroup label="Southwest">
                  <option value="AZ">Arizona</option>
                  <option value="NM">New Mexico</option>
                  <option value="OK">Oklahoma</option>
                  <option value="TX">Texas</option>
                </optgroup>
              </select>
            </div>

            <!-- 401k contribution -->
            <div>
              <label
                for="contrib-401k"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Traditional 401(k) Contribution (%)</label
              >
              <div class="relative">
                <input
                  type="number"
                  id="contrib-401k"
                  value="0"
                  min="0"
                  max="100"
                  step="1"
                  class="w-full h-10 pl-3 pr-8 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 5"
                  inputmode="numeric"
                />
                <span
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >%</span
                >
              </div>
              <p class="text-[10px] text-mute font-sans mt-1">
                Saves taxes on contributions up to $23,500/year.
              </p>
            </div>

            <!-- Traditional IRA -->
            <div>
              <label
                for="contrib-ira"
                class="block text-xs font-mono uppercase text-mute mb-1.5"
                >Traditional IRA Annual Contribution ($)</label
              >
              <div class="relative">
                <span
                  class="absolute left-3 top-1/2 -translate-y-1/2 text-mute text-sm font-sans"
                  >$</span
                >
                <input
                  type="text"
                  id="contrib-ira"
                  value="0"
                  class="w-full h-10 pl-7 pr-3 bg-canvas border border-hairline rounded-md text-sm font-sans focus:outline-none focus:border-hairline-strong text-ink transition-colors shadow-lvl1 tabular-nums"
                  placeholder="e.g., 7,500"
                  inputmode="decimal"
                />
              </div>
              <p class="text-[10px] text-mute font-sans mt-1">
                Deductible contributions capped at $7,500/year for 2026.
              </p>
            </div>
          </div>
        </div>

        <!-- Buttons -->
        <div class="flex flex-col gap-2 pt-4">
          <button
            type="submit"
            id="calculate-btn"
            class="w-full h-10 bg-primary hover:bg-primary-strong text-on-primary font-sans font-bold text-sm rounded-lg transition-colors cursor-pointer shadow-lvl2 text-center"
          >
            Calculate Take-Home
          </button>
          <button
            type="button"
            id="reset-btn"
            class="w-full py-2 text-mute hover:text-ink font-sans text-xs transition-colors cursor-pointer text-center"
          >
            Reset Form
          </button>
        </div>
      </form>

      <!-- Right Column: Results Dashboard (7 cols) -->
      <div class="lg:col-span-7 space-y-6">
        <!-- Output Cards Grid - Row 1 -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- Card 1: Annual Take Home -->
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 flex flex-col justify-between"
          >
            <div>
              <h3
                class="text-xs font-mono uppercase tracking-wider text-mute mb-1"
              >
                Annual Take-Home
              </h3>
              <p
                class="text-3xl font-bold font-sans text-ink tracking-tight tabular-nums"
                id="annual-takehome-val"
              >
                $0.00
              </p>
            </div>
            <div class="mt-4 pt-3 border-t border-hairline">
              <p class="text-[11px] font-sans text-body leading-normal">
                Net annual income
              </p>
              <p class="text-[10px] font-mono text-mute mt-0.5">
                After all federal, state, FICA
              </p>
            </div>
          </div>

          <!-- Card 2: Monthly Take Home -->
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 flex flex-col justify-between"
          >
            <div>
              <h3
                class="text-xs font-mono uppercase tracking-wider text-mute mb-1"
              >
                Monthly Take-Home
              </h3>
              <p
                class="text-3xl font-bold font-sans text-ink tracking-tight tabular-nums"
                id="monthly-takehome-val"
              >
                $0.00
              </p>
            </div>
            <div class="mt-4 pt-3 border-t border-hairline">
              <p class="text-[11px] font-sans text-body leading-normal">
                Net monthly income
              </p>
              <p class="text-[10px] font-mono text-mute mt-0.5">
                Estimated cash per month
              </p>
            </div>
          </div>

          <!-- Card 3: Effective Tax Rate -->
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2 flex flex-col justify-between"
          >
            <div>
              <h3
                class="text-xs font-mono uppercase tracking-wider text-mute mb-1"
              >
                Effective Tax Rate
              </h3>
              <p
                class="text-3xl font-bold font-sans text-ink tracking-tight tabular-nums"
                id="effective-rate-val"
              >
                0.0%
              </p>
            </div>
            <div class="mt-4 pt-3 border-t border-hairline">
              <p class="text-[11px] font-sans text-body leading-normal">
                Total tax burden
              </p>
              <p class="text-[10px] font-mono text-mute mt-0.5">
                Fed + State + FICA rate
              </p>
            </div>
          </div>
        </div>

        <!-- Output Cards Grid - Row 2 -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Card 4: Total Taxes Paid -->
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3
              class="text-xs font-mono uppercase tracking-wider text-mute mb-2"
            >
              Total Taxes Paid
            </h3>
            <p
              class="text-2xl font-bold font-sans text-ink tracking-tight mb-2 tabular-nums"
              id="total-taxes-val"
            >
              $0.00
            </p>
            <div
              class="text-[11px] font-mono text-mute space-y-1"
              id="tax-breakdown-subtext"
            >
              <!-- Inserted via JS -->
            </div>
          </div>

          <!-- Card 5: Pay Period Amounts -->
          <div
            class="bg-canvas border border-hairline rounded-xl p-5 shadow-lvl2"
          >
            <h3
              class="text-xs font-mono uppercase tracking-wider text-mute mb-2"
            >
              Pay Period Net Amounts
            </h3>
            <div class="divide-y divide-hairline text-xs font-sans">
              <div class="flex justify-between py-1.5">
                <span class="text-mute font-mono uppercase">Annual</span>
                <span
                  class="font-bold text-ink tabular-nums"
                  id="net-annual-list">$0.00</span
                >
              </div>
              <div class="flex justify-between py-1.5">
                <span class="text-mute font-mono uppercase">Monthly</span>
                <span
                  class="font-bold text-ink tabular-nums"
                  id="net-monthly-list">$0.00</span
                >
              </div>
              <div class="flex justify-between py-1.5">
                <span class="text-mute font-mono uppercase">Bi-weekly</span>
                <span
                  class="font-bold text-ink tabular-nums"
                  id="net-biweekly-list">$0.00</span
                >
              </div>
              <div class="flex justify-between py-1.5">
                <span class="text-mute font-mono uppercase">Weekly</span>
                <span
                  class="font-bold text-ink tabular-nums"
                  id="net-weekly-list">$0.00</span
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Breakdown Details Table -->
        <div
          class="bg-canvas border border-hairline rounded-xl p-6 md:p-8 shadow-lvl2 space-y-4"
        >
          <h3
            class="text-sm font-mono uppercase tracking-wider text-mute border-b border-hairline pb-2"
          >
            Full Tax Breakdown
          </h3>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-xs font-sans">
              <thead>
                <tr
                  class="border-b border-hairline font-mono text-mute uppercase text-[10px] tracking-wider"
                >
                  <th class="py-2.5 px-3">Tax Component</th>
                  <th class="py-2.5 px-3 text-right">Annual</th>
                  <th class="py-2.5 px-3 text-right">Monthly</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-hairline text-body tabular-nums">
                <tr>
                  <td class="py-3 px-3 font-semibold text-ink">Gross salary</td>
                  <td
                    class="py-3 px-3 text-right font-semibold text-ink"
                    id="row-gross">$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right font-semibold text-ink"
                    id="row-gross-monthly">$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body"
                    >Traditional 401(k) deduction</td
                  >
                  <td class="py-3 px-3 text-right text-rose-500" id="row-401k"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-401k-monthly">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body"
                    >Traditional IRA deduction</td
                  >
                  <td class="py-3 px-3 text-right text-rose-500" id="row-ira"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-ira-monthly">-$0.00</td
                  >
                </tr>

                <tr class="bg-canvas-soft-2/20">
                  <td class="py-3 px-3 font-semibold text-ink"
                    >Taxable Income (Fed AGI)</td
                  >
                  <td
                    class="py-3 px-3 text-right font-semibold text-ink"
                    id="row-taxable">$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right font-semibold text-ink"
                    id="row-taxable-monthly">$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body">Federal income tax</td>
                  <td class="py-3 px-3 text-right text-rose-500" id="row-fedtax"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-fedtax-monthly">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body" id="row-statetax-label"
                    >State income tax</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-statetax">-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-statetax-monthly">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body"
                    >Social Security tax (6.2%)</td
                  >
                  <td class="py-3 px-3 text-right text-rose-500" id="row-socsec"
                    >-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-socsec-monthly">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body">Medicare tax (1.45%)</td>
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-medicare">-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-medicare-monthly">-$0.00</td
                  >
                </tr>
                <tr>
                  <td class="py-3 px-3 pl-6 text-body"
                    >Additional Medicare tax (0.9%)</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-add-medicare">-$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right text-rose-500"
                    id="row-add-medicare-monthly">-$0.00</td
                  >
                </tr>

                <tr class="bg-emerald-500/10">
                  <td
                    class="py-3 px-3 font-semibold text-emerald-800 dark:text-emerald-400"
                    >Take-Home Pay (Net)</td
                  >
                  <td
                    class="py-3 px-3 text-right font-semibold text-emerald-800 dark:text-emerald-400"
                    id="row-net">$0.00</td
                  >
                  <td
                    class="py-3 px-3 text-right font-semibold text-emerald-800 dark:text-emerald-400"
                    id="row-net-monthly">$0.00</td
                  >
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Local error message panel -->
        <div
          id="error-panel"
