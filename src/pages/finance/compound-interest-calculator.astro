---
import Layout from '../../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is compound interest?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Compound interest is interest calculated on both the initial principal and the accumulated interest from previous periods. Unlike simple interest — which only accrues on the principal — compounding allows your money to grow exponentially over time because each period's interest earnings are added to the base that earns interest in the next period. Albert Einstein reportedly called it the 'eighth wonder of the world.'"
      }
    },
    {
      "@type": "Question",
      "name": "How does compounding frequency affect my returns?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The more frequently interest compounds, the faster your balance grows. Daily compounding yields slightly higher returns than monthly compounding, which beats quarterly, which beats semiannual, which beats annual compounding — given the same nominal interest rate. The difference is marginal at low rates but becomes more significant with higher rates and longer time horizons."
      }
    },
    {
      "@type": "Question",
      "name": "What is the compound interest formula?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The compound interest formula is A = P(1 + r/n)^(nt) + PMT × ((1 + r/n)^(nt) − 1) / (r/n), where A is the final amount, P is the initial principal, PMT is the monthly contribution, r is the annual interest rate (as a decimal), n is the number of compounding periods per year, and t is the number of years. The first term handles the initial investment; the second term handles recurring contributions."
      }
    },
    {
      "@type": "Question",
      "name": "How much should I contribute monthly to reach my goal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The monthly contribution needed depends on your target amount, time horizon, expected annual return, and compounding frequency. As a rule of thumb, starting earlier allows you to contribute less per month because compound interest does more of the heavy lifting. For example, investing $500/month at 7% annual return for 30 years yields over $600,000 — far more than the $180,000 you actually contributed."
      }
    },
    {
      "@type": "Question",
      "name": "Is the Effective Annual Rate the same as the nominal rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. The nominal annual rate is the stated rate before compounding is factored in. The Effective Annual Rate (EAR) accounts for the effect of compounding frequency and represents the actual annualized return you earn. For example, a 7% nominal rate compounded monthly yields an EAR of approximately 7.23%. The more frequent the compounding, the larger the gap between nominal and effective rates."
      }
    }
  ]
};

const faqJsonLd = JSON.stringify(faqSchema);
