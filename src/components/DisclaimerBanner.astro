---
interface Props {
  category: 'finance' | 'real-estate' | 'health' | 'legal';
}
const { category } = Astro.props;

const categoryDisclaimers = {
  finance: {
    title: "Financial Disclaimer",
    advice: "professional financial advice"
  },
  'real-estate': {
    title: "Financial Disclaimer",
    advice: "professional financial advice"
  },
  legal: {
    title: "Legal Disclaimer",
    advice: "legal advice. Consult a licensed attorney in your jurisdiction."
  },
  health: {
    title: "Medical Disclaimer",
    advice: "medical advice. Always consult a qualified healthcare provider."
  }
};

const d = categoryDisclaimers[category];
const bannerId = `disclaimer-${category}`;
---

<aside id={bannerId} class="mb-8 px-4 py-3 bg-canvas-soft-2 border border-hairline rounded-lg text-xs text-body font-sans leading-relaxed flex items-start justify-between gap-4 transition-all duration-200">
  <div>
    <strong class="text-ink">⚠ {d.title}:</strong>
    This tool is for informational purposes only and does not constitute {d.advice}
  </div>
  <button 
    type="button" 
    class="dismiss-btn text-mute hover:text-ink font-mono font-bold text-xs cursor-pointer select-none transition-colors"
    aria-label="Dismiss disclaimer"
  >
    ✕
  </button>
</aside>

<script define:vars={{ bannerId }}>
  (function() {
    const banner = document.getElementById(bannerId);
    if (banner) {
      const isDismissed = localStorage.getItem(`dismissed-${bannerId}`) === 'true';
      if (isDismissed) {
        banner.style.display = 'none';
      } else {
        const dismissBtn = banner.querySelector('.dismiss-btn');
        if (dismissBtn) {
          dismissBtn.addEventListener('click', () => {
            localStorage.setItem(`dismissed-${bannerId}`, 'true');
            banner.style.display = 'none';
          });
        }
      }
    }
  })();
</script>
