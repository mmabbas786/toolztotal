---
interface Props {
  toolName: string;
  toolSlug: string;
  categoryName: string;
  categorySlug: string;
  description: string;
  faqs?: Array<{ question: string; answer: string }>;
}

const {
  toolName,
  toolSlug,
  categoryName,
  categorySlug,
  description,
  faqs = [],
} = Astro.props;

const baseUrl = "https://toolztotal.com";

const toolUrl = `${baseUrl}/${categorySlug}/${toolSlug}`;
const categoryUrl = `${baseUrl}/${categorySlug}`;
const homeUrl = `${baseUrl}/`;

const applicationCategoryMap: Record<string, string> = {
  finance: "FinanceApplication",
  "real-estate": "FinanceApplication",
  dev: "DeveloperApplication",
  text: "UtilitiesApplication",
  marketing: "BusinessApplication",
  health: "HealthApplication",
  legal: "BusinessApplication",
  education: "EducationApplication",
  "image-tools": "MultimediaApplication",
  utility: "UtilitiesApplication",
};

const applicationCategory =
  applicationCategoryMap[categorySlug] ?? "SoftwareApplication";

const softwareApplication = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: toolName,
  url: toolUrl,
  applicationCategory: applicationCategory,
  operatingSystem: "Any (Web Browser)",
  description: description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  creator: {
    "@type": "Organization",
    name: "ToolzTotal",
    url: "https://toolztotal.com",
  },
};

const breadcrumbList = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: homeUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: categoryName,
      item: categoryUrl,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: toolName,
      item: toolUrl,
    },
  ],
};

const faqPage = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(softwareApplication, null, 2)}
/>

<script
  type="application/ld+json"
  set:html={JSON.stringify(breadcrumbList, null, 2)}
/>

{
  faqs.length > 0 && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(faqPage, null, 2)}
    />
  )
}
